{%- comment -%}
  BKS Member Tier Detection — metal tier system
  Sets: bks_tier (lead/iron/brass/silver/gold), bks_tier_label, bks_tier_rank
  Detection: customer.orders_count
    lead:   0 orders
    iron:   1-2 orders
    brass:  3-5 orders
    silver: 6-9 orders
    gold:   10+ orders
{%- endcomment -%}

{%- assign bks_tier       = "lead" -%}
{%- assign bks_tier_label = "" -%}
{%- assign bks_tier_rank  = 0 -%}

{%- if customer -%}
  {%- assign bks_orders = customer.orders_count | default: 0 -%}
  {%- if bks_orders >= 10 -%}
    {%- assign bks_tier       = "gold" -%}
    {%- assign bks_tier_label = "BKS Gold" -%}
    {%- assign bks_tier_rank  = 4 -%}
  {%- elsif bks_orders >= 6 -%}
    {%- assign bks_tier       = "silver" -%}
    {%- assign bks_tier_label = "BKS Silver" -%}
    {%- assign bks_tier_rank  = 3 -%}
  {%- elsif bks_orders >= 3 -%}
    {%- assign bks_tier       = "brass" -%}
    {%- assign bks_tier_label = "BKS Brass" -%}
    {%- assign bks_tier_rank  = 2 -%}
  {%- elsif bks_orders >= 1 -%}
    {%- assign bks_tier       = "iron" -%}
    {%- assign bks_tier_label = "BKS Iron" -%}
    {%- assign bks_tier_rank  = 1 -%}
  {%- endif -%}
{%- endif -%}
