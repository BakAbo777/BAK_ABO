{%- comment -%} BKS GDPR Cookie Consent Banner — BKS TM04 V.9 {%- endcomment -%}
<div id="bks-gdpr" class="bks-gdpr" role="dialog" aria-label="Cookie consent" aria-live="polite" style="display:none">
  <div class="bks-gdpr__inner">
    <p class="bks-gdpr__text">
      bakabo.club uses cookies to improve your experience and analyse traffic.
      <a href="/policies/privacy-policy" class="bks-gdpr__link">Privacy policy</a>
    </p>
    <div class="bks-gdpr__actions">
      <button class="bks-gdpr__btn bks-gdpr__btn--accept" id="bks-gdpr-accept">Accept all</button>
      <button class="bks-gdpr__btn bks-gdpr__btn--reject" id="bks-gdpr-reject">Reject</button>
    </div>
  </div>
</div>

<style>
  .bks-gdpr {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 9999;
    background: #0a0a0a;
    border-top: 1px solid rgba(250,250,247,0.12);
    transform: translateY(100%);
    transition: transform 0.32s cubic-bezier(0.16,1,0.3,1);
    will-change: transform;
  }
  .bks-gdpr.bks-gdpr--visible { transform: translateY(0); }
  .bks-gdpr__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 14px 20px;
    display: flex;
    align-items: center;
    gap: 20px;
    flex-wrap: wrap;
  }
  .bks-gdpr__text {
    font-family: 'DM Sans', sans-serif;
    font-size: 13px;
    color: rgba(250,250,247,0.76);
    line-height: 1.5;
    margin: 0;
    flex: 1;
    min-width: 200px;
  }
  .bks-gdpr__link {
    color: rgba(250,250,247,0.52);
    text-decoration: underline;
    text-underline-offset: 2px;
    margin-left: 4px;
  }
  .bks-gdpr__link:hover { color: #fafaf7; }
  .bks-gdpr__actions {
    display: flex;
    gap: 10px;
    flex-shrink: 0;
  }
  .bks-gdpr__btn {
    font-family: 'DM Sans', sans-serif;
    font-size: 13px;
    font-weight: 500;
    padding: 8px 20px;
    border-radius: 2px;
    cursor: pointer;
    transition: opacity 0.15s;
    letter-spacing: 0.02em;
  }
  .bks-gdpr__btn:hover { opacity: 0.82; }
  .bks-gdpr__btn--accept {
    background: #d4a030;
    color: #0a0a0a;
    border: none;
  }
  .bks-gdpr__btn--reject {
    background: transparent;
    color: rgba(250,250,247,0.72);
    border: 1px solid rgba(250,250,247,0.22);
  }
  @media (max-width: 640px) {
    .bks-gdpr__inner { padding: 12px 16px; gap: 12px; }
    .bks-gdpr__btn { padding: 8px 14px; }
  }
</style>

<script>
(function(){
  var KEY = 'bks_cookie_consent';
  var banner = document.getElementById('bks-gdpr');
  if (!banner) return;

  function getConsent() {
    try { return localStorage.getItem(KEY); } catch(e) { return null; }
  }
  function setConsent(value) {
    try { localStorage.setItem(KEY, value); } catch(e) {}
  }

  function applyConsent(value) {
    var granted = value === 'accepted';
    // Shopify Customer Privacy API (Dawn 14+)
    if (window.Shopify && window.Shopify.customerPrivacy) {
      try {
        Shopify.customerPrivacy.setTrackingConsent(
          { analytics: granted, marketing: granted, preferences: granted, sale_of_data: false },
          function() {}
        );
      } catch(e) {}
    }
    // GTM Consent Mode v2
    if (window.gtag) {
      try {
        gtag('consent', 'update', {
          analytics_storage:   granted ? 'granted' : 'denied',
          ad_storage:          granted ? 'granted' : 'denied',
          ad_user_data:        granted ? 'granted' : 'denied',
          ad_personalization:  granted ? 'granted' : 'denied'
        });
      } catch(e) {}
    }
    // dataLayer push for GTM triggers
    if (window.dataLayer) {
      window.dataLayer.push({ event: 'bks_consent_' + value });
    }
  }

  function hideBanner() {
    banner.classList.remove('bks-gdpr--visible');
    setTimeout(function(){ banner.style.display = 'none'; }, 350);
  }

  function showBanner() {
    banner.style.display = '';
    // Allow paint before animating
    requestAnimationFrame(function(){
      requestAnimationFrame(function(){
        banner.classList.add('bks-gdpr--visible');
      });
    });
  }

  // Show only if no prior consent
  if (!getConsent()) {
    showBanner();
  } else {
    applyConsent(getConsent());
  }

  document.getElementById('bks-gdpr-accept').addEventListener('click', function(){
    setConsent('accepted');
    applyConsent('accepted');
    hideBanner();
  });

  document.getElementById('bks-gdpr-reject').addEventListener('click', function(){
    setConsent('rejected');
    applyConsent('rejected');
    hideBanner();
  });
})();
</script>
