{%- if customer -%}

  {%- liquid

    assign _oc = customer.orders_count | default: 0

    if _oc >= 11

      assign bks_tier = 'gold'

      assign bks_tier_color = '#d4a030'

    elsif _oc >= 6

      assign bks_tier = 'silver'

      assign bks_tier_color = '#b0b0c8'

    elsif _oc >= 3

      assign bks_tier = 'brass'

      assign bks_tier_color = '#c8a96e'

    elsif _oc >= 1

      assign bks_tier = 'iron'

      assign bks_tier_color = '#8a8a8a'

    else

      assign bks_tier = 'lead'

      assign bks_tier_color = '#7a7a7a'

    endif

  -%}

{%- endif -%}

{%- if customer and bks_tier -%}
<style>:root { --bks-current-tier: var(--bks-tier-{{ bks_tier }}); }</style>
{%- endif -%}

{% comment %}

  BAKABO GLOBAL HEADER — BKS V21 BASE

  Presente su tutte le pagine via layout/theme.liquid

  Nav: CATALOG · COLLECTIONS · ABOUT | logo | SEARCH · CART

  Mobile: hamburger + drawer overlay

{% endcomment %}



<style>

  /* ── HEADER RESET ───────────────────────────────────────── */

  .bks-gh {

    position: sticky;

    top: 0;

    left: 0;

    width: 100%;

    z-index: 900;

    background: #fafaf7 !important;

    border-bottom: 1px solid rgba(10,10,10,0.08) !important;

    transition: transform 0.3s ease, background 0.3s ease;

    /* override any color-scheme or collection-accent that bleeds into header */

    color: #0a0a0a !important;

  }

  .bks-gh.bks-gh--scrolled {

    background: rgba(250,250,247,0.96) !important;

    backdrop-filter: blur(12px);

    -webkit-backdrop-filter: blur(12px);

  }

  /* language selector + market popup — hide Shopify floating widget only */

  /* .bks-lang-toggle and .bks-gh__drawer-lang are KEPT VISIBLE (integrated in nav) */

  .bks-lang-form,

  localization-form,

  .localization-form,

  .disclosure,

  country-localization,

  .country-selector,

  market-popup,

  .market-popup,

  .footer__localization,

  .header__localization,

  .bks-gh__locale,

  #market-selector,

  [data-market-popup],

  [data-localization-form],

  .localization-wrapper,

  .geolocation-form,

  shopify-geo-localization,

  /* GTranslate app */

  .gts-switcher-box,

  .gts-box,

  .gts-widget,

  .gts-select,

  #gts-widget-block,

  [class*="gts-switcher"],

  [id*="gts-widget"],

  /* Weglot */

  .weglot-widget,

  .weglot_switcher,

  #weglot_here,

  [class*="weglot"],

  /* Google Translate */

  #google_translate_element,

  .goog-te-gadget,

  .goog-te-banner-frame,

  #goog-gt-tt,

  .gtp-select-wrapper,

  /* LangShop / other translation apps */

  .language-switcher,

  .langify-switcher,

  [class*="translate-"],

  [class*="lang-switch"],

  /* Shopify Translate & Adapt floating widget */

  .shopify-translate-language-switcher,

  .translate-adapt-widget,

  /* Selecty app */

  .selecty-widget,

  .selecty-container,

  .selecty-popup,

  .selecty-bar,

  .selecty-flag,

  #selecty-widget,

  #selecty-app,

  [class*="selecty"],

  [id*="selecty"] { display: none !important; }

  .bks-gh.bks-gh--hidden {

    transform: translateY(-100%);

  }

  .bks-gh__inner {

    max-width: 1600px;

    margin: 0 auto;

    padding: 0 clamp(16px,3vw,48px);

    height: 64px;

    display: grid;

    grid-template-columns: auto 1fr auto;

    align-items: center;

    gap: clamp(16px,2.5vw,40px);

  }

  /* ── LEFT NAV ───────────────────────────────────────────── */

  .bks-gh__nav {

    display: flex;

    align-items: center;

    gap: clamp(16px,2.5vw,36px);

    list-style: none;

    margin: 0;

    padding: 0;

  }

  .bks-gh__nav a {

    font-family: var(--bks-font-mono, 'DM Mono', monospace);

    font-size: 0.88rem;

    font-weight: 500;

    letter-spacing: 0.10em;

    text-transform: uppercase;

    color: #0a0a0a;

    text-decoration: none;

    transition: color 0.2s;

    position: relative;

  }

  .bks-gh__nav a:hover { color: #444; }

  /* active page underline — uses current collection accent */

  .bks-gh__nav a[aria-current="page"] { color: var(--bks-active-accent, #0a0a0a); }

  .bks-gh__nav a[aria-current="page"]::after {
    content: '';
    position: absolute;
    bottom: -6px;
    left: 0; right: 0;
    height: 2px;
    background: var(--bks-active-accent, #0a0a0a);
    border-radius: 1px;
  }

  /* ── DRAWER COLLECTION COLORS ───────────────────────────── */

  .bks-gh__drawer-nav [data-coll="hours"]   { --cc: #c8c4be; }
  .bks-gh__drawer-nav [data-coll="origin"]  { --cc: #489808; }
  .bks-gh__drawer-nav [data-coll="glyph"]   { --cc: #d4a030; }
  .bks-gh__drawer-nav [data-coll="marker"]  { --cc: #c04418; }
  .bks-gh__drawer-nav [data-coll="riviera"] { --cc: #0ca898; }
  .bks-gh__drawer-nav [data-coll="pulse"]   { --cc: #8888cc; }
  .bks-gh__drawer-nav [data-coll="token"]   { --cc: #9828d8; }
  .bks-gh__drawer-nav [data-coll="flag"]    { --cc: #c82020; }

  .bks-gh__drawer-nav a[data-coll] {
    border-left: 3px solid var(--cc, transparent);
    padding-left: 13px;
  }

  /* ── LOGO ───────────────────────────────────────────────── */

  .bks-gh__logo {

    display: flex;

    justify-content: flex-start;

    align-items: center;

  }

  .bks-gh__logo a {

    display: block;

    line-height: 0;

  }

  .bks-gh__logo img {

    height: 40px;

    width: auto;

    display: block;

  }

  /* ── RIGHT ACTIONS ──────────────────────────────────────── */

  .bks-gh__actions {

    display: flex;

    align-items: center;

    justify-content: flex-end;

    gap: clamp(6px,1.2vw,16px);

  }

  .bks-gh__actions a,

  .bks-gh__actions button:not(.bks-gh__ask-btn) {

    display: flex;

    align-items: center;

    justify-content: center;

    width: 40px;

    height: 40px;

    background: none;

    border: none;

    cursor: pointer;

    color: #0a0a0a;

    text-decoration: none;

    transition: color 0.2s;

    position: relative;

    padding: 0;

  }

  .bks-gh__actions a:hover,

  .bks-gh__actions button:not(.bks-gh__ask-btn):hover { color: #666; }

  /* Separatore visivo tra utility controls e icone */

  .bks-gh__action-sep {

    width: 1px;

    height: 16px;

    background: rgba(10,10,10,0.13);

    flex-shrink: 0;

    align-self: center;

  }

  @media (max-width: 768px) {

    .bks-gh__actions .bks-lang-toggle,

    .bks-gh__actions .bks-gh__ask-btn,

    .bks-gh__actions .bks-gh__action-sep { display: none; }

  }

  /* ── LANGUAGE SELECTOR ──────────────────────────────────── */

  .bks-lang-form { display: flex; align-items: center; }

  .bks-lang-select {

    font-family: var(--bks-font-mono, 'DM Mono', monospace);

    font-size: 0.66rem;

    font-weight: 600;

    letter-spacing: 0.1em;

    background: transparent;

    border: 1px solid rgba(10,10,10,0.16);

    border-radius: 3px;

    padding: 4px 6px;

    color: #0a0a0a;

    cursor: pointer;

    appearance: none;

    -webkit-appearance: none;

    min-width: 36px;

    text-align: center;

  }

  .bks-lang-select:focus {

    outline: none;

    border-color: var(--bks-active-accent, #c8c4be);

  }

  .bks-lang-select:hover { border-color: rgba(10,10,10,0.4); }

  .bks-gh__actions svg { width: 20px; height: 20px; fill: none; stroke: currentColor; stroke-width: 1.5; stroke-linecap: round; stroke-linejoin: round; }

  /* ── language toggle IT · EN ───────────────────────────── */

  .bks-lang-toggle {

    display: flex;

    align-items: center;

    gap: 5px;

  }

  .bks-lang-toggle__btn {

    font-family: var(--bks-font-mono, 'DM Mono', monospace);

    font-size: 0.72rem;

    font-weight: 500;

    letter-spacing: 0.12em;

    text-transform: uppercase;

    background: none;

    border: none;

    cursor: pointer;

    color: #b0b0b0;

    padding: 0;

    line-height: 1;

    transition: color 0.15s;

  }

  .bks-lang-toggle__btn.is-active { color: #0a0a0a; font-weight: 700; }

  .bks-lang-toggle__btn:hover { color: #0a0a0a; }

  .bks-lang-toggle__sep { color: #d0d0d0; font-size: 0.65rem; font-family: var(--bks-font-mono, 'DM Mono', monospace); pointer-events: none; }

  /* ── AI BKS nav trigger — accent badge ──────────────────── */

  .bks-gh__ask-btn {

    font-family: var(--bks-font-mono, 'DM Mono', monospace);

    font-size: 0.72rem;

    font-weight: 700;

    letter-spacing: 0.14em;

    text-transform: uppercase;

    background: var(--bks-active-accent, #2f6f6b);

    border: none;

    border-radius: 3px;

    cursor: pointer;

    color: #0a0a0a;

    padding: 4px 10px;

    position: relative;

    transition: background 0.35s ease, color 0.2s, opacity 0.2s;

    white-space: nowrap;

    opacity: 0.92;

  }

  .bks-gh__ask-btn:hover {

    opacity: 1;

    filter: brightness(1.1);

  }

  .bks-gh__ask-btn[aria-expanded="true"] {

    opacity: 1;

    filter: brightness(0.88);

  }

  /* drawer versions */

  .bks-gh__drawer-ask-btn {

    display: block;

    width: 100%;

    text-align: left;

    padding: 14px 0;

    border: none;

    border-bottom: 1px solid #eee;

    background: none;

    font-family: var(--bks-font-mono, 'DM Mono', monospace);

    font-size: 0.85rem;

    font-weight: 700;

    letter-spacing: 0.10em;

    text-transform: uppercase;

    color: var(--bks-active-accent, #2f6f6b);

    cursor: pointer;

    transition: color 0.3s ease;

  }

  .bks-gh__drawer-ask-btn:hover { color: #0a0a0a; }

  .bks-gh__drawer-lang {

    display: flex;

    align-items: center;

    gap: 6px;

    padding: 14px 0;

    border-bottom: 1px solid #eee;

  }

  /* ── CART BUBBLE ────────────────────────────────────────── */

  .bks-cart-count {

    position: absolute;

    top: 4px;

    right: 2px;

    min-width: 16px;

    height: 16px;

    padding: 0 3px;

    background: #0a0a0a;

    color: #fff;

    font-size: 9px;

    font-weight: 700;

    letter-spacing: 0;

    border-radius: 99px;

    display: flex;

    align-items: center;

    justify-content: center;

    line-height: 1;

    font-family: var(--bks-font-mono, 'DM Mono', monospace);

    transition: transform 0.2s;

  }

  .bks-cart-count[data-count="0"] { display: none; }

  /* ── HAMBURGER (mobile only) ────────────────────────────── */

  .bks-gh__hamburger {

    display: none;

  }

  /* ── MOBILE DRAWER ──────────────────────────────────────── */

  .bks-gh__drawer {

    position: fixed;

    inset: 0;

    z-index: 1000;

    pointer-events: none;

  }

  .bks-gh__drawer-overlay {

    position: absolute;

    inset: 0;

    background: rgba(0,0,0,0);

    transition: background 0.3s ease;

  }

  .bks-gh__drawer-panel {

    position: absolute;

    top: 0;

    left: 0;

    width: min(320px, 85vw);

    height: 100%;

    background: #ffffff;

    transform: translateX(-100%);

    transition: transform 0.35s cubic-bezier(0.4,0,0.2,1);

    display: flex;

    flex-direction: column;

    padding: 24px;

    gap: 8px;

    overflow-y: auto;

  }

  .bks-gh__drawer.is-open { pointer-events: all; }

  .bks-gh__drawer.is-open .bks-gh__drawer-overlay { background: rgba(0,0,0,0.5); }

  .bks-gh__drawer.is-open .bks-gh__drawer-panel { transform: translateX(0); }

  .bks-gh__drawer-close {

    align-self: flex-end;

    background: none;

    border: none;

    cursor: pointer;

    padding: 8px;

    color: #0a0a0a;

    margin-bottom: 16px;

  }

  .bks-gh__drawer-close svg { width: 24px; height: 24px; stroke: currentColor; fill: none; stroke-width: 1.5; }

  .bks-gh__drawer-nav a {

    display: block;

    padding: 14px 0;

    border-bottom: 1px solid #eee;

    font-family: var(--bks-font-mono, 'DM Mono', monospace);

    font-size: 0.85rem;

    letter-spacing: 0.1em;

    text-transform: uppercase;

    color: #0a0a0a;

    text-decoration: none;

  }

  .bks-gh__drawer-nav a:hover { color: #666; }

  .bks-gh__drawer-sub {

    padding-left: 18px;

    font-size: 0.78rem;

    letter-spacing: 0.08em;

    opacity: 0.72;

  }

  @media (max-width: 420px) {

    .bks-gh__drawer-panel { width: min(92vw, 360px); padding: 22px 20px 32px; }

    .bks-gh__inner { height: 60px; padding: 0 14px; gap: 10px; }

    .bks-gh__logo img { height: 34px; }

    .bks-gh__actions a, .bks-gh__actions button { width: 36px; height: 36px; }

  }

  /* ── RESPONSIVE ─────────────────────────────────────────── */

  @media (max-width: 768px) {

    .bks-gh__nav { display: none; }

    .bks-gh__hamburger { display: flex; }

    .bks-gh__inner {

      grid-template-columns: auto 1fr auto;

      gap: 8px;

    }

    .bks-gh__logo { justify-content: flex-start; }

  }

  /* ── MEMBER RING — cerchio oro ──────────────────────────── */

  @keyframes bks-ring-pulse {

    0%, 100% { opacity: 0.8; transform: scale(1); }

    50%       { opacity: 1;   transform: scale(1.06); }

  }

  @keyframes bks-ring-spin {

    from { transform: rotate(0deg); }

    to   { transform: rotate(360deg); }

  }

  @keyframes bks-arrival {

    0%   { opacity: 0; }

    18%  { opacity: 1; }

    100% { opacity: 0; }

  }

  .bks-member-halo {

    position: relative;

    display: flex;

    align-items: center;

    justify-content: center;

    width: 40px;

    height: 40px;

  }

  .bks-member-halo::before {

    content: '';

    position: absolute;

    inset: 2px;

    border-radius: 50%;

    border: 1.5px solid var(--bks-member-ring, #d4a030);

    animation: bks-ring-pulse 2.8s ease-in-out infinite;

    pointer-events: none;

  }

  .bks-member-halo::after {

    content: '';

    position: absolute;

    inset: -1px;

    border-radius: 50%;

    border: 1px solid transparent;

    border-top-color: var(--bks-member-ring, #d4a030);

    border-right-color: var(--bks-member-ring, #d4a030);

    animation: bks-ring-spin 4s linear infinite;

    opacity: 0.6;

    pointer-events: none;

  }

  .bks-member-halo[data-tier="gold"]::before {

    border-width: 2px;

    box-shadow: 0 0 10px rgba(212,160,48,0.45);

    animation-duration: 2s;

  }

  .bks-member-halo[data-tier="gold"]::after {

    opacity: 1;

    animation-duration: 2.5s;

  }

  .bks-member-arrival {

    position: fixed;

    inset: 0;

    z-index: 9998;

    pointer-events: none;

    opacity: 0;

    animation: bks-arrival 2s cubic-bezier(0.16, 1, 0.3, 1) forwards;

  }

  @media (prefers-reduced-motion: reduce) {

    .bks-member-halo::before,

    .bks-member-halo::after { animation: none; }

    .bks-member-arrival { display: none; }

  }

</style>



<header class="bks-gh" id="bks-global-header" role="banner">

  <div class="bks-gh__inner">



    {%- comment -%} LEFT: logo {%- endcomment -%}

    <div class="bks-gh__logo">

      <a href="{{ routes.root_url }}" aria-label="BAKABO — home">

        <img

          src="{{ 'bakabo-logo-official.png' | asset_url }}"

          alt="BAKABO"

          loading="eager"

          width="160"

          height="44"

          style="height:40px;width:auto;"

        >

      </a>

    </div>



    {%- comment -%} CENTER: primary nav (desktop) + hamburger (mobile) {%- endcomment -%}

    <div style="display:flex;align-items:center;justify-content:center;">

      <button class="bks-gh__hamburger bks-gh__actions" id="bks-menu-toggle" aria-label="Open menu" aria-expanded="false"

              style="justify-content:flex-start;width:auto;">

        <svg viewBox="0 0 24 24"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>

      </button>

      <nav class="bks-gh__nav" aria-label="Main navigation">

        {%- liquid

          assign main_menu = linklists['main-menu-1']

          if main_menu.links.size == 0

            assign main_menu = linklists['main-menu']

          endif

        -%}

        {%- if main_menu.links.size > 0 -%}

          {%- for link in main_menu.links -%}

            {%- if link.links.size > 0 -%}

              <div class="bks-gh__dd">

                <a href="{{ link.url }}" aria-haspopup="true"{% if link.current %} aria-current="page"{% endif %}>{{ link.title | escape }}</a>

                <div class="bks-gh__dd-panel" role="menu" aria-label="{{ link.title | escape }}">

                  {%- for child in link.links -%}

                  {%- liquid
                    assign coll_slug = ''
                    if child.url contains 'bks-hours'
                      assign coll_slug = 'hours'
                    elsif child.url contains 'bks-origin'
                      assign coll_slug = 'origin'
                    elsif child.url contains 'bks-glyph'
                      assign coll_slug = 'glyph'
                    elsif child.url contains 'bks-marker'
                      assign coll_slug = 'marker'
                    elsif child.url contains 'bks-riviera'
                      assign coll_slug = 'riviera'
                    elsif child.url contains 'bks-pulse'
                      assign coll_slug = 'pulse'
                    elsif child.url contains 'bks-token'
                      assign coll_slug = 'token'
                    elsif child.url contains 'bks-flag'
                      assign coll_slug = 'flag'
                    endif
                  -%}

                    <a role="menuitem" href="{{ child.url }}"{% if coll_slug != '' %} data-coll="{{ coll_slug }}"{% endif %}{% if child.current %} aria-current="page"{% endif %}>

                      {%- if coll_slug != '' -%}
                        <span class="bks-dd-name"><span class="bks-dd-dot" aria-hidden="true"></span>{{- child.title | escape -}}</span>
                      {%- else -%}
                        {{- child.title | escape -}}
                      {%- endif -%}

                      {%- if child.links.size > 0 -%}

                        <span>

                          {%- for grand in child.links -%}

                            {{- grand.title | escape -}}{%- unless forloop.last %} · {% endunless -%}

                          {%- endfor -%}

                        </span>

                      {%- endif -%}

                    </a>

                  {%- endfor -%}

                </div>

              </div>

            {%- else -%}

              <a href="{{ link.url }}"{% if link.current %} aria-current="page"{% endif %}>{{ link.title | escape }}</a>

            {%- endif -%}

          {%- endfor -%}

        {%- else -%}

          {%- comment -%} Fallback: menu admin vuoto o assente {%- endcomment -%}

          <a href="/collections/all">Catalog</a>

          <div class="bks-gh__dd">

            <a href="/collections" aria-haspopup="true">Collections</a>

            <div class="bks-gh__dd-panel" role="menu" aria-label="BKS collections">

              <a role="menuitem" href="/collections/bks-hours" data-coll="hours"><span class="bks-dd-name"><span class="bks-dd-dot" aria-hidden="true"></span>Hours</span><span>Time as Graphic Language</span></a>

              <a role="menuitem" href="/collections/bks-origin" data-coll="origin"><span class="bks-dd-name"><span class="bks-dd-dot" aria-hidden="true"></span>Origin</span><span>Roots, Marks, Present Form</span></a>

              <a role="menuitem" href="/collections/bks-glyph" data-coll="glyph"><span class="bks-dd-name"><span class="bks-dd-dot" aria-hidden="true"></span>Glyph</span><span>Symbols and Signs</span></a>

              <a role="menuitem" href="/collections/bks-marker" data-coll="marker"><span class="bks-dd-name"><span class="bks-dd-dot" aria-hidden="true"></span>Marker</span><span>Urban Gestures</span></a>

              <a role="menuitem" href="/collections/bks-riviera" data-coll="riviera"><span class="bks-dd-name"><span class="bks-dd-dot" aria-hidden="true"></span>Riviera</span><span>Mediterranean Geometry</span></a>

              <a role="menuitem" href="/collections/bks-pulse" data-coll="pulse"><span class="bks-dd-name"><span class="bks-dd-dot" aria-hidden="true"></span>Pulse</span><span>Digital Motion</span></a>

              <a role="menuitem" href="/collections/bks-token" data-coll="token"><span class="bks-dd-name"><span class="bks-dd-dot" aria-hidden="true"></span>Token</span><span>Encoded Identity</span></a>

              <a role="menuitem" href="/collections/bks-flag" data-coll="flag"><span class="bks-dd-name"><span class="bks-dd-dot" aria-hidden="true"></span>Flag</span><span>Global Signals</span></a>

            </div>

          </div>

          <a href="/pages/contact">Contact</a>

        {%- endif -%}

      </nav>

    </div>



    <style>

      .bks-gh__dd { position: relative; display: flex; align-items: center; }

      .bks-gh__dd-panel {

        position: absolute;

        top: 100%;

        left: -16px;

        min-width: 320px;

        padding: 8px 0;

        background: #ffffff;

        border: 1px solid #e8e8e8;

        border-top: none;

        opacity: 0;

        visibility: hidden;

        transform: translateY(-4px);

        transition: opacity 200ms ease-out, transform 200ms ease-out, visibility 200ms;

        z-index: 950;

      }

      .bks-gh__dd:hover .bks-gh__dd-panel,

      .bks-gh__dd:focus-within .bks-gh__dd-panel {

        opacity: 1;

        visibility: visible;

        transform: translateY(0);

      }

      /* ── COLLECTION COLOR MAP ──────────────────────────────── */
      .bks-gh__dd-panel [data-coll="hours"]   { --cc: #c8c4be; }
      .bks-gh__dd-panel [data-coll="origin"]  { --cc: #489808; }
      .bks-gh__dd-panel [data-coll="glyph"]   { --cc: #d4a030; }
      .bks-gh__dd-panel [data-coll="marker"]  { --cc: #c04418; }
      .bks-gh__dd-panel [data-coll="riviera"] { --cc: #0ca898; }
      .bks-gh__dd-panel [data-coll="pulse"]   { --cc: #8888cc; }
      .bks-gh__dd-panel [data-coll="token"]   { --cc: #9828d8; }
      .bks-gh__dd-panel [data-coll="flag"]    { --cc: #c82020; }

      .bks-gh__dd-panel a {

        display: flex;

        align-items: center;

        justify-content: space-between;

        gap: 24px;

        padding: 10px 16px;

        font-family: var(--bks-font-mono, 'DM Mono', monospace);

        font-size: 0.72rem;

        font-weight: 500;

        letter-spacing: 0.14em;

        text-transform: uppercase;

        text-decoration: none;

        color: #0a0a0a;

        border-left: 3px solid transparent;

        transition: background 0.15s, border-color 0.15s, color 0.15s;

      }

      .bks-gh__dd-panel a span {

        font-size: 0.62rem;

        font-weight: 400;

        letter-spacing: 0.04em;

        text-transform: none;

        color: #9a9a9a;

        text-align: right;

        flex-shrink: 0;

      }

      /* non-collection items: classic BKS black hover */
      .bks-gh__dd-panel a:not([data-coll]):hover,
      .bks-gh__dd-panel a:not([data-coll]):focus-visible {

        background: #0a0a0a;

        color: #fafaf7;

        border-left-color: #0a0a0a;

      }

      .bks-gh__dd-panel a:not([data-coll]):hover span,
      .bks-gh__dd-panel a:not([data-coll]):focus-visible span { color: #efeae0; }

      /* ── COLLECTION ITEMS: tinted hover ─────────────────────── */
      .bks-dd-name {
        display: flex;
        align-items: center;
        gap: 8px;
      }

      .bks-dd-dot {
        display: block;
        width: 7px; height: 7px;
        border-radius: 50%;
        background: var(--cc, #cccccc);
        flex-shrink: 0;
        opacity: 0.6;
        transition: opacity 0.15s, transform 0.15s;
      }

      .bks-gh__dd-panel a[data-coll] {
        padding-left: 13px; /* compensate 3px border */
      }

      .bks-gh__dd-panel a[data-coll]:hover,
      .bks-gh__dd-panel a[data-coll]:focus-visible {
        background: color-mix(in srgb, var(--cc) 9%, #ffffff);
        border-left-color: var(--cc);
        color: #0a0a0a;
      }

      .bks-gh__dd-panel a[data-coll]:hover span,
      .bks-gh__dd-panel a[data-coll]:focus-visible span { color: #888888; }

      .bks-gh__dd-panel a[data-coll]:hover .bks-dd-dot,
      .bks-gh__dd-panel a[data-coll]:focus-visible .bks-dd-dot {
        opacity: 1;
        transform: scale(1.25);
      }

      @media (prefers-reduced-motion: reduce) {

        .bks-gh__dd-panel { transition: none; }

      }

      @media screen and (max-width: 989px) {

        .bks-gh__dd-panel { display: none; }

      }

    </style>



    {%- comment -%} RIGHT: IT·EN · AI BKS · | · search · account · cart {%- endcomment -%}

    <div class="bks-gh__actions">

      {%- if localization.available_languages.size > 1 -%}

        <form action="/localization" method="POST" class="bks-lang-toggle" aria-label="Language">

          <input type="hidden" name="_method" value="PUT">

          <input type="hidden" name="return_to" value="{{ request.path }}">

          {%- for lang in localization.available_languages -%}

            <button type="submit" name="locale_code" value="{{ lang.iso_code }}"

                    class="bks-lang-toggle__btn{% if lang.iso_code == localization.language.iso_code %} is-active{% endif %}">

              {{- lang.iso_code | upcase -}}

            </button>

            {%- unless forloop.last -%}<span class="bks-lang-toggle__sep" aria-hidden="true">·</span>{%- endunless -%}

          {%- endfor -%}

        </form>

      {%- endif -%}

      <button class="bks-gh__ask-btn" id="bks-nav-ask-trigger" type="button" aria-expanded="false" aria-label="Open BKS AI Assistant">AI BKS</button>

      <span class="bks-gh__action-sep" aria-hidden="true"></span>

      <a href="{{ routes.search_url }}" aria-label="Search catalog">

        <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>

      </a>

      {%- if customer -%}

      <div class="bks-member-halo" data-tier="{{ bks_tier }}" style="--bks-member-ring:{{ bks_tier_color }}" title="{{ customer.first_name }} · {{ bks_tier | capitalize }} Member">

        <a href="/pages/bks-members" aria-label="Il tuo account — {{ bks_tier | capitalize }} Member">

          <svg viewBox="0 0 24 24"><circle cx="12" cy="8" r="4"/><path d="M4 22c1.5-4 4.5-6 8-6s6.5 2 8 6"/></svg>

        </a>

      </div>

      {%- else -%}

      <div class="bks-login-wrap" style="position:relative;display:flex;align-items:center;gap:6px;">
        <a href="{{ routes.account_login_url }}" aria-label="Account" class="bks-login-icon">
          <svg viewBox="0 0 24 24"><circle cx="12" cy="8" r="4"/><path d="M4 22c1.5-4 4.5-6 8-6s6.5 2 8 6"/></svg>
        </a>
        <a href="https://bks-agent.bakabo.workers.dev/auth/google?redirect={{ request.path | url_encode }}" class="bks-google-signin" aria-label="Accedi con Google" title="Accedi con Google">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
          </svg>
        </a>
      </div>

      {%- endif -%}

      <a href="{{ routes.cart_url }}" aria-label="Open cart" style="position:relative;">

        <svg viewBox="0 0 24 24"><path d="M6 2 3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>

        <span class="bks-cart-count" id="bks-cart-bubble" data-count="{{ cart.item_count }}">

          {{- cart.item_count -}}

        </span>

      </a>

    </div>



  </div>

</header>



{%- if customer -%}

<div class="bks-member-arrival" aria-hidden="true"

     style="background:radial-gradient(ellipse at 88% 2%,{{ bks_tier_color }}33 0%,transparent 58%)"></div>

{%- endif -%}



{%- comment -%} MOBILE DRAWER {%- endcomment -%}

<div class="bks-gh__drawer" id="bks-nav-drawer" aria-hidden="true">

  <div class="bks-gh__drawer-overlay" id="bks-drawer-overlay"></div>

  <div class="bks-gh__drawer-panel" role="dialog" aria-modal="true" aria-label="Main menu">

    <button class="bks-gh__drawer-close" id="bks-drawer-close" aria-label="Close menu">

      <svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>

    </button>

    <nav class="bks-gh__drawer-nav">

      {%- liquid

        assign main_menu = linklists['main-menu-1']

        if main_menu.links.size == 0

          assign main_menu = linklists['main-menu']

        endif

      -%}

      {%- if main_menu.links.size > 0 -%}

        {%- for link in main_menu.links -%}

          <a href="{{ link.url }}"{% if link.current %} aria-current="page"{% endif %}>{{ link.title | escape }}</a>

          {%- for child in link.links -%}

            {%- liquid
              assign coll_slug = ''
              if child.url contains 'bks-hours'
                assign coll_slug = 'hours'
              elsif child.url contains 'bks-origin'
                assign coll_slug = 'origin'
              elsif child.url contains 'bks-glyph'
                assign coll_slug = 'glyph'
              elsif child.url contains 'bks-marker'
                assign coll_slug = 'marker'
              elsif child.url contains 'bks-riviera'
                assign coll_slug = 'riviera'
              elsif child.url contains 'bks-pulse'
                assign coll_slug = 'pulse'
              elsif child.url contains 'bks-token'
                assign coll_slug = 'token'
              elsif child.url contains 'bks-flag'
                assign coll_slug = 'flag'
              endif
            -%}

            <a class="bks-gh__drawer-sub" href="{{ child.url }}"{% if coll_slug != '' %} data-coll="{{ coll_slug }}"{% endif %}>{{ child.title | escape }}</a>

          {%- endfor -%}

        {%- endfor -%}

      {%- else -%}

        <a href="/">Home</a>

        <a href="/collections/all">Catalog</a>

        <a class="bks-gh__drawer-sub" href="/collections/bks-hours" data-coll="hours">BKS Hours</a>

        <a class="bks-gh__drawer-sub" href="/collections/bks-glyph" data-coll="glyph">BKS Glyph</a>

        <a class="bks-gh__drawer-sub" href="/collections/bks-marker" data-coll="marker">BKS Marker</a>

        <a class="bks-gh__drawer-sub" href="/collections/bks-riviera" data-coll="riviera">BKS Riviera</a>

        <a class="bks-gh__drawer-sub" href="/collections/bks-pulse" data-coll="pulse">BKS Pulse</a>

        <a class="bks-gh__drawer-sub" href="/collections/bks-token" data-coll="token">BKS Token</a>

        <a class="bks-gh__drawer-sub" href="/collections/bks-flag" data-coll="flag">BKS Flag</a>

        <a class="bks-gh__drawer-sub" href="/collections/bks-origin" data-coll="origin">BKS Origin</a>

        <a href="/pages/contact">Contact</a>

      {%- endif -%}

      <a href="{{ routes.search_url }}">Search</a>

      <a href="{{ routes.cart_url }}">Cart ({{ cart.item_count }})</a>

      {%- if localization.available_languages.size > 1 -%}

        <form action="/localization" method="POST" class="bks-gh__drawer-lang" aria-label="Language">

          <input type="hidden" name="_method" value="PUT">

          <input type="hidden" name="return_to" value="{{ request.path }}">

          {%- for lang in localization.available_languages -%}

            <button type="submit" name="locale_code" value="{{ lang.iso_code }}"

                    class="bks-lang-toggle__btn{% if lang.iso_code == localization.language.iso_code %} is-active{% endif %}">

              {{- lang.iso_code | upcase -}}

            </button>

            {%- unless forloop.last -%}<span class="bks-lang-toggle__sep" aria-hidden="true">·</span>{%- endunless -%}

          {%- endfor -%}

        </form>

      {%- endif -%}

      <button class="bks-gh__drawer-ask-btn" id="bks-drawer-ask-trigger" type="button">AI BKS</button>

    </nav>

  </div>

</div>



<script>

(function() {

  var header  = document.getElementById('bks-global-header');

  var drawer  = document.getElementById('bks-nav-drawer');

  var toggle  = document.getElementById('bks-menu-toggle');

  var close   = document.getElementById('bks-drawer-close');

  var overlay = document.getElementById('bks-drawer-overlay');

  var lastY   = 0;

  var ticking = false;



  // Scroll behaviour: always visible, only frosted-glass on scroll

  window.addEventListener('scroll', function() {

    if (!ticking) {

      requestAnimationFrame(function() {

        var y = window.scrollY;

        if (y > 80) { header.classList.add('bks-gh--scrolled'); }

        else { header.classList.remove('bks-gh--scrolled'); }

        // never hide header — always stays active during scroll

        header.classList.remove('bks-gh--hidden');

        lastY = y;

        ticking = false;

      });

      ticking = true;

    }

  }, { passive: true });



  // Drawer open/close

  function openDrawer() {

    header.classList.remove('bks-gh--hidden');

    drawer.classList.add('is-open');

    drawer.setAttribute('aria-hidden', 'false');

    toggle.setAttribute('aria-expanded', 'true');

    document.body.style.overflow = 'hidden';

  }

  function closeDrawer() {

    drawer.classList.remove('is-open');

    drawer.setAttribute('aria-hidden', 'true');

    toggle.setAttribute('aria-expanded', 'false');

    document.body.style.overflow = '';

  }

  if (toggle)  toggle.addEventListener('click', openDrawer);

  if (close)   close.addEventListener('click', closeDrawer);

  if (overlay) overlay.addEventListener('click', closeDrawer);

  document.addEventListener('keydown', function(e) {

    if (e.key === 'Escape') closeDrawer();

  });



  // Ask BKS — delegate to assistant toggle + sync aria-expanded

  function getAiToggle() { return document.querySelector('[data-bks-ai-toggle]'); }

  function syncAskBtns() {

    var expanded = (getAiToggle() || {}).getAttribute && getAiToggle().getAttribute('aria-expanded') === 'true';

    var navBtn = document.getElementById('bks-nav-ask-trigger');

    if (navBtn) navBtn.setAttribute('aria-expanded', expanded ? 'true' : 'false');

  }

  var navAsk = document.getElementById('bks-nav-ask-trigger');

  if (navAsk) {

    navAsk.addEventListener('click', function() {

      var ai = getAiToggle();

      if (ai) { ai.click(); syncAskBtns(); }

    });

  }

  var drawerAsk = document.getElementById('bks-drawer-ask-trigger');

  if (drawerAsk) {

    drawerAsk.addEventListener('click', function() {

      closeDrawer();

      setTimeout(function() {

        var ai = getAiToggle();

        if (ai) { ai.click(); syncAskBtns(); }

      }, 320);

    });

  }



  // ── Locale killer — MutationObserver + interval fallback ───────────────────

  var LOCALE_SELECTORS = [

    'localization-form', '.localization-form', '.disclosure',

    'market-popup', '.market-popup', '[data-market-popup]',

    'country-localization', '.country-selector',

    '.localization-wrapper', '.header__localization', '.footer__localization',

    '#shopify-market-redirect', '[id*="market-redirect"]',

    '[class*="gts-switcher"]', '[id*="gts-widget"]',

    '[class*="weglot"]', '#weglot_here',

    '#google_translate_element', '.goog-te-gadget', '.goog-te-banner-frame',

    '.language-switcher', '[class*="translate-"]',

    '.shopify-translate-language-switcher', '.translate-adapt-widget',

    '.nturl', '[class*="nturl"]',

    '.selecty-widget', '.selecty-container', '.selecty-popup', '.selecty-bar', '.selecty-flag',

    '#selecty-widget', '#selecty-app', '[class*="selecty"]', '[id*="selecty"]'

  ];

  function killLocaleEl(el) {

    if (!el) return;

    try {

      // Remove from DOM entirely so the app can't re-show it

      if (el.parentNode) { el.parentNode.removeChild(el); return; }

    } catch(e) {}

    // Fallback: aggressive hide

    try {

      el.style.setProperty('display',        'none',   'important');

      el.style.setProperty('visibility',     'hidden', 'important');

      el.style.setProperty('opacity',        '0',      'important');

      el.style.setProperty('pointer-events', 'none',   'important');

      el.style.setProperty('position',       'absolute','important');

      el.style.setProperty('clip',           'rect(0 0 0 0)', 'important');

    } catch(e2) {}

  }

  function killAllLocale() {

    LOCALE_SELECTORS.forEach(function(sel) {

      try { document.querySelectorAll(sel).forEach(killLocaleEl); } catch(e) {}

    });

  }

  killAllLocale();

  document.addEventListener('DOMContentLoaded', killAllLocale);

  window.addEventListener('load', killAllLocale);

  // Interval fallback: catches elements the observer might miss

  var _locInterval = setInterval(killAllLocale, 800);

  setTimeout(function() { clearInterval(_locInterval); }, 12000); // stop after 12s

  // MutationObserver for real-time interception

  var _locObs = new MutationObserver(function(mutations) {

    var needsKill = false;

    mutations.forEach(function(m) {

      m.addedNodes.forEach(function(n) {

        if (n.nodeType !== 1) return;

        var tag = (n.tagName || '').toLowerCase();

        var cls = (n.className || '').toString();

        var id  = (n.id || '');

        if (tag === 'localization-form' || tag === 'market-popup' ||

            tag === 'country-localization' ||

            cls.indexOf('localization') > -1 || cls.indexOf('disclosure') > -1 ||

            cls.indexOf('gts-') > -1 || cls.indexOf('weglot') > -1 ||

            cls.indexOf('nturl') > -1 ||

            cls.indexOf('translate') > -1 || cls.indexOf('lang-switch') > -1 ||

            id.indexOf('market') > -1 || id.indexOf('gts') > -1 ||

            id.indexOf('weglot') > -1 || id.indexOf('translate') > -1) {

          needsKill = true;

        }

      });

    });

    if (needsKill) killAllLocale();

  });

  _locObs.observe(document.documentElement, { childList: true, subtree: true });

})();

</script>

