{% liquid
  assign image = collection.featured_image
  if image == blank and collection.products.first
    assign image = collection.products.first.featured_image
  endif
  assign label = collection.title | default: fallback_label
%}

{% if collection != blank %}
  <a class="bks-orbit__card {{ class_name }}" href="{{ collection.url }}" aria-label="{{ label }}">
    {% if image != blank %}
      {{ image | image_url: width: 900 | image_tag: loading: 'eager', widths: '360, 540, 720, 900', alt: label }}
    {% endif %}
    <span>{{ label }}</span>
  </a>
{% else %}
  <a class="bks-orbit__card {{ class_name }}" href="/collections" aria-label="{{ label }}">
    <span>{{ label }}</span>
  </a>
{% endif %}

