{%- comment -%} ── Wallpaper Download ── {%- endcomment -%}
<div>
  <p class="bks-section-title">Wallpaper — pattern AI, alta risoluzione</p>
  <p style="font-size:13px;color:var(--bks-muted);margin-bottom:20px;line-height:1.6;">
    I pattern selezionati dalle collezioni BKS in formato 4K. Uso personale — desktop, telefono, stampa.
  </p>
  <div class="bks-archive-grid">

    {%- assign wallpapers = "Glyph Hex · 3840×2160,Folklore Bestiary · 3840×2160,Pulse Burst · 3840×2160,Flag Signal · 2160×3840,Marker Frame · 3840×2160,Riviera Cabana · 2160×3840" | split: "," -%}
    {%- for wp in wallpapers -%}
      {%- assign wp_parts = wp | split: " · " -%}
      <div class="bks-archive-card" style="display:flex;align-items:center;gap:16px;padding:16px;">
        <div style="width:52px;height:52px;background:var(--bks-surface-2);border-radius:3px;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:18px;">
          🖼
        </div>
        <div style="flex:1;min-width:0;">
          <p class="bks-archive-card-title" style="margin:0 0 4px;">{{ wp_parts[0] }}</p>
          <p class="bks-archive-card-desc" style="margin:0 0 8px;">{{ wp_parts[1] }}</p>
          <a href="#" style="font-size:11px;color:var(--bks-gold);text-decoration:none;font-weight:500;" download>
            ↓ Download
          </a>
        </div>
      </div>
    {%- endfor -%}

  </div>
</div>
