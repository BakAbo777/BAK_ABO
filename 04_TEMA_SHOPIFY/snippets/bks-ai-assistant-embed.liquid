{%- comment -%}
  BKS AI Assistant — embed globale nel layout.
  Sempre attivo. Endpoint configurabile via metafield o hardcoded quando live.
  Senza endpoint mostra fallback testuale.
{%- endcomment -%}

<style>
  .bks-ai {
    --bks-ai-ink: #111111;
    --bks-ai-paper: #ffffff;
    --bks-ai-muted: #5f5a52;
    --bks-ai-line: #ded8cd;
    --bks-ai-accent: #2f6f6b;
    bottom: 18px;
    font-family: var(--bks-font-text, "DM Sans", "Segoe UI", sans-serif);
    font-size: 14px;
    line-height: 1.5;
    position: fixed;
    right: 18px;
    z-index: 80;
  }
  .bks-ai__btn {
    background: var(--bks-ai-ink);
    border: 1px solid var(--bks-ai-ink);
    border-radius: 0;
    color: #fff;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: inherit;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    min-height: 44px;
    padding: 12px 16px;
    transition: background 0.2s;
  }
  .bks-ai__btn:hover { background: #2a2a2a; }
  .bks-ai__btn svg { width: 16px; height: 16px; fill: none; stroke: currentColor; stroke-width: 1.6; flex-shrink: 0; }
  .bks-ai__panel {
    background: var(--bks-ai-paper);
    border: 1px solid var(--bks-ai-line);
    bottom: 54px;
    box-shadow: 0 18px 48px rgba(17,17,17,.18);
    color: var(--bks-ai-ink);
    display: flex;
    flex-direction: column;
    max-height: min(560px, calc(100vh - 100px));
    overflow: hidden;
    position: absolute;
    right: 0;
    width: min(360px, calc(100vw - 36px));
  }
  .bks-ai__panel[hidden] { display: none; }
  .bks-ai__head {
    align-items: center;
    border-bottom: 1px solid var(--bks-ai-line);
    display: flex;
    gap: 12px;
    justify-content: space-between;
    padding: 12px 14px;
    flex-shrink: 0;
  }
  .bks-ai__head-info strong { display: block; font-family: var(--bks-font-display, "Bebas Neue", sans-serif); font-size: 1rem; letter-spacing: 0.05em; line-height: 1; }
  .bks-ai__head-info small { color: var(--bks-ai-muted); font-size: 11px; }
  .bks-ai__close { background: none; border: 0; color: var(--bks-ai-ink); cursor: pointer; font-size: 1.2rem; line-height: 1; padding: 4px 6px; }
  .bks-ai__log {
    display: flex;
    flex-direction: column;
    gap: 8px;
    flex: 1;
    overflow-y: auto;
    padding: 12px 14px;
    scroll-behavior: smooth;
  }
  .bks-ai__msg {
    border: 1px solid var(--bks-ai-line);
    font-size: 13px;
    line-height: 1.5;
    margin: 0;
    padding: 9px 11px;
    white-space: pre-wrap;
    word-break: break-word;
  }
  .bks-ai__msg--user { background: #f1ede5; margin-left: 24px; }
  .bks-ai__msg--ai   { background: #fff;    margin-right: 24px; }
  .bks-ai__msg--ai.is-loading { color: var(--bks-ai-muted); font-style: italic; }
  .bks-ai__form {
    border-top: 1px solid var(--bks-ai-line);
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 0;
    flex-shrink: 0;
  }
  .bks-ai__input {
    border: none;
    border-right: 1px solid var(--bks-ai-line);
    color: var(--bks-ai-ink);
    font: inherit;
    font-size: 14px;
    min-width: 0;
    outline: none;
    padding: 12px 13px;
  }
  .bks-ai__send {
    background: var(--bks-ai-accent);
    border: none;
    color: #fff;
    cursor: pointer;
    font: inherit;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    padding: 0 14px;
    text-transform: uppercase;
    transition: background 0.2s;
  }
  .bks-ai__send:hover { background: #235856; }
  .bks-ai__footer { color: var(--bks-ai-muted); font-size: 11px; line-height: 1.4; padding: 8px 14px 12px; flex-shrink: 0; }
  @media (max-width: 480px) {
    .bks-ai { bottom: 10px; right: 10px; }
    .bks-ai__panel { bottom: 50px; width: calc(100vw - 20px); }
    .bks-ai__msg--user, .bks-ai__msg--ai { margin-left: 0; margin-right: 0; }
  }
</style>

<div class="bks-ai" id="bks-ai-root"
  data-endpoint="https://bks-agent.bakabo.workers.dev/chat"
  data-customer="{{ customer.id | default: 'anonymous' }}"
  data-tier="{{ customer.tags | split: ',' | first | strip | downcase | default: 'none' }}"
  data-bound="0">
  <button class="bks-ai__btn" id="bks-ai-toggle" aria-expanded="false" aria-controls="bks-ai-panel">
    <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="9"/><path d="M9 10h.01M15 10h.01"/><path d="M9.5 15a3.5 3.5 0 0 0 5 0"/></svg>
    BKS AI
  </button>
  <div class="bks-ai__panel" id="bks-ai-panel" hidden role="dialog" aria-modal="true" aria-label="BKS AI Assistant">
    <div class="bks-ai__head">
      <div class="bks-ai__head-info">
        <strong>BKS AI Studio</strong>
        <small>AI Assistant — answers from verified BKS data</small>
      </div>
      <button class="bks-ai__close" id="bks-ai-close" aria-label="Close">&#x2715;</button>
    </div>
    <div class="bks-ai__log" id="bks-ai-log">
      <p class="bks-ai__msg bks-ai__msg--ai">Hi! I'm BKS AI. I can help with collections, shipping, returns and bakabo.club products. What do you need?</p>
    </div>
    <form class="bks-ai__form" id="bks-ai-form" autocomplete="off">
      <input class="bks-ai__input" id="bks-ai-input" type="text" placeholder="Ask a question…" aria-label="Message">
      <button class="bks-ai__send" type="submit">Send</button>
    </form>
    <p class="bks-ai__footer">The assistant does not collect payment data and does not replace checkout. <a href="/policies/privacy-policy" style="color:inherit">Privacy</a></p>
  </div>
</div>

<script>
(function () {
  var root        = document.getElementById('bks-ai-root');
  var toggle      = document.getElementById('bks-ai-toggle');
  var panel       = document.getElementById('bks-ai-panel');
  var closeBtn    = document.getElementById('bks-ai-close');
  var form        = document.getElementById('bks-ai-form');
  var input       = document.getElementById('bks-ai-input');
  var log         = document.getElementById('bks-ai-log');
  var endpoint    = root.dataset.endpoint || '';
  var customerId  = root.dataset.customer || 'anonymous';
  var customerTier= root.dataset.tier || 'none';

  function msg(text, cls, id) {
    var p = document.createElement('p');
    p.className = 'bks-ai__msg bks-ai__msg--' + cls;
    p.textContent = text;
    if (id) p.id = id;
    log.appendChild(p);
    log.scrollTop = log.scrollHeight;
    return p;
  }

  function open(state) {
    panel.hidden = !state;
    toggle.setAttribute('aria-expanded', state ? 'true' : 'false');
    if (state) { input.focus(); }
    document.body.style.overflow = (state && window.innerWidth < 480) ? 'hidden' : '';
  }

  toggle.addEventListener('click', function () { open(panel.hidden); });
  closeBtn.addEventListener('click', function () { open(false); });
  document.addEventListener('keydown', function (e) { if (e.key === 'Escape' && !panel.hidden) open(false); });

  form.addEventListener('submit', function (e) {
    e.preventDefault();
    var text = (input.value || '').trim();
    if (!text) return;
    input.value = '';
    msg(text, 'user');

    if (!endpoint) {
      msg('Sono BKS AI. Per informazioni su collezioni, spedizioni e resi visita bakabo.club/pages/contact oppure scrivi a crew@bakabo.club.', 'ai');
      return;
    }

    var loading = msg('Sto cercando tra i dati BKS…', 'ai is-loading', 'bks-ai-loading');

    fetch(endpoint, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        message:       text,
        customer_id:   customerId,
        customer_tier: customerTier,
        page_url:      window.location.href,
        product_title: (window.ShopifyAnalytics && window.ShopifyAnalytics.meta && window.ShopifyAnalytics.meta.product)
                       ? window.ShopifyAnalytics.meta.product.title : ''
      })
    })
    .then(function (r) { return r.json(); })
    .then(function (d) {
      var el = document.getElementById('bks-ai-loading');
      if (el) el.remove();
      msg(d.reply || 'Non ho trovato una risposta verificata. Prova con il supporto ufficiale.', 'ai');
    })
    .catch(function () {
      var el = document.getElementById('bks-ai-loading');
      if (el) el.remove();
      msg('Non riesco a raggiungere il server BKS. Usa la chat o le pagine policy.', 'ai');
    });
  });
})();
</script>
