{%- comment -%} BKS JSON-LD Structured Data — emitted once per page type {%- endcomment -%}

{%- liquid
  assign is_product    = false
  assign is_home       = false
  assign is_collection = false
  assign is_faq        = false
  if request.page_type == 'product'
    assign is_product = true
  elsif request.page_type == 'index'
    assign is_home = true
  elsif request.page_type == 'collection'
    assign is_collection = true
  elsif request.page_type == 'page' and page.handle == 'bks-faq'
    assign is_faq = true
  endif
-%}

{%- comment -%} ── PRODUCT ─────────────────────────────────────────────── {%- endcomment -%}
{%- if is_product -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Product",
  "name": {{ product.title | json }},
  "description": {{ product.description | strip_html | truncatewords: 200 | json }},
  "url": "{{ shop.url }}{{ product.url }}",
  "brand": {
    "@type": "Brand",
    "name": "BKS Studio"
  },
  "category": {{ product.type | json }},
  {%- if product.featured_image -%}
  "image": [
    "https:{{ product.featured_image | image_url: width: 1200 }}"
    {%- for img in product.images offset: 1 limit: 4 -%}
    , "https:{{ img | image_url: width: 1200 }}"
    {%- endfor -%}
  ],
  {%- endif -%}
  "offers": [
    {%- for variant in product.variants -%}
    {
      "@type": "Offer",
      "priceCurrency": {{ cart.currency.iso_code | json }},
      "price": {{ variant.price | money_without_currency | remove: ',' }},
      "availability": "{% if variant.available %}https://schema.org/InStock{% else %}https://schema.org/OutOfStock{% endif %}",
      "url": "{{ shop.url }}{{ product.url }}?variant={{ variant.id }}",
      "seller": { "@type": "Organization", "name": "BakAbo" },
      "hasMerchantReturnPolicy": {
        "@type": "MerchantReturnPolicy",
        "applicableCountry": ["IT","DE","FR","ES","US"],
        "returnPolicyCategory": "https://schema.org/MerchantReturnFiniteReturnWindow",
        "merchantReturnDays": 30,
        "returnMethod": "https://schema.org/ReturnByMail",
        "returnFees": "https://schema.org/ReturnShippingFees"
      },
      "shippingDetails": {
        "@type": "OfferShippingDetails",
        "shippingDestination": [
          { "@type": "DefinedRegion", "addressCountry": "IT" },
          { "@type": "DefinedRegion", "addressCountry": "DE" },
          { "@type": "DefinedRegion", "addressCountry": "FR" },
          { "@type": "DefinedRegion", "addressCountry": "ES" },
          { "@type": "DefinedRegion", "addressCountry": "US" }
        ],
        "shippingRate": { "@type": "MonetaryAmount", "value": "6.90", "currency": "EUR" },
        "deliveryTime": {
          "@type": "ShippingDeliveryTime",
          "handlingTime": { "@type": "QuantitativeValue", "minValue": 7, "maxValue": 14, "unitCode": "DAY" },
          "transitTime": { "@type": "QuantitativeValue", "minValue": 3, "maxValue": 10, "unitCode": "DAY" }
        }
      }
      {%- if variant.sku != blank -%}
      ,"sku": {{ variant.sku | json }}
      {%- endif -%}
    }{% unless forloop.last %},{% endunless %}
    {%- endfor -%}
  ]
}
</script>
{%- endif -%}

{%- comment -%} ── HOME — WebSite SearchAction + Organization ──────────── {%- endcomment -%}
{%- if is_home -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": {{ shop.name | json }},
  "url": "{{ request.origin }}",
  "potentialAction": {
    "@type": "SearchAction",
    "target": {
      "@type": "EntryPoint",
      "urlTemplate": "{{ request.origin }}/search?q={search_term_string}"
    },
    "query-input": "required name=search_term_string"
  }
}
</script>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "BKS Studio",
  "alternateName": "BakAbo",
  "url": "{{ request.origin }}",
  "logo": "{{ request.origin }}/cdn/shop/files/bks-logo.png",
  "description": "AI-art fashion atelier. Designed in Italy, made on demand worldwide. Eight collections of AI-generated wearable art.",
  "email": "crew@bakabo.club",
  "foundingDate": "2024",
  "areaServed": "Worldwide",
  "brand": {
    "@type": "Brand",
    "name": "BKS Studio"
  },
  "sameAs": [
    "https://www.instagram.com/bakabofirm"
  ]
}
</script>
{%- endif -%}

{%- comment -%} ── COLLECTION — CollectionPage + BreadcrumbList ─────────── {%- endcomment -%}
{%- if is_collection -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": {{ collection.title | json }},
  "description": {{ collection.description | strip_html | truncatewords: 100 | json }},
  "url": "{{ request.origin }}{{ collection.url }}",
  "numberOfItems": {{ collection.products_count }},
  "mainEntity": {
    "@type": "ItemList",
    "numberOfItems": {{ collection.products_count }},
    "itemListElement": [
      {%- for p in collection.products limit: 20 -%}
      {
        "@type": "ListItem",
        "position": {{ forloop.index }},
        "url": "{{ request.origin }}{{ p.url }}",
        "name": {{ p.title | json }}
      }{% unless forloop.last %},{% endunless %}
      {%- endfor -%}
    ]
  }
}
</script>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "{{ request.origin }}" },
    { "@type": "ListItem", "position": 2, "name": {{ collection.title | json }}, "item": "{{ request.origin }}{{ collection.url }}" }
  ]
}
</script>
{%- endif -%}

{%- comment -%} ── FAQ — FAQPage ────────────────────────────────────────── {%- endcomment -%}
{%- if is_faq -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How are BKS products made?",
      "acceptedAnswer": { "@type": "Answer", "text": "Every piece is built from artwork generated by the BKS crew using AI. Products are printed on demand by Printify using all-over-print (AOP) technology — edge-to-edge colour and detail on every piece. Nothing is produced until you order." }
    },
    {
      "@type": "Question",
      "name": "Are BKS products sustainable?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. The made-to-order model eliminates overstock and surplus production. Your piece is printed only when you place the order — zero inventory waste, zero guesswork on quantities." }
    },
    {
      "@type": "Question",
      "name": "How long does delivery take?",
      "acceptedAnswer": { "@type": "Answer", "text": "Production: 7–14 business days (all pieces are made to order). Shipping: 3–5 business days after dispatch in Europe. Total estimated delivery: 10–19 business days." }
    },
    {
      "@type": "Question",
      "name": "Do you ship outside Europe?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes, we ship worldwide. US orders typically arrive within 7–14 business days after production." }
    },
    {
      "@type": "Question",
      "name": "What is your return policy?",
      "acceptedAnswer": { "@type": "Answer", "text": "We accept returns within 30 days of delivery for defective items, print errors, or wrong items received. Because every piece is made to order, we cannot accept returns for size choices or change of mind. Contact crew@bakabo.club with photos of the issue." }
    },
    {
      "@type": "Question",
      "name": "Can I change or cancel an order?",
      "acceptedAnswer": { "@type": "Answer", "text": "Orders can be cancelled within 12 hours of purchase — email crew@bakabo.club immediately. Once Printify confirms production has started, the order cannot be changed or cancelled." }
    },
    {
      "@type": "Question",
      "name": "How does BKS Membership work?",
      "acceptedAnswer": { "@type": "Answer", "text": "BKS Membership uses the Metal Tier system — 5 levels, all free to join: Lead (0 orders), Iron (1–2 orders), Brass (3–5 orders) with AI Personal Shopper and Try-On, Silver (6–10 orders), Gold (11+ orders) with VIP access. Create a free account on bakabo.club to start." }
    },
    {
      "@type": "Question",
      "name": "Which payment methods do you accept?",
      "acceptedAnswer": { "@type": "Answer", "text": "We accept credit and debit cards (Visa, Mastercard, Amex), PayPal, and all digital wallets supported by Shopify Payments including Apple Pay and Google Pay." }
    }
  ]
}
</script>
{%- endif -%}
