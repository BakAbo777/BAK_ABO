{{ 'bks-future.css' | asset_url | stylesheet_tag }}

{% liquid
  assign handles_string = section.settings.collection_handles | default: 'bks-folklore,bks-glyph,bks-marker,bks-riviera,bks-pulse,bks-token,bks-flag,bks-hours'
  assign collection_handles = handles_string | split: ','
  assign collection_count = collection_handles | size
%}

<style>
  /* ── BKS IMPACT HOME — Cinematic Interactions ───────────── */

  #shopify-section-{{ section.id }} .bks-impact {
    position: relative;
    min-height: calc(100svh - var(--header-height, 72px));
    overflow: hidden;
    background: radial-gradient(ellipse at 20% 30%, #1a1510 0%, #0A0A0A 50%, #000 100%);
    color: #FAFAF7;
    cursor: crosshair;
    perspective: 1200px;
  }

  /* Vignette overlay */
  #shopify-section-{{ section.id }} .bks-impact::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at center, transparent 30%, rgba(0,0,0,0.6) 100%);
    pointer-events: none;
    z-index: 1;
  }

  /* Animated grain texture */
  #shopify-section-{{ section.id }} .bks-impact::after {
    content: '';
    position: absolute;
    inset: -50%;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='3'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.4'/%3E%3C/svg%3E");
    opacity: 0.08;
    pointer-events: none;
    z-index: 2;
    animation: grainShift 8s steps(6) infinite;
    mix-blend-mode: overlay;
  }

  @keyframes grainShift {
    0%, 100% { transform: translate(0, 0); }
    20% { transform: translate(-5%, -5%); }
    40% { transform: translate(5%, -5%); }
    60% { transform: translate(-5%, 5%); }
    80% { transform: translate(5%, 5%); }
  }

  #shopify-section-{{ section.id }} .bks-math-canvas {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    opacity: 0.6;
  }

  #shopify-section-{{ section.id }} .bks-elastic-lines {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 5;
    overflow: visible;
  }

  #shopify-section-{{ section.id }} .bks-impact__inner {
    position: relative;
    z-index: 10;
    display: grid;
    grid-template-columns: minmax(0,1fr) minmax(280px,0.86fr);
    gap: clamp(28px,5vw,80px);
    align-items: center;
    width: min(1560px, calc(100% - 32px));
    min-height: inherit;
    margin: 0 auto;
    padding: clamp(52px,8vw,132px) 0 clamp(36px,5vw,72px);
    transform-style: preserve-3d;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  #shopify-section-{{ section.id }} .bks-impact__content {
    color: #FAFAF7;
    pointer-events: none;
    transform: translateZ(40px);
  }

  #shopify-section-{{ section.id }} .bks-brand-context {
    display: inline-flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 10px;
    margin: 0 0 18px;
    pointer-events: auto;
    opacity: 0;
    animation: slideInLeft 1s cubic-bezier(0.16, 1, 0.3, 1) 0.1s forwards;
  }

  #shopify-section-{{ section.id }} .bks-brand-context__item {
    display: inline-flex;
    align-items: center;
    min-height: 34px;
    padding: 8px 12px;
    border: 1px solid rgba(250,250,247,0.28);
    border-radius: 999px;
    background: rgba(10,10,10,0.48);
    color: #FAFAF7;
    box-shadow: 0 12px 34px rgba(0,0,0,0.24);
    font-family: var(--bks-font-mono,'DM Mono',monospace);
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0;
    text-transform: uppercase;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  #shopify-section-{{ section.id }} .bks-brand-context__item:hover {
    transform: translateY(-2px);
    border-color: rgba(201,183,156,0.6);
    box-shadow: 0 16px 40px rgba(201,183,156,0.2);
  }

  #shopify-section-{{ section.id }} .bks-brand-context__container {
    border-color: rgba(201,183,156,0.72);
  }

  #shopify-section-{{ section.id }} .bks-brand-context__creator {
    gap: 8px;
    border-color: rgba(250,250,247,0.92);
    background: #FAFAF7;
    color: #0A0A0A;
  }

  #shopify-section-{{ section.id }} .bks-brand-context__creator img {
    display: block;
    width: auto;
    height: 18px;
    max-width: 76px;
    background: transparent;
  }

  #shopify-section-{{ section.id }} .bks-impact__eyebrow {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-bottom: 18px;
    font-family: var(--bks-font-mono,'DM Mono',monospace);
    font-size: 0.76rem;
    text-transform: uppercase;
    letter-spacing: 0;
    color: var(--bks-dune, #C9B79C);
    opacity: 0;
    animation: slideInLeft 1s cubic-bezier(0.16, 1, 0.3, 1) 0.25s forwards;
  }

  #shopify-section-{{ section.id }} .bks-impact__eyebrow span {
    display: inline-block;
    position: relative;
  }

  #shopify-section-{{ section.id }} .bks-impact__eyebrow span::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: -4px;
    width: 0;
    height: 1px;
    background: linear-gradient(90deg, #C9B79C, transparent);
    animation: lineGrow 1.5s cubic-bezier(0.16, 1, 0.3, 1) 1s forwards;
  }

  @keyframes lineGrow {
    to { width: 100%; }
  }

  /* SPLIT TEXT - lettere animate singolarmente */
  #shopify-section-{{ section.id }} .bks-impact__title {
    margin: 0;
    font-family: var(--bks-font-display,'Bebas Neue',sans-serif);
    font-size: clamp(56px, 9vw, 136px);
    line-height: 0.88;
    letter-spacing: 0;
    text-transform: uppercase;
    color: #FAFAF7;
    max-width: 12ch;
  }

  #shopify-section-{{ section.id }} .bks-impact__title .char {
    display: inline-block;
    opacity: 0;
    transform: translateY(100%) rotateX(-90deg);
    transform-origin: bottom;
    animation: charReveal 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    background: linear-gradient(180deg, #FAFAF7 0%, #C9B79C 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    transition: transform 0.3s ease;
  }

  #shopify-section-{{ section.id }} .bks-impact__title .char:hover {
    transform: translateY(-8px) scale(1.1);
  }

  @keyframes charReveal {
    to {
      opacity: 1;
      transform: translateY(0) rotateX(0);
    }
  }

  /* Colori identitari per collezione — ogni mondo ha il suo tono */
  #shopify-section-{{ section.id }} [data-handle="bks-folklore"] .bks-collection-card__overlay { background: rgba(82,54,32,0.82); }
  #shopify-section-{{ section.id }} [data-handle="bks-folklore"] .bks-collection-card__overlay-count { color: #D4A96A; }
  #shopify-section-{{ section.id }} [data-handle="bks-glyph"]    .bks-collection-card__overlay { background: rgba(20,20,20,0.88); }
  #shopify-section-{{ section.id }} [data-handle="bks-glyph"]    .bks-collection-card__overlay-count { color: #E8E8E4; }
  #shopify-section-{{ section.id }} [data-handle="bks-marker"]   .bks-collection-card__overlay { background: rgba(28,48,28,0.84); }
  #shopify-section-{{ section.id }} [data-handle="bks-marker"]   .bks-collection-card__overlay-count { color: #7DBF72; }
  #shopify-section-{{ section.id }} [data-handle="bks-riviera"]  .bks-collection-card__overlay { background: rgba(20,38,72,0.84); }
  #shopify-section-{{ section.id }} [data-handle="bks-riviera"]  .bks-collection-card__overlay-count { color: #7EB3D4; }
  #shopify-section-{{ section.id }} [data-handle="bks-pulse"]    .bks-collection-card__overlay { background: rgba(80,16,16,0.84); }
  #shopify-section-{{ section.id }} [data-handle="bks-pulse"]    .bks-collection-card__overlay-count { color: #E05C5C; }
  #shopify-section-{{ section.id }} [data-handle="bks-token"]    .bks-collection-card__overlay { background: rgba(60,44,10,0.84); }
  #shopify-section-{{ section.id }} [data-handle="bks-token"]    .bks-collection-card__overlay-count { color: #F0C84A; }
  #shopify-section-{{ section.id }} [data-handle="bks-flag"]     .bks-collection-card__overlay { background: rgba(60,16,50,0.84); }
  #shopify-section-{{ section.id }} [data-handle="bks-flag"]     .bks-collection-card__overlay-count { color: #C97AB8; }
  #shopify-section-{{ section.id }} [data-handle="bks-hours"]    .bks-collection-card__overlay { background: rgba(10,10,10,0.90); }
  #shopify-section-{{ section.id }} [data-handle="bks-hours"]    .bks-collection-card__overlay-count { color: #C9B79C; }

  #shopify-section-{{ section.id }} .bks-impact__copy {
    max-width: 56ch;
    margin: 24px 0 0;
    font-family: var(--bks-font-body,'DM Sans',sans-serif);
    font-size: 18px;
    line-height: 1.65;
    color: rgba(250,250,247,0.72);
    opacity: 0;
    animation: slideInLeft 1s cubic-bezier(0.16, 1, 0.3, 1) 0.7s forwards;
  }

  #shopify-section-{{ section.id }} .bks-impact__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 32px;
    opacity: 0;
    animation: slideInLeft 1s cubic-bezier(0.16, 1, 0.3, 1) 0.9s forwards;
    pointer-events: auto;
  }

  #shopify-section-{{ section.id }} .bks-button {
    position: relative;
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    padding: 0 24px;
    background: #FAFAF7;
    color: #0A0A0A;
    border: 1px solid #FAFAF7;
    text-decoration: none;
    font-family: var(--bks-font-mono,'DM Mono',monospace);
    font-size: 0.74rem;
    text-transform: uppercase;
    letter-spacing: 0;
    border-radius: 0;
    overflow: hidden;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    pointer-events: auto;
    isolation: isolate;
  }

  #shopify-section-{{ section.id }} .bks-button::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, #C9B79C, #FAFAF7);
    transform: translateX(-101%);
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    z-index: -1;
  }

  #shopify-section-{{ section.id }} .bks-button:hover::before {
    transform: translateX(0);
  }

  #shopify-section-{{ section.id }} .bks-button:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 32px rgba(201,183,156,0.4);
    color: #0A0A0A;
  }

  #shopify-section-{{ section.id }} .bks-button--ghost {
    background: transparent;
    color: #FAFAF7;
    border-color: rgba(250,250,247,0.3);
  }

  #shopify-section-{{ section.id }} .bks-button--ghost::before {
    background: rgba(250,250,247,0.1);
  }

  #shopify-section-{{ section.id }} .bks-orbit {
    position: relative;
    display: grid;
    min-height: min(72svh,720px);
    isolation: isolate;
    pointer-events: auto;
    transform-style: preserve-3d;
    opacity: 0;
    animation: orbitEnter 1.4s cubic-bezier(0.16, 1, 0.3, 1) 0.4s forwards;
  }

  @keyframes orbitEnter {
    from {
      opacity: 0;
      transform: scale(0.7) rotate(-15deg);
    }
    to {
      opacity: 1;
      transform: scale(1) rotate(0);
    }
  }

  @keyframes slideInLeft {
    from {
      opacity: 0;
      transform: translateX(-40px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  /* Punto focale invisibile al centro — le 8 collezioni orbitano come mondi */
  #shopify-section-{{ section.id }} .bks-orbit__focal {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(201,183,156,0.3), transparent);
    pointer-events: none;
    z-index: 1;
    box-shadow: 0 0 40px 20px rgba(201,183,156,0.06);
  }

  #shopify-section-{{ section.id }} .bks-orbit__ring {
    position: absolute;
    left: 50%;
    top: 50%;
    border: 1px solid rgba(250,250,247,0.08);
    border-radius: 50%;
    pointer-events: none;
    transform: translate(-50%, -50%);
  }

  #shopify-section-{{ section.id }} .bks-orbit__ring--1 { 
    width: 40%; height: 40%; 
    animation: orbitSpin 60s linear infinite, ringPulse 4s ease-in-out infinite;
    border-style: dashed;
  }
  #shopify-section-{{ section.id }} .bks-orbit__ring--2 { 
    width: 65%; height: 65%; 
    animation: orbitSpinReverse 80s linear infinite, ringPulse 5s ease-in-out infinite 1s;
    border-color: rgba(200,71,61,0.15);
  }
  #shopify-section-{{ section.id }} .bks-orbit__ring--3 { 
    width: 90%; height: 90%; 
    animation: orbitSpin 100s linear infinite, ringPulse 6s ease-in-out infinite 2s;
    border-color: rgba(200,183,156,0.1);
    border-style: dotted;
  }

  @keyframes ringPulse {
    0%, 100% { opacity: 0.4; border-width: 1px; }
    50% { opacity: 1; border-width: 2px; }
  }

  /* COLLECTION CARD — con effetto magnetico */
  #shopify-section-{{ section.id }} .bks-collection-card {
    position: absolute;
    width: clamp(120px,16vw,200px);
    aspect-ratio: 1;
    display: grid;
    place-items: center;
    cursor: grab;
    pointer-events: auto;
    transition: filter 0.3s ease;
    user-select: none;
    z-index: 20;
    opacity: 0;
    animation: cardAppear 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes cardAppear {
    from {
      opacity: 0;
      transform: translate(-50%, -50%) scale(0) rotate(-180deg);
    }
    to {
      opacity: 1;
      transform: translate(-50%, -50%) scale(1) rotate(0);
    }
  }

  #shopify-section-{{ section.id }} .bks-collection-card:active {
    cursor: grabbing;
  }

  #shopify-section-{{ section.id }} .bks-collection-card__inner {
    width: 100%;
    height: 100%;
    position: relative;
    overflow: visible;
    border-radius: 50%;
    background: rgba(250,250,247,0.05);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 1px solid rgba(250,250,247,0.1);
    box-shadow: 
      0 8px 32px rgba(0,0,0,0.3),
      inset 0 0 0 1px rgba(250,250,247,0.05);
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* Animated border gradient */
  #shopify-section-{{ section.id }} .bks-collection-card__inner::before {
    content: '';
    position: absolute;
    inset: -2px;
    border-radius: 50%;
    background: conic-gradient(from 0deg, transparent 0%, #C9B79C 25%, transparent 50%);
    opacity: 0;
    transition: opacity 0.4s ease;
    z-index: -1;
    animation: borderRotate 4s linear infinite;
  }

  @keyframes borderRotate {
    to { transform: rotate(360deg); }
  }

  #shopify-section-{{ section.id }} .bks-collection-card img {
    width: 80%;
    height: 80%;
    object-fit: contain;
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    filter: drop-shadow(0 8px 16px rgba(0,0,0,0.4));
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1), filter 0.4s ease;
    pointer-events: none;
  }

  /* Portal overlay — appare al hover, tutta la card è il portale */
  #shopify-section-{{ section.id }} .bks-collection-card__overlay {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 4px;
    background: rgba(10,10,10,0.78);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    opacity: 0;
    transition: opacity 0.35s cubic-bezier(0.16, 1, 0.3, 1);
    pointer-events: none;
  }

  #shopify-section-{{ section.id }} .bks-collection-card:hover .bks-collection-card__overlay {
    opacity: 1;
  }

  #shopify-section-{{ section.id }} .bks-collection-card__overlay-name {
    font-family: var(--bks-font-display,'Bebas Neue',sans-serif);
    font-size: clamp(14px,1.4vw,20px);
    letter-spacing: 0.02em;
    color: #FAFAF7;
    text-align: center;
    padding: 0 12px;
    line-height: 1.1;
  }

  #shopify-section-{{ section.id }} .bks-collection-card__overlay-count {
    font-family: var(--bks-font-mono,'DM Mono',monospace);
    font-size: 0.6rem;
    text-transform: uppercase;
    color: #C9B79C;
    letter-spacing: 0.06em;
  }

  #shopify-section-{{ section.id }} .bks-collection-card__overlay-enter {
    margin-top: 6px;
    font-family: var(--bks-font-mono,'DM Mono',monospace);
    font-size: 0.58rem;
    text-transform: uppercase;
    color: rgba(250,250,247,0.5);
    letter-spacing: 0.1em;
  }

  #shopify-section-{{ section.id }} .bks-collection-card:hover .bks-collection-card__inner {
    background: rgba(250,250,247,0.1);
    border-color: rgba(250,250,247,0.3);
    box-shadow: 
      0 16px 56px rgba(0,0,0,0.5),
      0 0 0 2px rgba(250,250,247,0.1),
      0 0 40px rgba(201,183,156,0.2),
      inset 0 0 20px rgba(250,250,247,0.05);
  }

  #shopify-section-{{ section.id }} .bks-collection-card:hover .bks-collection-card__inner::before {
    opacity: 1;
  }

  #shopify-section-{{ section.id }} .bks-collection-card:hover img {
    transform: translate(-50%, -50%) scale(1.2) rotate(5deg);
    filter: drop-shadow(0 12px 24px rgba(201,183,156,0.4));
  }

  #shopify-section-{{ section.id }} .bks-collection-card.connected {
    z-index: 25;
  }

  #shopify-section-{{ section.id }} .bks-collection-card.connected .bks-collection-card__inner {
    background: rgba(200,183,156,0.15);
    border-color: rgba(200,183,156,0.5);
    box-shadow: 
      0 0 0 3px rgba(200,183,156,0.3),
      0 12px 48px rgba(0,0,0,0.4),
      0 0 60px rgba(201,183,156,0.3);
    animation: connectedPulse 2s ease-in-out infinite;
  }

  @keyframes connectedPulse {
    0%, 100% { box-shadow: 0 0 0 3px rgba(200,183,156,0.3), 0 12px 48px rgba(0,0,0,0.4), 0 0 60px rgba(201,183,156,0.3); }
    50% { box-shadow: 0 0 0 6px rgba(200,183,156,0.5), 0 12px 48px rgba(0,0,0,0.4), 0 0 100px rgba(201,183,156,0.5); }
  }

  #shopify-section-{{ section.id }} .elastic-path {
    fill: none;
    stroke: url(#gradientLine);
    stroke-width: 2;
    stroke-linecap: round;
    opacity: 0;
    transition: opacity 0.3s ease;
    filter: drop-shadow(0 0 6px rgba(201,183,156,0.6));
    stroke-dasharray: 1000;
    stroke-dashoffset: 1000;
    animation: pathDraw 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes pathDraw {
    to {
      stroke-dashoffset: 0;
      opacity: 0.8;
    }
  }

  #shopify-section-{{ section.id }} .elastic-path.active {
    opacity: 0.8;
  }

  #shopify-section-{{ section.id }} .math-tooltip {
    position: absolute;
    padding: 8px 16px;
    background: rgba(10,10,10,0.95);
    border: 1px solid rgba(201,183,156,0.4);
    color: #C9B79C;
    font-family: var(--bks-font-mono,'DM Mono',monospace);
    font-size: 0.7rem;
    border-radius: 4px;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.3s ease, transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    z-index: 100;
    white-space: nowrap;
    box-shadow: 0 8px 32px rgba(0,0,0,0.4), 0 0 20px rgba(201,183,156,0.2);
    transform: translateY(10px);
    backdrop-filter: blur(8px);
  }

  #shopify-section-{{ section.id }} .math-tooltip.visible {
    opacity: 1;
    transform: translateY(0);
  }

  #shopify-section-{{ section.id }} .bks-impact__stats {
    display: grid;
    grid-template-columns: repeat(3,minmax(0,1fr));
    gap: 1px;
    max-width: 520px;
    margin-top: 46px;
    background: rgba(250,250,247,0.15);
    opacity: 0;
    animation: slideInLeft 1s cubic-bezier(0.16, 1, 0.3, 1) 1.1s forwards;
    pointer-events: auto;
    overflow: hidden;
    border-radius: 4px;
  }

  #shopify-section-{{ section.id }} .bks-impact__stat {
    padding: 14px 16px;
    background: rgba(10,10,10,0.85);
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    cursor: pointer;
    position: relative;
    overflow: hidden;
  }

  #shopify-section-{{ section.id }} .bks-impact__stat::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(201,183,156,0.2), transparent);
    transform: translateX(-100%);
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  #shopify-section-{{ section.id }} .bks-impact__stat:hover::before {
    transform: translateX(0);
  }

  #shopify-section-{{ section.id }} .bks-impact__stat:hover {
    background: rgba(200,183,156,0.1);
    transform: translateY(-2px);
  }

  #shopify-section-{{ section.id }} .bks-impact__stat strong {
    display: block;
    font-family: var(--bks-font-display,'Bebas Neue',sans-serif);
    font-size: 52px;
    line-height: 0.85;
    color: #FAFAF7;
    background: linear-gradient(180deg, #FAFAF7, #C9B79C);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  #shopify-section-{{ section.id }} .bks-impact__stat span {
    display: block;
    margin-top: 8px;
    font-family: var(--bks-font-mono,'DM Mono',monospace);
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0;
    color: rgba(250,250,247,0.55);
  }

  /* Mouse trail particles */
  #shopify-section-{{ section.id }} .cursor-particle {
    position: absolute;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: radial-gradient(circle, #C9B79C, transparent);
    pointer-events: none;
    z-index: 50;
    opacity: 0.8;
    animation: particleFade 1s ease-out forwards;
  }

  @keyframes particleFade {
    to {
      transform: scale(0);
      opacity: 0;
    }
  }

  @media screen and (max-width: 989px) {
    #shopify-section-{{ section.id }} .bks-impact__inner {
      grid-template-columns: 1fr;
      padding: clamp(40px,8vw,80px) 0 clamp(24px,5vw,48px);
    }

    #shopify-section-{{ section.id }} .bks-impact__title {
      font-size: 86px;
      max-width: 11ch;
    }

    #shopify-section-{{ section.id }} .bks-impact__copy {
      font-size: 17px;
    }

    #shopify-section-{{ section.id }} .bks-orbit {
      min-height: 600px;
      margin-top: 40px;
    }

    #shopify-section-{{ section.id }} .bks-collection-card {
      width: clamp(100px,22vw,160px);
    }
  }

  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .bks-impact__title {
      font-size: 52px;
      line-height: 0.9;
    }

    #shopify-section-{{ section.id }} .bks-impact__copy {
      font-size: 15px;
      line-height: 1.6;
    }

    #shopify-section-{{ section.id }} .bks-orbit__core {
      font-size: 42px;
    }

    #shopify-section-{{ section.id }} .bks-impact__stat strong {
      font-size: 38px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    *, *::before, *::after { 
      animation-duration: 0.01ms !important; 
      animation-iteration-count: 1 !important; 
      transition-duration: 0.01ms !important; 
    }
  }
</style>

<section class="bks-impact" id="bks-impact-{{ section.id }}">
  <canvas class="bks-math-canvas" id="mathCanvas"></canvas>

  <svg class="bks-elastic-lines" id="elasticSvg">
    <defs>
      <linearGradient id="gradientLine" x1="0%" y1="0%" x2="100%" y2="0%">
        <stop offset="0%" style="stop-color:#C9B79C;stop-opacity:1">
          <animate attributeName="stop-color" values="#C9B79C;#FAFAF7;#C9B79C" dur="3s" repeatCount="indefinite"/>
        </stop>
        <stop offset="50%" style="stop-color:#FAFAF7;stop-opacity:1">
          <animate attributeName="stop-color" values="#FAFAF7;#C9B79C;#FAFAF7" dur="3s" repeatCount="indefinite"/>
        </stop>
        <stop offset="100%" style="stop-color:#C9B79C;stop-opacity:1">
          <animate attributeName="stop-color" values="#C9B79C;#FAFAF7;#C9B79C" dur="3s" repeatCount="indefinite"/>
        </stop>
      </linearGradient>
      <filter id="glow">
        <feGaussianBlur stdDeviation="3" result="coloredBlur"/>
        <feMerge>
          <feMergeNode in="coloredBlur"/>
          <feMergeNode in="SourceGraphic"/>
        </feMerge>
      </filter>
    </defs>
  </svg>

  <div class="math-tooltip" id="mathTooltip"></div>

  <div class="bks-impact__inner" id="impactInner">
    <div class="bks-impact__content">
      <div class="bks-brand-context" aria-label="BakAbo container and BKS Studio creator">
        <span class="bks-brand-context__item bks-brand-context__container">BakAbo container</span>
        <span class="bks-brand-context__item bks-brand-context__creator">
          <img src="{{ 'bks-studio-logo.png' | asset_url }}" alt="" loading="eager" width="223" height="67">
          Creator: BKS Studio
        </span>
      </div>

      <div class="bks-impact__eyebrow">
        <span>{{ section.settings.kicker }}</span>
        <span>{{ section.settings.drop_label }}</span>
      </div>
      <h1 class="bks-impact__title" id="animatedTitle" data-text="{{ section.settings.heading }}">{{ section.settings.heading }}</h1>
      <p class="bks-impact__copy">{{ section.settings.copy }}</p>
      <div class="bks-impact__actions">
        <a class="bks-button" href="{{ section.settings.primary_link }}">{{ section.settings.primary_label }}</a>
        <a class="bks-button bks-button--ghost" href="{{ section.settings.secondary_link }}">{{ section.settings.secondary_label }}</a>
      </div>
      <div class="bks-impact__stats">
        <div class="bks-impact__stat"><strong data-count="{{ collection_count }}">0</strong><span>Collections</span></div>
        <div class="bks-impact__stat"><strong data-count="189">0</strong><span>Pieces</span></div>
        <div class="bks-impact__stat"><strong data-text="AOP">—</strong><span>On Demand</span></div>
      </div>
    </div>

    <div class="bks-orbit" id="orbitContainer">
      <div class="bks-orbit__ring bks-orbit__ring--1"></div>
      <div class="bks-orbit__ring bks-orbit__ring--2"></div>
      <div class="bks-orbit__ring bks-orbit__ring--3"></div>

      <div class="bks-orbit__focal" aria-hidden="true"></div>

      {% for handle in collection_handles %}
        {% assign collection = collections[handle] %}
        {% if collection %}
          {% assign angle = forloop.index0 | times: 45 %}
          <a href="{{ collection.url }}"
             class="bks-collection-card"
             data-index="{{ forloop.index0 }}"
             data-angle="{{ angle }}"
             data-handle="{{ collection.handle }}"
             data-url="{{ collection.url }}"
             id="card-{{ forloop.index0 }}"
             style="animation-delay: {{ 0.6 | plus: forloop.index0 | times: 0.1 }}s"
             aria-label="{{ collection.title | escape }}">
            <div class="bks-collection-card__inner">
              {% if collection.image %}
                <img src="{{ collection.image | image_url: width: 400 }}"
                     alt="{{ collection.title | escape }}"
                     width="400"
                     height="400"
                     loading="lazy">
              {% else %}
                <div style="width:100%;height:100%;display:grid;place-items:center;color:rgba(250,250,247,0.5);font-size:0.7rem;text-align:center;padding:20px;">
                  {{ collection.title }}
                </div>
              {% endif %}
              <div class="bks-collection-card__overlay" aria-hidden="true">
                <span class="bks-collection-card__overlay-name">{{ collection.title }}</span>
                <span class="bks-collection-card__overlay-count">{{ collection.products_count }} pezzi</span>
                <span class="bks-collection-card__overlay-enter">Entra →</span>
              </div>
            </div>
          </a>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

<script>
(function() {
  'use strict';

  const impactSection = document.getElementById('bks-impact-{{ section.id }}');
  if (!impactSection) return;

  const container = impactSection.querySelector('#orbitContainer');
  const svg = impactSection.querySelector('#elasticSvg');
  const tooltip = impactSection.querySelector('#mathTooltip');
  const cards = impactSection.querySelectorAll('.bks-collection-card');
  const canvas = impactSection.querySelector('#mathCanvas');
  const impactInner = impactSection.querySelector('#impactInner');
  if (!container || !svg || !tooltip || !canvas || !impactInner) return;

  const ctx = canvas.getContext('2d');
  if (!ctx) return;

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  let connections = new Map();
  let isDragging = false;
  let dragMoved  = false;   // distingue click da drag
  let draggedCard = null;
  let mousePos = { x: 0, y: 0 };
  let corePos = { x: 0, y: 0 };
  let particles = [];

  // ── SPLIT TEXT ANIMATION ──
  function splitTextAnimation() {
    const title = impactSection.querySelector('#animatedTitle');
    if (!title) return;
    const text = title.dataset.text || title.textContent;
    title.innerHTML = '';
    let charIndex = 0;
    
    text.split('').forEach((char, i) => {
      const span = document.createElement('span');
      span.className = 'char';
      span.textContent = char === ' ' ? '\u00A0' : char;
      span.style.animationDelay = `${0.4 + i * 0.04}s`;
      title.appendChild(span);
      charIndex++;
    });
  }

  // ── COUNTER ANIMATION ──
  function animateCounters() {
    impactSection.querySelectorAll('[data-count]').forEach(el => {
      const target = parseInt(el.dataset.count);
      const duration = 2000;
      const startTime = performance.now();
      
      function update(now) {
        const progress = Math.min((now - startTime) / duration, 1);
        const eased = 1 - Math.pow(1 - progress, 3);
        el.textContent = Math.floor(eased * target);
        if (progress < 1) requestAnimationFrame(update);
        else el.textContent = target;
      }
      setTimeout(() => requestAnimationFrame(update), 1200);
    });

    const aopEl = impactSection.querySelector('[data-text="AOP"]');
    if (aopEl) {
      setTimeout(() => {
        aopEl.textContent = 'AOP';
        aopEl.style.animation = 'charReveal 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards';
      }, 1800);
    }
  }

  // ── NEURAL NETWORK CANVAS ──
  function initParticles() {
    const rect = container.getBoundingClientRect();
    canvas.width = rect.width;
    canvas.height = rect.height;
    particles = [];
    
    const count = Math.min(80, Math.floor((rect.width * rect.height) / 15000));
    for (let i = 0; i < count; i++) {
      particles.push({
        x: Math.random() * rect.width,
        y: Math.random() * rect.height,
        vx: (Math.random() - 0.5) * 0.4,
        vy: (Math.random() - 0.5) * 0.4,
        size: Math.random() * 2 + 0.5,
        pulse: Math.random() * Math.PI * 2
      });
    }
  }

  function animateCanvas() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    const time = Date.now() / 1000;
    
    // Update particles
    particles.forEach(p => {
      p.x += p.vx;
      p.y += p.vy;
      p.pulse += 0.02;
      
      if (p.x < 0 || p.x > canvas.width) p.vx *= -1;
      if (p.y < 0 || p.y > canvas.height) p.vy *= -1;
      
      // Attraction to mouse
      const dx = mousePos.x - p.x;
      const dy = mousePos.y - p.y;
      const dist = Math.sqrt(dx*dx + dy*dy);
      if (dist < 200 && dist > 0) {
        p.vx += (dx / dist) * 0.02;
        p.vy += (dy / dist) * 0.02;
      }
      
      // Damping
      p.vx *= 0.98;
      p.vy *= 0.98;
    });
    
    // Draw connections
    for (let i = 0; i < particles.length; i++) {
      for (let j = i + 1; j < particles.length; j++) {
        const dx = particles[i].x - particles[j].x;
        const dy = particles[i].y - particles[j].y;
        const dist = Math.sqrt(dx*dx + dy*dy);
        
        if (dist < 120) {
          const alpha = (1 - dist / 120) * 0.3;
          ctx.strokeStyle = `rgba(201, 183, 156, ${alpha})`;
          ctx.lineWidth = 0.5;
          ctx.beginPath();
          ctx.moveTo(particles[i].x, particles[i].y);
          ctx.lineTo(particles[j].x, particles[j].y);
          ctx.stroke();
        }
      }
    }
    
    // Draw particles
    particles.forEach(p => {
      const pulseSize = p.size * (1 + Math.sin(p.pulse) * 0.3);
      const gradient = ctx.createRadialGradient(p.x, p.y, 0, p.x, p.y, pulseSize * 3);
      gradient.addColorStop(0, 'rgba(201, 183, 156, 0.8)');
      gradient.addColorStop(0.5, 'rgba(201, 183, 156, 0.3)');
      gradient.addColorStop(1, 'rgba(201, 183, 156, 0)');
      
      ctx.fillStyle = gradient;
      ctx.beginPath();
      ctx.arc(p.x, p.y, pulseSize * 3, 0, Math.PI * 2);
      ctx.fill();
      
      ctx.fillStyle = 'rgba(250, 250, 247, 0.9)';
      ctx.beginPath();
      ctx.arc(p.x, p.y, pulseSize, 0, Math.PI * 2);
      ctx.fill();
    });

    requestAnimationFrame(animateCanvas);
  }

  // ── PARALLAX 3D ──
  function initParallax() {
    impactSection.addEventListener('mousemove', (e) => {
      const rect = impactSection.getBoundingClientRect();
      const x = (e.clientX - rect.left) / rect.width - 0.5;
      const y = (e.clientY - rect.top) / rect.height - 0.5;
      
      impactInner.style.transform = `rotateY(${x * 3}deg) rotateX(${-y * 3}deg)`;
      
      const sectionRect = impactSection.getBoundingClientRect();
      mousePos.x = e.clientX - sectionRect.left;
      mousePos.y = e.clientY - sectionRect.top;
      
      // Cursor trail particles
      if (!prefersReducedMotion && Math.random() > 0.7) {
        createCursorParticle(e.clientX, e.clientY);
      }
    });
    
    impactSection.addEventListener('mouseleave', () => {
      impactInner.style.transform = 'rotateY(0) rotateX(0)';
    });
  }

  function createCursorParticle(x, y) {
    const particle = document.createElement('div');
    particle.className = 'cursor-particle';
    particle.style.left = `${x - impactSection.getBoundingClientRect().left}px`;
    particle.style.top = `${y - impactSection.getBoundingClientRect().top}px`;
    impactSection.appendChild(particle);
    setTimeout(() => particle.remove(), 1000);
  }

  // ── MAGNETIC CARDS ──
  function initMagneticCards() {
    cards.forEach(card => {
      card.addEventListener('mousemove', (e) => {
        if (isDragging) return;
        const rect = card.getBoundingClientRect();
        const x = e.clientX - rect.left - rect.width / 2;
        const y = e.clientY - rect.top - rect.height / 2;
        
        card.style.transform = `translate(calc(-50% + ${x * 0.15}px), calc(-50% + ${y * 0.15}px)) scale(1.15) rotateY(${x * 0.1}deg) rotateX(${-y * 0.1}deg)`;
      });
      
      card.addEventListener('mouseleave', () => {
        if (isDragging) return;
        card.style.transform = 'translate(-50%, -50%)';
      });
    });
  }

  // ── INIT POSITIONS ──
  function initPositions() {
    const rect = container.getBoundingClientRect();

    // Centro geometrico invisibile — nessun core, solo gravità
    corePos = { x: rect.width / 2, y: rect.height / 2 };

    const centerX = rect.width / 2;
    const centerY = rect.height / 2;
    const radius = Math.min(rect.width, rect.height) * 0.35;

    cards.forEach((card, index) => {
      const angle = (index * (360 / cards.length) - 90) * (Math.PI / 180);
      const x = Math.cos(angle) * radius + centerX;
      const y = Math.sin(angle) * radius + centerY;
      
      card.style.left = `${x}px`;
      card.style.top = `${y}px`;
      card.style.transform = 'translate(-50%, -50%)';
      
      card.dataset.ox = x;
      card.dataset.oy = y;
    });
  }

  function weierstrassFunction(x, a = 0.5, b = 3, n = 50) {
    let sum = 0;
    for (let i = 0; i < n; i++) {
      sum += Math.pow(a, i) * Math.cos(Math.pow(b, i) * Math.PI * x);
    }
    return sum;
  }

  function getWeierstrassPoint(t, startX, startY, endX, endY, amplitude = 30) {
    const x = startX + (endX - startX) * t;
    const y = startY + (endY - startY) * t;
    const deviation = weierstrassFunction(t * 2, 0.5, 3, 50) * amplitude;
    const len = Math.sqrt(Math.pow(endX - startX, 2) + Math.pow(endY - startY, 2)) || 1;
    const perpX = -(endY - startY) / len;
    const perpY = (endX - startX) / len;
    
    return {
      x: x + perpX * deviation,
      y: y + perpY * deviation
    };
  }

  function updateElasticLine(cardIndex, targetX, targetY) {
    const card = impactSection.querySelector(`#card-${cardIndex}`);
    if (!card) return;

    const rect = container.getBoundingClientRect();
    const cardRect = card.getBoundingClientRect();
    
    const startX = cardRect.left + cardRect.width / 2 - rect.left;
    const startY = cardRect.top + cardRect.height / 2 - rect.top;
    const endX = targetX || corePos.x;
    const endY = targetY || corePos.y;

    let path = svg.querySelector(`#path-${cardIndex}`);
    if (!path) {
      path = document.createElementNS('http://www.w3.org/2000/svg', 'path');
      path.id = `path-${cardIndex}`;
      path.classList.add('elastic-path');
      path.setAttribute('filter', 'url(#glow)');
      svg.appendChild(path);
    }

    const points = [];
    const steps = 80;
    for (let i = 0; i <= steps; i++) {
      const t = i / steps;
      const point = getWeierstrassPoint(t, startX, startY, endX, endY, 35);
      points.push(`${point.x},${point.y}`);
    }

    path.setAttribute('d', `M ${points.join(' L ')}`);
    path.classList.add('active');
  }

  function removeElasticLine(cardIndex) {
    const path = svg.querySelector(`#path-${cardIndex}`);
    if (path) {
      path.style.opacity = '0';
      setTimeout(() => path.remove(), 300);
    }
    const card = impactSection.querySelector(`#card-${cardIndex}`);
    if (card) card.classList.remove('connected');
  }

  function animateElasticReturn(cardIndex) {
    const card = impactSection.querySelector(`#card-${cardIndex}`);
    if (!card) return;

    const ox = parseFloat(card.dataset.ox);
    const oy = parseFloat(card.dataset.oy);
    let startTime = null;
    const duration = 800;

    function animate(timestamp) {
      if (!startTime) startTime = timestamp;
      const progress = (timestamp - startTime) / duration;
      const eased = 1 - Math.exp(-5 * progress);
      
      const currentX = ox + (parseFloat(card.dataset.dx || ox) - ox) * (1 - eased);
      const currentY = oy + (parseFloat(card.dataset.dy || oy) - oy) * (1 - eased);
      
      card.style.left = `${currentX}px`;
      card.style.top = `${currentY}px`;
      
      if (connections.has(cardIndex)) {
        updateElasticLine(cardIndex, corePos.x, corePos.y);
      }

      if (progress < 1) {
        requestAnimationFrame(animate);
      } else {
        card.style.left = `${ox}px`;
        card.style.top = `${oy}px`;
        card.style.transform = 'translate(-50%, -50%)';
        delete card.dataset.dx;
        delete card.dataset.dy;
      }
    }

    requestAnimationFrame(animate);
  }

  // ── EVENTS ──
  cards.forEach((card, index) => {
    card.addEventListener('click', (e) => {
      // Blocca la navigazione se era un drag, non un click pulito
      if (dragMoved) { e.preventDefault(); dragMoved = false; }
    });

    card.addEventListener('mousedown', (e) => {
      if (e.target.tagName === 'A' && e.target !== card) return;
      isDragging = true;
      dragMoved   = false;
      draggedCard = card;
      card.style.cursor = 'grabbing';
      
      card.dataset.ox = parseFloat(card.dataset.ox) || card.offsetLeft;
      card.dataset.oy = parseFloat(card.dataset.oy) || card.offsetTop;
      
      e.preventDefault();
    });
  });

  document.addEventListener('mousemove', (e) => {
    if (isDragging && draggedCard) {
      const rect = container.getBoundingClientRect();
      const x = Math.max(0, Math.min(rect.width, e.clientX - rect.left));
      const y = Math.max(0, Math.min(rect.height, e.clientY - rect.top));
      
      draggedCard.style.left = `${x}px`;
      draggedCard.style.top = `${y}px`;
      draggedCard.style.transform = 'translate(-50%, -50%) scale(1.1)';
      draggedCard.dataset.dx = x;
      draggedCard.dataset.dy = y;
      dragMoved = true;

      const index = parseInt(draggedCard.dataset.index);
      if (connections.has(index)) {
        updateElasticLine(index, corePos.x, corePos.y);
      }
    }
  });

  document.addEventListener('mouseup', () => {
    if (isDragging && draggedCard) {
      const index = parseInt(draggedCard.dataset.index);
      draggedCard.style.cursor = 'grab';
      
      if (connections.has(index)) {
        animateElasticReturn(index);
      } else {
        const ox = parseFloat(draggedCard.dataset.ox);
        const oy = parseFloat(draggedCard.dataset.oy);
        draggedCard.style.transition = 'all 0.5s cubic-bezier(0.34, 1.56, 0.64, 1)';
        draggedCard.style.left = `${ox}px`;
        draggedCard.style.top = `${oy}px`;
        setTimeout(() => {
          draggedCard.style.transition = '';
        }, 500);
      }
      
      isDragging = false;
      draggedCard = null;
    }
  });

  function showTooltip(text, x, y) {
    tooltip.textContent = text;
    tooltip.classList.add('visible');
    const rect = impactSection.getBoundingClientRect();
    tooltip.style.left = `${x - rect.left + 15}px`;
    tooltip.style.top = `${y - rect.top}px`;
    
    setTimeout(() => tooltip.classList.remove('visible'), 2000);
  }

  // ── INIT ──
  function initImpactHome() {
    splitTextAnimation();
    animateCounters();
    initPositions();
    if (!prefersReducedMotion) {
      initParticles();
      animateCanvas();
      initParallax();
      initMagneticCards();
    }
  }

  if (document.readyState === 'complete' || document.readyState === 'interactive') {
    requestAnimationFrame(initImpactHome);
  } else {
    window.addEventListener('load', initImpactHome, { once: true });
  }

  window.addEventListener('resize', () => {
    initPositions();
    if (!prefersReducedMotion) initParticles();
  });

  document.addEventListener('click', (e) => {
    if (!container.contains(e.target)) {
      connections.forEach((_, index) => removeElasticLine(index));
      connections.clear();
    }
  });
})();
</script>

{% schema %}
{
  "name": "BKS hero impact",
  "settings": [
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "BakAbo container / Creator: BKS Studio" },
    { "type": "text", "id": "drop_label", "label": "Drop label", "default": "Catalog 2026" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "BKS" },
    { "type": "textarea", "id": "copy", "label": "Copy", "default": "BKS Studio turns eight visual systems into wearable daily objects: AI-generated surfaces, made-to-order products and a clear BakAbo shopping experience." },
    { "type": "text", "id": "primary_link", "label": "Primary link", "default": "/collections/all" },
    { "type": "text", "id": "primary_label", "label": "Primary label", "default": "Shop BKS" },
    { "type": "text", "id": "secondary_link", "label": "Secondary link", "default": "/collections" },
    { "type": "text", "id": "secondary_label", "label": "Secondary label", "default": "Explore series" },
    { "type": "text", "id": "collection_handles", "label": "Collection handles (comma-separated)", "default": "bks-folklore,bks-glyph,bks-marker,bks-riviera,bks-pulse,bks-token,bks-flag,bks-hours" }
  ],
  "presets": [{ "name": "BKS hero impact" }]
}
{% endschema %}
