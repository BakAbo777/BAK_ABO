{% comment %}
  BKS FAQ — Domande frequenti
  Accordion BKS-branded, schema-driven blocks
  Categorie: Ordini · Prodotti · Resi · Members · Try-On · Spedizioni
{% endcomment %}

<style>
  #bks-faq-{{ section.id }} {
    background: var(--bks-paper, #fafaf7);
    padding: clamp(48px, 8vw, 100px) clamp(20px, 5vw, 80px);
  }
  #bks-faq-{{ section.id }} .bks-faq__header {
    max-width: 820px;
    margin: 0 auto 48px;
    text-align: center;
  }
  #bks-faq-{{ section.id }} .bks-faq__overline {
    font-family: var(--bks-font-mono, 'DM Mono', monospace);
    font-size: 0.62rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--bks-sand, #c9b79c);
    margin: 0 0 12px;
  }
  #bks-faq-{{ section.id }} .bks-faq__title {
    font-family: var(--bks-font-display, 'Bebas Neue', sans-serif);
    font-size: clamp(2.8rem, 6vw, 5rem);
    line-height: 0.92;
    color: var(--bks-ink, #0a0a0a);
    margin: 0 0 16px;
  }
  #bks-faq-{{ section.id }} .bks-faq__subtitle {
    font-family: var(--bks-font-body, 'DM Sans', sans-serif);
    font-size: 1rem;
    color: rgba(10,10,10,0.6);
    margin: 0;
  }
  /* Category filter pills */
  #bks-faq-{{ section.id }} .bks-faq__cats {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    justify-content: center;
    margin-bottom: 40px;
  }
  #bks-faq-{{ section.id }} .bks-faq__cat {
    font-family: var(--bks-font-mono, 'DM Mono', monospace);
    font-size: 0.65rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    padding: 6px 16px;
    border: 1px solid rgba(10,10,10,0.18);
    background: transparent;
    cursor: pointer;
    color: rgba(10,10,10,0.55);
    transition: background 0.15s, color 0.15s, border-color 0.15s;
  }
  #bks-faq-{{ section.id }} .bks-faq__cat.is-active,
  #bks-faq-{{ section.id }} .bks-faq__cat:hover {
    background: #0a0a0a;
    color: #fafaf7;
    border-color: #0a0a0a;
  }
  /* Accordion */
  #bks-faq-{{ section.id }} .bks-faq__list {
    max-width: 820px;
    margin: 0 auto;
  }
  #bks-faq-{{ section.id }} .bks-faq__item {
    border-top: 1px solid rgba(10,10,10,0.1);
  }
  #bks-faq-{{ section.id }} .bks-faq__item:last-child {
    border-bottom: 1px solid rgba(10,10,10,0.1);
  }
  #bks-faq-{{ section.id }} .bks-faq__q {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 24px;
    padding: 20px 0;
    cursor: pointer;
    font-family: var(--bks-font-body, 'DM Sans', sans-serif);
    font-size: 1rem;
    font-weight: 500;
    color: var(--bks-ink, #0a0a0a);
    background: none;
    border: none;
    width: 100%;
    text-align: left;
    line-height: 1.4;
  }
  #bks-faq-{{ section.id }} .bks-faq__q:hover { color: rgba(10,10,10,0.7); }
  #bks-faq-{{ section.id }} .bks-faq__icon {
    flex-shrink: 0;
    width: 20px;
    height: 20px;
    position: relative;
  }
  #bks-faq-{{ section.id }} .bks-faq__icon::before,
  #bks-faq-{{ section.id }} .bks-faq__icon::after {
    content: '';
    position: absolute;
    background: currentColor;
    border-radius: 1px;
    transition: transform 0.25s, opacity 0.25s;
  }
  #bks-faq-{{ section.id }} .bks-faq__icon::before { width: 14px; height: 1.5px; top: 9px; left: 3px; }
  #bks-faq-{{ section.id }} .bks-faq__icon::after  { width: 1.5px; height: 14px; top: 3px; left: 9px; }
  #bks-faq-{{ section.id }} .bks-faq__item.is-open .bks-faq__icon::after { transform: scaleY(0); opacity: 0; }
  #bks-faq-{{ section.id }} .bks-faq__a {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.28s ease;
  }
  #bks-faq-{{ section.id }} .bks-faq__item.is-open .bks-faq__a { grid-template-rows: 1fr; }
  #bks-faq-{{ section.id }} .bks-faq__a-inner {
    overflow: hidden;
    padding-bottom: 0;
    transition: padding-bottom 0.28s ease;
  }
  #bks-faq-{{ section.id }} .bks-faq__item.is-open .bks-faq__a-inner { padding-bottom: 20px; }
  #bks-faq-{{ section.id }} .bks-faq__a-inner p {
    margin: 0;
    font-family: var(--bks-font-body, 'DM Sans', sans-serif);
    font-size: 0.93rem;
    line-height: 1.65;
    color: rgba(10,10,10,0.72);
  }
  #bks-faq-{{ section.id }} .bks-faq__a-inner a { color: #0a0a0a; text-decoration: underline; }
  /* Category label */
  #bks-faq-{{ section.id }} .bks-faq__cat-tag {
    font-family: var(--bks-font-mono, 'DM Mono', monospace);
    font-size: 0.55rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    padding: 3px 7px;
    border: 1px solid rgba(10,10,10,0.14);
    color: rgba(10,10,10,0.4);
    margin-left: 10px;
    white-space: nowrap;
    flex-shrink: 0;
    align-self: center;
  }
  /* CTA bottom */
  #bks-faq-{{ section.id }} .bks-faq__cta {
    max-width: 820px;
    margin: 48px auto 0;
    padding: 32px;
    background: var(--bks-bone, #efeae0);
    text-align: center;
  }
  #bks-faq-{{ section.id }} .bks-faq__cta p {
    font-family: var(--bks-font-body, 'DM Sans', sans-serif);
    font-size: 0.93rem;
    color: rgba(10,10,10,0.65);
    margin: 0 0 16px;
  }
  #bks-faq-{{ section.id }} .bks-faq__cta a {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--bks-font-mono, 'DM Mono', monospace);
    font-size: 0.68rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #fafaf7;
    background: #0a0a0a;
    padding: 11px 24px;
    text-decoration: none;
    transition: opacity 0.2s;
  }
  #bks-faq-{{ section.id }} .bks-faq__cta a:hover { opacity: 0.8; }
  /* Hidden item when filtered */
  #bks-faq-{{ section.id }} .bks-faq__item[hidden] { display: none; }
  @media (max-width: 600px) {
    #bks-faq-{{ section.id }} .bks-faq__title { font-size: 2.4rem; }
    #bks-faq-{{ section.id }} .bks-faq__q { font-size: 0.93rem; padding: 16px 0; }
  }
</style>

<section id="bks-faq-{{ section.id }}" aria-label="Domande frequenti">
  <div class="bks-faq__header">
    <p class="bks-faq__overline">{{ section.settings.overline | default: 'BKS Studio' }}</p>
    <h2 class="bks-faq__title">{{ section.settings.title | default: 'Domande Frequenti' }}</h2>
    {%- if section.settings.subtitle != blank -%}
      <p class="bks-faq__subtitle">{{ section.settings.subtitle }}</p>
    {%- endif -%}
  </div>

  {%- assign cats = '' -%}
  {%- for block in section.blocks -%}
    {%- if block.settings.category != blank -%}
      {%- unless cats contains block.settings.category -%}
        {%- assign cats = cats | append: block.settings.category | append: '|' -%}
      {%- endunless -%}
    {%- endif -%}
  {%- endfor -%}

  {%- if cats != '' -%}
    {%- assign cat_list = cats | split: '|' -%}
    <div class="bks-faq__cats" id="bks-faq-cats-{{ section.id }}" role="tablist" aria-label="Filtra per categoria">
      <button class="bks-faq__cat is-active" data-cat="" role="tab" aria-selected="true">Tutte</button>
      {%- for cat in cat_list -%}
        {%- if cat != '' -%}
          <button class="bks-faq__cat" data-cat="{{ cat | downcase | replace: ' ', '-' }}" role="tab" aria-selected="false">{{ cat }}</button>
        {%- endif -%}
      {%- endfor -%}
    </div>
  {%- endif -%}

  <div class="bks-faq__list" id="bks-faq-list-{{ section.id }}">
    {%- for block in section.blocks -%}
      {%- if block.type == 'faq_item' -%}
        {%- assign item_cat = block.settings.category | downcase | replace: ' ', '-' -%}
        <div class="bks-faq__item"
             data-cat="{{ item_cat }}"
             {{ block.shopify_attributes }}>
          <button class="bks-faq__q" aria-expanded="false" aria-controls="bks-faq-a-{{ section.id }}-{{ forloop.index }}">
            <span>{{ block.settings.question }}</span>
            <span class="bks-faq__cat-tag" aria-hidden="true">{{ block.settings.category }}</span>
            <span class="bks-faq__icon" aria-hidden="true"></span>
          </button>
          <div class="bks-faq__a" id="bks-faq-a-{{ section.id }}-{{ forloop.index }}" role="region">
            <div class="bks-faq__a-inner">
              <p>{{ block.settings.answer }}</p>
            </div>
          </div>
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>

  {%- if section.settings.show_cta -%}
    <div class="bks-faq__cta">
      <p>{{ section.settings.cta_text | default: 'Non hai trovato risposta? Contatta la crew BKS.' }}</p>
      <a href="{{ section.settings.cta_url | default: '/pages/contatti' }}">
        {{ section.settings.cta_label | default: 'Scrivi alla crew' }}
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
      </a>
    </div>
  {%- endif -%}
</section>

<script>
(function() {
  var sid = {{ section.id | json }};
  var list = document.getElementById('bks-faq-list-' + sid);
  var catsEl = document.getElementById('bks-faq-cats-' + sid);
  if (!list) return;

  // Accordion
  list.querySelectorAll('.bks-faq__q').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var item = btn.closest('.bks-faq__item');
      var isOpen = item.classList.contains('is-open');
      // Close all
      list.querySelectorAll('.bks-faq__item.is-open').forEach(function(el) {
        el.classList.remove('is-open');
        el.querySelector('.bks-faq__q').setAttribute('aria-expanded', 'false');
      });
      if (!isOpen) {
        item.classList.add('is-open');
        btn.setAttribute('aria-expanded', 'true');
      }
    });
  });

  // Category filter
  if (catsEl) {
    catsEl.querySelectorAll('.bks-faq__cat').forEach(function(pill) {
      pill.addEventListener('click', function() {
        catsEl.querySelectorAll('.bks-faq__cat').forEach(function(p) {
          p.classList.remove('is-active');
          p.setAttribute('aria-selected', 'false');
        });
        pill.classList.add('is-active');
        pill.setAttribute('aria-selected', 'true');
        var cat = pill.getAttribute('data-cat');
        list.querySelectorAll('.bks-faq__item').forEach(function(item) {
          if (!cat || item.getAttribute('data-cat') === cat) {
            item.removeAttribute('hidden');
          } else {
            item.setAttribute('hidden', '');
          }
        });
      });
    });
  }
})();
</script>

{%- comment -%} ── FAQ STRUCTURED DATA — Google rich results ─────── {%- endcomment -%}
{%- if section.blocks.size > 0 -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {%- for block in section.blocks -%}
      {%- if block.type == 'faq_item' and block.settings.question != blank -%}
        {
          "@type": "Question",
          "name": {{ block.settings.question | json }},
          "acceptedAnswer": {
            "@type": "Answer",
            "text": {{ block.settings.answer | strip_html | json }}
          }
        }{%- unless forloop.last -%},{%- endunless -%}
      {%- endif -%}
    {%- endfor -%}
  ]
}
</script>
{%- endif -%}

{% schema %}
{
  "name": "BKS FAQ",
  "tag": "section",
  "class": "shopify-section",
  "settings": [
    { "type": "text", "id": "overline", "label": "Sopratitolo", "default": "BKS Studio" },
    { "type": "text", "id": "title", "label": "Titolo", "default": "Domande Frequenti" },
    { "type": "text", "id": "subtitle", "label": "Sottotitolo", "default": "Tutto quello che devi sapere sui prodotti, spedizioni e membership BKS." },
    { "type": "header", "content": "CTA contatto" },
    { "type": "checkbox", "id": "show_cta", "label": "Mostra blocco contatto", "default": true },
    { "type": "text", "id": "cta_text", "label": "Testo CTA", "default": "Non hai trovato risposta? Contatta la crew BKS." },
    { "type": "url", "id": "cta_url", "label": "Link CTA" },
    { "type": "text", "id": "cta_label", "label": "Label bottone", "default": "Scrivi alla crew" }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "Domanda & Risposta",
      "settings": [
        { "type": "text", "id": "question", "label": "Domanda", "default": "Come funziona BKS Studio?" },
        { "type": "textarea", "id": "answer", "label": "Risposta", "default": "BKS Studio è un atelier AI-art: ogni capo è generato da intelligenza artificiale e prodotto in print-on-demand. Ogni pezzo è unico e disponibile fino a esaurimento." },
        {
          "type": "select",
          "id": "category",
          "label": "Categoria",
          "options": [
            { "value": "Prodotti", "label": "Prodotti" },
            { "value": "Ordini", "label": "Ordini" },
            { "value": "Spedizioni", "label": "Spedizioni" },
            { "value": "Resi", "label": "Resi" },
            { "value": "Members", "label": "Members" },
            { "value": "Try-On", "label": "Try-On" },
            { "value": "Pagamenti", "label": "Pagamenti" }
          ],
          "default": "Prodotti"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "BKS FAQ",
      "blocks": [
        { "type": "faq_item", "settings": { "category": "Prodotti", "question": "Come vengono realizzati i prodotti BKS?", "answer": "Ogni capo nasce da artwork generati con intelligenza artificiale dalla crew BKS. I prodotti sono realizzati in print-on-demand da Printify e spediti direttamente a casa tua." } },
        { "type": "faq_item", "settings": { "category": "Prodotti", "question": "I prodotti sono sostenibili?", "answer": "Sì. Il modello on-demand elimina le rimanenze di magazzino. Stampato e spedito solo quando ordini — nessuno spreco di produzione." } },
        { "type": "faq_item", "settings": { "category": "Spedizioni", "question": "Quanto tempo ci vuole per la spedizione?", "answer": "Produzione: 3-5 giorni lavorativi. Spedizione: 4-8 giorni (Europa). Riceverai email di tracking non appena il pacco viene affidato al corriere." } },
        { "type": "faq_item", "settings": { "category": "Spedizioni", "question": "Spedite in tutta Europa?", "answer": "Sì, spediamo in tutta Europa. I costi di spedizione vengono calcolati al checkout in base al paese di destinazione." } },
        { "type": "faq_item", "settings": { "category": "Resi", "question": "Posso restituire un prodotto?", "answer": "Accettiamo resi entro 14 giorni dalla ricezione per prodotti difettosi o errori di stampa. I prodotti personalizzati (Try-On, custom request) non sono rimborsabili salvo difetto di produzione." } },
        { "type": "faq_item", "settings": { "category": "Ordini", "question": "Posso modificare o annullare un ordine?", "answer": "Gli ordini possono essere annullati entro 12 ore dall'acquisto scrivendo alla crew. Dopo l'avvio della produzione non è possibile modificare l'ordine." } },
        { "type": "faq_item", "settings": { "category": "Members", "question": "Come funziona la BKS Membership?", "answer": "La membership BKS è gratuita e ti dà accesso al Camerino (Try-On virtuale), alla wishlist, alle anteprime collezione e agli offerte riservate. Più acquisti, più sali di livello: da Lead a Gold." } },
        { "type": "faq_item", "settings": { "category": "Try-On", "question": "Il Try-On AI è privato?", "answer": "Sì. L'anteprima del Camerino è elaborata interamente nel tuo browser — nessuna foto viene inviata a server BKS o terze parti. Se usi 'Invia alla crew' per una prova manuale, ti chiediamo il consenso esplicito GDPR prima dell'invio." } },
        { "type": "faq_item", "settings": { "category": "Pagamenti", "question": "Quali metodi di pagamento accettate?", "answer": "Accettiamo carte di credito/debito (Visa, Mastercard, Amex), PayPal e tutti i wallet digitali supportati da Shopify Payments (Apple Pay, Google Pay)." } }
      ]
    }
  ]
}
{% endschema %}
