{% comment %}
  BKS Planet Collections Orbit
  Shopify OS 2.0 section compatible with Dawn.

  Concept:
  - Planetary BKS hero for Shopify collections
  - Collections become interactive orbiting satellites
  - First click/tap selects and locks a collection in front
  - Second click/tap opens the selected collection
  - Mouse/touch FX: glow, particle trail, ripple, orbital tilt

  Installation:
  Online Store > Themes > Edit code > sections >
  Create: bks-planet-collections-orbit.liquid
{% endcomment %}

{% liquid
  assign handles_string = section.settings.collection_handles | default: 'bks-hours,bks-glyph,bks-marker,bks-riviera,bks-pulse,bks-token,bks-flag,bks-folklore'
  assign collection_handles = handles_string | split: ','
  assign collection_count = 0

  for raw_handle in collection_handles
    assign clean_handle = raw_handle | strip
    if collections[clean_handle] != blank
      assign collection_count = collection_count | plus: 1
    endif
  endfor
%}

<style>
  #shopify-section-{{ section.id }} .bks-planet-orbit {
    --bks-bg: {{ section.settings.background_color }};
    --bks-text: {{ section.settings.text_color }};
    --bks-muted: {{ section.settings.muted_text_color }};
    --bks-accent: {{ section.settings.accent_color }};
    --bks-accent-2: {{ section.settings.accent_color_2 }};
    --bks-font-display: "BKS Display", var(--font-heading-family, "Segoe UI", Arial, sans-serif);
    --bks-font-text: "BKS Text", var(--font-body-family, "Segoe UI", Arial, sans-serif);
    --bks-planet-size: 250px;
    position: relative;
    overflow: hidden;
    min-height: {{ section.settings.section_height }}svh;
    background:
      radial-gradient(circle at 72% 42%, color-mix(in srgb, var(--bks-accent) 16%, transparent), transparent 34%),
      radial-gradient(circle at 18% 18%, color-mix(in srgb, var(--bks-accent-2) 14%, transparent), transparent 30%),
      linear-gradient(135deg, rgba(17,17,17,0.025), transparent 42%),
      var(--bks-bg);
    color: var(--bks-text);
    font-family: var(--bks-font-text);
    letter-spacing: 0;
    isolation: isolate;
    touch-action: pan-y;
  }

  #shopify-section-{{ section.id }} .bks-planet-orbit *,
  #shopify-section-{{ section.id }} .bks-planet-orbit *::before,
  #shopify-section-{{ section.id }} .bks-planet-orbit *::after {
    box-sizing: border-box;
  }

  #shopify-section-{{ section.id }} .bks-orbit-stars,
  #shopify-section-{{ section.id }} .bks-orbit-fx {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }

  #shopify-section-{{ section.id }} .bks-orbit-stars {
    z-index: 0;
    opacity: {{ section.settings.stars_opacity | divided_by: 100.0 }};
  }

  #shopify-section-{{ section.id }} .bks-orbit-fx {
    z-index: 4;
    opacity: {{ section.settings.fx_opacity | divided_by: 100.0 }};
    mix-blend-mode: screen;
  }

  #shopify-section-{{ section.id }} .bks-planet-orbit__shell {
    position: relative;
    z-index: 2;
    width: min({{ section.settings.max_width }}px, calc(100% - 32px));
    min-height: inherit;
    margin: 0 auto;
    display: grid;
    grid-template-columns: minmax(0, 0.92fr) minmax(420px, 1.08fr);
    gap: 64px;
    align-items: center;
    padding: 92px 0 84px;
  }

  #shopify-section-{{ section.id }} .bks-planet-orbit__content {
    max-width: 680px;
  }

  #shopify-section-{{ section.id }} .bks-orbit-kicker {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin: 0 0 18px;
    font-family: var(--bks-font-text);
    font-size: 12px;
    line-height: 1.25;
    letter-spacing: 0;
    text-transform: uppercase;
    color: var(--bks-accent);
  }

  #shopify-section-{{ section.id }} .bks-orbit-kicker span {
    display: inline-flex;
    align-items: center;
    min-height: 32px;
    padding: 8px 12px;
    border: 1px solid color-mix(in srgb, var(--bks-accent) 52%, transparent);
    background: rgba(255, 255, 255, 0.72);
    backdrop-filter: blur(12px);
  }

  #shopify-section-{{ section.id }} .bks-planet-orbit__heading {
    margin: 0;
    max-width: 10ch;
    font-family: var(--bks-font-display);
    font-size: 96px;
    font-weight: 850;
    line-height: 0.9;
    letter-spacing: 0;
    text-transform: uppercase;
    color: var(--bks-text);
  }

  #shopify-section-{{ section.id }} .bks-planet-orbit__copy {
    margin: 28px 0 0;
    max-width: 58ch;
    font-family: var(--bks-font-text);
    font-size: 16px;
    line-height: 1.62;
    color: var(--bks-muted);
  }

  #shopify-section-{{ section.id }} .bks-planet-orbit__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 34px;
  }

  #shopify-section-{{ section.id }} .bks-orbit-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 46px;
    padding: 0 24px;
    border: 1px solid var(--bks-text);
    background: var(--bks-text);
    color: var(--bks-bg);
    text-decoration: none;
    font-family: var(--bks-font-text);
    font-size: 12px;
    font-weight: 750;
    letter-spacing: 0;
    line-height: 1.2;
    text-transform: uppercase;
    transition: transform 220ms ease, box-shadow 220ms ease, background 220ms ease, color 220ms ease;
  }

  #shopify-section-{{ section.id }} .bks-orbit-btn--ghost {
    background: transparent;
    color: var(--bks-text);
    border-color: color-mix(in srgb, var(--bks-text) 32%, transparent);
  }

  #shopify-section-{{ section.id }} .bks-orbit-btn:hover,
  #shopify-section-{{ section.id }} .bks-orbit-btn:focus-visible {
    transform: translateY(-2px);
    box-shadow: 0 18px 42px rgba(0, 0, 0, 0.32);
  }

  #shopify-section-{{ section.id }} .bks-planet-orbit__stats {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1px;
    width: min(520px, 100%);
    margin-top: 44px;
    background: color-mix(in srgb, var(--bks-text) 14%, transparent);
  }

  #shopify-section-{{ section.id }} .bks-planet-orbit__stat {
    min-height: 98px;
    padding: 16px;
    background: rgba(255, 255, 255, 0.82);
  }

  #shopify-section-{{ section.id }} .bks-planet-orbit__stat strong {
    display: block;
    font-family: var(--bks-font-display);
    font-size: 44px;
    line-height: 1;
    letter-spacing: 0;
    color: var(--bks-text);
  }

  #shopify-section-{{ section.id }} .bks-planet-orbit__stat span {
    display: block;
    margin-top: 8px;
    font-family: var(--bks-font-text);
    font-size: 12px;
    font-weight: 750;
    letter-spacing: 0;
    line-height: 1.3;
    text-transform: uppercase;
    color: var(--bks-muted);
  }

  #shopify-section-{{ section.id }} .bks-planet-orbit__stage {
    position: relative;
    z-index: 3;
    min-height: min(88svh, 920px);
    perspective: 1500px;
    transform-style: preserve-3d;
    touch-action: manipulation;
  }

  #shopify-section-{{ section.id }} .bks-orbit-system {
    position: absolute;
    inset: 0;
    transform-style: preserve-3d;
    transform: none;
    transition: none;
  }

  #shopify-section-{{ section.id }} .bks-orbit-ring {
    position: absolute;
    left: 50%;
    top: 50%;
    border: 1px solid color-mix(in srgb, var(--bks-text) 11%, transparent);
    border-radius: 50%;
    transform: translate(-50%, -50%);
    pointer-events: none;
    box-shadow:
      inset 0 0 58px color-mix(in srgb, var(--bks-accent) 7%, transparent),
      0 0 24px rgba(0, 0, 0, 0.24);
  }

  #shopify-section-{{ section.id }} .bks-orbit-ring::before {
    content: "";
    position: absolute;
    inset: -1px;
    border-radius: 50%;
    background:
      linear-gradient(
        90deg,
        transparent 0%,
        color-mix(in srgb, var(--bks-accent) 18%, transparent) 46%,
        color-mix(in srgb, var(--bks-text) 24%, transparent) 50%,
        color-mix(in srgb, var(--bks-accent) 18%, transparent) 54%,
        transparent 100%
      );
    opacity: 0.38;
    pointer-events: none;
    mask: radial-gradient(ellipse, transparent 63%, #000 64%, #000 67%, transparent 68%);
  }

  #shopify-section-{{ section.id }} .bks-orbit-ring--1 { width: 52%; height: 31%; }
  #shopify-section-{{ section.id }} .bks-orbit-ring--2 { width: 80%; height: 48%; border-color: color-mix(in srgb, var(--bks-accent) 19%, transparent); }
  #shopify-section-{{ section.id }} .bks-orbit-ring--3 { width: 110%; height: 66%; border-color: color-mix(in srgb, var(--bks-text) 7%, transparent); }
  #shopify-section-{{ section.id }} .bks-orbit-ring--4 { width: 126%; height: 76%; border-color: color-mix(in srgb, var(--bks-accent-2) 11%, transparent); }

  #shopify-section-{{ section.id }} .bks-orbit-planet {
    position: absolute;
    left: 50%;
    top: 50%;
    z-index: 50;
    width: var(--bks-planet-size);
    aspect-ratio: 1;
    transform: translate(-50%, -50%);
    border-radius: 50%;
    pointer-events: auto;
    transform-style: preserve-3d;
  }

  #shopify-section-{{ section.id }} .bks-orbit-planet__halo {
    position: absolute;
    inset: -30%;
    border-radius: 50%;
    background:
      radial-gradient(circle, color-mix(in srgb, var(--bks-text) 18%, transparent), transparent 54%),
      conic-gradient(from 0deg, transparent, color-mix(in srgb, var(--bks-accent) 34%, transparent), transparent, color-mix(in srgb, var(--bks-accent-2) 22%, transparent), transparent);
    filter: blur(5px);
    opacity: 0.78;
    animation: bksOrbitHaloSpin-{{ section.id }} 22s linear infinite;
    pointer-events: none;
  }

  #shopify-section-{{ section.id }} .bks-orbit-planet__surface {
    position: relative;
    z-index: 2;
    display: grid;
    place-items: center;
    width: 100%;
    height: 100%;
    overflow: hidden;
    border-radius: 50%;
    transform: translateZ(0);
    background:
      radial-gradient(circle at 26% 18%, rgba(255,255,255,0.92), rgba(250,250,247,0.44) 14%, transparent 36%),
      repeating-linear-gradient(92deg, rgba(10,10,10,0.18) 0 1px, transparent 1px 18px),
      repeating-linear-gradient(0deg, rgba(10,10,10,0.12) 0 1px, transparent 1px 24px),
      radial-gradient(circle at 65% 70%, var(--bks-accent), #FAFAF7 48%, #877C69 100%);
    background-size: 100% 100%, 240% 100%, 100% 240%, 100% 100%;
    box-shadow:
      inset -34px -30px 54px rgba(0,0,0,0.38),
      inset 18px 16px 30px rgba(255,255,255,0.24),
      0 0 0 1px color-mix(in srgb, var(--bks-text) 19%, transparent),
      0 0 54px color-mix(in srgb, var(--bks-accent) 22%, transparent),
      0 28px 88px rgba(0,0,0,0.62);
    animation:
      bksOrbitPlanetSurface-{{ section.id }} 12s linear infinite,
      bksOrbitPlanetFloat-{{ section.id }} 5s ease-in-out infinite;
  }

  #shopify-section-{{ section.id }} .bks-orbit-planet__surface::before {
    content: "";
    position: absolute;
    inset: 7%;
    border-radius: 50%;
    background:
      repeating-conic-gradient(
        from 0deg,
        rgba(10,10,10,0.16) 0deg 1.3deg,
        transparent 1.3deg 13deg
      );
    mix-blend-mode: multiply;
    opacity: 0.40;
    animation: bksOrbitMeridianSpin-{{ section.id }} 16s linear infinite reverse;
  }

  #shopify-section-{{ section.id }} .bks-orbit-planet__surface::after {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background:
      radial-gradient(circle at 30% 18%, rgba(255,255,255,0.48), transparent 22%),
      linear-gradient(135deg, transparent 0%, rgba(0,0,0,0.26) 70%, rgba(0,0,0,0.52) 100%);
    pointer-events: none;
  }

  #shopify-section-{{ section.id }} .bks-orbit-planet__logo,
  #shopify-section-{{ section.id }} .bks-orbit-planet__text {
    position: relative;
    z-index: 4;
  }

  #shopify-section-{{ section.id }} .bks-orbit-planet__logo {
    display: block;
    width: min(72%, 210px);
    height: auto;
    object-fit: contain;
    filter: drop-shadow(0 2px 0 rgba(255,255,255,0.30)) drop-shadow(0 16px 28px rgba(0,0,0,0.22));
  }

  #shopify-section-{{ section.id }} .bks-orbit-planet__text {
    font-family: var(--bks-font-display);
    font-size: 48px;
    font-weight: 900;
    line-height: 1;
    letter-spacing: 0;
    color: #0A0A0A;
    text-shadow: 0 1px 0 rgba(255,255,255,0.30);
  }

  #shopify-section-{{ section.id }} .bks-satellite-layer {
    position: absolute;
    inset: 0;
    z-index: 60;
    pointer-events: none;
    transform-style: preserve-3d;
  }

  #shopify-section-{{ section.id }} .bks-orbit-satellite {
    position: absolute;
    width: clamp({{ section.settings.satellite_min_size }}px, 10vw, {{ section.settings.satellite_max_size }}px);
    aspect-ratio: 1;
    color: var(--bks-text);
    text-decoration: none;
    pointer-events: auto;
    will-change: left, top, transform, opacity, filter;
    transform: translate(-50%, -50%);
    transition: filter 220ms ease, opacity 220ms ease;
  }

  #shopify-section-{{ section.id }} .bks-orbit-satellite.is-selected {
    cursor: pointer;
  }

  #shopify-section-{{ section.id }} .bks-orbit-satellite.is-dimmed {
    pointer-events: auto;
  }

  #shopify-section-{{ section.id }} .bks-orbit-satellite__orb {
    position: relative;
    display: block;
    width: 100%;
    height: 100%;
    overflow: hidden;
    border-radius: 50%;
    transform: translateZ(0);
    border: 1px solid color-mix(in srgb, var(--sat-accent, var(--bks-accent)) 42%, transparent);
    background:
      radial-gradient(circle at var(--hover-x, 28%) var(--hover-y, 20%), rgba(255,255,255,0.60), transparent 28%),
      repeating-linear-gradient(112deg, rgba(255,255,255,0.10) 0 1px, transparent 1px 15px),
      repeating-linear-gradient(18deg, rgba(0,0,0,0.18) 0 1px, transparent 1px 24px),
      radial-gradient(circle at 42% 45%, color-mix(in srgb, var(--sat-accent, var(--bks-accent)) 86%, #FAFAF7 6%), color-mix(in srgb, var(--sat-accent, var(--bks-accent)) 48%, #0A0A0A 52%) 66%, rgba(0,0,0,0.72) 100%);
    box-shadow:
      0 16px 48px rgba(0,0,0,0.52),
      0 0 34px color-mix(in srgb, var(--sat-accent, var(--bks-accent)) 18%, transparent),
      inset -18px -16px 32px rgba(0,0,0,0.40),
      inset 10px 8px 18px rgba(255,255,255,0.12);
    isolation: isolate;
  }

  #shopify-section-{{ section.id }} .bks-orbit-satellite.is-selected .bks-orbit-satellite__orb {
    border-color: color-mix(in srgb, var(--sat-accent, var(--bks-accent)) 92%, transparent);
    box-shadow:
      0 28px 90px rgba(0,0,0,0.64),
      0 0 0 2px color-mix(in srgb, var(--sat-accent, var(--bks-accent)) 30%, transparent),
      0 0 86px color-mix(in srgb, var(--sat-accent, var(--bks-accent)) 62%, transparent),
      inset -18px -16px 32px rgba(0,0,0,0.34),
      inset 10px 8px 18px rgba(255,255,255,0.18);
  }

  #shopify-section-{{ section.id }} .bks-orbit-satellite__orb::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 0;
    border-radius: 50%;
    background:
      conic-gradient(from 0deg, transparent, color-mix(in srgb, var(--sat-accent, var(--bks-accent)) 32%, transparent), transparent 36%, rgba(255,255,255,0.12), transparent 72%),
      radial-gradient(circle at 30% 22%, rgba(255,255,255,0.42), transparent 26%);
    opacity: 0.74;
    animation: bksSatelliteTextureSpin-{{ section.id }} 14s linear infinite;
  }

  #shopify-section-{{ section.id }} .bks-orbit-satellite__orb::after {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 3;
    border-radius: 50%;
    background:
      radial-gradient(circle at 28% 18%, rgba(255,255,255,0.30), transparent 25%),
      linear-gradient(135deg, transparent 40%, rgba(0,0,0,0.46));
    pointer-events: none;
  }

  #shopify-section-{{ section.id }} .bks-orbit-satellite__image {
    display: none !important;
  }

  #shopify-section-{{ section.id }} .bks-orbit-satellite__code {
    position: relative;
    z-index: 4;
    display: grid;
    place-items: center;
    width: 100%;
    height: 100%;
    padding: 18px;
    text-align: center;
    font-family: var(--bks-font-display);
    font-size: 25px;
    font-weight: 950;
    line-height: 1;
    letter-spacing: 0;
    text-transform: uppercase;
    color: #FAFAF7;
    text-shadow:
      0 1px 0 rgba(0,0,0,0.42),
      0 14px 34px rgba(0,0,0,0.34);
  }

  #shopify-section-{{ section.id }} .bks-orbit-satellite__code small {
    display: block;
    margin-top: 7px;
    font-family: var(--bks-font-text);
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0;
    line-height: 1.2;
    color: color-mix(in srgb, #FAFAF7 72%, transparent);
  }

  #shopify-section-{{ section.id }} .bks-orbit-satellite__fallback {
    position: relative;
    z-index: 2;
    display: grid;
    place-items: center;
    width: 100%;
    height: 100%;
    padding: 18px;
    text-align: center;
    font-family: var(--bks-font-text);
    font-size: 12px;
    font-weight: 800;
    line-height: 1.18;
    letter-spacing: 0;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--bks-text) 78%, transparent);
  }

  #shopify-section-{{ section.id }} .bks-orbit-satellite__label {
    position: absolute;
    left: 50%;
    bottom: -25px;
    z-index: 5;
    max-width: 210px;
    transform: translateX(-50%);
    padding: 6px 11px;
    overflow: hidden;
    text-overflow: ellipsis;
    border: 1px solid color-mix(in srgb, var(--bks-text) 14%, transparent);
    background: rgba(10,10,10,0.86);
    color: var(--bks-text);
    font-family: var(--bks-font-text);
    font-size: 12px;
    font-weight: 750;
    letter-spacing: 0;
    line-height: 1.2;
    text-transform: uppercase;
    white-space: nowrap;
    opacity: 0.76;
    transition: opacity 240ms ease, transform 240ms ease;
  }

  #shopify-section-{{ section.id }} .bks-orbit-satellite.is-selected .bks-orbit-satellite__label,
  #shopify-section-{{ section.id }} .bks-orbit-satellite:hover .bks-orbit-satellite__label {
    opacity: 1;
    transform: translateX(-50%) translateY(-4px);
  }

  #shopify-section-{{ section.id }} .bks-orbit-selection {
    --selected-accent: var(--bks-accent);
    position: absolute;
    right: clamp(8px, 2vw, 26px);
    bottom: clamp(8px, 2vw, 28px);
    z-index: 220;
    width: min(430px, calc(100% - 16px));
    padding: 20px 20px 18px;
    border: 1px solid color-mix(in srgb, var(--selected-accent) 54%, transparent);
    background:
      radial-gradient(circle at 18% 0%, color-mix(in srgb, var(--selected-accent) 22%, transparent), transparent 42%),
      linear-gradient(135deg, rgba(255,255,255,0.48), transparent 42%),
      rgba(255,255,255,0.96);
    color: var(--bks-text);
    backdrop-filter: blur(22px);
    box-shadow:
      0 24px 68px rgba(17,17,17,0.18),
      0 0 58px color-mix(in srgb, var(--selected-accent) 20%, transparent);
    opacity: 0;
    transform: translateY(18px);
    pointer-events: none;
    transition: opacity 260ms ease, transform 260ms ease;
  }

  #shopify-section-{{ section.id }} .bks-orbit-selection__preview {
    display: none;
    width: 100%;
    aspect-ratio: 16 / 9;
    margin: 0 0 14px;
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--selected-accent) 42%, transparent);
    background:
      radial-gradient(circle at 50% 50%, color-mix(in srgb, var(--selected-accent) 24%, transparent), transparent 60%),
      rgba(255,255,255,0.04);
  }

  #shopify-section-{{ section.id }} .bks-orbit-selection.is-active.has-image .bks-orbit-selection__preview {
    display: block;
  }

  #shopify-section-{{ section.id }} .bks-orbit-selection__preview img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  #shopify-section-{{ section.id }} .bks-orbit-selection.is-active {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  #shopify-section-{{ section.id }} .bks-orbit-selection__meta {
    margin: 0 0 9px;
    color: var(--bks-accent);
    font-family: var(--bks-font-text);
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0;
    line-height: 1.2;
    text-transform: uppercase;
  }

  #shopify-section-{{ section.id }} .bks-orbit-selection__title {
    margin: 0;
    font-family: var(--bks-font-display);
    font-size: 34px;
    line-height: 1.08;
    letter-spacing: 0;
    text-transform: uppercase;
    color: var(--bks-text);
    text-shadow: none;
  }

  #shopify-section-{{ section.id }} .bks-orbit-selection__desc {
    margin: 13px 0 0;
    color: var(--bks-muted);
    font-family: var(--bks-font-text);
    font-size: 15px;
    line-height: 1.58;
  }

  #shopify-section-{{ section.id }} .bks-orbit-selection__hint {
    margin: 12px 0 0;
    color: var(--bks-accent);
    font-family: var(--bks-font-text);
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0;
    line-height: 1.35;
    text-transform: uppercase;
  }

  #shopify-section-{{ section.id }} .bks-orbit-selection__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 15px;
  }

  #shopify-section-{{ section.id }} .bks-orbit-selection__open,
  #shopify-section-{{ section.id }} .bks-orbit-selection__close {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 38px;
    padding: 0 14px;
    border: 1px solid var(--bks-text);
    background: var(--bks-text);
    color: var(--bks-bg);
    font-family: var(--bks-font-text);
    font-size: 12px;
    font-weight: 850;
    letter-spacing: 0;
    line-height: 1.2;
    text-transform: uppercase;
    text-decoration: none;
    cursor: pointer;
  }

  #shopify-section-{{ section.id }} .bks-orbit-selection__close {
    background: transparent;
    color: var(--bks-text);
    border-color: color-mix(in srgb, var(--bks-text) 24%, transparent);
  }

  #shopify-section-{{ section.id }} .bks-orbit-empty {
    position: absolute;
    left: 50%;
    top: 50%;
    z-index: 240;
    width: min(420px, 86%);
    transform: translate(-50%, calc(-50% + 170px));
    padding: 16px 18px;
    border: 1px solid color-mix(in srgb, var(--bks-accent) 30%, transparent);
    background: rgba(10,10,10,0.72);
    color: var(--bks-muted);
    font-family: var(--bks-font-text);
    font-size: 14px;
    line-height: 1.45;
    text-align: center;
  }

  @keyframes bksOrbitPlanetSurface-{{ section.id }} {
    from { background-position: 0 0, 0 0, 0 0, 0 0; }
    to { background-position: 0 0, 240px 0, 0 210px, 0 0; }
  }

  @keyframes bksOrbitPlanetFloat-{{ section.id }} {
    0%, 100% { transform: translateY(0) scale(1); }
    50% { transform: translateY(-8px) scale(1.015); }
  }

  @keyframes bksOrbitMeridianSpin-{{ section.id }} {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  @keyframes bksOrbitHaloSpin-{{ section.id }} {
    from { transform: rotate(0deg) scale(1); }
    to { transform: rotate(360deg) scale(1); }
  }

  @keyframes bksSatelliteTextureSpin-{{ section.id }} {
    from { transform: rotate(0deg) scale(1.04); }
    to { transform: rotate(360deg) scale(1.04); }
  }

  @media screen and (max-width: 989px) {
    #shopify-section-{{ section.id }} .bks-planet-orbit__shell {
      grid-template-columns: 1fr;
      gap: 42px;
      padding: 72px 0 64px;
    }

    #shopify-section-{{ section.id }} .bks-planet-orbit__stage {
      min-height: 620px;
    }

    #shopify-section-{{ section.id }} .bks-planet-orbit__content {
      max-width: none;
    }
  }

  @media screen and (max-width: 640px) {
    #shopify-section-{{ section.id }} .bks-planet-orbit {
      --bks-planet-size: 176px;
      min-height: auto;
    }

    #shopify-section-{{ section.id }} .bks-planet-orbit__shell {
      width: min(100% - 24px, {{ section.settings.max_width }}px);
      padding-top: 42px;
    }

    #shopify-section-{{ section.id }} .bks-planet-orbit__heading {
      font-size: 52px;
      max-width: 8ch;
    }

    #shopify-section-{{ section.id }} .bks-planet-orbit__copy {
      font-size: 15px;
      line-height: 1.58;
    }

    #shopify-section-{{ section.id }} .bks-planet-orbit__stats {
      grid-template-columns: 1fr;
    }

    #shopify-section-{{ section.id }} .bks-planet-orbit__stage {
      min-height: 560px;
    }

    #shopify-section-{{ section.id }} .bks-orbit-satellite {
      width: clamp(70px, 22vw, 118px);
    }

    #shopify-section-{{ section.id }} .bks-orbit-satellite__code {
      font-size: 18px;
      padding: 14px;
    }

    #shopify-section-{{ section.id }} .bks-orbit-planet__text {
      font-size: 36px;
    }

    #shopify-section-{{ section.id }} .bks-orbit-selection__title {
      font-size: 26px;
    }

    #shopify-section-{{ section.id }} .bks-orbit-satellite__label {
      display: none;
    }

    #shopify-section-{{ section.id }} .bks-orbit-ring--4 {
      display: none;
    }

    #shopify-section-{{ section.id }} .bks-orbit-selection {
      left: 8px;
      right: 8px;
      width: auto;
    }
  }

  @supports not (color: color-mix(in srgb, white 50%, black)) {
    #shopify-section-{{ section.id }} .bks-planet-orbit {
      background: {{ section.settings.background_color }};
    }

    #shopify-section-{{ section.id }} .bks-orbit-ring,
    #shopify-section-{{ section.id }} .bks-orbit-satellite__label,
    #shopify-section-{{ section.id }} .bks-orbit-selection {
      border-color: rgba(250,250,247,0.14);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #shopify-section-{{ section.id }} .bks-planet-orbit *,
    #shopify-section-{{ section.id }} .bks-planet-orbit *::before,
    #shopify-section-{{ section.id }} .bks-planet-orbit *::after {
      animation: none !important;
      transition: none !important;
      scroll-behavior: auto !important;
    }
  }
</style>

<section class="bks-planet-orbit" id="bks-planet-orbit-{{ section.id }}">
  <canvas class="bks-orbit-stars" data-bks-stars aria-hidden="true"></canvas>
  <canvas class="bks-orbit-fx" data-bks-fx aria-hidden="true"></canvas>

  <div class="bks-planet-orbit__shell">
    <div class="bks-planet-orbit__content">
      {% if section.settings.kicker != blank or section.settings.drop_label != blank %}
        <div class="bks-orbit-kicker">
          {% if section.settings.kicker != blank %}
            <span>{{ section.settings.kicker }}</span>
          {% endif %}
          {% if section.settings.drop_label != blank %}
            <span>{{ section.settings.drop_label }}</span>
          {% endif %}
        </div>
      {% endif %}

      {% if section.settings.heading != blank %}
        <h2 class="bks-planet-orbit__heading">{{ section.settings.heading }}</h2>
      {% endif %}

      {% if section.settings.copy != blank %}
        <div class="bks-planet-orbit__copy">
          {{ section.settings.copy }}
        </div>
      {% endif %}

      <div class="bks-planet-orbit__actions">
        {% if section.settings.primary_link != blank and section.settings.primary_label != blank %}
          <a class="bks-orbit-btn" href="{{ section.settings.primary_link }}">{{ section.settings.primary_label }}</a>
        {% endif %}
        {% if section.settings.secondary_link != blank and section.settings.secondary_label != blank %}
          <a class="bks-orbit-btn bks-orbit-btn--ghost" href="{{ section.settings.secondary_link }}">{{ section.settings.secondary_label }}</a>
        {% endif %}
      </div>

      {% if section.settings.show_stats %}
        <div class="bks-planet-orbit__stats">
          <div class="bks-planet-orbit__stat">
            <strong>{{ collection_count }}</strong>
            <span>{{ section.settings.stat_1_label }}</span>
          </div>
          <div class="bks-planet-orbit__stat">
            <strong>{{ section.settings.stat_2_value }}</strong>
            <span>{{ section.settings.stat_2_label }}</span>
          </div>
          <div class="bks-planet-orbit__stat">
            <strong>{{ section.settings.stat_3_value }}</strong>
            <span>{{ section.settings.stat_3_label }}</span>
          </div>
        </div>
      {% endif %}
    </div>

    <div class="bks-planet-orbit__stage" data-bks-stage>
      <div class="bks-orbit-system" data-bks-orbit-system>
        <div class="bks-orbit-ring bks-orbit-ring--1"></div>
        <div class="bks-orbit-ring bks-orbit-ring--2"></div>
        <div class="bks-orbit-ring bks-orbit-ring--3"></div>
        <div class="bks-orbit-ring bks-orbit-ring--4"></div>

        <div class="bks-orbit-planet" aria-label="{{ section.settings.planet_aria | escape }}">
          <div class="bks-orbit-planet__halo"></div>
          <div class="bks-orbit-planet__surface">
            {% if section.settings.planet_logo != blank %}
              {{
                section.settings.planet_logo
                | image_url: width: 420
                | image_tag:
                  class: 'bks-orbit-planet__logo',
                  loading: 'eager',
                  widths: '180, 260, 360, 420',
                  alt: section.settings.planet_text
              }}
            {% else %}
              <span class="bks-orbit-planet__text">{{ section.settings.planet_text }}</span>
            {% endif %}
          </div>
        </div>

        <div class="bks-satellite-layer" data-bks-satellite-layer>
          {% assign visible_index = 0 %}
          {% for raw_handle in collection_handles %}
            {% liquid
              assign clean_handle = raw_handle | strip
              assign collection = collections[clean_handle]
              assign palette_index = visible_index | modulo: 8
              assign sat_accent = section.settings.accent_color
              case palette_index
                when 0
                  assign sat_accent = section.settings.sat_color_1
                when 1
                  assign sat_accent = section.settings.sat_color_2
                when 2
                  assign sat_accent = section.settings.sat_color_3
                when 3
                  assign sat_accent = section.settings.sat_color_4
                when 4
                  assign sat_accent = section.settings.sat_color_5
                when 5
                  assign sat_accent = section.settings.sat_color_6
                when 6
                  assign sat_accent = section.settings.sat_color_7
                else
                  assign sat_accent = section.settings.sat_color_8
              endcase
            %}
            {% if collection != blank %}
              <a
                class="bks-orbit-satellite"
                href="{{ collection.url }}"
                data-bks-satellite
                data-index="{{ visible_index }}"
                data-title="{{ collection.title | escape }}"
                data-url="{{ collection.url }}"
                data-desc="{{ collection.description | strip_html | truncate: 180 | escape }}"
                data-accent="{{ sat_accent }}"
                data-image="{% if collection.image %}{{ collection.image | image_url: width: 900 }}{% elsif collection.featured_image %}{{ collection.featured_image | image_url: width: 900 }}{% endif %}"
                style="--sat-accent: {{ sat_accent }};"
                aria-label="{{ collection.title | escape }}"
              >
                <span class="bks-orbit-satellite__orb">
                  <span class="bks-orbit-satellite__code">
                    BKS
                    <small>{{ collection.title | truncate: 12 }}</small>
                  </span>
                </span>
                {% if section.settings.show_satellite_labels %}
                  <span class="bks-orbit-satellite__label">{{ collection.title }}</span>
                {% endif %}
              </a>
              {% assign visible_index = visible_index | plus: 1 %}
            {% endif %}
          {% endfor %}
        </div>

        {% if collection_count == 0 %}
          <div class="bks-orbit-empty">
            Enter valid collection handles in the <strong>Collection handles</strong> field. Example:<br>
            <code>bks-hours,bks-glyph,bks-marker,bks-riviera</code>
          </div>
        {% endif %}

        {% if section.settings.show_selection_panel %}
          <aside class="bks-orbit-selection" data-bks-selection-panel aria-live="polite">
            <div class="bks-orbit-selection__preview" data-bks-selection-preview></div>
            <p class="bks-orbit-selection__meta">{{ section.settings.selection_meta }}</p>
            <h3 class="bks-orbit-selection__title" data-bks-selection-title></h3>
            <p class="bks-orbit-selection__desc" data-bks-selection-desc></p>
            <p class="bks-orbit-selection__hint">{{ section.settings.selection_hint }}</p>
            <div class="bks-orbit-selection__actions">
              <a class="bks-orbit-selection__open" href="#" data-bks-selection-open>{{ section.settings.selection_open_label }}</a>
              <button class="bks-orbit-selection__close" type="button" data-bks-selection-close>{{ section.settings.selection_close_label }}</button>
            </div>
          </aside>
        {% endif %}
      </div>
    </div>
  </div>
</section>

<script>
(function() {
  'use strict';

  const root = document.getElementById('bks-planet-orbit-{{ section.id }}');
  if (!root) return;

  const stage = root.querySelector('[data-bks-stage]');
  const system = root.querySelector('[data-bks-orbit-system]');
  const satellites = Array.from(root.querySelectorAll('[data-bks-satellite]'));
  const starsCanvas = root.querySelector('[data-bks-stars]');
  const fxCanvas = root.querySelector('[data-bks-fx]');
  const panel = root.querySelector('[data-bks-selection-panel]');
  const panelTitle = root.querySelector('[data-bks-selection-title]');
  const panelDesc = root.querySelector('[data-bks-selection-desc]');
  const panelOpen = root.querySelector('[data-bks-selection-open]');
  const panelClose = root.querySelector('[data-bks-selection-close]');
  const panelPreview = root.querySelector('[data-bks-selection-preview]');
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (!stage || !system) return;

  const config = {
    speed: {{ section.settings.orbit_speed | divided_by: 1000.0 }},
    tilt: {{ section.settings.orbit_tilt }},
    radiusScaleDesktop: {{ section.settings.orbit_radius | divided_by: 100.0 }},
    radiusScaleMobile: {{ section.settings.mobile_orbit_radius | divided_by: 100.0 }},
    depthStrength: {{ section.settings.depth_strength | divided_by: 100.0 }},
    bounce: {{ section.settings.bounce_amount }},
    mouseTilt: {{ section.settings.mouse_tilt }},
    starCount: {{ section.settings.star_count }},
    particleCount: {{ section.settings.pointer_particle_count }},
    pauseOnSelect: {{ section.settings.pause_on_select | json }},
    openOnSecondTap: {{ section.settings.open_on_second_tap | json }},
    enableMouseTilt: {{ section.settings.enable_mouse_tilt | json }},
    enableFx: {{ section.settings.enable_pointer_fx | json }},
    focusX: {{ section.settings.selected_focus_x | divided_by: 100.0 }},
    focusY: {{ section.settings.selected_focus_y | divided_by: 100.0 }}
  };

  let raf = null;
  let starsRaf = null;
  let fxRaf = null;
  let starsCtx = null;
  let fxCtx = null;
  let stars = [];
  let particles = [];
  let ripples = [];
  let t = 0;
  let selectedIndex = null;
  let selectedSatellite = null;
  let activePointer = false;
  const pointer = { x: 0, y: 0, px: 0, py: 0 };

  function clamp(value, min, max) {
    return Math.max(min, Math.min(max, value));
  }

  function getRectPoint(event, relativeTo) {
    const rect = relativeTo.getBoundingClientRect();
    const point = event.touches && event.touches[0] ? event.touches[0] : event;
    return {
      x: point.clientX - rect.left,
      y: point.clientY - rect.top,
      rect: rect
    };
  }

  function getStageData() {
    const rect = stage.getBoundingClientRect();
    const base = Math.min(rect.width, rect.height);
    const isMobile = window.innerWidth <= 640;
    const radiusScale = isMobile ? config.radiusScaleMobile : config.radiusScaleDesktop;

    return {
      width: rect.width,
      height: rect.height,
      centerX: rect.width / 2,
      centerY: rect.height / 2,
      radiusX: base * radiusScale,
      radiusY: base * radiusScale * (isMobile ? 0.68 : 0.72)
    };
  }

  function updatePanel(satellite) {
    if (!panel || !satellite) return;

    const title = satellite.dataset.title || '';
    const desc = satellite.dataset.desc || '';
    const url = satellite.dataset.url || satellite.getAttribute('href') || '#';
    const image = satellite.dataset.image || '';
    const accent = satellite.dataset.accent || '';

    if (panelTitle) panelTitle.textContent = title;
    if (panelDesc) panelDesc.textContent = desc || '{{ section.settings.selection_empty_description | escape }}';
    if (panelOpen) panelOpen.setAttribute('href', url);
    if (accent) panel.style.setProperty('--selected-accent', accent);

    if (panelPreview) {
      if (image) {
        panelPreview.innerHTML = '<img src="' + image + '" alt="" loading="lazy">';
        panel.classList.add('has-image');
      } else {
        panelPreview.innerHTML = '';
        panel.classList.remove('has-image');
      }
    }

    panel.classList.add('is-active');
  }

  function clearSelection() {
    selectedIndex = null;
    selectedSatellite = null;

    satellites.forEach(function(item) {
      item.classList.remove('is-selected', 'is-dimmed');
      item.removeAttribute('aria-current');
    });

    if (panel) {
      panel.classList.remove('is-active', 'has-image');
      panel.style.removeProperty('--selected-accent');
    }
    if (panelPreview) panelPreview.innerHTML = '';
  }

  function selectSatellite(satellite) {
    selectedSatellite = satellite;
    selectedIndex = Number(satellite.dataset.index);

    satellites.forEach(function(item) {
      const isCurrent = item === satellite;
      item.classList.toggle('is-selected', isCurrent);
      item.classList.toggle('is-dimmed', !isCurrent);
      if (isCurrent) {
        item.setAttribute('aria-current', 'true');
      } else {
        item.removeAttribute('aria-current');
      }
    });

    updatePanel(satellite);
    createRippleFromElement(satellite, 1.1);
  }

  function placeStatic() {
    const data = getStageData();
    const total = Math.max(satellites.length, 1);

    satellites.forEach(function(satellite, index) {
      const angle = ((Math.PI * 2) / total) * index - Math.PI / 2;
      const x = data.centerX + Math.cos(angle) * data.radiusX;
      const y = data.centerY + Math.sin(angle) * data.radiusY;

      satellite.style.left = x + 'px';
      satellite.style.top = y + 'px';
      satellite.style.opacity = '1';
      satellite.style.zIndex = '60';
      satellite.style.filter = 'none';
      satellite.style.transform = 'translate(-50%, -50%) scale(1)';
    });
  }

  function animateOrbit() {
    const data = getStageData();
    const total = Math.max(satellites.length, 1);

    if (!(selectedSatellite && config.pauseOnSelect)) {
      t += config.speed;
    }

    const positions = satellites.map(function(satellite, index) {
      const isSelected = satellite === selectedSatellite;
      const hasSelection = selectedSatellite !== null;

      if (isSelected) {
        return {
          satellite: satellite,
          selected: true,
          x: data.centerX + data.radiusX * config.focusX,
          y: data.centerY + data.radiusY * config.focusY,
          scale: 1.30,
          opacity: 1,
          blur: 0,
          zIndex: 180
        };
      }

      const baseAngle = ((Math.PI * 2) / total) * index - Math.PI / 2;
      const lane = index % 3;
      const laneScale = lane === 0 ? 0.92 : (lane === 1 ? 1.08 : 1.22);
      const lanePhase = lane * 0.42;
      const angle = baseAngle + lanePhase + (t * (0.64 + (index % 5) * 0.032));
      const bounce = Math.sin(t * 2.3 + index * 1.65) * (config.bounce * 0.55);

      const x = data.centerX + Math.cos(angle) * data.radiusX * laneScale;
      const y = data.centerY + Math.sin(angle) * data.radiusY * laneScale + bounce;

      const depth = (Math.sin(angle) + 1) / 2;
      const depthMix = clamp(depth * config.depthStrength + (1 - config.depthStrength) * 0.5, 0, 1);
      const scale = (hasSelection ? 0.46 : 0.62) + depthMix * (hasSelection ? 0.16 : 0.30);
      const opacity = hasSelection ? (0.22 + depthMix * 0.18) : (0.62 + depthMix * 0.38);
      const blur = hasSelection ? (1.15 + (1 - depthMix) * 0.9) : ((1 - depthMix) * 0.34);
      const zIndex = hasSelection ? Math.round(12 + depthMix * 24) : (depthMix > 0.5 ? Math.round(55 + depthMix * 35) : Math.round(14 + depthMix * 28));

      return {
        satellite: satellite,
        selected: false,
        x: x,
        y: y,
        scale: scale,
        opacity: opacity,
        blur: blur,
        zIndex: zIndex
      };
    });

    // Soft collision separation: keeps planets from visually hitting each other.
    for (let pass = 0; pass < 3; pass += 1) {
      for (let i = 0; i < positions.length; i += 1) {
        for (let j = i + 1; j < positions.length; j += 1) {
          if (positions[i].selected || positions[j].selected) continue;

          const a = positions[i];
          const b = positions[j];
          const dx = b.x - a.x;
          const dy = b.y - a.y;
          const dist = Math.sqrt(dx * dx + dy * dy) || 1;
          const minDist = window.innerWidth < 640 ? 92 : 126;

          if (dist < minDist) {
            const push = (minDist - dist) * 0.5;
            const ux = dx / dist;
            const uy = dy / dist;
            a.x -= ux * push;
            a.y -= uy * push * 0.55;
            b.x += ux * push;
            b.y += uy * push * 0.55;
          }
        }
      }
    }

    positions.forEach(function(pos) {
      pos.satellite.style.left = pos.x + 'px';
      pos.satellite.style.top = pos.y + 'px';
      pos.satellite.style.opacity = pos.opacity.toFixed(3);
      pos.satellite.style.zIndex = pos.zIndex;
      pos.satellite.style.filter = 'blur(' + pos.blur.toFixed(2) + 'px)';
      pos.satellite.style.transform = 'translate(-50%, -50%) scale(' + pos.scale.toFixed(3) + ')';
    });

    raf = window.requestAnimationFrame(animateOrbit);
  }

  function setupCanvas(canvas) {
    if (!canvas) return null;
    const rect = root.getBoundingClientRect();
    const dpr = window.devicePixelRatio || 1;
    canvas.width = Math.max(1, Math.floor(rect.width * dpr));
    canvas.height = Math.max(1, Math.floor(rect.height * dpr));
    canvas.style.width = rect.width + 'px';
    canvas.style.height = rect.height + 'px';
    const ctx = canvas.getContext('2d');
    if (ctx) ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    return ctx;
  }

  function resizeCanvases() {
    starsCtx = setupCanvas(starsCanvas);
    fxCtx = setupCanvas(fxCanvas);

    const rect = root.getBoundingClientRect();
    const colors = ['201,183,156', '250,250,247', '82,42,118', '31,112,88'];

    stars = Array.from({ length: config.starCount }).map(function() {
      return {
        x: Math.random() * rect.width,
        y: Math.random() * rect.height,
        radius: Math.random() * 1.8 + 0.35,
        speed: Math.random() * 0.36 + 0.08,
        alpha: Math.random() * 0.58 + 0.12,
        color: colors[Math.floor(Math.random() * colors.length)]
      };
    });
  }

  function animateStars() {
    if (!starsCanvas || !starsCtx) return;

    const rect = root.getBoundingClientRect();
    starsCtx.clearRect(0, 0, rect.width, rect.height);

    stars.forEach(function(star) {
      star.y += star.speed;
      if (star.y > rect.height + 6) {
        star.y = -8;
        star.x = Math.random() * rect.width;
      }

      starsCtx.beginPath();
      starsCtx.arc(star.x, star.y, star.radius, 0, Math.PI * 2);
      starsCtx.fillStyle = 'rgba(' + star.color + ', ' + star.alpha + ')';
      starsCtx.fill();
    });

    starsRaf = window.requestAnimationFrame(animateStars);
  }

  function createParticles(x, y, amount) {
    if (!config.enableFx) return;

    for (let i = 0; i < amount; i += 1) {
      const angle = Math.random() * Math.PI * 2;
      const speed = Math.random() * 1.6 + 0.35;
      particles.push({
        x: x,
        y: y,
        vx: Math.cos(angle) * speed,
        vy: Math.sin(angle) * speed,
        life: 1,
        decay: Math.random() * 0.025 + 0.015,
        radius: Math.random() * 2.2 + 0.8,
        hue: Math.random() > 0.5 ? '201,183,156' : '250,250,247'
      });
    }

    if (particles.length > 260) {
      particles.splice(0, particles.length - 260);
    }
  }

  function createRipple(x, y, strength) {
    if (!config.enableFx) return;

    ripples.push({
      x: x,
      y: y,
      radius: 8,
      alpha: 0.62,
      speed: 7.5 * strength
    });

    if (ripples.length > 16) {
      ripples.shift();
    }
  }

  function createRippleFromElement(element, strength) {
    if (!element) return;
    const rootRect = root.getBoundingClientRect();
    const rect = element.getBoundingClientRect();
    createRipple(
      rect.left - rootRect.left + rect.width / 2,
      rect.top - rootRect.top + rect.height / 2,
      strength
    );
  }

  function animateFx() {
    if (!fxCanvas || !fxCtx) return;

    const rect = root.getBoundingClientRect();
    fxCtx.clearRect(0, 0, rect.width, rect.height);

    if (activePointer) {
      const glow = fxCtx.createRadialGradient(pointer.x, pointer.y, 0, pointer.x, pointer.y, 230);
      glow.addColorStop(0, 'rgba(201,183,156,0.20)');
      glow.addColorStop(0.45, 'rgba(82,42,118,0.12)');
      glow.addColorStop(1, 'rgba(201,183,156,0)');
      fxCtx.fillStyle = glow;
      fxCtx.fillRect(0, 0, rect.width, rect.height);
    }

    particles.forEach(function(p) {
      p.x += p.vx;
      p.y += p.vy;
      p.vx *= 0.985;
      p.vy *= 0.985;
      p.life -= p.decay;

      fxCtx.beginPath();
      fxCtx.arc(p.x, p.y, p.radius, 0, Math.PI * 2);
      fxCtx.fillStyle = 'rgba(' + p.hue + ', ' + Math.max(0, p.life) * 0.65 + ')';
      fxCtx.fill();
    });

    particles = particles.filter(function(p) {
      return p.life > 0;
    });

    ripples.forEach(function(r) {
      r.radius += r.speed;
      r.alpha *= 0.925;

      fxCtx.beginPath();
      fxCtx.arc(r.x, r.y, r.radius, 0, Math.PI * 2);
      fxCtx.strokeStyle = 'rgba(201,183,156,' + r.alpha + ')';
      fxCtx.lineWidth = 1.4;
      fxCtx.stroke();
    });

    ripples = ripples.filter(function(r) {
      return r.alpha > 0.035;
    });

    fxRaf = window.requestAnimationFrame(animateFx);
  }

  function handlePointerMove(event) {
    const point = getRectPoint(event, root);
    pointer.px = pointer.x;
    pointer.py = pointer.y;
    pointer.x = point.x;
    pointer.y = point.y;
    activePointer = true;

    const dx = pointer.x - pointer.px;
    const dy = pointer.y - pointer.py;
    if (Math.abs(dx) + Math.abs(dy) > 7) {
      createParticles(pointer.x, pointer.y, Math.max(1, Math.round(config.particleCount / 5)));
    }

    if (config.enableMouseTilt && system && stage && !selectedSatellite) {
      const stagePoint = getRectPoint(event, stage);
      const px = ((stagePoint.x / stagePoint.rect.width) - 0.5);
      const py = ((stagePoint.y / stagePoint.rect.height) - 0.5);
      system.style.setProperty('--bks-pointer-x', px.toFixed(3));
      system.style.setProperty('--bks-pointer-y', py.toFixed(3));
    }
  }

  function handlePointerLeave() {
    activePointer = false;
    if (system && !selectedSatellite) {
      system.style.removeProperty('--bks-pointer-x');
      system.style.removeProperty('--bks-pointer-y');
    }
  }

  function handlePointerDown(event) {
    const point = getRectPoint(event, root);
    createRipple(point.x, point.y, 1);
    createParticles(point.x, point.y, config.particleCount);
  }

  satellites.forEach(function(satellite) {
    satellite.addEventListener('mousemove', function(event) {
      const rect = satellite.getBoundingClientRect();
      const x = ((event.clientX - rect.left) / rect.width) * 100;
      const y = ((event.clientY - rect.top) / rect.height) * 100;
      satellite.style.setProperty('--hover-x', x.toFixed(1) + '%');
      satellite.style.setProperty('--hover-y', y.toFixed(1) + '%');
    });

    satellite.addEventListener('click', function(event) {
      const alreadySelected = satellite === selectedSatellite;

      if (config.openOnSecondTap && alreadySelected) {
        return;
      }

      event.preventDefault();
      selectSatellite(satellite);
    });

    satellite.addEventListener('keydown', function(event) {
      if (event.key === 'Enter' || event.key === ' ') {
        const alreadySelected = satellite === selectedSatellite;

        if (config.openOnSecondTap && alreadySelected && event.key === 'Enter') {
          return;
        }

        event.preventDefault();
        selectSatellite(satellite);
      }

      if (event.key === 'Escape') {
        clearSelection();
      }
    });
  });

  if (panelClose) {
    panelClose.addEventListener('click', clearSelection);
  }

  root.addEventListener('pointermove', handlePointerMove, { passive: true });
  root.addEventListener('pointerdown', handlePointerDown, { passive: true });
  root.addEventListener('pointerleave', handlePointerLeave, { passive: true });

  function init() {
    if (raf) window.cancelAnimationFrame(raf);
    if (starsRaf) window.cancelAnimationFrame(starsRaf);
    if (fxRaf) window.cancelAnimationFrame(fxRaf);

    resizeCanvases();

    if (reduceMotion) {
      placeStatic();
      return;
    }

    animateOrbit();
    animateStars();

    if (config.enableFx) {
      animateFx();
    }
  }

  window.addEventListener('resize', init);

  document.addEventListener('shopify:section:load', function(event) {
    if (event.detail && event.detail.sectionId === '{{ section.id }}') {
      init();
    }
  });

  document.addEventListener('shopify:section:unload', function(event) {
    if (event.detail && event.detail.sectionId === '{{ section.id }}') {
      if (raf) window.cancelAnimationFrame(raf);
      if (starsRaf) window.cancelAnimationFrame(starsRaf);
      if (fxRaf) window.cancelAnimationFrame(fxRaf);
    }
  });

  init();
})();
</script>

