{% comment %}
  BakAbo / BKS Guida Taglie — Puffer Jacket
  File: sections/bks-size-guide.liquid
  v2 — pulsante editabile dal Theme Editor, modal BKS, finder interattivo cm/in
{% endcomment %}

<style>
  /* ── TRIGGER INLINE ── */
  #shopify-section-{{ section.id }} .bks-sg__trigger {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-weight: 500;
    font-family: var(--font-body-family);
    background: none;
    border: 1px solid {{ section.settings.btn_border_color }};
    color: {{ section.settings.btn_text_color }};
    background: {{ section.settings.btn_bg }};
    padding: 10px 18px;
    cursor: pointer;
    transition: background 0.18s, color 0.18s, border-color 0.18s;
    border-radius: 0;
  }
  #shopify-section-{{ section.id }} .bks-sg__trigger:hover {
    background: {{ section.settings.accent_color }};
    color: #080808;
    border-color: {{ section.settings.accent_color }};
  }
  #shopify-section-{{ section.id }} .bks-sg__trigger svg {
    width: 13px; height: 13px;
    stroke: currentColor; fill: none;
    stroke-width: 1.7; stroke-linecap: round;
  }

  /* ── MODAL OVERLAY ── */
  .bks-sg-modal {
    position: fixed; inset: 0; z-index: 10000;
    display: flex; align-items: center; justify-content: center;
    padding: 16px;
    background: rgba(8,8,8,0.72);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    opacity: 0; pointer-events: none;
    transition: opacity 0.22s ease;
  }
  .bks-sg-modal.is-open { opacity: 1; pointer-events: all; }

  .bks-sg-modal__box {
    background: {{ section.settings.background_color }};
    color: {{ section.settings.text_color }};
    width: 100%; max-width: 720px;
    max-height: 92vh; overflow-y: auto;
    padding: 36px 40px 32px;
    position: relative;
    transform: translateY(14px);
    transition: transform 0.22s ease;
    border-top: 2px solid {{ section.settings.accent_color }};
    font-family: var(--font-body-family);
  }
  .bks-sg-modal.is-open .bks-sg-modal__box { transform: translateY(0); }

  @media (max-width: 640px) {
    .bks-sg-modal { padding: 0; align-items: flex-end; }
    .bks-sg-modal__box {
      max-width: 100%;
      max-height: 88vh;
      padding: 28px 18px 24px;
      transform: translateY(40px);
      border-radius: 0;
    }
    .bks-sg-modal.is-open .bks-sg-modal__box { transform: translateY(0); }
    /* scrollable table on small screens */
    .bks-sg__finder, table { font-size: 12px; }
    .bks-sg__head { flex-direction: column; gap: 12px; }
  }

  .bks-sg-modal__close {
    position: absolute; top: 16px; right: 18px;
    background: none; border: none;
    font-size: 20px; color: {{ section.settings.muted_color }};
    cursor: pointer; padding: 4px; line-height: 1;
    transition: color 0.15s;
  }
  .bks-sg-modal__close:hover { color: {{ section.settings.text_color }}; }

  /* ── MODAL HEADER ── */
  .bks-sg__head {
    display: flex; align-items: flex-start;
    justify-content: space-between; gap: 20px;
    margin-bottom: 24px;
    padding-bottom: 20px;
    border-bottom: 1px solid {{ section.settings.border_color }};
    flex-wrap: wrap;
  }
  .bks-sg__kicker {
    font-size: 10px; letter-spacing: 0.26em;
    text-transform: uppercase; color: {{ section.settings.accent_color }};
    margin: 0 0 6px;
    display: flex; align-items: center; gap: 10px;
  }
  .bks-sg__kicker::before {
    content: ''; display: block;
    width: 18px; height: 1px; background: {{ section.settings.accent_color }};
  }
  .bks-sg__title {
    font-size: clamp(18px, 2.5vw, 24px);
    font-weight: 600; letter-spacing: -0.02em;
    text-transform: uppercase; margin: 0;
    color: {{ section.settings.text_color }};
  }
  .bks-sg__unit-toggle {
    display: inline-flex;
    border: 1px solid {{ section.settings.border_color }};
    overflow: hidden; align-self: flex-end;
    flex-shrink: 0;
  }
  .bks-sg__unit-btn {
    background: none; border: none;
    padding: 7px 16px;
    font-size: 11px; letter-spacing: 0.12em;
    cursor: pointer; color: {{ section.settings.muted_color }};
    font-family: var(--font-body-family);
    transition: all 0.15s;
  }
  .bks-sg__unit-btn.active {
    background: {{ section.settings.text_color }};
    color: {{ section.settings.background_color }};
  }

  /* ── FINDER ── */
  .bks-sg__finder {
    background: {{ section.settings.card_bg }};
    border: 1px solid {{ section.settings.border_color }};
    padding: 20px 22px; margin-bottom: 22px;
  }
  .bks-sg__finder-label {
    font-size: 10px; letter-spacing: 0.22em;
    text-transform: uppercase; color: {{ section.settings.accent_color }};
    margin: 0 0 14px; font-weight: 500;
    display: flex; align-items: center; gap: 8px;
  }
  .bks-sg__finder-label::before {
    content: ''; display: block;
    width: 14px; height: 1px; background: {{ section.settings.accent_color }};
  }
  .bks-sg__finder-inputs {
    display: grid; grid-template-columns: 1fr 1fr 1fr;
    gap: 12px; margin-bottom: 0;
  }
  .bks-sg__field label {
    display: block; font-size: 10px;
    letter-spacing: 0.14em; text-transform: uppercase;
    color: {{ section.settings.muted_color }}; margin-bottom: 6px;
  }
  .bks-sg__field input {
    width: 100%; border: 1px solid {{ section.settings.border_color }};
    padding: 9px 12px; font-size: 14px;
    font-family: var(--font-body-family);
    color: {{ section.settings.text_color }};
    background: {{ section.settings.background_color }};
    transition: border-color 0.15s; -moz-appearance: textfield;
  }
  .bks-sg__field input::-webkit-inner-spin-button,
  .bks-sg__field input::-webkit-outer-spin-button { -webkit-appearance: none; margin: 0; }
  .bks-sg__field input:focus { outline: none; border-color: {{ section.settings.accent_color }}; }

  .bks-sg__result {
    display: none; align-items: center; gap: 18px;
    padding-top: 16px; margin-top: 16px;
    border-top: 1px solid {{ section.settings.border_color }};
  }
  .bks-sg__result.visible { display: flex; }
  .bks-sg__res-size {
    font-size: 40px; font-weight: 700;
    color: {{ section.settings.text_color }}; min-width: 60px; line-height: 1;
  }
  .bks-sg__res-badge {
    display: inline-block; font-size: 9px; letter-spacing: 0.18em;
    text-transform: uppercase;
    background: {{ section.settings.accent_color }};
    color: #080808; padding: 3px 10px;
    margin-bottom: 5px; font-weight: 600;
  }
  .bks-sg__res-info { font-size: 12.5px; color: {{ section.settings.muted_color }}; line-height: 1.5; }

  /* ── UNIFIED TABLE ── */
  .bks-sg__table-wrap {
    border: 1px solid {{ section.settings.border_color }};
    overflow: hidden; margin-bottom: 20px;
    overflow-x: auto;
  }
  .bks-sg__table {
    width: 100%; border-collapse: collapse;
    font-size: 12.5px; min-width: 520px;
  }
  .bks-sg__table thead tr {
    background: {{ section.settings.card_bg }};
    border-bottom: 1px solid {{ section.settings.border_color }};
  }
  .bks-sg__table th {
    padding: 9px 12px; font-size: 9px; letter-spacing: 0.2em;
    text-transform: uppercase; color: {{ section.settings.muted_color }};
    font-weight: 500; text-align: left; white-space: nowrap;
  }
  .bks-sg__table th:not(:first-child) { text-align: center; }
  .bks-sg__table td {
    padding: 10px 12px;
    border-bottom: 1px solid {{ section.settings.border_color }};
    color: {{ section.settings.muted_color }};
    white-space: nowrap;
  }
  .bks-sg__table tr:last-child td { border-bottom: none; }
  .bks-sg__table td:not(:first-child) { text-align: center; }
  .bks-sg__table td strong {
    font-size: 15px; font-weight: 700;
    color: {{ section.settings.text_color }};
    display: block; letter-spacing: 0;
  }
  .bks-sg__table td small {
    font-size: 9.5px; color: {{ section.settings.muted_color }};
    letter-spacing: 0.08em;
  }
  .bks-sg__table tr.bks-sg--hl td { background: {{ section.settings.highlight_bg }}; }
  .bks-sg__table tr.bks-sg--hl td strong { color: {{ section.settings.accent_color }}; }
  /* Separatore colonne metriche / internazionali */
  .bks-sg__table td.bks-sg--sep,
  .bks-sg__table th.bks-sg--sep {
    border-left: 2px solid {{ section.settings.accent_color }};
    opacity: 0.4;
  }

  /* ── TIP ── */
  .bks-sg__tip {
    font-size: 12.5px; color: {{ section.settings.muted_color }};
    padding: 12px 16px; line-height: 1.55;
    border-left: 3px solid {{ section.settings.accent_color }};
    background: {{ section.settings.card_bg }};
  }
  .bks-sg__tip strong { color: {{ section.settings.text_color }}; }

  @media screen and (max-width: 600px) {
    .bks-sg-modal__box { padding: 24px 16px 20px; }
    .bks-sg__finder-inputs { grid-template-columns: 1fr 1fr; }
    .bks-sg__head { gap: 12px; }
  }
</style>

{%- comment -%} TRIGGER PULSANTE {%- endcomment -%}
<button
  class="bks-sg__trigger"
  onclick="document.getElementById('BksSgModal-{{ section.id }}').classList.add('is-open');document.getElementById('BksSgModal-{{ section.id }}').focus();"
  aria-haspopup="dialog"
  aria-controls="BksSgModal-{{ section.id }}"
>
  <svg viewBox="0 0 16 16" aria-hidden="true">
    <line x1="1" y1="4" x2="15" y2="4"/>
    <line x1="1" y1="8" x2="11" y2="8"/>
    <line x1="1" y1="12" x2="15" y2="12"/>
  </svg>
  {{ section.settings.trigger_label | default: 'Guida alle taglie' }}
</button>

{%- comment -%} MODAL {%- endcomment -%}
<div
  class="bks-sg-modal"
  id="BksSgModal-{{ section.id }}"
  role="dialog"
  aria-modal="true"
  aria-label="Guida alle taglie BKS Puffer Jacket"
  tabindex="-1"
  onclick="if(event.target===this)this.classList.remove('is-open')"
>
  <div class="bks-sg-modal__box">
    <button
      class="bks-sg-modal__close"
      onclick="document.getElementById('BksSgModal-{{ section.id }}').classList.remove('is-open')"
      aria-label="Chiudi"
    >&#215;</button>

    <div class="bks-sg__head">
      <div>
        <p class="bks-sg__kicker">Bakabo Club · BKS</p>
        <h2 class="bks-sg__title">{{ section.settings.modal_title | default: 'Guida alle Taglie — Puffer Jacket' }}</h2>
      </div>
      <div class="bks-sg__unit-toggle" role="group" aria-label="Unità di misura">
        <button class="bks-sg__unit-btn active" onclick="bksSgUnit('cm','{{ section.id }}',this)" aria-pressed="true">cm</button>
        <button class="bks-sg__unit-btn" onclick="bksSgUnit('in','{{ section.id }}',this)" aria-pressed="false">in</button>
      </div>
    </div>

    {%- comment -%} FINDER {%- endcomment -%}
    <div class="bks-sg__finder">
      <p class="bks-sg__finder-label">Trova la tua taglia</p>
      <div class="bks-sg__finder-inputs">
        <div class="bks-sg__field">
          <label for="bksSgCh-{{ section.id }}">Petto</label>
          <input type="number" id="bksSgCh-{{ section.id }}" placeholder="es. 96" oninput="bksSgFind('{{ section.id }}')" min="60" max="160">
        </div>
        <div class="bks-sg__field">
          <label for="bksSgWa-{{ section.id }}">Vita</label>
          <input type="number" id="bksSgWa-{{ section.id }}" placeholder="es. 82" oninput="bksSgFind('{{ section.id }}')" min="50" max="150">
        </div>
        <div class="bks-sg__field">
          <label for="bksSgHi-{{ section.id }}">Fianchi</label>
          <input type="number" id="bksSgHi-{{ section.id }}" placeholder="es. 100" oninput="bksSgFind('{{ section.id }}')" min="60" max="160">
        </div>
      </div>
      <div class="bks-sg__result" id="bksSgRes-{{ section.id }}" role="status" aria-live="polite">
        <div class="bks-sg__res-size" id="bksSgResS-{{ section.id }}">M</div>
        <div>
          <span class="bks-sg__res-badge">Taglia consigliata</span>
          <div class="bks-sg__res-info" id="bksSgResI-{{ section.id }}"></div>
        </div>
      </div>
    </div>

    {%- comment -%} TABELLA UNIFICATA: misure corpo + taglie internazionali {%- endcomment -%}
    <div class="bks-sg__table-wrap">
      <table class="bks-sg__table" id="bksSgTab-{{ section.id }}">
        <thead>
          <tr>
            <th>Taglia</th>
            <th>Petto</th>
            <th>Vita</th>
            <th>Fianchi</th>
            <th>Altezza</th>
            <th class="bks-sg--sep">EU</th>
            <th>US / UK</th>
          </tr>
        </thead>
        <tbody id="bksSgBody-{{ section.id }}"></tbody>
      </table>
    </div>

    <p class="bks-sg__tip">
      <strong>Fit:</strong> La BKS Puffer è tagliata regular/relaxed.
      Tra due taglie? Scegli la più piccola per un look fitted,
      la più grande per layering con felpa o maglione.
    </p>
  </div>
</div>

<script>
(function(){
  var SID='{{ section.id }}';
  var DATA=[
    {s:'XS',eu:'44',us:'34/XS', chest:[82,87],waist:[68,73],hips:[88,93],h:[160,170]},
    {s:'S', eu:'46',us:'36/S',  chest:[88,93],waist:[74,79],hips:[94,99],h:[168,176]},
    {s:'M', eu:'48',us:'38/M',  chest:[94,99],waist:[80,85],hips:[100,105],h:[174,180]},
    {s:'L', eu:'50',us:'40/L',  chest:[100,105],waist:[86,91],hips:[106,111],h:[178,184]},
    {s:'XL',eu:'52',us:'42/XL', chest:[106,111],waist:[92,97],hips:[112,117],h:[182,188]},
    {s:'XXL',eu:'54',us:'44/XXL',chest:[112,118],waist:[98,104],hips:[118,124],h:[186,192]}
  ];
  var unit={};unit[SID]='cm';

  function toIn(v){return Math.round(v/2.54*10)/10;}
  function disp(v,sid){return unit[sid]==='cm'?v:toIn(v);}
  function fromInp(v,sid){return unit[sid]==='cm'?parseFloat(v):parseFloat(v)*2.54;}
  function u(sid){return unit[sid];}

  function render(sid){
    var body=document.getElementById('bksSgBody-'+sid);
    if(!body)return;
    body.innerHTML=DATA.map(function(r){
      return '<tr id="bksSgR-'+sid+'-'+r.s+'">'
        +'<td><strong>'+r.s+'</strong></td>'
        +'<td>'+disp(r.chest[0],sid)+'–'+disp(r.chest[1],sid)+' '+u(sid)+'</td>'
        +'<td>'+disp(r.waist[0],sid)+'–'+disp(r.waist[1],sid)+' '+u(sid)+'</td>'
        +'<td>'+disp(r.hips[0],sid)+'–'+disp(r.hips[1],sid)+' '+u(sid)+'</td>'
        +'<td>'+disp(r.h[0],sid)+'–'+disp(r.h[1],sid)+' '+u(sid)+'</td>'
        +'<td class="bks-sg--sep">'+r.eu+'</td>'
        +'<td>'+r.us+'</td>'
        +'</tr>';
    }).join('');
  }

  window.bksSgUnit=function(u,sid,btn){
    unit[sid]=u;
    btn.parentNode.querySelectorAll('.bks-sg__unit-btn').forEach(function(b){
      b.classList.remove('active');b.setAttribute('aria-pressed','false');
    });
    btn.classList.add('active');btn.setAttribute('aria-pressed','true');
    var ph={cm:['es. 96','es. 82','es. 100'],in:['es. 38','es. 32','es. 39']};
    var ids=['bksSgCh-','bksSgWa-','bksSgHi-'];
    ids.forEach(function(id,i){
      var el=document.getElementById(id+sid);
      if(el)el.placeholder=ph[u][i];
    });
    render(sid); bksSgFind(sid);
  };

  window.bksSgFind=function(sid){
    var cv=document.getElementById('bksSgCh-'+sid);
    var wv=document.getElementById('bksSgWa-'+sid);
    var hv=document.getElementById('bksSgHi-'+sid);
    var res=document.getElementById('bksSgRes-'+sid);
    document.querySelectorAll('[id^="bksSgR-'+sid+'"]').forEach(function(r){r.classList.remove('bks-sg--hl');});
    if(!cv||(!cv.value&&!wv.value&&!hv.value)){if(res)res.classList.remove('visible');return;}
    var chest=cv.value?fromInp(cv.value,sid):null;
    var waist=wv.value?fromInp(wv.value,sid):null;
    var hips=hv.value?fromInp(hv.value,sid):null;
    var best=null,bs=Infinity;
    DATA.forEach(function(r){
      var sc=0,cnt=0;
      if(chest){sc+=Math.abs(chest-(r.chest[0]+r.chest[1])/2);cnt++;}
      if(waist){sc+=Math.abs(waist-(r.waist[0]+r.waist[1])/2);cnt++;}
      if(hips){sc+=Math.abs(hips-(r.hips[0]+r.hips[1])/2);cnt++;}
      if(cnt>0&&sc/cnt<bs){bs=sc/cnt;best=r;}
    });
    if(best){
      document.getElementById('bksSgResS-'+sid).textContent=best.s;
      document.getElementById('bksSgResI-'+sid).innerHTML=
        'EU '+best.eu+' / US '+best.us+'<br>Petto '+
        disp(best.chest[0],sid)+'–'+disp(best.chest[1],sid)+' '+unit[sid];
      if(res)res.classList.add('visible');
      var row=document.getElementById('bksSgR-'+sid+'-'+best.s);
      if(row)row.classList.add('bks-sg--hl');
    }
  };

  /* Init + keyboard close */
  function init(){render(SID);}
  if(document.readyState==='loading'){document.addEventListener('DOMContentLoaded',init);}else{init();}
  document.addEventListener('keydown',function(e){
    if(e.key==='Escape'){var m=document.getElementById('BksSgModal-'+SID);if(m)m.classList.remove('is-open');}
  });
})();
</script>

{% schema %}
{
  "name": "BKS Guida Taglie",
  "tag": "div",
  "class": "bks-size-guide-section",
  "settings": [
    {
      "type": "header",
      "content": "Pulsante"
    },
    {
      "type": "text",
      "id": "trigger_label",
      "label": "Testo del pulsante",
      "default": "Guida alle taglie"
    },
    {
      "type": "color",
      "id": "btn_bg",
      "label": "Sfondo pulsante",
      "default": "transparent"
    },
    {
      "type": "color",
      "id": "btn_text_color",
      "label": "Testo pulsante",
      "default": "#0a0a0a"
    },
    {
      "type": "color",
      "id": "btn_border_color",
      "label": "Bordo pulsante",
      "default": "#e0d9ce"
    },
    {
      "type": "header",
      "content": "Modal"
    },
    {
      "type": "text",
      "id": "modal_title",
      "label": "Titolo modal",
      "default": "Guida alle Taglie — Puffer Jacket"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Sfondo modal",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Testo principale",
      "default": "#0a0a0a"
    },
    {
      "type": "color",
      "id": "muted_color",
      "label": "Testo secondario",
      "default": "#666666"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Bordi",
      "default": "#e0d9ce"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accento (oro BKS)",
      "default": "#c4964a"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Sfondo card/finder",
      "default": "#f9f6f1"
    },
    {
      "type": "color",
      "id": "highlight_bg",
      "label": "Sfondo riga evidenziata",
      "default": "#fdf4e7"
    }
  ],
  "presets": [
    {
      "name": "BKS Guida Taglie"
    }
  ]
}
{% endschema %}
