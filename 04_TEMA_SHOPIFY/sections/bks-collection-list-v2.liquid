{% comment %}
  BakAbo / BKS Collection List
  File: sections/bks-collection-list-v2.liquid
  Editorial collection showcase with featured first card
{% endcomment %}

<style>
  #shopify-section-{{ section.id }} .bks-cl {
    position: relative;
    overflow: hidden;
    background: {{ section.settings.background }};
    color: {{ section.settings.text_color }};
  }

  #shopify-section-{{ section.id }} .bks-cl__checker {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    opacity: {{ section.settings.checker_opacity | divided_by: 100.0 }};
    background-image:
      linear-gradient(45deg, {{ section.settings.border_color }} 25%, transparent 25%),
      linear-gradient(-45deg, {{ section.settings.border_color }} 25%, transparent 25%),
      linear-gradient(45deg, transparent 75%, {{ section.settings.border_color }} 75%),
      linear-gradient(-45deg, transparent 75%, {{ section.settings.border_color }} 75%);
    background-size: {{ section.settings.checker_size }}px {{ section.settings.checker_size }}px;
    background-position: 0 0, 0 {{ section.settings.checker_size | divided_by: 2 }}px, {{ section.settings.checker_size | divided_by: 2 }}px {{ section.settings.checker_size | divided_by: -2 }}px, {{ section.settings.checker_size | divided_by: -2 }}px 0;
  }

  #shopify-section-{{ section.id }} .bks-cl > * {
    position: relative;
    z-index: 1;
  }

  #shopify-section-{{ section.id }} .bks-cl__wrap {
    max-width: 1600px;
    margin: 0 auto;
    padding: 0 clamp(16px, 3vw, 48px);
  }

  #shopify-section-{{ section.id }} .bks-cl__head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    padding: clamp(36px, 4vw, 60px) 0 clamp(28px, 3vw, 44px);
    border-bottom: 1px solid {{ section.settings.border_color }};
    gap: 20px;
    flex-wrap: wrap;
  }

  #shopify-section-{{ section.id }} .bks-cl__kicker {
    font-size: 10px;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: {{ section.settings.muted_color }};
    margin: 0 0 10px;
  }

  #shopify-section-{{ section.id }} .bks-cl__title {
    font-size: clamp(30px, 4.5vw, 68px);
    font-weight: 500;
    letter-spacing: -0.06em;
    line-height: 0.88;
    text-transform: uppercase;
    margin: 0;
  }

  #shopify-section-{{ section.id }} .bks-cl__count {
    font-size: 10px;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: {{ section.settings.muted_color }};
    padding: 8px 16px;
    border: 1px solid {{ section.settings.border_color }};
  }

  #shopify-section-{{ section.id }} .bks-cl__grid {
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns_desktop }}, 1fr);
    gap: 1px;
    background: {{ section.settings.border_color }};
    border-bottom: 1px solid {{ section.settings.border_color }};
  }

  #shopify-section-{{ section.id }} .bks-cl__card {
    background: {{ section.settings.background }};
    text-decoration: none;
    color: {{ section.settings.text_color }};
    display: flex;
    flex-direction: column;
    position: relative;
    overflow: hidden;
    transition: background 0.22s ease;
  }

  #shopify-section-{{ section.id }} .bks-cl__card:hover {
    background: {{ section.settings.card_bg_hover }};
  }

  #shopify-section-{{ section.id }} .bks-cl__media {
    aspect-ratio: {{ section.settings.card_ratio }};
    overflow: hidden;
    position: relative;
    background: {{ section.settings.border_color }};
  }

  #shopify-section-{{ section.id }} .bks-cl__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.55s ease;
  }

  #shopify-section-{{ section.id }} .bks-cl__card:hover .bks-cl__img { transform: scale(1.06); }

  #shopify-section-{{ section.id }} .bks-cl__veil {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 40%, rgba(0, 0, 0, 0.5) 100%);
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  #shopify-section-{{ section.id }} .bks-cl__card:hover .bks-cl__veil { opacity: 1; }

  #shopify-section-{{ section.id }} .bks-cl__num {
    position: absolute;
    top: 12px;
    left: 14px;
    font-size: 10px;
    letter-spacing: 0.18em;
    color: rgba(255, 255, 255, 0.75);
    font-weight: 600;
    z-index: 2;
    mix-blend-mode: difference;
  }

  #shopify-section-{{ section.id }} .bks-cl__tag {
    position: absolute;
    top: 12px;
    right: 12px;
    font-size: 9px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    padding: 4px 10px;
    border: 1px solid rgba(255, 255, 255, 0.5);
    color: rgba(255, 255, 255, 0.9);
    background: rgba(0, 0, 0, 0.2);
    z-index: 2;
  }

  #shopify-section-{{ section.id }} .bks-cl__hover-cta {
    position: absolute;
    bottom: 18px;
    left: 50%;
    transform: translateX(-50%);
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #fff;
    padding: 9px 20px;
    border: 1px solid rgba(255, 255, 255, 0.5);
    background: rgba(0, 0, 0, 0.24);
    opacity: 0;
    transition: opacity 0.3s ease;
    z-index: 3;
    white-space: nowrap;
  }

  #shopify-section-{{ section.id }} .bks-cl__card:hover .bks-cl__hover-cta { opacity: 1; }

  #shopify-section-{{ section.id }} .bks-cl__info {
    padding: clamp(14px, 2vw, 22px) clamp(14px, 2vw, 22px) clamp(18px, 2.5vw, 28px);
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 10px;
    border-top: 1px solid {{ section.settings.border_color }};
  }

  #shopify-section-{{ section.id }} .bks-cl__info-left {
    flex: 1;
    min-width: 0;
  }

  #shopify-section-{{ section.id }} .bks-cl__name {
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin: 0 0 4px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  #shopify-section-{{ section.id }} .bks-cl__sub {
    font-size: 11px;
    color: {{ section.settings.muted_color }};
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  #shopify-section-{{ section.id }} .bks-cl__arrow {
    flex-shrink: 0;
    width: 32px;
    height: 32px;
    border: 1px solid {{ section.settings.border_color }};
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 14px;
    border-radius: 999px;
    transition: background 0.22s ease, color 0.22s ease;
  }

  #shopify-section-{{ section.id }} .bks-cl__card:hover .bks-cl__arrow {
    background: {{ section.settings.text_color }};
    color: {{ section.settings.background }};
    border-color: {{ section.settings.text_color }};
  }

  {%- if section.settings.featured_first -%}
    #shopify-section-{{ section.id }} .bks-cl__grid > .bks-cl__card:first-child {
      grid-column: span 2;
    }
    #shopify-section-{{ section.id }} .bks-cl__grid > .bks-cl__card:first-child .bks-cl__media {
      aspect-ratio: {{ section.settings.featured_ratio }};
    }
  {%- endif -%}

  #shopify-section-{{ section.id }} .bks-cl__footer {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: clamp(24px, 3vw, 40px) 0;
    gap: 16px;
  }

  #shopify-section-{{ section.id }} .bks-cl__footer-link {
    display: inline-flex;
    align-items: center;
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    text-decoration: none;
    color: {{ section.settings.text_color }};
    padding: 14px 32px;
    border: 1px solid {{ section.settings.border_color }};
    transition: background 0.22s ease, color 0.22s ease;
  }

  #shopify-section-{{ section.id }} .bks-cl__footer-link:hover {
    background: {{ section.settings.text_color }};
    color: {{ section.settings.background }};
  }

  @media screen and (max-width: 989px) {
    #shopify-section-{{ section.id }} .bks-cl__grid { grid-template-columns: repeat({{ section.settings.columns_tablet }}, 1fr); }
    {%- if section.settings.featured_first -%}
      #shopify-section-{{ section.id }} .bks-cl__grid > .bks-cl__card:first-child .bks-cl__media { aspect-ratio: 4/3; }
    {%- endif -%}
  }

  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .bks-cl__grid { grid-template-columns: repeat({{ section.settings.columns_mobile }}, 1fr); }
    {%- if section.settings.featured_first -%}
      #shopify-section-{{ section.id }} .bks-cl__grid > .bks-cl__card:first-child { grid-column: span 1; }
      #shopify-section-{{ section.id }} .bks-cl__grid > .bks-cl__card:first-child .bks-cl__media { aspect-ratio: {{ section.settings.card_ratio }}; }
    {%- endif -%}
    #shopify-section-{{ section.id }} .bks-cl__info { padding: 12px 12px 14px; }
    #shopify-section-{{ section.id }} .bks-cl__name { font-size: 12px; }
  }
</style>

{%- liquid
  assign total_count = 0
  for block in section.blocks
    if block.type == 'collection_item'
      assign total_count = total_count | plus: 1
    endif
  endfor
-%}

<section class="bks-cl">
  <div class="bks-cl__checker" aria-hidden="true"></div>

  <div class="bks-cl__wrap">
    <header class="bks-cl__head">
      <div>
        {%- if section.settings.kicker != blank -%}
          <p class="bks-cl__kicker">{{ section.settings.kicker | escape }}</p>
        {%- endif -%}
        {%- if section.settings.title != blank -%}
          <h2 class="bks-cl__title">{{ section.settings.title | escape }}</h2>
        {%- endif -%}
      </div>
      <span class="bks-cl__count">{{ total_count }} Collections</span>
    </header>

    <div class="bks-cl__grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'collection_item' -%}
          {%- liquid
            assign col = collections[block.settings.collection]
            assign col_url = '#'
            if block.settings.custom_link != blank
              assign col_url = block.settings.custom_link
            elsif col.url != blank
              assign col_url = col.url
            endif

            assign col_title = block.settings.custom_title
            if col_title == blank and col.title != blank
              assign col_title = col.title
            endif
            if col_title == blank
              assign col_title = 'Collection'
            endif

            assign col_sub = block.settings.subtitle
            if col_sub == blank and col.products_count > 0
              assign col_sub = col.products_count | append: ' items'
            endif
          -%}
          <a class="bks-cl__card" href="{{ col_url }}" {{ block.shopify_attributes }}>
            <div class="bks-cl__media">
              <span class="bks-cl__num">{{ forloop.index | prepend: '0' | slice: -2, 2 }}</span>
              {%- if block.settings.tag != blank -%}
                <span class="bks-cl__tag">{{ block.settings.tag | escape }}</span>
              {%- endif -%}

              {%- if block.settings.custom_image != blank -%}
                <img class="bks-cl__img" src="{{ block.settings.custom_image | image_url: width: 900 }}" alt="{{ col_title | escape }}" loading="lazy" width="900" height="900">
              {%- elsif col.featured_image != blank -%}
                <img class="bks-cl__img" src="{{ col.featured_image | image_url: width: 900 }}" alt="{{ col_title | escape }}" loading="lazy" width="900" height="900">
              {%- else -%}
                {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg bks-cl__img' }}
              {%- endif -%}

              <div class="bks-cl__veil"></div>
              <span class="bks-cl__hover-cta">{{ section.settings.hover_cta | default: 'Explore' | escape }} →</span>
            </div>
            <div class="bks-cl__info">
              <div class="bks-cl__info-left">
                <p class="bks-cl__name">{{ col_title | escape }}</p>
                {%- if col_sub != blank -%}
                  <p class="bks-cl__sub">{{ col_sub | escape }}</p>
                {%- endif -%}
              </div>
              <span class="bks-cl__arrow">→</span>
            </div>
          </a>
        {%- endif -%}
      {%- endfor -%}
    </div>

    {%- if section.settings.show_footer_cta and section.settings.footer_cta_label != blank -%}
      <div class="bks-cl__footer">
        <a href="{{ section.settings.footer_cta_link | default: '#' }}" class="bks-cl__footer-link">{{ section.settings.footer_cta_label | escape }}</a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "BKS Collection List",
  "tag": "section",
  "class": "section-bks-collection-list",
  "settings": [
    { "type": "header", "content": "Contenuto" },
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "SHOP BY COLLECTION" },
    { "type": "text", "id": "title", "label": "Titolo", "default": "Collections" },
    { "type": "text", "id": "hover_cta", "label": "Testo CTA hover", "default": "Explore" },
    { "type": "header", "content": "Layout" },
    { "type": "range", "id": "columns_desktop", "label": "Colonne desktop", "min": 2, "max": 5, "step": 1, "default": 4 },
    { "type": "range", "id": "columns_tablet", "label": "Colonne tablet", "min": 2, "max": 4, "step": 1, "default": 3 },
    { "type": "range", "id": "columns_mobile", "label": "Colonne mobile", "min": 1, "max": 3, "step": 1, "default": 2 },
    { "type": "checkbox", "id": "featured_first", "label": "Prima card grande", "default": true },
    { "type": "select", "id": "card_ratio", "label": "Ratio card", "options": [
        { "value": "1/1", "label": "Quadrato" },
        { "value": "3/4", "label": "Portrait" },
        { "value": "4/5", "label": "Tall" }
      ], "default": "4/5" },
    { "type": "select", "id": "featured_ratio", "label": "Ratio prima card", "options": [
        { "value": "16/9", "label": "Panoramica" },
        { "value": "3/2", "label": "Landscape" },
        { "value": "4/3", "label": "Standard" }
      ], "default": "16/9" },
    { "type": "header", "content": "Footer" },
    { "type": "checkbox", "id": "show_footer_cta", "label": "Mostra CTA", "default": true },
    { "type": "text", "id": "footer_cta_label", "label": "Label", "default": "View All Collections" },
    { "type": "url", "id": "footer_cta_link", "label": "Link" },
    { "type": "header", "content": "Colori" },
    { "type": "color", "id": "background", "label": "Sfondo", "default": "#ffffff" },
    { "type": "color", "id": "text_color", "label": "Testo", "default": "#050505" },
    { "type": "color", "id": "muted_color", "label": "Testo secondario", "default": "#888888" },
    { "type": "color", "id": "border_color", "label": "Bordi", "default": "#e0e0e0" },
    { "type": "color", "id": "card_bg_hover", "label": "Sfondo card hover", "default": "#f7f7f7" },
    { "type": "header", "content": "Pattern" },
    { "type": "range", "id": "checker_size", "label": "Checker px", "min": 6, "max": 32, "step": 2, "unit": "px", "default": 12 },
    { "type": "range", "id": "checker_opacity", "label": "Opacita checker", "min": 0, "max": 10, "step": 1, "unit": "%", "default": 2 }
  ],
  "blocks": [
    {
      "type": "collection_item",
      "name": "Collezione",
      "settings": [
        { "type": "collection", "id": "collection", "label": "Collezione" },
        { "type": "text", "id": "custom_title", "label": "Titolo custom" },
        { "type": "text", "id": "subtitle", "label": "Sottotitolo" },
        { "type": "text", "id": "tag", "label": "Badge (es SS25)" },
        { "type": "image_picker", "id": "custom_image", "label": "Immagine custom" },
        { "type": "url", "id": "custom_link", "label": "Link custom" }
      ]
    }
  ],
  "presets": [
    {
      "name": "BKS Collection List",
      "blocks": [
        { "type": "collection_item", "settings": { "custom_title": "Light Code", "subtitle": "Full Collection", "tag": "SS25" } },
        { "type": "collection_item", "settings": { "custom_title": "Dark Code", "subtitle": "Full Collection", "tag": "SS25" } },
        { "type": "collection_item", "settings": { "custom_title": "Accessories", "subtitle": "Bags Towels and More" } },
        { "type": "collection_item", "settings": { "custom_title": "Footwear", "subtitle": "Sneakers and Flip Flops" } },
        { "type": "collection_item", "settings": { "custom_title": "Outerwear", "subtitle": "BKS Technical" } },
        { "type": "collection_item", "settings": { "custom_title": "Swimwear", "subtitle": "Resort Collection" } }
      ]
    }
  ]
}
{% endschema %}
