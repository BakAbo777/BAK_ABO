{%- style -%}

  .footer {

    margin-top: {{ section.settings.margin_top | times: 0.75 | round: 0 }}px;

  }

  .section-{{ section.id }}-padding {

    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;

    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;

  }

  @media screen and (min-width: 750px) {

    .footer {

      margin-top: {{ section.settings.margin_top }}px;

    }

    .section-{{ section.id }}-padding {

      padding-top: {{ section.settings.padding_top }}px;

      padding-bottom: {{ section.settings.padding_bottom }}px;

    }

  }



  /* ── BKS FOOTER OVERRIDES ─────────────────────────────── */

  footer.footer.color-accent-1 {

    --color-foreground: 250, 250, 247;

    --color-base-text: 250, 250, 247;

    background:

      radial-gradient(ellipse at 20% 0%, rgba(200,196,190,0.04) 0 20rem, transparent 40rem),

      linear-gradient(170deg, #111009 0%, #0a0a0a 35%, #0a0a0a 100%);

    border-top: 1px solid rgba(250,250,247,0.06);

    color: #fafaf7;

  }

  footer.footer.color-accent-1 *,

  footer.footer.color-accent-1 a,

  footer.footer.color-accent-1 p,

  footer.footer.color-accent-1 h3,

  footer.footer.color-accent-1 li,

  footer.footer.color-accent-1 small,

  footer.footer.color-accent-1 label,

  footer.footer.color-accent-1 input::placeholder {

    color: #fafaf7;

  }

  footer.footer.color-accent-1 input {

    color: #fafaf7;

    border-color: rgba(250,250,247,0.3);

    background: transparent;

  }

  footer.footer.color-accent-1 .icon svg,

  footer.footer.color-accent-1 svg {

    fill: #fafaf7;

  }



  .bks-footer-top {

    display: grid;

    grid-template-columns: 1fr 1fr 1fr auto;

    gap: clamp(24px, 4vw, 64px);

    align-items: start;

    padding: clamp(48px, 7vw, 80px) 0 clamp(32px, 5vw, 56px);

  }

  @media (max-width: 1024px) {

    .bks-footer-top { grid-template-columns: 1fr 1fr; }

  }

  @media (max-width: 600px) {

    .bks-footer-top { grid-template-columns: 1fr; gap: 32px; }

  }



  .bks-footer-brand__logo {

    height: 32px;

    width: auto;

    display: block;

    margin-bottom: 16px;

    opacity: 0.9;

  }

  .bks-footer-brand__tagline {

    font-family: var(--bks-font-mono, 'DM Mono', monospace);

    font-size: 0.7rem;

    letter-spacing: 0.12em;

    text-transform: uppercase;

    color: var(--color-foreground);

    opacity: 0.72;

    margin: 0 0 20px;

    line-height: 1.6;

  }

  .bks-footer-brand__desc {

    font-size: 0.82rem;

    line-height: 1.65;

    color: var(--color-foreground);

    opacity: 0.76;

    max-width: 26ch;

    margin: 0 0 20px;

  }



  /* ── NAV COLS ─────────────────────────────────────────── */

  .bks-footer-col__heading {

    font-family: var(--bks-font-mono, 'DM Mono', monospace);

    font-size: 0.68rem;

    letter-spacing: 0.14em;

    text-transform: uppercase;

    color: var(--color-foreground);

    opacity: 0.62;

    margin: 0 0 16px;

    font-weight: 500;

  }

  .bks-footer-col ul {

    list-style: none;

    margin: 0;

    padding: 0;

    display: flex;

    flex-direction: column;

    gap: 10px;

  }

  .bks-footer-col ul a {

    font-size: 0.84rem;

    color: var(--color-foreground);

    opacity: 0.82;

    text-decoration: none;

    transition: opacity 0.2s;

    line-height: 1.4;

  }

  .bks-footer-col ul a:hover { opacity: 1; }



  /* ── NEWSLETTER ───────────────────────────────────────── */

  .bks-footer-newsletter { min-width: 220px; max-width: 280px; }

  .bks-footer-newsletter__heading {

    font-family: var(--bks-font-mono, 'DM Mono', monospace);

    font-size: 0.68rem;

    letter-spacing: 0.14em;

    text-transform: uppercase;

    color: var(--color-foreground);

    opacity: 0.62;

    margin: 0 0 16px;

    font-weight: 500;

  }

  .bks-footer-newsletter__sub {

    font-size: 0.82rem;

    line-height: 1.55;

    opacity: 0.74;

    margin: 0 0 18px;

    color: var(--color-foreground);

  }

  .bks-footer-newsletter .field {

    position: relative;

  }

  .bks-footer-newsletter .field__input {

    background: transparent;

    border: 1px solid currentColor;

    opacity: 0.35;

    border-radius: 0;

    padding: 10px 44px 10px 12px;

    font-size: 0.82rem;

    width: 100%;

    transition: opacity 0.2s;

  }

  .bks-footer-newsletter .field__input:focus {

    opacity: 1;

    outline: none;

  }

  .bks-footer-newsletter .field__label {

    font-size: 0.78rem;

  }



  /* ── DIVIDER ──────────────────────────────────────────── */

  .bks-footer-divider {

    border: none;

    border-top: 1px solid currentColor;

    opacity: 0.1;

    margin: 0;

  }



  /* ── BOTTOM BAR ───────────────────────────────────────── */

  .bks-footer-bottom {

    padding: 20px 0;

    display: flex;

    flex-wrap: wrap;

    align-items: center;

    justify-content: space-between;

    gap: 12px;

  }

  .bks-footer-bottom__left,

  .bks-footer-bottom__right {

    display: flex;

    flex-wrap: wrap;

    align-items: center;

    gap: 8px 20px;

  }

  .bks-footer-bottom small,

  .bks-footer-bottom a {

    font-size: 0.72rem;

    color: var(--color-foreground);

    opacity: 0.58;

    text-decoration: none;

    font-family: var(--bks-font-mono, 'DM Mono', monospace);

    letter-spacing: 0.06em;

  }

  .bks-footer-bottom a:hover { opacity: 0.8; }

  .bks-footer-policies {

    display: flex;

    flex-wrap: wrap;

    gap: 4px 16px;

    list-style: none;

    margin: 0;

    padding: 0;

  }



  /* ── EU REP ───────────────────────────────────────────── */

  .bks-footer-eu {

    padding: 14px 0 0;

    border-top: 1px solid currentColor;

    opacity: 1;

  }

  .bks-footer-eu p {

    font-size: 0.68rem;

    line-height: 1.55;

    color: var(--color-foreground);

    opacity: 0.52;

    margin: 0;

    font-family: var(--bks-font-mono, 'DM Mono', monospace);

  }

  .bks-footer-eu a {

    color: inherit;

    text-decoration: underline;

    opacity: 0.5;

  }



  /* ── LANGUAGE SELECTOR — hidden, single-market store ──── */

  localization-form,

  .localization-form,

  .disclosure,

  .bks-lang-form { display: none !important; }



  /* ── PAYMENT ICONS ────────────────────────────────────── */

  .bks-footer-payment {

    display: flex;

    flex-wrap: wrap;

    align-items: center;

    gap: 6px;

  }

  .bks-footer-payment .icon { opacity: 0.5; }



  /* ── SOCIAL ───────────────────────────────────────────── */

  .bks-footer-social.footer__list-social {

    display: flex;

    gap: 12px;

    margin: 0;

    padding: 0;

    list-style: none;

  }

  .bks-footer-social.footer__list-social a {

    opacity: 0.45;

    transition: opacity 0.2s;

  }

  .bks-footer-social.footer__list-social a:hover { opacity: 1; }



  @media (max-width: 600px) {

    .bks-footer-bottom {

      flex-direction: column;

      align-items: flex-start;

    }

  }

{%- endstyle -%}



{%- liquid

  assign has_social_icons = true

  if settings.social_facebook_link == blank and settings.social_instagram_link == blank and settings.social_youtube_link == blank and settings.social_tiktok_link == blank and settings.social_twitter_link == blank and settings.social_pinterest_link == blank and settings.social_snapchat_link == blank and settings.social_tumblr_link == blank and settings.social_vimeo_link == blank

    assign has_social_icons = false

  endif

-%}



<footer class="footer color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding" role="contentinfo">

  <div class="page-width">



    {%- comment -%} ── TOP GRID ────────────────────────────────────────── {%- endcomment -%}

    <div class="bks-footer-top">



      {%- comment -%} COL 1 — Brand {%- endcomment -%}

      <div class="bks-footer-brand">

        <a href="{{ routes.root_url }}" aria-label="BKS Studio home">

          <img

            src="{{ 'bakabo-logo-official.png' | asset_url }}"

            alt="BKS Studio"

            class="bks-footer-brand__logo"

            loading="lazy"

            width="120"

            height="32"

          >

        </a>

        <p class="bks-footer-brand__tagline">BKS Studio — AI-Art Atelier<br>Designed in Italy · On demand worldwide</p>

        <p class="bks-footer-brand__desc">Eight editorial collections. AI-generated all-over print, made after every order.</p>

        {%- if has_social_icons -%}

          {%- render 'social-icons', class: 'footer__list-social bks-footer-social' -%}

        {%- endif -%}

      </div>



      {%- comment -%} COL 2 — Collections {%- endcomment -%}

      <div class="bks-footer-col">

        <h3 class="bks-footer-col__heading">Collections</h3>

        <ul>

          <li><a href="/pages/bks-hours">BKS Hours</a></li>

          <li><a href="/pages/bks-glyph">BKS Glyph</a></li>

          <li><a href="/pages/bks-marker">BKS Marker</a></li>

          <li><a href="/pages/bks-riviera">BKS Riviera</a></li>

          <li><a href="/pages/bks-pulse">BKS Pulse</a></li>

          <li><a href="/pages/bks-token">BKS Token</a></li>

          <li><a href="/pages/bks-flag">BKS Flag</a></li>

          <li><a href="/pages/bks-origin">BKS Origin</a></li>

        </ul>

      </div>



      {%- comment -%} COL 3 — Info / Support {%- endcomment -%}

      <div class="bks-footer-col">

        <h3 class="bks-footer-col__heading">Support</h3>

        <ul>

          <li><a href="/pages/help-faq">Help &amp; FAQ</a></li>
          <li><a href="/policies/shipping-policy">Shipping</a></li>
          <li><a href="/policies/refund-policy">Returns</a></li>
          <li><a href="/policies/privacy-policy">Privacy</a></li>
          <li><a href="/policies/terms-of-service">Terms</a></li>
          <li><a href="/pages/contact">Contact</a></li>

        </ul>

      </div>



      {%- comment -%} COL 4 — Newsletter {%- endcomment -%}

      <div class="bks-footer-newsletter">

        <h3 class="bks-footer-newsletter__heading">Studio notes</h3>

        <p class="bks-footer-newsletter__sub">New drops, editorial releases, behind-the-prompt.</p>

        {%- form 'customer', id: 'ContactFooter', class: 'footer__newsletter newsletter-form' -%}

          <input type="hidden" name="contact[tags]" value="newsletter">

          <div class="newsletter-form__field-wrapper">

            <div class="field">

              <input

                id="NewsletterForm--{{ section.id }}"

                type="email"

                name="contact[email]"

                class="field__input"

                value="{{ form.email }}"

                aria-required="true"

                autocorrect="off"

                autocapitalize="off"

                autocomplete="email"

                {% if form.errors %}

                  autofocus

                  aria-invalid="true"

                  aria-describedby="ContactFooter-error"

                {% elsif form.posted_successfully? %}

                  aria-describedby="ContactFooter-success"

                {% endif %}

                placeholder="{{ 'newsletter.label' | t }}"

                required

              >

              <label class="field__label" for="NewsletterForm--{{ section.id }}">

                {{ 'newsletter.label' | t }}

              </label>

              <button

                type="submit"

                class="newsletter-form__button field__button"

                name="commit"

                id="Subscribe"

                aria-label="{{ 'newsletter.button_label' | t }}"

              >

                <span class="svg-wrapper">

                  {{- 'icon-arrow.svg' | inline_asset_content -}}

                </span>

              </button>

            </div>

            {%- if form.errors -%}

              <small class="newsletter-form__message form__message" id="ContactFooter-error">

                <span class="svg-wrapper">{{- 'icon-error.svg' | inline_asset_content -}}</span>

                {{- form.errors.translated_fields.email | capitalize }} {{ form.errors.messages.email -}}

              </small>

            {%- endif -%}

          </div>

          {%- if form.posted_successfully? -%}

            <h3 class="newsletter-form__message newsletter-form__message--success form__message"

                id="ContactFooter-success" tabindex="-1" autofocus>

              <span class="svg-wrapper">{{- 'icon-success.svg' | inline_asset_content -}}</span>

              {{- 'newsletter.success' | t }}

            </h3>

          {%- endif -%}

        {%- endform -%}



        {%- if section.settings.show_social and has_social_icons == false -%}

          {%- comment -%} fallback: social qui se non già mostrato nel brand block {%- endcomment -%}

        {%- endif -%}

      </div>



    </div>{%- comment -%} /bks-footer-top {%- endcomment -%}



    <hr class="bks-footer-divider">



    {%- comment -%} ── BOTTOM BAR ──────────────────────────────────────── {%- endcomment -%}

    <div class="bks-footer-bottom">



      <div class="bks-footer-bottom__left">

        <small>&copy; {{ 'now' | date: '%Y' }} BKS Studio / BakAbo</small>

        <small>P.IVA 00774100556</small>

        {%- comment -%} BKS: language/country selector disabled — single-market store {%- endcomment -%}

      </div>



      <div class="bks-footer-bottom__right">

        {%- if section.settings.show_policy -%}

          <ul class="bks-footer-policies">

            {%- for policy in shop.policies -%}

              {%- if policy != blank -%}

                <li><small><a href="{{ policy.url }}">{{ policy.title | escape }}</a></small></li>

              {%- endif -%}

            {%- endfor -%}

          </ul>

        {%- endif -%}

        {%- if section.settings.payment_enable -%}

          <div class="bks-footer-payment">

            <span class="visually-hidden">{{ 'sections.footer.payment' | t }}</span>

            {%- for type in shop.enabled_payment_types -%}

              {{ type | payment_type_svg_tag: class: 'icon icon--full-color bks-footer-payment' }}

            {%- endfor -%}

          </div>

        {%- endif -%}

      </div>



    </div>



    {%- comment -%} ── EU REP (GPSR) ────────────────────────────────── {%- endcomment -%}

    <div class="bks-footer-eu">

      <p>

        EU Representative (GPSR): HONSON VENTURES LIMITED — Gnaftis House flat 102, Limassol, Mesa Geitonia, 4003, Cyprus —

        <a href="mailto:gpsr@honsonventures.com">gpsr@honsonventures.com</a>

      </p>

    </div>



  </div>{%- comment -%} /page-width {%- endcomment -%}

</footer>



{% schema %}

{

  "name": "t:sections.footer.name",

  "blocks": [

    { "type": "@app" },

    {

      "type": "link_list",

      "name": "t:sections.footer.blocks.link_list.name",

      "settings": [

        {

          "type": "inline_richtext",

          "id": "heading",

          "default": "t:sections.footer.blocks.link_list.settings.heading.default",

          "label": "t:sections.footer.blocks.link_list.settings.heading.label"

        },

        {

          "type": "link_list",

          "id": "menu",

          "default": "footer",

          "label": "t:sections.footer.blocks.link_list.settings.menu.label"

        }

      ]

    },

    {

      "type": "brand_information",

      "name": "t:sections.footer.blocks.brand_information.name",

      "settings": [

        {

          "type": "paragraph",

          "content": "t:sections.footer.blocks.brand_information.settings.paragraph.content"

        },

        {

          "type": "checkbox",

          "id": "show_social",

          "default": true,

          "label": "t:sections.footer.blocks.brand_information.settings.show_social.label",

          "info": "t:sections.footer.blocks.brand_information.settings.show_social.info"

        }

      ]

    },

    {

      "type": "text",

      "name": "t:sections.footer.blocks.text.name",

      "settings": [

        {

          "type": "inline_richtext",

          "id": "heading",

          "default": "t:sections.footer.blocks.text.settings.heading.default",

          "label": "t:sections.footer.blocks.text.settings.heading.label"

        },

        {

          "type": "richtext",

          "id": "subtext",

          "default": "t:sections.footer.blocks.text.settings.subtext.default",

          "label": "t:sections.footer.blocks.text.settings.subtext.label"

        }

      ]

    },

    {

      "type": "image",

      "name": "Image",

      "settings": [

        { "type": "image_picker", "id": "image", "label": "Image" },

        {

          "type": "range",

          "id": "image_width",

          "min": 50, "max": 550, "step": 5, "unit": "px",

          "label": "Width",

          "default": 100

        },

        {

          "type": "select",

          "id": "alignment",

          "label": "Alignment",

          "options": [

            { "value": "", "label": "Left" },

            { "value": "center", "label": "Center" },

            { "value": "right", "label": "Right" }

          ],

          "default": "center"

        }

      ]

    }

  ],

  "settings": [

    {

      "type": "color_scheme",

      "id": "color_scheme",

      "label": "t:sections.all.colors.label",

      "default": "accent-1"

    },

    {

      "type": "header",

      "content": "t:sections.footer.settings.header__1.content",

      "info": "t:sections.footer.settings.header__1.info"

    },

    {

      "type": "checkbox",

      "id": "newsletter_enable",

      "default": true,

      "label": "t:sections.footer.settings.newsletter_enable.label"

    },

    {

      "type": "inline_richtext",

      "id": "newsletter_heading",

      "default": "t:sections.footer.settings.newsletter_heading.default",

      "label": "t:sections.footer.settings.newsletter_heading.label"

    },

    {

      "type": "header",

      "content": "t:sections.footer.settings.header__9.content"

    },

    {

      "type": "checkbox",

      "id": "enable_follow_on_shop",

      "default": true,

      "label": "t:sections.footer.settings.enable_follow_on_shop.label",

      "info": "t:sections.footer.settings.enable_follow_on_shop.info"

    },

    {

      "type": "checkbox",

      "id": "show_social",

      "default": true,

      "label": "t:sections.footer.settings.show_social.label",

      "info": "t:sections.footer.settings.show_social.info"

    },

    {

      "type": "checkbox",

      "id": "enable_country_selector",

      "default": true,

      "label": "t:sections.footer.settings.enable_country_selector.label",

      "info": "t:sections.footer.settings.enable_country_selector.info"

    },

    {

      "type": "checkbox",

      "id": "enable_language_selector",

      "default": true,

      "label": "t:sections.footer.settings.enable_language_selector.label",

      "info": "t:sections.footer.settings.enable_language_selector.info"

    },

    {

      "type": "checkbox",

      "id": "payment_enable",

      "default": true,

      "label": "t:sections.footer.settings.payment_enable.label"

    },

    {

      "type": "checkbox",

      "id": "show_policy",

      "default": true,

      "label": "t:sections.footer.settings.show_policy.label",

      "info": "t:sections.footer.settings.show_policy.info"

    },

    {

      "type": "header",

      "content": "t:sections.all.spacing"

    },

    {

      "type": "range",

      "id": "margin_top",

      "min": 0, "max": 100, "step": 4, "unit": "px",

      "label": "t:sections.footer.settings.margin_top.label",

      "default": 0

    },

    {

      "type": "header",

      "content": "t:sections.all.padding.section_padding_heading"

    },

    {

      "type": "range",

      "id": "padding_top",

      "min": 0, "max": 100, "step": 4, "unit": "px",

      "label": "t:sections.all.padding.padding_top",

      "default": 36

    },

    {

      "type": "range",

      "id": "padding_bottom",

      "min": 0, "max": 100, "step": 4, "unit": "px",

      "label": "t:sections.all.padding.padding_bottom",

      "default": 36

    }

  ],

  "default": {

    "blocks": [

      { "type": "link_list" },

      { "type": "text" }

    ]

  }

}

{% endschema %}

