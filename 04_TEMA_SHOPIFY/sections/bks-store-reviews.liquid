{% if section.settings.enabled %}
<section class="bks-store-reviews" aria-label="Store ratings">
  <div class="bks-store-reviews__inner">
    {% if section.settings.heading != blank %}
      <p class="bks-store-reviews__heading">{{ section.settings.heading | escape }}</p>
    {% endif %}
    <div class="bks-store-reviews__badge">
      {% render 'bks-gcr-badge' %}
    </div>
    {% if section.settings.subtext != blank %}
      <p class="bks-store-reviews__sub">{{ section.settings.subtext | escape }}</p>
    {% endif %}
  </div>
</section>

<style>
  .bks-store-reviews {
    --bks-rev-accent: var(--bks-active-accent, #2f6f6b);
    background: #fafaf7;
    border-bottom: 1px solid rgba(10,10,10,0.07);
    border-top: 1px solid rgba(10,10,10,0.07);
    padding: {{ section.settings.padding_v }}px 16px;
    position: relative;
  }

  .bks-store-reviews::before {
    background: var(--bks-rev-accent);
    content: '';
    height: 2px;
    left: 0;
    position: absolute;
    right: 0;
    top: 0;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.32s cubic-bezier(0.22,1,0.36,1);
  }

  .bks-store-reviews:hover::before {
    transform: scaleX(1);
  }

  .bks-store-reviews__inner {
    align-items: center;
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin: 0 auto;
    max-width: 640px;
  }

  .bks-store-reviews__heading {
    color: #0a0a0a;
    font-family: 'DM Mono', 'Courier New', monospace;
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.10em;
    margin: 0;
    text-transform: uppercase;
  }

  .bks-store-reviews__badge {
    display: flex;
    justify-content: center;
  }

  .bks-store-reviews__sub {
    color: rgba(10,10,10,0.50);
    font-family: 'DM Mono', 'Courier New', monospace;
    font-size: 0.65rem;
    letter-spacing: 0.06em;
    margin: 0;
    text-align: center;
    text-transform: uppercase;
  }
</style>
{% endif %}

{% schema %}
{
  "name": "BKS Store reviews",
  "settings": [
    { "type": "checkbox", "id": "enabled", "label": "Show section", "default": true },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Verified by Google" },
    { "type": "text", "id": "subtext", "label": "Subtext (optional)" },
    { "type": "range", "id": "padding_v", "label": "Vertical padding (px)", "min": 12, "max": 64, "step": 4, "default": 28 }
  ],
  "presets": [
    { "name": "BKS Store reviews" }
  ]
}
{% endschema %}
