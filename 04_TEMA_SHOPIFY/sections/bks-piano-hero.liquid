          "default": "Do"
        },
        {
          "type": "range",
          "id": "freq",
          "label": "Frequency Hz (display only)",
          "min": 220,
          "max": 440,
          "step": 10,
          "default": 260,
          "unit": "Hz"
        },
        {
          "type": "checkbox",
          "id": "white",
          "label": "White key",
          "default": true,
          "info": "Disable for black key (Do#, Re♭, etc.)"
        },
        {
          "type": "color",
          "id": "color",
          "label": "Collection identity colour",
          "default": "#C9B79C"
        },
        {
          "type": "url",
          "id": "url",
