{{ 'bks-member.css' | asset_url | stylesheet_tag }}

<section class="bks-wishlist-page" data-section-id="{{ section.id }}">
  <div class="bks-wishlist-page__header">
    <p class="bks-wishlist-page__eyebrow">{{ section.settings.eyebrow | default: 'BKS Members' }}</p>
    <h1 class="bks-wishlist-page__title">{{ section.settings.title | default: 'Wishlist' }}</h1>
    <p class="bks-wishlist-page__count" id="bks-wl-count"></p>
  </div>

  <div id="bks-wishlist-container" class="bks-wishlist-page__body">
    <div class="bks-wishlist-loading">
      <span class="bks-wishlist-loading-dot"></span>
      <span class="bks-wishlist-loading-dot"></span>
      <span class="bks-wishlist-loading-dot"></span>
    </div>
  </div>

  {%- if section.settings.show_cta -%}
  <div class="bks-wishlist-page__cta">
    <a href="{{ section.settings.cta_url | default: '/collections/all' }}" class="bks-btn-ghost">
      {{ section.settings.cta_label | default: 'Explore the catalog' }}
    </a>
  </div>
  {%- endif -%}
</section>

<style>
  .bks-wishlist-page {
    min-height: 60vh;
    padding: 64px 24px 80px;
    max-width: 1200px;
    margin: 0 auto;
  }
  .bks-wishlist-page__header {
    margin-bottom: 40px;
  }
  .bks-wishlist-page__eyebrow {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #888;
    margin: 0 0 8px;
  }
  .bks-wishlist-page__title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(40px, 6vw, 72px);
    letter-spacing: 0.04em;
    color: #0A0A0A;
    margin: 0 0 8px;
    line-height: 1;
  }
  .bks-wishlist-page__count {
    font-family: 'DM Mono', monospace;
    font-size: 12px;
    color: #aaa;
    margin: 0;
  }
  .bks-wishlist-page__body {
    min-height: 200px;
  }
  .bks-wishlist-page__cta {
    margin-top: 48px;
    text-align: center;
  }
  .bks-wishlist-loading {
    display: flex;
    gap: 8px;
    padding: 60px 0;
    justify-content: center;
  }
  .bks-wishlist-loading-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #ccc;
    animation: bks-wl-pulse 1.2s infinite ease-in-out;
  }
  .bks-wishlist-loading-dot:nth-child(2) { animation-delay: 0.2s; }
  .bks-wishlist-loading-dot:nth-child(3) { animation-delay: 0.4s; }
  @keyframes bks-wl-pulse {
    0%, 80%, 100% { opacity: 0.3; transform: scale(0.8); }
    40% { opacity: 1; transform: scale(1); }
  }
  /* wishlist grid — reuses bks-member.css .bks-wishlist-* classes */
  #bks-wishlist-container .bks-wishlist-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 24px;
  }
  #bks-wishlist-container .bks-wishlist-empty {
    text-align: center;
    padding: 80px 0;
    color: #888;
  }
  #bks-wishlist-container .bks-wishlist-empty svg {
    margin-bottom: 16px;
    opacity: 0.4;
    display: block;
    margin-inline: auto;
  }
  #bks-wishlist-container .bks-wishlist-empty p {
    font-family: 'DM Sans', sans-serif;
    font-size: 15px;
    margin: 0 0 24px;
  }
  #bks-wishlist-container .bks-wishlist-share {
    margin-top: 32px;
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    background: none;
    border: 1px solid #ddd;
    padding: 10px 18px;
    cursor: pointer;
    color: #555;
    transition: border-color 0.2s, color 0.2s;
  }
  #bks-wishlist-container .bks-wishlist-share:hover {
    border-color: #0A0A0A;
    color: #0A0A0A;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    if (typeof renderWishlistPanel === 'function') {
      renderWishlistPanel();
      var count = (function () {
        try { return JSON.parse(localStorage.getItem('bks_wishlist_v1') || '[]').length; } catch { return 0; }
      })();
      var el = document.getElementById('bks-wl-count');
      if (el) el.textContent = count === 0 ? '' : count + (count === 1 ? ' item' : ' items');
    }
  });
</script>

{% schema %}
{
  "name": "BKS Wishlist",
  "tag": "section",
  "settings": [
    { "type": "text",     "id": "eyebrow",   "label": "Eyebrow",    "default": "BKS Members" },
    { "type": "text",     "id": "title",     "label": "Title",      "default": "Wishlist" },
    { "type": "checkbox", "id": "show_cta",  "label": "Show CTA",   "default": true },
    { "type": "text",     "id": "cta_label", "label": "CTA label",  "default": "Explore the catalog" },
    { "type": "url",      "id": "cta_url",   "label": "CTA URL",    "default": "/collections/all" }
  ],
  "presets": [{ "name": "BKS Wishlist" }]
}
{% endschema %}
