{{ 'bks-member.css' | asset_url | stylesheet_tag }}

{%- render 'bks-member-tier' -%}

<div class="bks-member-wrap">
  <div style="max-width:1100px;padding:{{ section.settings.padding_top }}px 32px {{ section.settings.padding_bottom }}px;">

    {%- if customer -%}
      {%- if bks_tier_rank >= 3 -%}
        {%- render 'bks-member-archive' -%}
      {%- else -%}
        <div class="bks-upgrade-card" style="max-width:480px;">
          <div class="bks-upgrade-icon">◈</div>
          <h3 class="bks-upgrade-title">BKS Studio Archive</h3>
          <p class="bks-upgrade-text">
            {%- assign bks_orders = customer.orders_count | default: 0 -%}
            {%- assign bks_needed = 6 | minus: bks_orders -%}
            {%- if bks_orders > 0 -%}
              You have {{ bks_orders }} order{% if bks_orders != 1 %}s{% endif %}.
              Archive access unlocks at 6 orders —
              {{ bks_needed }} more to go.
            {%- else -%}
              Reserved for members with 6+ orders.
              Keep exploring BKS — the archive will be waiting.
            {%- endif -%}
          </p>
          <a href="/collections/all" class="bks-btn-gold">Explore products</a>
        </div>
      {%- endif -%}
    {%- else -%}
      <div class="bks-upgrade-card" style="max-width:480px;">
        <div class="bks-upgrade-icon">—</div>
        <h3 class="bks-upgrade-title">Members only</h3>
        <p class="bks-upgrade-text">Sign in to your account to view this content.</p>
        <a href="{{ routes.account_login_url }}?return_url=/pages/bks-archive" class="bks-btn-gold">
          Sign in
        </a>
      </div>
    {%- endif -%}

  </div>
</div>

{% schema %}
{
  "name": "BKS Archive Page",
  "settings": [
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 60
    }
  ]
}
{% endschema %}
