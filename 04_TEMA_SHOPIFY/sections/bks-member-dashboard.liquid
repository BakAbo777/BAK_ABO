{% schema %}
{
  "name": "BKS Member Dashboard",
  "settings": [
    { "type": "header", "content": "Early Access — next drop" },
    { "type": "text", "id": "drop_title", "label": "Drop title", "placeholder": "BKS Glyph — Summer 2026" },
    { "type": "text", "id": "drop_date", "label": "Drop date (ISO 8601)", "placeholder": "2026-07-10T10:00:00+02:00", "info": "Format: YYYY-MM-DDTHH:MM:SS+02:00" },
    { "type": "textarea", "id": "drop_teaser", "label": "Teaser (short description)", "placeholder": "A new interpretation of the Glyph pattern, in recycled technical fabrics." },
    { "type": "image_picker", "id": "drop_image", "label": "Teaser image (blurred preview)" },
    { "type": "checkbox", "id": "drop_live", "label": "Drop is live?", "default": false },
    { "type": "url", "id": "drop_url", "label": "Collection URL (when live)" },
    { "type": "header", "content": "Try-On — API" },
    { "type": "text", "id": "tryon_api_base", "label": "API Base URL (try-on engine)", "default": "http://127.0.0.1:8010/api", "info": "Local: http://127.0.0.1:8010/api — Production: https://ai.bakabo.club/api" },
    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding top", "default": 0 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding bottom", "default": 0 }
  ]
}
{% endschema %}
