      <!-- Privacy notice -->
      <div class="bks-cv3-privacy">
        <span>⊙</span>
        <span><strong>Your photo stays in your browser.</strong> Processing is local — no image is sent to BKS servers. If you use "Send to crew", the photo is transmitted only with your explicit consent (GDPR art. 6.1.a).</span>
      </div>

      <!-- Upload zone -->
      <div class="bks-cv3-upload-wrap" id="bks-upload-zone">
        <input type="file" id="bks-photo-input" accept="image/jpeg,image/png,image/webp,image/heic" style="display:none" aria-label="Upload your photo">
        <div class="bks-cv3-upload-zone">
          <label for="bks-photo-input" class="bks-cv3-upload-label" id="bks-upload-label">
            <div class="bks-cv3-upload-icon">↑</div>
            <strong>Drag your photo here</strong>
            <span>or click to upload</span>
            <em>JPG · PNG · WEBP · max 12 MB · Full body · Portrait · Min 600×900</em>
          </label>
        </div>
        <!-- Photo guide (collapsible) -->
        <button class="bks-cv3-guide-toggle" id="bks-guide-toggle" type="button">
          <span>Photo guide — how to get a good result</span>
          <span class="bks-cv3-guide-toggle__arrow">▾</span>
        </button>
        <div class="bks-cv3-guide-body" id="bks-guide-body">
          <div class="bks-cv3-guide-rule"><span class="bks-cv3-guide-rule__icon">↕</span><strong>Full body</strong><span>Head to toe, standing, arms slightly away.</span></div>
          <div class="bks-cv3-guide-rule"><span class="bks-cv3-guide-rule__icon">◎</span><strong>Frontal</strong><span>0° angle, straight to camera, no 3/4 turn.</span></div>
          <div class="bks-cv3-guide-rule"><span class="bks-cv3-guide-rule__icon">◻</span><strong>Neutral background</strong><span>White, beige or light grey. No clutter.</span></div>
          <div class="bks-cv3-guide-rule"><span class="bks-cv3-guide-rule__icon">◑</span><strong>Front light</strong><span>Window or natural light facing you.</span></div>
          <div class="bks-cv3-guide-rule"><span class="bks-cv3-guide-rule__icon">▭</span><strong>Fitted base</strong><span>T-shirt and leggings — the BKS garment overlays.</span></div>
          <div class="bks-cv3-guide-rule"><span class="bks-cv3-guide-rule__icon">⊡</span><strong>Portrait format</strong><span>Vertical, min 600×900 px, JPG or PNG.</span></div>
