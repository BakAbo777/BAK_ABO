      <div class="bks-cv3-split" id="bks-camerino-grid">

        <!-- Left: user photo panel -->
        <div class="bks-cv3-photo-panel">
          <img class="bks-cv3-photo-panel__img" id="bks-cv3-photo-img" alt="Your photo" src="">
          <div class="bks-cv3-photo-panel__footer">
            <span class="bks-cv3-photo-label">Your photo</span>
            <button class="bks-cv3-change-btn" id="bks-cv3-change-btn" type="button">Change ↺</button>
          </div>
        </div>

        <!-- Right: garment selection + preview canvas -->
        <div class="bks-cv3-right">
