              <div style="color:#6a6560;font-size:12px;font-family:'DM Mono',monospace;letter-spacing:0.06em;">Loading wishlist...</div>
            </div>
          </div>
          <div class="bks-cv3-preview" data-bks-preview>
            <div class="bks-cv3-preview__empty" id="bks-cv3-preview-empty">
              <div class="bks-cv3-preview__empty-icon">◈</div>
              <span class="bks-cv3-preview__empty-text">03 · Select a garment above to preview</span>
            </div>
