            </label>

          </div>
        </div>

        <div class="bks-cz-field" style="margin-top:24px;">
          <label class="bks-cz-label" for="bks-cz-desc">Request description <span class="bks-cz-req">*</span></label>
          <textarea id="bks-cz-desc" class="bks-cz-textarea" rows="4"
                    placeholder="Describe the customization you'd like. The more detail, the more accurate our response."
                    required minlength="20"></textarea>
          <span class="bks-cz-char-count"><span id="bks-cz-desc-count">0</span> / 500</span>
        </div>

        <div class="bks-cz-field" style="margin-top:16px;">
          <label class="bks-cz-label" for="bks-cz-ref">Visual reference (URL, optional)</label>
          <input type="url" id="bks-cz-ref" class="bks-cz-input" placeholder="https://...">
