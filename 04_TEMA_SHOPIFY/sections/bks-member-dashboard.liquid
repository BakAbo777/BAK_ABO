{{ 'bks-member.css' | asset_url | stylesheet_tag }}
{{ 'bks-tryon.css' | asset_url | stylesheet_tag }}

<style>
  body { background: #0c0c0c !important; }
  #MainContent,
  .content-for-layout { padding-top: 0 !important; padding-bottom: 0 !important; }
  .shopify-section { margin-top: 0 !important; margin-bottom: 0 !important; }
  .page-width { max-width: none !important; padding: 0 !important; margin: 0 !important; }
  footer.footer, .footer { background: #0c0c0c !important; border-top: 1px solid rgba(255,255,255,0.06) !important; }
</style>

{%- comment -%} ── GATE — show login card if not authenticated ── {%- endcomment -%}
{%- unless customer -%}
<div class="bks-member-gate">
  <div class="bks-member-gate__wrap">
    <p class="bks-member-gate__eyebrow">Members</p>
    <h1 class="bks-member-gate__title">BKS Members</h1>
    <p class="bks-member-gate__sub">Sign in to manage orders, wishlist and the virtual fitting room.</p>
    <div class="bks-member-gate__actions">
      <a href="{{ routes.account_login_url }}" class="bks-btn-gold">Sign in</a>
      <a href="{{ routes.account_register_url }}" class="bks-btn-ghost">Create account</a>
    </div>
    <div class="bks-member-gate__benefits">
      <div class="bks-member-gate__benefit">
        <span class="bks-member-gate__benefit-icon">◯</span>
        <span class="bks-member-gate__benefit-label">Wishlist</span>
      </div>
      <div class="bks-member-gate__benefit">
        <span class="bks-member-gate__benefit-icon">◱</span>
        <span class="bks-member-gate__benefit-label">Virtual Try-On</span>
      </div>
      <div class="bks-member-gate__benefit">
        <span class="bks-member-gate__benefit-icon">→</span>
        <span class="bks-member-gate__benefit-label">Early Access</span>
      </div>
    </div>
    <p class="bks-member-gate__note">
      By creating an account you accept the <a href="{{ routes.root_url }}policies/terms-of-service">Terms</a>
      and <a href="{{ routes.root_url }}policies/privacy-policy">Privacy Policy</a>.
    </p>
  </div>
</div>
<style>
.bks-member-gate {
  min-height: 100vh;
  background: #0c0c0c;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: clamp(40px,8vh,100px) 20px;
  font-family: var(--bks-font-text,"DM Sans",sans-serif);
}
.bks-member-gate__wrap {
  width: 100%;
  max-width: 440px;
  text-align: center;
}
.bks-member-gate__eyebrow {
  font-family: var(--bks-font-mono,"DM Mono",monospace);
  font-size: 0.68rem;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: #8a8480;
  margin: 0 0 12px;
}
.bks-member-gate__title {
  font-family: var(--bks-font-display,"Bebas Neue",sans-serif);
  font-size: clamp(2.4rem,7vw,3.8rem);
  font-weight: 400;
  letter-spacing: 0.04em;
  line-height: 1;
  color: #f0ece4;
  margin: 0 0 14px;
}
.bks-member-gate__sub {
  font-size: 0.88rem;
  color: #8a8480;
  margin: 0 0 36px;
  line-height: 1.6;
}
.bks-member-gate__actions {
  display: flex;
  flex-direction: column;
  gap: 10px;
  margin-bottom: 32px;
}
.bks-member-gate__benefits {
  display: flex;
  justify-content: center;
  gap: 32px;
  padding: 24px 0;
  border-top: 1px solid rgba(255,255,255,0.07);
  border-bottom: 1px solid rgba(255,255,255,0.07);
  margin-bottom: 20px;
}
.bks-member-gate__benefit {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6px;
}
.bks-member-gate__benefit-icon {
  font-size: 1.1rem;
  color: #c8a96e;
  line-height: 1;
}
.bks-member-gate__benefit-label {
  font-family: var(--bks-font-mono,"DM Mono",monospace);
  font-size: 0.62rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: #8a8480;
}
.bks-member-gate__note {
  font-size: 0.72rem;
  color: #6a6460;
  line-height: 1.5;
}
.bks-member-gate__note a { color: #8a8480; text-decoration: underline; }
</style>
{%- endunless -%}

{%- if customer -%}

{%- comment -%} ── Metal Tier detection (tag override → orders_count) ── {%- endcomment -%}
{%- liquid
  assign _oc = customer.orders_count | default: 0
  if customer.tags contains 'bks_tier_gold' or _oc >= 11
    assign bks_metal_tier   = 'gold'
    assign bks_metal_label  = 'Gold Member'
    assign bks_metal_symbol = '✦'
    assign bks_metal_color  = '#d4a030'
    assign bks_metal_rank   = 4
  elsif customer.tags contains 'bks_tier_silver' or _oc >= 6
    assign bks_metal_tier   = 'silver'
    assign bks_metal_label  = 'Silver Member'
    assign bks_metal_symbol = '◇'
    assign bks_metal_color  = '#b0b0c8'
    assign bks_metal_rank   = 3
  elsif customer.tags contains 'bks_tier_brass' or _oc >= 3
    assign bks_metal_tier   = 'brass'
    assign bks_metal_label  = 'Brass Member'
    assign bks_metal_symbol = '◈'
    assign bks_metal_color  = '#c8a96e'
    assign bks_metal_rank   = 2
  elsif customer.tags contains 'bks_tier_iron' or _oc >= 1
    assign bks_metal_tier   = 'iron'
    assign bks_metal_label  = 'Iron Member'
    assign bks_metal_symbol = '⬡'
    assign bks_metal_color  = '#8a8a8a'
    assign bks_metal_rank   = 1
  else
    assign bks_metal_tier   = 'lead'
    assign bks_metal_label  = 'Lead Member'
    assign bks_metal_symbol = '○'
    assign bks_metal_color  = '#7a7a7a'
    assign bks_metal_rank   = 0
  endif
  assign bks_initials      = customer.first_name | slice: 0, 1 | upcase
  assign bks_last_initial  = customer.last_name  | slice: 0, 1 | upcase
  assign bks_initials      = bks_initials | append: bks_last_initial
-%}

{%- assign bks_ref_code = customer.id -%}
{%- assign bks_ref_url  = shop.url | append: "?ref=" | append: bks_ref_code -%}
{%- assign bks_latest_order = customer.orders | first -%}

<div class="bks-member-wrap">

  {%- comment -%} ── Hero ── {%- endcomment -%}
  <div class="bks-member-hero">
    <div class="bks-member-hero__left">
      <div class="bks-member-avatar"
           data-tier="{{ bks_metal_tier }}"
           style="--bks-avatar-ring:{{ bks_metal_color }}"
           title="{{ bks_metal_label }}">
        <div class="bks-member-avatar__inner">{{ bks_initials }}</div>
      </div>
      <div>
        <h1 class="bks-member-greeting">
          Hello, <span>{{ customer.first_name }}</span>
        </h1>
        <p class="bks-member-meta">{{ customer.email }}</p>
      </div>
    </div>
    <div class="bks-member-actions">
      <span class="bks-tier-badge bks-tier-badge--{{ bks_metal_tier }}">
        <span class="bks-tier-dot"></span>
        {{ bks_metal_symbol }} {{ bks_metal_label }}
      </span>
      <a href="{{ routes.account_logout_url }}" class="bks-logout-link">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4M16 17l5-5-5-5M21 12H9"/>
        </svg>
        Sign out
      </a>
    </div>
  </div>

  {%- comment -%} ── Tabs ── {%- endcomment -%}
  <nav class="bks-member-tabs">
    <button class="bks-tab-btn" data-tab="orders">Orders</button>
    <button class="bks-tab-btn" data-tab="wishlist">Wishlist</button>
    <button class="bks-tab-btn" data-tab="early-access">Early Access</button>
    <button class="bks-tab-btn" data-tab="referral">Referral</button>
    <button class="bks-tab-btn" data-tab="customize">Customize</button>
    <button class="bks-tab-btn" data-tab="camerino">Try-On</button>
    {%- if bks_metal_rank >= 3 -%}
      <button class="bks-tab-btn" data-tab="archive">Archive</button>
    {%- else -%}
      <button class="bks-tab-btn" data-tab="archive" title="Unlocks at Silver (6+ orders)">
        Archive <span class="bks-tab-lock">◌</span>
      </button>
    {%- endif -%}
    {%- if bks_metal_rank >= 2 -%}
      <button class="bks-tab-btn" data-tab="verse">BKS Verse</button>
    {%- else -%}
      <button class="bks-tab-btn" data-tab="verse" title="Unlocks at Brass (3+ orders)">
        BKS Verse <span class="bks-tab-lock">◌</span>
      </button>
    {%- endif -%}
    <button class="bks-tab-btn" data-tab="creations">Creations</button>
    <button class="bks-tab-btn" data-tab="account">Account</button>
  </nav>

  {%- comment -%} ══════════════════════════════════════════
      TAB: Orders
  ══════════════════════════════════════════ {%- endcomment -%}
  <div id="bks-panel-orders" class="bks-member-panel">

    {%- if bks_metal_rank >= 2 and bks_latest_order -%}
      {%- render 'bks-member-tracker', order: bks_latest_order -%}
    {%- endif -%}

    <p class="bks-section-title">Order history</p>

    {%- if customer.orders.size > 0 -%}
      <table class="bks-orders-table" role="table">
        <thead>
          <tr>
            <th>Order</th>
            <th>Date</th>
            <th>Payment</th>
            <th>Shipping</th>
            <th>Total</th>
          </tr>
        </thead>
        <tbody>
          {%- for order in customer.orders limit: 20 -%}
            {%- assign pay_class = "bks-status-pill--" | append: order.financial_status -%}
            {%- assign ful_class = "bks-status-pill--" | append: order.fulfillment_status -%}
            <tr>
              <td><a href="{{ order.customer_url }}">{{ order.name }}</a></td>
              <td>{{ order.created_at | time_tag: format: 'date' }}</td>
              <td><span class="bks-status-pill {{ pay_class }}">{{ order.financial_status_label }}</span></td>
              <td><span class="bks-status-pill {{ ful_class }}">{{ order.fulfillment_status_label }}</span></td>
              <td>{{ order.total_net_amount | money_with_currency }}</td>
            </tr>
          {%- endfor -%}
        </tbody>
      </table>

      {%- if bks_metal_rank >= 2 and bks_latest_order.fulfillment_status == "fulfilled" -%}
        {%- assign fulfilled_days = bks_latest_order.created_at | date: "%s" | plus: 604800 -%}
        {%- assign now_ts = "now" | date: "%s" | plus: 0 -%}
        {%- if now_ts >= fulfilled_days -%}
          <div style="margin-top:24px;padding:20px 24px;background:var(--bks-surface);border:1px solid var(--bks-border);display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;">
            <div>
              <p style="margin:0 0 4px;font-size:13px;font-weight:500;">How is your {{ bks_latest_order.line_items.first.title | split: " " | slice: 0, 3 | join: " " }}?</p>
              <p style="margin:0;font-size:12px;color:var(--bks-muted);">Leave a review — it helps the BKS community.</p>
            </div>
            <a href="{{ bks_latest_order.customer_url }}#reviews" class="bks-btn-gold" style="font-size:11px;">Write a review</a>
          </div>
        {%- endif -%}
      {%- endif -%}

    {%- else -%}
      <div class="bks-empty-state">
        <p>No orders yet.</p>
        <a href="/collections/all" class="bks-btn-ghost" style="margin-top:16px;">Explore products</a>
      </div>
    {%- endif -%}

    {%- if customer.orders.size > 20 -%}
      <p style="margin-top:16px;font-size:12px;color:var(--bks-muted);text-align:center;">
        Showing last 20 orders.
        <a href="{{ routes.account_url }}" style="color:inherit;text-decoration:underline;">View all in account</a>
      </p>
    {%- endif -%}
  </div>

  {%- comment -%} ══════════════════════════════════════════
      TAB: Wishlist
  ══════════════════════════════════════════ {%- endcomment -%}
  <div id="bks-panel-wishlist" class="bks-member-panel">
    <p class="bks-section-title">Your wishlist</p>
    <div id="bks-wishlist-container">
      <div class="bks-empty-state" style="color:var(--bks-muted);font-size:13px;">Loading...</div>
    </div>
  </div>

  {%- comment -%} ══════════════════════════════════════════
      TAB: Early Access
  ══════════════════════════════════════════ {%- endcomment -%}
  <div id="bks-panel-early-access" class="bks-member-panel">
    <p class="bks-section-title">Early Access</p>

    {%- if bks_metal_rank >= 1 -%}
      {%- assign drop_title  = section.settings.drop_title -%}
      {%- assign drop_date   = section.settings.drop_date -%}
      {%- assign drop_teaser = section.settings.drop_teaser -%}
      {%- assign drop_live   = section.settings.drop_live -%}
      {%- assign drop_url    = section.settings.drop_url -%}

      {%- if drop_title != blank -%}
        <div class="bks-early-access-card">
          <div style="flex:1;min-width:220px;">
            <p class="bks-early-access-label">
              {%- if bks_metal_rank >= 3 -%}+24h exclusive preview{%- else -%}Next drop{%- endif -%}
            </p>
            <h2 class="bks-early-access-title">{{ drop_title }}</h2>
            <p class="bks-early-access-date">
              Public drop: <strong>{{ drop_date }}</strong>
              {%- if bks_metal_rank >= 3 -%} — you get access <strong>24h earlier</strong>{%- endif -%}
            </p>
            {%- if drop_teaser != blank -%}
              <p style="font-size:13px;color:var(--bks-muted);line-height:1.6;margin:0 0 20px;">{{ drop_teaser }}</p>
            {%- endif -%}
            {%- if drop_live -%}
              <a href="{{ drop_url | default: '/collections/new-arrivals' }}" class="bks-btn-gold">Go to collection →</a>
            {%- else -%}
              {%- if drop_date != blank -%}
                <div class="bks-countdown" id="bks-countdown" data-target="{{ drop_date }}">
                  <div class="bks-countdown-block"><span class="bks-countdown-num bks-countdown-d">--</span><span class="bks-countdown-unit">days</span></div>
                  <div class="bks-countdown-block"><span class="bks-countdown-num bks-countdown-h">--</span><span class="bks-countdown-unit">hrs</span></div>
                  <div class="bks-countdown-block"><span class="bks-countdown-num bks-countdown-m">--</span><span class="bks-countdown-unit">min</span></div>
                  <div class="bks-countdown-block"><span class="bks-countdown-num bks-countdown-s">--</span><span class="bks-countdown-unit">sec</span></div>
                </div>
              {%- endif -%}
              <p class="bks-early-access-teaser-label" style="margin-top:16px;">We'll notify you by email at launch.</p>
            {%- endif -%}
          </div>
          {%- if section.settings.drop_image -%}
            <img class="bks-early-access-image" src="{{ section.settings.drop_image | image_url: width: 400 }}" alt="{{ drop_title }}" loading="lazy">
          {%- endif -%}
        </div>
      {%- else -%}
        <div class="bks-empty-state"><p>No upcoming drop announced yet.<br>Check back soon.</p></div>
      {%- endif -%}

    {%- else -%}
      <div class="bks-upgrade-card">
        <div class="bks-upgrade-icon">→</div>
        <h3 class="bks-upgrade-title">Early Access is for members</h3>
        <p class="bks-upgrade-text">Place your first order to become an Iron Member and get early access to upcoming drops.</p>
        <span class="bks-upgrade-badge"><span class="bks-tier-dot"></span>⬡ Iron Member — 1+ orders</span>
      </div>
    {%- endif -%}
  </div>

  {%- comment -%} ══════════════════════════════════════════
      TAB: Referral
  ══════════════════════════════════════════ {%- endcomment -%}
  <div id="bks-panel-referral" class="bks-member-panel">
    <p class="bks-section-title">Referral program</p>

    {%- if bks_metal_rank >= 1 -%}
      <div class="bks-referral-card">
        <h2 class="bks-referral-heading">Refer a friend, both earn</h2>
        <p class="bks-referral-sub">
          Every person who orders via your link gets <strong style="color:var(--bks-text);">€10 off</strong> their first order.<br>
          You get <strong style="color:var(--bks-gold);">€10 store credit</strong>.
        </p>
        <div class="bks-referral-link-row">
          <input id="bks-referral-url" class="bks-referral-input" type="text" readonly value="{{ bks_ref_url }}">
          <button id="bks-referral-copy" class="bks-referral-copy-btn">Copy link</button>
        </div>
        <div class="bks-referral-stats">
          <div><span class="bks-referral-stat-val">—</span><span class="bks-referral-stat-label">Invites sent</span></div>
          <div><span class="bks-referral-stat-val">—</span><span class="bks-referral-stat-label">Completed orders</span></div>
          <div><span class="bks-referral-stat-val">€0</span><span class="bks-referral-stat-label">Credits earned</span></div>
        </div>
        <div class="bks-referral-how">
          <p class="bks-referral-how-title">How it works</p>
          <ol>
            <li>Copy your personal link and share it</li>
            <li>Your friend arrives on bakabo.club with €10 off automatically</li>
            <li>After their first order you receive €10 store credit by email</li>
          </ol>
        </div>
      </div>
    {%- else -%}
      <div class="bks-upgrade-card">
        <div class="bks-upgrade-icon">◌</div>
        <h3 class="bks-upgrade-title">Referral for members only</h3>
        <p class="bks-upgrade-text">Place your first order to unlock your personal referral link.</p>
        <span class="bks-upgrade-badge"><span class="bks-tier-dot"></span>⬡ Iron Member — 1+ orders</span>
      </div>
    {%- endif -%}
  </div>

  {%- comment -%} ══════════════════════════════════════════
      TAB: Customize
  ══════════════════════════════════════════ {%- endcomment -%}
  <div id="bks-panel-customize" class="bks-member-panel">
    <p class="bks-section-title">Garment customization</p>

    <div class="bks-cz-tier-banner bks-cz-tier-banner--{{ bks_metal_tier }}">
      <span class="bks-cz-tier-icon">{{ bks_metal_symbol }}</span>
      <div>
        <p class="bks-cz-tier-name">
          {%- if bks_metal_rank >= 4 -%}Gold — Full customization
          {%- elsif bks_metal_rank >= 3 -%}Silver — Full customization
          {%- elsif bks_metal_rank >= 2 -%}Brass — Advanced customization
          {%- elsif bks_metal_rank >= 1 -%}Iron — Base customization
          {%- else -%}Lead — Open request
          {%- endif -%}
        </p>
        <p class="bks-cz-tier-desc">
          {%- if bks_metal_rank >= 3 -%}All options unlocked: palette, text, graphic placement, custom sizing and full compositions.
          {%- elsif bks_metal_rank >= 2 -%}Palette, text, graphic placement and non-standard sizing available.
          {%- elsif bks_metal_rank >= 1 -%}Palette variation and text / monogram requests available.
          {%- else -%}Send a customization request. Place your first order for faster turnaround.
          {%- endif -%}
        </p>
      </div>
    </div>

    <div id="bks-cz-history"></div>

    <div class="bks-cz-form-wrap">
      <p class="bks-cz-form-title">New request</p>

      <form id="bks-cz-form"
            data-tier="{{ bks_metal_tier }}"
            data-tier-rank="{{ bks_metal_rank }}"
            data-customer-name="{{ customer.name | escape }}"
            data-customer-email="{{ customer.email | escape }}">

        <div class="bks-cz-row">
          <div class="bks-cz-field">
            <label class="bks-cz-label" for="bks-cz-collection">Collection</label>
            <select id="bks-cz-collection" class="bks-cz-select" required>
              <option value="">— Select —</option>
              <option value="BKS Origin">Origin</option>
              <option value="BKS Glyph">Glyph</option>
              <option value="BKS Marker">Marker</option>
              <option value="BKS Riviera">Riviera</option>
              <option value="BKS Pulse">Pulse</option>
              <option value="BKS Token">Token</option>
              <option value="BKS Flag">Flag</option>
              <option value="BKS Hours">Hours</option>
              <option value="Other / Not sure">Other / Not sure</option>
            </select>
          </div>
          <div class="bks-cz-field">
            <label class="bks-cz-label" for="bks-cz-product">Garment type</label>
            <select id="bks-cz-product" class="bks-cz-select" required>
              <option value="">— Select —</option>
              <option value="Pullover Hoodie">Pullover Hoodie</option>
              <option value="Puffer Jacket">Puffer Jacket</option>
              <option value="Windbreaker">Windbreaker</option>
              <option value="T-Shirt">T-Shirt</option>
              <option value="Lounge Pants">Lounge Pants</option>
              <option value="Athletic Shorts">Athletic Shorts</option>
              <option value="Swim Trunks">Swim Trunks</option>
              <option value="One-Piece Swimsuit">One-Piece Swimsuit</option>
              <option value="Racerback Dress">Racerback Dress</option>
              <option value="Sneakers">Sneakers</option>
              <option value="Backpack">Backpack</option>
              <option value="Travel Bag">Travel Bag</option>
              <option value="Flip Flop">Flip Flop</option>
              <option value="Other">Other</option>
            </select>
          </div>
          <div class="bks-cz-field">
            <label class="bks-cz-label" for="bks-cz-size">Size</label>
            <select id="bks-cz-size" class="bks-cz-select">
              <option value="XS">XS</option>
              <option value="S">S</option>
              <option value="M" selected>M</option>
              <option value="L">L</option>
              <option value="XL">XL</option>
              <option value="XXL">XXL</option>
              <option value="Custom">Custom</option>
            </select>
          </div>
        </div>

        <div class="bks-cz-field" style="margin-top:24px;">
          <label class="bks-cz-label">Customization type <span class="bks-cz-req">*</span></label>
          <div class="bks-cz-type-grid">

            <label class="bks-cz-type-card">
              <input type="radio" name="bks-cz-type" value="palette" required>
              <span class="bks-cz-type-icon">◐</span>
              <span class="bks-cz-type-name">Color palette</span>
              <span class="bks-cz-type-desc">Tonal variation of the pattern</span>
            </label>

            <label class="bks-cz-type-card">
              <input type="radio" name="bks-cz-type" value="text">
              <span class="bks-cz-type-icon">◁</span>
              <span class="bks-cz-type-name">Text / Monogram</span>
              <span class="bks-cz-type-desc">Add initials or custom text</span>
            </label>

