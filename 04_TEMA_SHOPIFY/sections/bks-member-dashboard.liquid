          <p class="bks-cz-note">Reply within 2–3 business days to <strong>{{ customer.email }}</strong></p>
        </div>

      </form>

      <div id="bks-cz-success" class="bks-cz-success" hidden>
        <div class="bks-cz-success-icon">✓</div>
        <h3>Request sent</h3>
        <p>We'll get back to you within 2–3 business days at <strong>{{ customer.email }}</strong>.</p>
        <button class="bks-btn-ghost" id="bks-cz-new">New request</button>
      </div>
    </div>
  </div>

