          <div class="bks-preview__status"><div data-bks-status>Choose a garment from your wishlist.</div></div>
        </div>
      </div>

    </section>

    <style>
      .bks-photo-guide { background:#f5f0e8;border:1px solid rgba(10,10,10,0.08);padding:clamp(20px,3vw,32px);margin-bottom:28px; }
      .bks-photo-guide__grid { display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:16px;margin-bottom:24px; }
      .bks-photo-guide__rule { display:flex;flex-direction:column;gap:4px;padding:14px;background:#fafaf7;border-left:2px solid #c9b79c; }
      .bks-photo-guide__icon { font-size:1.1rem;color:#c9b79c;line-height:1;margin-bottom:4px; }
      .bks-photo-guide__rule strong { font-family:var(--bks-font-mono,'DM Mono',monospace);font-size:0.72rem;letter-spacing:0.1em;text-transform:uppercase;color:#0a0a0a; }
      .bks-photo-guide__rule span { font-size:0.8rem;color:#5a5a5a;line-height:1.5; }
      .bks-photo-guide__example { display:flex;align-items:center;gap:20px;padding-top:16px;border-top:1px solid rgba(10,10,10,0.08); }
      .bks-photo-guide__example svg { width:80px;flex-shrink:0; }
      .bks-photo-guide__caption { font-family:var(--bks-font-mono,'DM Mono',monospace);font-size:0.72rem;color:#5a5a5a;letter-spacing:0.06em;line-height:1.6; }
      .bks-camerino__upload-zone { margin-bottom:24px; }
      .bks-upload-label { display:flex;flex-direction:column;align-items:center;justify-content:center;gap:8px;padding:40px 24px;border:2px dashed rgba(10,10,10,0.2);cursor:pointer;text-align:center;transition:border-color 0.2s,background 0.2s;background:#fafaf7; }
      .bks-upload-label:hover { border-color:#0a0a0a;background:#f0ebe0; }
      .bks-upload-label__icon { font-size:2rem;color:#c9b79c;line-height:1; }
      .bks-upload-label strong { font-family:var(--bks-font-mono,'DM Mono',monospace);font-size:0.85rem;letter-spacing:0.1em;text-transform:uppercase;color:#0a0a0a; }
      .bks-upload-label span { font-size:0.72rem;color:#9a9a9a;font-family:var(--bks-font-mono,'DM Mono',monospace);letter-spacing:0.06em; }
      .bks-upload-preview { position:relative;max-width:280px;margin:0 auto; }
      .bks-upload-preview img { width:100%;display:block;border:1px solid rgba(10,10,10,0.12); }
      .bks-upload-remove { position:absolute;top:8px;right:8px;background:rgba(10,10,10,0.75);color:#fafaf7;border:none;width:28px;height:28px;cursor:pointer;font-size:0.8rem;display:flex;align-items:center;justify-content:center; }
      .bks-privacy-notice { display:flex;gap:12px;align-items:flex-start;background:#f0ebe0;border-left:3px solid #c9b79c;padding:14px 16px;margin-bottom:20px;font-size:0.8rem;line-height:1.55;color:#3d3d3d; }
      .bks-privacy-notice__icon { font-size:1rem;flex-shrink:0;margin-top:1px; }
      .bks-privacy-notice strong { color:#0a0a0a; }
      .bks-consent-row { display:flex;gap:10px;align-items:flex-start;font-size:0.75rem;color:#5a5a5a;line-height:1.5;margin-bottom:12px;cursor:pointer; }
      .bks-consent-row input { flex-shrink:0;margin-top:2px; }
      .bks-photo-error { display:none;background:#fef0ee;border-left:3px solid #c04418;padding:10px 14px;font-size:0.78rem;color:#c04418;margin-top:8px;font-family:var(--bks-font-mono,'DM Mono',monospace); }
      .bks-photo-ok { display:none;background:#eef8ee;border-left:3px solid #489808;padding:10px 14px;font-size:0.78rem;color:#2d6006;margin-top:8px;font-family:var(--bks-font-mono,'DM Mono',monospace); }
    </style>

    <script>
    (function() {
      var MAX_BYTES=12*1024*1024, MIN_W=600, MIN_H=900;
      var ALLOWED=['image/jpeg','image/png','image/webp','image/heic','image/heif'];
      var input=document.getElementById('bks-photo-input');
      var labelEl=document.getElementById('bks-upload-label');
      var previewBox=document.getElementById('bks-upload-preview');
      var img=document.getElementById('bks-uploaded-img');
      var removeBtn=document.getElementById('bks-upload-remove');
      var grid=document.getElementById('bks-camerino-grid');
      var errBox=document.getElementById('bks-photo-feedback');
      var okBox=document.getElementById('bks-photo-ok');
      var consentChk=document.getElementById('bks-consent-check');
      var crewBtn=document.getElementById('bks-crew-btn');
      if (!input) return;
      function showErr(m){errBox.textContent='✗ '+m;errBox.style.display='block';okBox.style.display='none';}
      function showOk(m){okBox.textContent='✓ '+m;okBox.style.display='block';errBox.style.display='none';}
      function clearFeedback(){errBox.style.display=okBox.style.display='none';}
      function validateAndLoad(file){
        clearFeedback();
        if(ALLOWED.indexOf(file.type)===-1&&!file.name.match(/\.(heic|heif)$/i)){showErr('Unsupported format. Use JPG, PNG or WEBP.');return;}
        if(file.size>MAX_BYTES){showErr('File too large ('+(file.size/1024/1024).toFixed(1)+' MB). Maximum 12 MB.');return;}
        var url=URL.createObjectURL(file);
        var tmp=new Image();
        tmp.onload=function(){
          var w=tmp.naturalWidth,h=tmp.naturalHeight;
          URL.revokeObjectURL(url);
          if(w<MIN_W||h<MIN_H){showErr('Photo too small ('+w+'×'+h+'px). Minimum 600×900 px — full body portrait.');return;}
          if(w>h){showErr('Horizontal photo. Rotate your phone and shoot in portrait (vertical) mode.');return;}
          var displayUrl=URL.createObjectURL(file);
          img.src=displayUrl;
          labelEl.style.display='none';previewBox.style.display='block';grid.style.display='grid';
          showOk('Photo valid ('+w+'×'+h+'px). Choose a garment from your wishlist.');
          document.querySelectorAll('.bks-camerino__step').forEach(function(s,i){s.classList.toggle('is-active',i===1);});
        };
        tmp.onerror=function(){showErr('Cannot read file. Try a different format.');};
        tmp.src=url;
      }
      input.addEventListener('change',function(){if(input.files[0])validateAndLoad(input.files[0]);});
      removeBtn.addEventListener('click',function(){
        input.value='';img.src='';previewBox.style.display='none';labelEl.style.display='flex';grid.style.display='none';
        clearFeedback();if(consentChk)consentChk.checked=false;if(crewBtn)crewBtn.disabled=true;
        document.querySelectorAll('.bks-camerino__step').forEach(function(s,i){s.classList.toggle('is-active',i===0);});
      });
      if(consentChk&&crewBtn){consentChk.addEventListener('change',function(){crewBtn.disabled=!consentChk.checked;});}
      var zone=document.getElementById('bks-upload-zone');
      zone.addEventListener('dragover',function(e){e.preventDefault();labelEl.style.borderColor='#0a0a0a';});
      zone.addEventListener('dragleave',function(){labelEl.style.borderColor='';});
      zone.addEventListener('drop',function(e){
        e.preventDefault();labelEl.style.borderColor='';
        var f=e.dataTransfer.files[0];
        if(f&&f.type.startsWith('image/')){
          try{var dt=new DataTransfer();dt.items.add(f);input.files=dt.files;}catch(x){}
          validateAndLoad(f);
        }
      });
    })();
    </script>

  </div>

