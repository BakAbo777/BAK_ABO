    var submitBtn  = document.getElementById('bks-verse-submit');
    var successBox = document.getElementById('bks-verse-success');
    var errorBox   = document.getElementById('bks-verse-error');
    var newBtn     = document.getElementById('bks-verse-new');
    var langBtns   = document.querySelectorAll('.bks-verse-lang-btn');
    var activeLang = 'it';

    langBtns.forEach(function (btn) {
      btn.addEventListener('click', function () {
        activeLang = btn.dataset.lang;
        langBtns.forEach(function (b) { b.classList.toggle('is-active', b === btn); });
      });
    });

    textarea.addEventListener('input', function () {
      var len = textarea.value.length;
      countEl.textContent = len;
      var pct = Math.min((len / 280) * 100, 100);
      fillEl.style.width = pct + '%';
      fillEl.classList.toggle('is-ready', len >= 80 && len <= 280);
      fillEl.classList.toggle('is-over',  len > 280);
      submitBtn.disabled = len < 80 || len > 280;
    });
    submitBtn.disabled = true;

    form.addEventListener('submit', function (e) {
      e.preventDefault();
      errorBox.hidden = true;

      var payload = {
        member_email:    form.dataset.customerEmail,
        member_id:       form.dataset.customerId,
        collection_slug: document.getElementById('bks-verse-collection').value || null,
        poem_text:       textarea.value.trim(),
        poem_lang:       activeLang
      };

      submitBtn.disabled = true;
      submitBtn.textContent = 'Sending...';

      fetch('https://verse.bakabo.club/verse/submit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      })
      .then(function (r) {
        if (!r.ok) return r.json().then(function (d) { throw new Error(d.detail || d.message || 'Error ' + r.status); });
        return r.json();
      })
      .then(function (data) {
        form.hidden = true;
        successBox.hidden = false;
        var msg = document.getElementById('bks-verse-success-msg');
        if (msg) {
          var id = data.id ? ' #' + data.id : '';
          msg.innerHTML = 'Verse' + id + ' received. The Gran Giudice will evaluate it. '
            + 'You\'ll receive the result at <strong>' + form.dataset.customerEmail + '</strong>.';
        }
      })
      .catch(function (err) {
        errorBox.hidden = false;
        errorBox.textContent = '✗ ' + (err.message || 'Submission failed. Try again.');
        submitBtn.disabled = false;
        submitBtn.textContent = 'Submit verse';
      });
    });

    if (newBtn) {
      newBtn.addEventListener('click', function () {
        form.reset();
        textarea.dispatchEvent(new Event('input'));
        form.hidden = false;
        successBox.hidden = true;
        errorBox.hidden = true;
      });
    }
  })();
  </script>

  {%- comment -%} ══════════════════════════════════════════
      TAB: Creations — BAK ABO Member Creations
  ══════════════════════════════════════════ {%- endcomment -%}
  <div id="bks-panel-creations" class="bks-member-panel">
    <p class="bks-section-title">BAK ABO Originals &amp; Member Creations</p>

    {%- comment -%} Collect approved creation tags (bks_creation_*) {%- endcomment -%}
    {%- assign _creation_tags = "" -%}
    {%- for tag in customer.tags -%}
      {%- if tag contains "bks_creation_" -%}
        {%- assign _creation_tags = _creation_tags | append: tag | append: "|" -%}
      {%- endif -%}
    {%- endfor -%}
    {%- assign _creation_list = _creation_tags | split: "|" | compact -%}

    <div class="bks-creation-origin">
      <p class="bks-creation-origin__eyebrow">BKS Origins</p>
      <p class="bks-creation-origin__text">
        BKS Studio grew from a longer arc — traditional art on paper and canvas, NFTs, AI artworks,
        then AOP textile production. Every pattern carries the DNA of 15,000&plus; digital works created by Roberto Picchioni.
        The 8 editorial collections are the distilled output of that transition.<br>
        <a href="/pages/about-bakabo-1" class="bks-creation-origin__link">Full story &rarr;</a>
      </p>
    </div>

    <div class="bks-creation-gate-info">
      <div class="bks-creation-gate-info__icon">◈</div>
      <div>
        <p class="bks-creation-gate-title">How Member Creations work</p>
        <ol class="bks-creation-gate-list">
          <li>Submit your artwork or AOP pattern to <a href="mailto:crew@bakabo.club?subject=Member%20Creation%20Submission">crew@bakabo.club</a></li>
          <li>The BKS AI quality gate evaluates it on 5 axes (score 0–25)</li>
          <li>Score &ge;21/25: your design enters the BKS catalog as a Member Creation</li>
          <li>You receive tier credit: <strong>Iron &rarr; Brass</strong> on first approved creation</li>
          <li>Your name appears on the product page as creator</li>
        </ol>
      </div>
    </div>

    {%- if _creation_list.size > 0 -%}
      <p class="bks-section-title" style="margin-top:36px;">Your approved creations</p>
      <div class="bks-creation-grid">
        {%- for ctag in _creation_list -%}
          {%- assign _slug = ctag | remove: "bks_creation_" | replace: "_", " " | capitalize -%}
          <div class="bks-creation-card">
            <div class="bks-creation-card__badge">◈ Approved</div>
            <p class="bks-creation-card__title">{{ _slug }}</p>
            <a href="/collections/all?q={{ _slug | url_encode }}" class="bks-creation-card__link">View in catalog &rarr;</a>
          </div>
        {%- endfor -%}
      </div>
    {%- else -%}
      <div class="bks-creation-empty">
        <p class="bks-creation-empty__label">No approved creations yet.</p>
        {%- if bks_metal_rank >= 1 -%}
          <a href="mailto:crew@bakabo.club?subject=Member%20Creation%20Submission&body=Hi%20BKS%20crew%2C%0A%0AI%20would%20like%20to%20submit%20an%20artwork%20for%20the%20Member%20Creations%20gate.%0A%0AMember%3A%20{{ customer.email | url_encode }}%0ATier%3A%20{{ bks_metal_label | url_encode }}"
             class="bks-btn-gold" style="margin-top:20px;">Submit your artwork &rarr;</a>
        {%- else -%}
          <div class="bks-upgrade-card" style="margin-top:20px;">
            <div class="bks-upgrade-icon">→</div>
            <h3 class="bks-upgrade-title">Submissions open at Iron</h3>
            <p class="bks-upgrade-text">Place your first order to unlock artwork submission for the BAK ABO quality gate.</p>
            <span class="bks-upgrade-badge"><span class="bks-tier-dot"></span>⬡ Iron Member — 1+ orders</span>
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="bks-creation-tier-credits">
      <p class="bks-creation-tier-credits__title">Tier credits for Member Creations</p>
      <div class="bks-creation-tier-table">
        <div class="bks-creation-tier-row{% if bks_metal_rank >= 4 %} bks-creation-tier-row--active{% endif %}">
          <span style="color:#d4a030;">✦ Gold</span><span>Founding creator — 4+ approved</span>
        </div>
        <div class="bks-creation-tier-row{% if bks_metal_rank >= 3 %} bks-creation-tier-row--active{% endif %}">
          <span style="color:#b0b0c8;">◇ Silver</span><span>2+ approved creations</span>
        </div>
        <div class="bks-creation-tier-row{% if bks_metal_rank >= 2 %} bks-creation-tier-row--active{% endif %}">
          <span style="color:#c8a96e;">◈ Brass</span><span>First approved creation</span>
        </div>
        <div class="bks-creation-tier-row{% if bks_metal_rank >= 1 %} bks-creation-tier-row--active{% endif %}">
          <span style="color:#8a8a8a;">⬡ Iron</span><span>Submission unlocked</span>
        </div>
      </div>
    </div>

