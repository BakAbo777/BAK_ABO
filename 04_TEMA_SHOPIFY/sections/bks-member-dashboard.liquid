            <div class="bks-cv3-status" id="bks-cv3-status" style="display:none">
              <span data-bks-status>—</span>
              <button class="bks-cv3-btn-download" data-bks-tryon-download>↓ Save</button>
            </div>
          </div>
          <div class="bks-cv3-actions" id="bks-cv3-actions">
            <label class="bks-cv3-consent">
              <input type="checkbox" id="bks-consent-check">
              <span>I consent to sending my photo to the BKS crew for manual try-on processing (GDPR art. 6.1.a)</span>
            </label>
