    <script>
    (function() {
      var MAX_BYTES=12*1024*1024, MIN_W=600, MIN_H=900;
      var ALLOWED=['image/jpeg','image/png','image/webp','image/heic','image/heif'];
      var input=document.getElementById('bks-photo-input');
      var uploadWrap=document.getElementById('bks-upload-zone');
      var labelEl=document.getElementById('bks-upload-label');
      var img=document.getElementById('bks-uploaded-img');
      var photoImg=document.getElementById('bks-cv3-photo-img');
      var changeBtn=document.getElementById('bks-cv3-change-btn');
      var grid=document.getElementById('bks-camerino-grid');
      var errBox=document.getElementById('bks-photo-feedback');
      var okBox=document.getElementById('bks-photo-ok');
      var consentChk=document.getElementById('bks-consent-check');
      var crewBtn=document.getElementById('bks-crew-btn');
      var uploadZoneInner=uploadWrap?uploadWrap.querySelector('.bks-cv3-upload-zone'):null;
      var guideToggle=document.getElementById('bks-guide-toggle');
      var guideBody=document.getElementById('bks-guide-body');
      if(!input)return;

      if(guideToggle&&guideBody){
        guideToggle.addEventListener('click',function(){
          var open=guideBody.classList.toggle('is-open');
          guideToggle.classList.toggle('is-open',open);
        });
      }

      function showErr(m){errBox.textContent='✗ '+m;errBox.style.display='block';okBox.style.display='none';}
      function showOk(m){okBox.textContent='✓ '+m;okBox.style.display='block';errBox.style.display='none';}
      function clearFeedback(){errBox.style.display=okBox.style.display='none';}

      function setStep(n){
        document.querySelectorAll('[data-bks-step]').forEach(function(s){
          var i=parseInt(s.getAttribute('data-bks-step'),10);
          s.classList.toggle('is-active',i===n);
          s.classList.toggle('is-done',i<n);
        });
      }

      function validateAndLoad(file){
        clearFeedback();
        if(ALLOWED.indexOf(file.type)===-1&&!file.name.match(/\.(heic|heif)$/i)){showErr('Unsupported format. Use JPG, PNG or WEBP.');return;}
        if(file.size>MAX_BYTES){showErr('File too large ('+(file.size/1024/1024).toFixed(1)+' MB). Maximum 12 MB.');return;}
        var url=URL.createObjectURL(file);
        var tmp=new Image();
        tmp.onload=function(){
          var w=tmp.naturalWidth,h=tmp.naturalHeight;
          URL.revokeObjectURL(url);
          if(w<MIN_W||h<MIN_H){showErr('Photo too small ('+w+'\xd7'+h+'px). Minimum 600\xd7900 px — full body portrait.');return;}
          if(w>h){showErr('Horizontal photo. Rotate to portrait (vertical) mode.');return;}
          var displayUrl=URL.createObjectURL(file);
          if(img)img.src=displayUrl;
          if(photoImg)photoImg.src=displayUrl;
          uploadWrap.style.display='none';
          grid.classList.add('is-visible');
          showOk('Photo loaded ('+w+'\xd7'+h+'px). Now choose a garment from your wishlist.');
          setStep(1);
        };
        tmp.onerror=function(){showErr('Cannot read file. Try a different format.');};
        tmp.src=url;
      }

      input.addEventListener('change',function(){if(input.files[0])validateAndLoad(input.files[0]);});

      if(changeBtn){
        changeBtn.addEventListener('click',function(){
          input.value='';
          if(img){img.src='';}
          if(photoImg){photoImg.src='';}
          uploadWrap.style.display='';
          grid.classList.remove('is-visible');
          clearFeedback();
          if(consentChk)consentChk.checked=false;
          if(crewBtn)crewBtn.disabled=true;
          setStep(0);
        });
      }

      if(consentChk&&crewBtn){consentChk.addEventListener('change',function(){crewBtn.disabled=!consentChk.checked;});}

      if(uploadZoneInner){
        uploadZoneInner.addEventListener('dragover',function(e){e.preventDefault();uploadZoneInner.classList.add('is-drag');});
        uploadZoneInner.addEventListener('dragleave',function(){uploadZoneInner.classList.remove('is-drag');});
        uploadZoneInner.addEventListener('drop',function(e){
          e.preventDefault();uploadZoneInner.classList.remove('is-drag');
          var f=e.dataTransfer.files[0];
          if(f&&f.type.startsWith('image/')){
            try{var dt=new DataTransfer();dt.items.add(f);input.files=dt.files;}catch(x){}
            validateAndLoad(f);
          }
        });
      }
    })();
    </script>

  </div>

