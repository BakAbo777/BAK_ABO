            <circle cx="60" cy="32" r="14" stroke="#0a0a0a" stroke-width="1.5"/>
            <line x1="60" y1="46" x2="60" y2="120" stroke="#0a0a0a" stroke-width="1.5"/>
            <line x1="60" y1="68" x2="34" y2="96" stroke="#0a0a0a" stroke-width="1.5"/>
            <line x1="60" y1="68" x2="86" y2="96" stroke="#0a0a0a" stroke-width="1.5"/>
            <line x1="60" y1="120" x2="42" y2="172" stroke="#0a0a0a" stroke-width="1.5"/>
            <line x1="60" y1="120" x2="78" y2="172" stroke="#0a0a0a" stroke-width="1.5"/>
            <line x1="14" y1="18" x2="14" y2="182" stroke="#c9b79c" stroke-width="1"/>
            <line x1="10" y1="18" x2="18" y2="18" stroke="#c9b79c" stroke-width="1"/>
            <line x1="10" y1="182" x2="18" y2="182" stroke="#c9b79c" stroke-width="1"/>
