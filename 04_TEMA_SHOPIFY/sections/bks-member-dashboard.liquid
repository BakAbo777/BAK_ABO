            <label class="bks-cz-type-card{%- if bks_metal_rank < 3 %} bks-cz-type-locked{%- endif -%}">
              <input type="radio" name="bks-cz-type" value="full"{% if bks_metal_rank < 3 %} disabled{% endif %}>
