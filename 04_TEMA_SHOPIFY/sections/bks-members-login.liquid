{% comment %}
  BKS Members — Landing page per area riservata.
  Mostra dashboard se loggato, schermata di accesso branded se non loggato.
{% endcomment %}

<style>
  .bks-mlogin {
    --ink: #0a0a0a;
    --paper: #fafaf7;
    --warm: #efeae0;
    --accent: #c9b79c;
    --muted: #6f6a60;
    --line: #dedad4;
    min-height: 100vh;
    background: var(--paper);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: clamp(40px, 8vh, 100px) 20px;
    font-family: var(--bks-font-text, "DM Sans", "Segoe UI", sans-serif);
  }
  .bks-mlogin__wrap {
    width: 100%;
    max-width: 440px;
    display: grid;
    gap: 0;
  }
  .bks-mlogin__top {
    text-align: center;
    margin-bottom: 40px;
  }
  .bks-mlogin__logo {
    display: inline-block;
    margin-bottom: 20px;
  }
  .bks-mlogin__logo img {
    height: 44px;
    width: auto;
  }
  .bks-mlogin__eyebrow {
    font-family: var(--bks-font-mono, "DM Mono", monospace);
    font-size: 0.68rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted);
    margin: 0 0 10px;
  }
  .bks-mlogin__title {
    font-family: var(--bks-font-display, "Bebas Neue", sans-serif);
    font-size: clamp(2rem, 6vw, 3rem);
    font-weight: 400;
    letter-spacing: 0.04em;
    line-height: 1;
    color: var(--ink);
    margin: 0 0 10px;
  }
  .bks-mlogin__sub {
    font-size: 0.88rem;
    color: var(--muted);
    margin: 0;
    line-height: 1.5;
  }
  .bks-mlogin__card {
    background: var(--paper);
    border: 1px solid var(--line);
    padding: 36px 32px 32px;
    display: grid;
    gap: 12px;
  }
  .bks-mlogin__divider {
    display: flex;
    align-items: center;
    gap: 12px;
    color: var(--muted);
    font-size: 0.78rem;
    font-family: var(--bks-font-mono, monospace);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .bks-mlogin__divider::before,
  .bks-mlogin__divider::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--line);
  }
  .bks-mlogin__btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    width: 100%;
    padding: 16px 20px;
    font-family: var(--bks-font-mono, monospace);
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    text-decoration: none;
    cursor: pointer;
    border: 1px solid var(--ink);
    transition: background 0.2s, color 0.2s;
  }
  .bks-mlogin__btn--primary {
    background: var(--ink);
    color: var(--paper);
  }
  .bks-mlogin__btn--primary:hover {
    background: #2a2a2a;
  }
  .bks-mlogin__btn--ghost {
    background: transparent;
    color: var(--ink);
    border-color: var(--line);
  }
  .bks-mlogin__btn--ghost:hover {
    background: var(--warm);
    border-color: var(--ink);
  }
  .bks-mlogin__btn--accent {
    background: var(--accent);
    color: var(--ink);
    border-color: var(--accent);
  }
  .bks-mlogin__btn--accent:hover {
    background: #b8a48a;
    border-color: #b8a48a;
  }
  .bks-mlogin__note {
    text-align: center;
    font-size: 0.78rem;
    color: var(--muted);
    margin: 4px 0 0;
    line-height: 1.5;
  }
  .bks-mlogin__note a {
    color: var(--ink);
    text-decoration: underline;
  }
  /* Benefits strip */
  .bks-mlogin__benefits {
    margin-top: 32px;
    border-top: 1px solid var(--line);
    padding-top: 24px;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }
  .bks-mlogin__benefit {
    text-align: center;
  }
  .bks-mlogin__benefit-icon {
    font-size: 1.2rem;
    margin-bottom: 6px;
    display: block;
    color: var(--accent);
  }
  .bks-mlogin__benefit-label {
    font-family: var(--bks-font-mono, monospace);
    font-size: 0.62rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
    line-height: 1.4;
  }
  @media (max-width: 480px) {
    .bks-mlogin__card { padding: 28px 20px 24px; }
    .bks-mlogin__benefits { grid-template-columns: 1fr; gap: 12px; }
    .bks-mlogin__benefit { display: flex; align-items: center; gap: 12px; text-align: left; }
  }
</style>

<div class="bks-mlogin">
  <div class="bks-mlogin__wrap">

    <div class="bks-mlogin__top">
      <a class="bks-mlogin__logo" href="{{ routes.root_url }}" aria-label="BAKABO home">
        <img src="{{ 'bakabo-logo-official.png' | asset_url }}" alt="BAKABO" width="160" height="44">
      </a>
      <p class="bks-mlogin__eyebrow">Members Area</p>
      <h1 class="bks-mlogin__title">BKS Members</h1>
      <p class="bks-mlogin__sub">Sign in to your personal area to manage orders,<br>wishlist and virtual fitting room.</p>
    </div>

    <div class="bks-mlogin__card">

      {%- if customer -%}
        {%- comment -%} Già loggato: redirect al dashboard {%- endcomment -%}
        <p style="text-align:center;font-size:0.9rem;color:var(--muted);margin:0 0 4px;">
          Welcome, <strong style="color:var(--ink);">{{ customer.first_name | default: customer.email }}</strong>
        </p>
        <a class="bks-mlogin__btn bks-mlogin__btn--primary" href="{{ routes.account_url }}">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="8" r="4"/><path d="M4 22c1.5-4 4.5-6 8-6s6.5 2 8 6"/></svg>
          Go to your profile
        </a>
        <a class="bks-mlogin__btn bks-mlogin__btn--ghost" href="{{ routes.root_url }}collections/all">
          Browse the catalogue
        </a>
        <p class="bks-mlogin__note"><a href="{{ routes.account_logout_url }}">Sign out</a></p>

      {%- else -%}
        {%- comment -%} Non loggato: mostra opzioni accesso {%- endcomment -%}
        <a class="bks-mlogin__btn bks-mlogin__btn--primary" href="{{ routes.account_login_url }}">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="8" r="4"/><path d="M4 22c1.5-4 4.5-6 8-6s6.5 2 8 6"/></svg>
          Sign in to your account
        </a>

        <div class="bks-mlogin__divider">or</div>

        <a class="bks-mlogin__btn bks-mlogin__btn--accent" href="{{ routes.account_register_url }}">
          Create a BKS Members account
        </a>

        <p class="bks-mlogin__note">
          By registering you accept the <a href="{{ routes.root_url }}policies/terms-of-service">Terms of service</a>
          and the <a href="{{ routes.root_url }}policies/privacy-policy">Privacy Policy</a>.
        </p>
      {%- endif -%}

    </div>

    <div class="bks-mlogin__benefits">
      <div class="bks-mlogin__benefit">
        <span class="bks-mlogin__benefit-icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
        </span>
        <span class="bks-mlogin__benefit-label">Personal<br>Wishlist</span>
      </div>
      <div class="bks-mlogin__benefit">
        <span class="bks-mlogin__benefit-icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="1"/><path d="M3 9h18M9 21V9"/></svg>
        </span>
        <span class="bks-mlogin__benefit-label">AI Virtual<br>Fitting Room</span>
      </div>
      <div class="bks-mlogin__benefit">
        <span class="bks-mlogin__benefit-icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </span>
        <span class="bks-mlogin__benefit-label">Early<br>Access</span>
      </div>
    </div>

  </div>
</div>

{% schema %}
{
  "name": "BKS Members Login",
  "settings": [],
  "presets": [
    { "name": "BKS Members Login" }
  ]
}
{% endschema %}
