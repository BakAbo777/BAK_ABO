{% comment %}
  BakAbo / BKS Product Type Guide
  File: sections/bks-product-type-guide.liquid
  Purpose: collection-level hero + size guide + fit + care instructions per product typology.
  Compatible with Dawn / Shopify JSON templates.
{% endcomment %}

{%- liquid
  assign product_key = section.settings.product_type | default: 'puffer_jackets'
  assign accent = section.settings.accent_color | default: '#C9B79C'
  assign title = section.settings.hero_title
  assign kicker = section.settings.hero_kicker
  assign intro = section.settings.hero_text
  assign fit_note = section.settings.fit_note

  if title == blank
    case product_key
      when 'puffer_jackets'
        assign title = 'Puffer Jackets'
      when 'windbreakers'
        assign title = 'Windbreakers'
      when 'pullover_hoodies'
        assign title = 'Pullover Hoodies'
      when 'lounge_pants'
        assign title = 'Lounge Pants'
      when 'sneakers'
        assign title = 'Sneakers'
      when 'backpacks'
        assign title = 'Backpacks'
      when 'travel_bags'
        assign title = 'Travel Bags'
      when 'swimwear'
        assign title = 'Swimwear'
      when 'flip_flops'
        assign title = 'Flip Flops'
      when 'athletic_shorts'
        assign title = 'Athletic Shorts'
      when 'one_piece_swimsuits'
        assign title = 'One-Piece Swimsuits'
      when 'racerback_dresses'
        assign title = 'Racerback Dresses'
      else
        assign title = 'BKS Product Guide'
    endcase
  endif

  if kicker == blank
    assign kicker = 'BKS Product Type Guide'
  endif

  if intro == blank
    case product_key
      when 'puffer_jackets'
        assign intro = 'Insulated outerwear with graphic surface, regular volume and made-to-order production.'
      when 'windbreakers'
        assign intro = 'Light technical shell, built for transitional weather and full-surface BKS graphics.'
      when 'pullover_hoodies'
        assign intro = 'Soft everyday volume, clean shoulder line and printed surface for urban layering.'
      when 'lounge_pants'
        assign intro = 'Relaxed lower-body silhouette designed for resort, studio and travel use.'
      when 'sneakers'
        assign intro = 'Printed footwear with structured profile, rubber sole and BKS graphic language.'
      when 'backpacks'
        assign intro = 'Daily carry format with all-over print surface and practical internal capacity.'
      when 'travel_bags'
        assign intro = 'Large-format travel piece for weekend, gym and short-stay movement.'
      when 'swimwear'
        assign intro = 'Resort swim category with fast-dry surface and BKS graphic identity.'
      when 'flip_flops'
        assign intro = 'Summer footwear for pool, beach and resort contexts, with light EVA structure.'
      when 'athletic_shorts'
        assign intro = 'Active short silhouette with light construction, movement space and graphic print.'
      when 'one_piece_swimsuits'
        assign intro = 'Single-piece resort silhouette with clean coverage and edge-to-edge printed surface.'
      when 'racerback_dresses'
        assign intro = 'Sleeveless dress silhouette with athletic shoulder line and editorial surface print.'
    endcase
  endif

  if fit_note == blank
    case product_key
      when 'puffer_jackets'
        assign fit_note = 'Regular outerwear fit. If you are between sizes, choose the larger size for layering.'
      when 'windbreakers'
        assign fit_note = 'Regular technical fit. Size up if worn over hoodies or heavier layers.'
      when 'pullover_hoodies'
        assign fit_note = 'Relaxed fit. Choose your usual size for an easy silhouette.'
      when 'lounge_pants'
        assign fit_note = 'Relaxed waist and leg. Use waist and hip measurement as primary reference.'
      when 'sneakers'
        assign fit_note = 'Regular footwear fit. If you have a wide foot or sit between sizes, choose the larger EU size.'
      when 'backpacks'
        assign fit_note = 'One size. Capacity and dimensions are the reference measurements.'
      when 'travel_bags'
        assign fit_note = 'One size. Check dimensions against carry-on and travel requirements before purchase.'
      when 'swimwear'
        assign fit_note = 'Close-to-body fit. For a softer fit, choose the larger size when between two sizes.'
      when 'flip_flops'
        assign fit_note = 'Standard summer footwear fit. If between sizes, choose the larger size.'
      when 'athletic_shorts'
        assign fit_note = 'Regular athletic fit. Prioritise waist comfort and movement space.'
      when 'one_piece_swimsuits'
        assign fit_note = 'Close fit. Check bust, waist, hips and torso length together.'
      when 'racerback_dresses'
        assign fit_note = 'Slim-to-regular dress fit. Size up for a softer line through bust and hips.'
    endcase
  endif

  assign hero_media = section.settings.hero_image
  if hero_media == blank and collection.image != blank
    assign hero_media = collection.image
  endif
  if hero_media == blank and collection.products.first.featured_image != blank
    assign hero_media = collection.products.first.featured_image
  endif
-%}

<style>
  #shopify-section-{{ section.id }} .bks-ptg {
    --bks-ptg-accent: {{ accent }};
    background: {{ section.settings.background_color }};
    color: {{ section.settings.text_color }};
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
    border-top: 1px solid rgba(10,10,10,0.08);
    border-bottom: 1px solid rgba(10,10,10,0.08);
  }
  #shopify-section-{{ section.id }} .bks-ptg__wrap {
    max-width: 1240px;
    margin: 0 auto;
    padding: 0 20px;
  }
  #shopify-section-{{ section.id }} .bks-ptg__hero {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(320px, 0.95fr);
    gap: clamp(22px, 4vw, 54px);
    align-items: stretch;
    margin-bottom: clamp(28px, 4vw, 56px);
  }
  #shopify-section-{{ section.id }} .bks-ptg__media {
    min-height: clamp(300px, 40vw, 520px);
    background:
      radial-gradient(circle at 20% 18%, color-mix(in srgb, var(--bks-ptg-accent) 32%, transparent), transparent 34%),
      linear-gradient(135deg, #0A0A0A 0%, #232323 52%, color-mix(in srgb, var(--bks-ptg-accent) 50%, #0A0A0A) 100%);
    overflow: hidden;
    position: relative;
  }
  #shopify-section-{{ section.id }} .bks-ptg__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  #shopify-section-{{ section.id }} .bks-ptg__media::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 46%, rgba(0,0,0,0.34));
    pointer-events: none;
  }
  #shopify-section-{{ section.id }} .bks-ptg__placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: flex-end;
    padding: clamp(24px, 4vw, 42px);
    color: #FAFAF7;
    letter-spacing: -0.04em;
    font-size: clamp(38px, 7vw, 86px);
    font-weight: 700;
    line-height: 0.9;
    text-transform: uppercase;
    opacity: 0.92;
  }
  #shopify-section-{{ section.id }} .bks-ptg__copy {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: clamp(26px, 4vw, 50px);
    background: {{ section.settings.card_bg }};
    border-left: 4px solid var(--bks-ptg-accent);
  }
  #shopify-section-{{ section.id }} .bks-ptg__kicker {
    margin: 0 0 12px;
    font-size: 10px;
    letter-spacing: 0.26em;
    text-transform: uppercase;
    color: var(--bks-ptg-accent);
  }
  #shopify-section-{{ section.id }} .bks-ptg__title {
    margin: 0 0 18px;
    font-size: clamp(34px, 5.8vw, 76px);
    line-height: 0.92;
    letter-spacing: -0.06em;
    text-transform: uppercase;
  }
  #shopify-section-{{ section.id }} .bks-ptg__intro {
    max-width: 58ch;
    margin: 0;
    font-size: clamp(15px, 1.5vw, 18px);
    line-height: 1.55;
    color: {{ section.settings.muted_color }};
  }
  #shopify-section-{{ section.id }} .bks-ptg__chips {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-top: 24px;
  }
  #shopify-section-{{ section.id }} .bks-ptg__chip {
    border: 1px solid color-mix(in srgb, var(--bks-ptg-accent) 52%, #000000 8%);
    color: {{ section.settings.text_color }};
    background: color-mix(in srgb, var(--bks-ptg-accent) 8%, transparent);
    padding: 8px 12px;
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }
  #shopify-section-{{ section.id }} .bks-ptg__grid {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(280px, 0.8fr);
    gap: clamp(18px, 3vw, 38px);
    align-items: start;
  }
  #shopify-section-{{ section.id }} .bks-ptg__panel {
    background: {{ section.settings.card_bg }};
    border: 1px solid rgba(10,10,10,0.09);
    padding: clamp(20px, 3vw, 32px);
  }
  #shopify-section-{{ section.id }} .bks-ptg__label {
    margin: 0 0 16px;
    font-size: 10px;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--bks-ptg-accent);
  }
  #shopify-section-{{ section.id }} .bks-ptg__table-wrap {
    overflow-x: auto;
    border: 1px solid rgba(10,10,10,0.09);
    background: {{ section.settings.background_color }};
  }
  #shopify-section-{{ section.id }} .bks-ptg__table {
    width: 100%;
    min-width: 560px;
    border-collapse: collapse;
    font-size: 13px;
  }
  #shopify-section-{{ section.id }} .bks-ptg__table th,
  #shopify-section-{{ section.id }} .bks-ptg__table td {
    padding: 12px 13px;
    border-bottom: 1px solid rgba(10,10,10,0.08);
    text-align: center;
    white-space: nowrap;
  }
  #shopify-section-{{ section.id }} .bks-ptg__table th:first-child,
  #shopify-section-{{ section.id }} .bks-ptg__table td:first-child {
    text-align: left;
    font-weight: 600;
    color: {{ section.settings.text_color }};
  }
  #shopify-section-{{ section.id }} .bks-ptg__table th {
    font-size: 9px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: {{ section.settings.muted_color }};
    background: color-mix(in srgb, var(--bks-ptg-accent) 10%, {{ section.settings.card_bg }});
  }
  #shopify-section-{{ section.id }} .bks-ptg__table tr:last-child td {
    border-bottom: 0;
  }
  #shopify-section-{{ section.id }} .bks-ptg__fit {
    margin: 16px 0 0;
    padding: 14px 16px;
    border-left: 3px solid var(--bks-ptg-accent);
    background: color-mix(in srgb, var(--bks-ptg-accent) 8%, transparent);
    color: {{ section.settings.muted_color }};
    font-size: 13px;
    line-height: 1.55;
  }
  #shopify-section-{{ section.id }} .bks-ptg__fit strong,
  #shopify-section-{{ section.id }} .bks-ptg__care strong {
    color: {{ section.settings.text_color }};
  }
  #shopify-section-{{ section.id }} .bks-ptg__care {
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 12px;
    font-size: 14px;
    line-height: 1.5;
    color: {{ section.settings.muted_color }};
  }
  #shopify-section-{{ section.id }} .bks-ptg__care li {
    display: grid;
    grid-template-columns: 22px 1fr;
    gap: 10px;
    align-items: start;
  }
  #shopify-section-{{ section.id }} .bks-ptg__care li::before {
    content: '—';
    color: var(--bks-ptg-accent);
    font-weight: 700;
  }
  #shopify-section-{{ section.id }} .bks-ptg__note {
    margin: 18px 0 0;
    font-size: 12px;
    line-height: 1.55;
    color: {{ section.settings.muted_color }};
    opacity: 0.86;
  }
  @media screen and (max-width: 860px) {
    #shopify-section-{{ section.id }} .bks-ptg__hero,
    #shopify-section-{{ section.id }} .bks-ptg__grid {
      grid-template-columns: 1fr;
    }
    #shopify-section-{{ section.id }} .bks-ptg__copy {
      padding: 24px 18px;
    }
    #shopify-section-{{ section.id }} .bks-ptg__media {
      min-height: 320px;
    }
  }
</style>

<section class="bks-ptg" aria-labelledby="BksProductTypeGuideTitle-{{ section.id }}">
  <div class="bks-ptg__wrap">
    <div class="bks-ptg__hero">
      <div class="bks-ptg__media">
        {%- if hero_media != blank -%}
          {{ hero_media | image_url: width: 1800 | image_tag: loading: 'lazy', class: 'bks-ptg__image', alt: title }}
        {%- else -%}
          <div class="bks-ptg__placeholder">{{ title }}</div>
        {%- endif -%}
      </div>
      <div class="bks-ptg__copy">
        <p class="bks-ptg__kicker">{{ kicker }}</p>
        <h2 class="bks-ptg__title" id="BksProductTypeGuideTitle-{{ section.id }}">{{ title }}</h2>
        <p class="bks-ptg__intro">{{ intro }}</p>
        <div class="bks-ptg__chips" aria-label="Product guide highlights">
          <span class="bks-ptg__chip">Size guide</span>
          <span class="bks-ptg__chip">Fit note</span>
          <span class="bks-ptg__chip">Care</span>
          <span class="bks-ptg__chip">Made to order</span>
        </div>
      </div>
    </div>

