{% comment %}
  BKS HOME VIDEO CANVAS — up to 8 avatar videos in sequence, no audio
  Strategic sequence: Hours → Glyph → Marker → Riviera → Pulse → Token → Flag → Origin
  Direct <video> stack + CSS crossfade (GPU) — no canvas, no getImageData
  Grain via CSS SVG filter overlay (zero CPU)
  Next video preloaded during current playback for seamless crossfade
{% endcomment %}

<style>
  #bks-canvas-hero-{{ section.id }} {
    position: relative;
    width: 100%;
    height: {{ section.settings.height | default: 100 }}svh;
    background: #0a0a0a;
    overflow: hidden;
  }

  /* Video stack — all videos positioned absolute, crossfade via opacity */
  #bks-canvas-hero-{{ section.id }} .bks-cvh__vid {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transition: opacity 0.85s ease-in-out;
    pointer-events: none;
  }
  #bks-canvas-hero-{{ section.id }} .bks-cvh__vid.active {
    opacity: 1;
  }

  /* Film grain — CSS SVG noise, animated shift, GPU compositor only */
  #bks-canvas-hero-{{ section.id }}::after {
    content: '';
    position: absolute;
    inset: -10%;
    z-index: 2;
    pointer-events: none;
    opacity: 0.038;
    background-image: url("data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' width='180' height='180'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/><feColorMatrix type='saturate' values='0'/></filter><rect width='180' height='180' filter='url(%23n)'/></svg>");
    background-size: 180px 180px;
    animation: bks-grain {{ section.id }} 0.45s steps(1) infinite;
  }
  @keyframes bks-grain{{ section.id }} {
    0%   { transform: translate(0,0); }
    12%  { transform: translate(-4%,-8%); }
    25%  { transform: translate(-12%,4%); }
    37%  { transform: translate(6%,-20%); }
    50%  { transform: translate(-4%,18%); }
    62%  { transform: translate(-12%,8%); }
    75%  { transform: translate(12%,0); }
    87%  { transform: translate(0,12%); }
  }

  /* Dark vignette */
  #bks-canvas-hero-{{ section.id }} .bks-cvh__overlay {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at center, transparent 25%, rgba(0,0,0,0.6) 100%);
    pointer-events: none;
    z-index: 3;
  }

  /* Copy */
  #bks-canvas-hero-{{ section.id }} .bks-cvh__copy {
    position: absolute;
    inset: 0;
    z-index: 4;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: clamp(32px,5vw,72px);
    color: #fafaf7;
  }
  #bks-canvas-hero-{{ section.id }} .bks-cvh__overline {
    font-family: var(--bks-font-mono,'DM Mono',monospace);
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    opacity: 0.65;
    margin: 0 0 12px;
  }
  #bks-canvas-hero-{{ section.id }} .bks-cvh__headline {
    font-family: var(--bks-font-display,'Bebas Neue',sans-serif);
    font-size: clamp(4rem,10vw,10rem);
    line-height: 0.88;
    margin: 0 0 24px;
    max-width: 14ch;
    color: #fafaf7;
  }
  #bks-canvas-hero-{{ section.id }} .bks-cvh__accent-band {
    display: flex;
    gap: 3px;
    width: clamp(160px,20vw,320px);
    margin-bottom: 28px;
  }
  #bks-canvas-hero-{{ section.id }} .bks-cvh__accent-band span {
    flex: 1; height: 2px; display: block; opacity: 0.85;
  }
  #bks-canvas-hero-{{ section.id }} .bks-cvh__cta {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--bks-font-mono,'DM Mono',monospace);
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #fafaf7;
    text-decoration: none;
    border: 1px solid rgba(250,250,247,0.4);
    padding: 12px 24px;
    width: fit-content;
    transition: background 0.2s, border-color 0.2s;
  }
  #bks-canvas-hero-{{ section.id }} .bks-cvh__cta:hover {
    background: rgba(250,250,247,0.12);
    border-color: rgba(250,250,247,0.7);
  }

  /* Progress dots */
  #bks-canvas-hero-{{ section.id }} .bks-cvh__progress {
    position: absolute;
    bottom: clamp(32px,5vw,72px);
    right: clamp(32px,5vw,72px);
    display: flex;
    gap: 8px;
    z-index: 5;
  }
  #bks-canvas-hero-{{ section.id }} .bks-cvh__dot {
    width: 24px;
    height: 2px;
    background: rgba(250,250,247,0.3);
    transition: background 0.4s;
  }
  #bks-canvas-hero-{{ section.id }} .bks-cvh__dot.active {
    background: rgba(250,250,247,0.9);
  }
</style>

<div id="bks-canvas-hero-{{ section.id }}">

  {%- assign bks_vid_count = 0 -%}
  {%- for i in (1..8) -%}
    {%- assign vid_key = 'video_' | append: i -%}
    {%- assign vid_url = section.settings[vid_key] -%}
    {%- if vid_url != blank -%}
      <video
        class="bks-cvh__vid{% if bks_vid_count == 0 %} active{% endif %}"
        id="bks-vid-{{ section.id }}-{{ bks_vid_count }}"
        src="{{ vid_url }}"
        muted
        playsinline
        preload="{% if bks_vid_count == 0 %}auto{% elsif bks_vid_count == 1 %}metadata{% else %}none{% endif %}"
        data-idx="{{ bks_vid_count }}"
      ></video>
      {%- assign bks_vid_count = bks_vid_count | plus: 1 -%}
    {%- endif -%}
  {%- endfor -%}

  <div class="bks-cvh__overlay"></div>

  <div class="bks-cvh__copy">
    <p class="bks-cvh__overline">BKS Studio — AI-Art Atelier</p>
    <h2 class="bks-cvh__headline">{{ section.settings.headline | default: 'Designed by AI.' }}</h2>
    <div class="bks-cvh__accent-band">
      <span style="background:#c8c4be"></span>
      <span style="background:#489808"></span>
      <span style="background:#d4a030"></span>
      <span style="background:#c04418"></span>
      <span style="background:#0ca898"></span>
      <span style="background:#8888cc"></span>
      <span style="background:#9828d8"></span>
      <span style="background:#c82020"></span>
    </div>
    <a href="{{ section.settings.cta_url | default: '/collections/all' }}" class="bks-cvh__cta">
      {{ section.settings.cta_label | default: 'Shop all collections' }}
      <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
    </a>
  </div>

  <div class="bks-cvh__progress" id="bks-cvh-dots-{{ section.id }}"></div>
</div>

<script>
(function() {
  var SID = {{ section.id | json }};
  var dotsEl = document.getElementById('bks-cvh-dots-' + SID);

  var videos = [];
  for (var i = 0; i < 8; i++) {
    var v = document.getElementById('bks-vid-' + SID + '-' + i);
    if (v && v.getAttribute('src')) videos.push(v);
  }
  if (videos.length === 0) return;

  // Build dots dynamically based on actual video count
  videos.forEach(function(_, idx) {
    var d = document.createElement('div');
    d.className = 'bks-cvh__dot' + (idx === 0 ? ' active' : '');
    d.setAttribute('data-idx', idx);
    dotsEl.appendChild(d);
  });
  var dots = dotsEl.querySelectorAll('.bks-cvh__dot');

  var current = 0;

  function preloadNext(idx) {
    var next = (idx + 1) % videos.length;
    var nv = videos[next];
    if (nv.preload === 'none') {
      nv.preload = 'metadata';
      nv.load();
    }
  }

  function setActive(idx) {
    videos.forEach(function(v) { v.classList.remove('active'); });
    videos[idx].classList.add('active');
    dots.forEach(function(d) { d.classList.remove('active'); });
    if (dots[idx]) dots[idx].classList.add('active');
    preloadNext(idx);
  }

  function advance() {
    var next = (current + 1) % videos.length;
    var nv = videos[next];
    nv.currentTime = 0;
    if (nv.readyState < 2) {
      nv.preload = 'auto';
      nv.load();
    }
    nv.play().then(function() {
      setActive(next);
      current = next;
    }).catch(function(){});
  }

  videos.forEach(function(v) {
    v.addEventListener('ended', advance);
  });

  preloadNext(0);
  videos[0].play().catch(function() {
    document.addEventListener('click', function starter() {
      videos[0].play().catch(function(){});
      document.removeEventListener('click', starter);
    }, { once: true });
  });
})();
</script>

{% schema %}
{
  "name": "BKS Video Canvas Hero",
  "tag": "section",
  "class": "shopify-section",
  "settings": [
    {
      "type": "range",
      "id": "height",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "svh",
      "label": "Section height",
      "default": 95
    },
    {
      "type": "text",
      "id": "headline",
      "label": "Headline",
      "default": "Designed by AI."
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA link",
      "default": "/collections/all"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA label",
      "default": "Shop all collections"
    },
    {
      "type": "header",
      "content": "Avatar videos (up to 8, brand sequence)"
    },
    {
      "type": "url",
      "id": "video_1",
      "label": "Video 1 — BKS Hours (signature)",
      "info": "Upload avatar MP4 to Shopify Files → paste CDN URL here. Sequence follows brand priority."
    },
    {
      "type": "url",
      "id": "video_2",
      "label": "Video 2 — BKS Glyph"
    },
    {
      "type": "url",
      "id": "video_3",
      "label": "Video 3 — BKS Marker"
    },
    {
      "type": "url",
      "id": "video_4",
      "label": "Video 4 — BKS Riviera"
    },
    {
      "type": "url",
      "id": "video_5",
      "label": "Video 5 — BKS Pulse"
    },
    {
      "type": "url",
      "id": "video_6",
      "label": "Video 6 — BKS Token"
    },
    {
      "type": "url",
      "id": "video_7",
      "label": "Video 7 — BKS Flag"
    },
    {
      "type": "url",
      "id": "video_8",
      "label": "Video 8 — BKS Origin"
    }
  ],
  "presets": [
    {
      "name": "BKS Video Canvas Hero"
    }
  ]
}
{% endschema %}
