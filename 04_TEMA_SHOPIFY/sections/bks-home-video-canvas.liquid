{% comment %}
  BKS HOME VIDEO CANVAS — 4 avatar videos in sequence, no audio
  Canvas renders each video frame — grain overlay, crossfade between clips
  Videos are loaded from section settings (Shopify admin → set 4 video URLs)
{% endcomment %}

<style>
  #bks-canvas-hero-{{ section.id }} {
    position: relative;
    width: 100%;
    height: {{ section.settings.height | default: 100 }}svh;
    background: #0a0a0a;
    overflow: hidden;
  }
  #bks-canvas-hero-{{ section.id }} canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
  }
  #bks-canvas-hero-{{ section.id }} .bks-cvh__overlay {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at center, transparent 30%, rgba(0,0,0,0.55) 100%);
    pointer-events: none;
    z-index: 2;
  }
  #bks-canvas-hero-{{ section.id }} .bks-cvh__copy {
    position: absolute;
    inset: 0;
    z-index: 3;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: clamp(32px,5vw,72px);
    color: #fafaf7;
  }
  #bks-canvas-hero-{{ section.id }} .bks-cvh__overline {
    font-family: var(--bks-font-mono,'DM Mono',monospace);
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    opacity: 0.65;
    margin: 0 0 12px;
  }
  #bks-canvas-hero-{{ section.id }} .bks-cvh__headline {
    font-family: var(--bks-font-display,'Bebas Neue',sans-serif);
    font-size: clamp(4rem,10vw,10rem);
    line-height: 0.88;
    margin: 0 0 24px;
    max-width: 14ch;
    color: #fafaf7;
  }
  #bks-canvas-hero-{{ section.id }} .bks-cvh__accent-band {
    display: flex;
    gap: 3px;
    width: clamp(160px,20vw,320px);
    margin-bottom: 28px;
  }
  #bks-canvas-hero-{{ section.id }} .bks-cvh__accent-band span {
    flex: 1; height: 2px; display: block; opacity: 0.85;
  }
  #bks-canvas-hero-{{ section.id }} .bks-cvh__cta {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--bks-font-mono,'DM Mono',monospace);
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #fafaf7;
    text-decoration: none;
    border: 1px solid rgba(250,250,247,0.4);
    padding: 12px 24px;
    width: fit-content;
    transition: background 0.2s, border-color 0.2s;
  }
  #bks-canvas-hero-{{ section.id }} .bks-cvh__cta:hover {
    background: rgba(250,250,247,0.12);
    border-color: rgba(250,250,247,0.7);
  }
  /* Video clip indicator */
  #bks-canvas-hero-{{ section.id }} .bks-cvh__progress {
    position: absolute;
    bottom: clamp(32px,5vw,72px);
    right: clamp(32px,5vw,72px);
    display: flex;
    gap: 8px;
    z-index: 4;
  }
  #bks-canvas-hero-{{ section.id }} .bks-cvh__dot {
    width: 24px;
    height: 2px;
    background: rgba(250,250,247,0.3);
    transition: background 0.4s;
  }
  #bks-canvas-hero-{{ section.id }} .bks-cvh__dot.active {
    background: rgba(250,250,247,0.9);
  }
</style>

{%- comment -%} Hidden video elements — muted, no controls {%- endcomment -%}
{%- for i in (1..4) -%}
  {%- assign vid_key = 'video_' | append: i -%}
  {%- assign vid_url = section.settings[vid_key] -%}
  {%- if vid_url != blank -%}
    <video
      id="bks-vid-{{ section.id }}-{{ forloop.index0 }}"
      src="{{ vid_url }}"
      muted
      playsinline
      preload="{% if forloop.first %}auto{% else %}metadata{% endif %}"
      style="display:none; position:absolute; pointer-events:none;"
      crossorigin="anonymous"
    ></video>
  {%- endif -%}
{%- endfor -%}

<div id="bks-canvas-hero-{{ section.id }}">
  <canvas id="bks-cvh-canvas-{{ section.id }}"></canvas>
  <div class="bks-cvh__overlay"></div>

  <div class="bks-cvh__copy">
    <p class="bks-cvh__overline">BKS Studio — AI-Art Atelier</p>
    <h2 class="bks-cvh__headline">{{ section.settings.headline | default: 'Designed<br>by AI.' }}</h2>
    <div class="bks-cvh__accent-band">
      <span style="background:#c8c4be"></span>
      <span style="background:#489808"></span>
      <span style="background:#d4a030"></span>
      <span style="background:#c04418"></span>
      <span style="background:#0ca898"></span>
      <span style="background:#8888cc"></span>
      <span style="background:#9828d8"></span>
      <span style="background:#c82020"></span>
    </div>
    <a href="{{ section.settings.cta_url | default: '/collections/all' }}" class="bks-cvh__cta">
      {{ section.settings.cta_label | default: 'Shop all collections' }}
      <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
    </a>
  </div>

  <div class="bks-cvh__progress" id="bks-cvh-dots-{{ section.id }}">
    <div class="bks-cvh__dot active" data-idx="0"></div>
    <div class="bks-cvh__dot" data-idx="1"></div>
    <div class="bks-cvh__dot" data-idx="2"></div>
    <div class="bks-cvh__dot" data-idx="3"></div>
  </div>
</div>

<script>
(function() {
  var SID = {{ section.id | json }};
  var canvas = document.getElementById('bks-cvh-canvas-' + SID);
  if (!canvas) return;
  var ctx = canvas.getContext('2d');
  var dotsEl = document.getElementById('bks-cvh-dots-' + SID);
  var dots = dotsEl ? dotsEl.querySelectorAll('.bks-cvh__dot') : [];

  // Collect available videos
  var videos = [];
  for (var i = 0; i < 4; i++) {
    var v = document.getElementById('bks-vid-' + SID + '-' + i);
    if (v && v.src) videos.push(v);
  }
  if (videos.length === 0) return;

  var current = 0;
  var fadeAlpha = 1;
  var fading = false;
  var FADE_DURATION = 800; // ms
  var fadeStart = 0;

  function resize() {
    var hero = canvas.parentElement;
    canvas.width  = hero.offsetWidth;
    canvas.height = hero.offsetHeight;
  }
  resize();
  window.addEventListener('resize', resize);

  function setDot(idx) {
    dots.forEach(function(d) { d.classList.remove('active'); });
    if (dots[idx]) dots[idx].classList.add('active');
  }

  function drawFrame(vid, alpha) {
    if (vid.readyState < 2) return;
    ctx.save();
    ctx.globalAlpha = alpha;
    // Cover fit
    var vw = vid.videoWidth || canvas.width;
    var vh = vid.videoHeight || canvas.height;
    var scale = Math.max(canvas.width / vw, canvas.height / vh);
    var dw = vw * scale, dh = vh * scale;
    var dx = (canvas.width - dw) / 2, dy = (canvas.height - dh) / 2;
    ctx.drawImage(vid, dx, dy, dw, dh);
    ctx.restore();
  }

  function applyGrain() {
    if (Math.random() > 0.4) return; // skip most frames for perf
    var id = ctx.getImageData(0, 0, canvas.width, canvas.height);
    var data = id.data;
    var len = data.length;
    for (var j = 0; j < len; j += 4) {
      var noise = (Math.random() - 0.5) * 22;
      data[j]   = Math.min(255, Math.max(0, data[j]   + noise));
      data[j+1] = Math.min(255, Math.max(0, data[j+1] + noise));
      data[j+2] = Math.min(255, Math.max(0, data[j+2] + noise));
    }
    ctx.putImageData(id, 0, 0);
  }

  var nextVid = null;

  function loop(ts) {
    requestAnimationFrame(loop);
    ctx.clearRect(0, 0, canvas.width, canvas.height);

    if (!fading) {
      drawFrame(videos[current], 1);
      applyGrain();
    } else {
      // crossfade: old fades out, new fades in
      var elapsed = ts - fadeStart;
      var t = Math.min(elapsed / FADE_DURATION, 1);
      drawFrame(videos[current], 1 - t);
      if (nextVid) drawFrame(nextVid, t);
      applyGrain();
      if (t >= 1) {
        fading = false;
        current = videos.indexOf(nextVid);
        nextVid = null;
        setDot(current);
      }
    }
  }

  function advance() {
    var nxt = (current + 1) % videos.length;
    nextVid = videos[nxt];
    nextVid.currentTime = 0;
    nextVid.play().catch(function(){});
    fading = true;
    fadeStart = performance.now();
  }

  // Wire ended events
  videos.forEach(function(v) {
    v.addEventListener('ended', advance);
  });

  // Start first video
  videos[0].play().catch(function() {
    // autoplay blocked — start on first interaction
    document.addEventListener('click', function starter() {
      videos[0].play().catch(function(){});
      document.removeEventListener('click', starter);
    }, { once: true });
  });

  setDot(0);
  requestAnimationFrame(loop);
})();
</script>

{% schema %}
{
  "name": "BKS Video Canvas Hero",
  "tag": "section",
  "class": "shopify-section",
  "settings": [
    {
      "type": "range",
      "id": "height",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "svh",
      "label": "Section height",
      "default": 95
    },
    {
      "type": "text",
      "id": "headline",
      "label": "Headline",
      "default": "Designed by AI."
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA link",
      "default": "/collections/all"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA label",
      "default": "Shop all collections"
    },
    {
      "type": "header",
      "content": "Video clips (4 in sequence, no audio)"
    },
    {
      "type": "url",
      "id": "video_1",
      "label": "Video 1",
      "info": "Upload video to Files in Shopify admin, paste URL here"
    },
    {
      "type": "url",
      "id": "video_2",
      "label": "Video 2"
    },
    {
      "type": "url",
      "id": "video_3",
      "label": "Video 3"
    },
    {
      "type": "url",
      "id": "video_4",
      "label": "Video 4"
    }
  ],
  "presets": [
    {
      "name": "BKS Video Canvas Hero"
    }
  ]
}
{% endschema %}
