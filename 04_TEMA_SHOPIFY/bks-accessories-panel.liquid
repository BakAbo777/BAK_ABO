{% comment %}
  BKS Accessories Panel — con filtro categorie
  Pattern Dawn 15.4 — scoping via #shopify-section-{{ section.id }}
  Filtro client-side: le pill si generano dalle categorie assegnate ai blocchi.
{% endcomment %}

{%- assign sid = section.id -%}

<style>
  #shopify-section-{{ sid }} .bks-acc {
    --bks-onyx: #0A0A0A;
    --bks-salt: #FAFAF7;
    --bks-bone: #EFEAE0;
    --bks-graphite: #3D3D3D;
    --bks-ash: #9A9A9A;
    background: var(--bks-salt);
    padding: 64px 24px;
  }
  @media (min-width: 1024px) {
    #shopify-section-{{ sid }} .bks-acc { padding: 96px 80px; }
  }
  #shopify-section-{{ sid }} .bks-acc__inner {
    max-width: 1440px;
    margin: 0 auto;
  }
  #shopify-section-{{ sid }} .bks-acc__head {
    margin-bottom: 32px;
  }
  #shopify-section-{{ sid }} .bks-acc__kicker {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--bks-ash);
    margin: 0 0 8px;
  }
  #shopify-section-{{ sid }} .bks-acc__title {
    font-size: clamp(34px, 4vw, 44px);
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.1;
    color: var(--bks-onyx);
    margin: 0;
  }

  /* ---- Barra filtri ---- */
  #shopify-section-{{ sid }} .bks-acc__filters {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin: 0 0 48px;
    padding: 0;
    list-style: none;
  }
  #shopify-section-{{ sid }} .bks-acc__filter {
    appearance: none;
    background: transparent;
    border: 1px solid var(--bks-onyx);
    border-radius: 0;
    color: var(--bks-onyx);
    cursor: pointer;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    min-height: 44px;
    padding: 0 20px;
    transition: background 200ms ease-out, color 200ms ease-out;
  }
  #shopify-section-{{ sid }} .bks-acc__filter:hover,
  #shopify-section-{{ sid }} .bks-acc__filter:focus-visible {
    background: var(--bks-onyx);
    color: var(--bks-salt);
  }
  #shopify-section-{{ sid }} .bks-acc__filter:focus-visible {
    outline: 1px solid var(--bks-onyx);
    outline-offset: 4px;
  }
  #shopify-section-{{ sid }} .bks-acc__filter[aria-pressed="true"] {
    background: var(--bks-onyx);
    color: var(--bks-salt);
  }

  /* ---- Griglia ---- */
  #shopify-section-{{ sid }} .bks-acc__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }
  @media (min-width: 768px) {
    #shopify-section-{{ sid }} .bks-acc__grid { grid-template-columns: repeat(3, 1fr); gap: 24px; }
  }
  #shopify-section-{{ sid }} .bks-acc__card {
    display: block;
    text-decoration: none;
    color: var(--bks-onyx);
    transition: opacity 240ms ease-out, transform 240ms ease-out;
  }
  #shopify-section-{{ sid }} .bks-acc__card.is-hidden {
    display: none;
  }
  #shopify-section-{{ sid }} .bks-acc__media {
    aspect-ratio: 4 / 5;
    background: var(--bks-bone);
    overflow: hidden;
  }
  #shopify-section-{{ sid }} .bks-acc__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 240ms ease-out;
  }
  #shopify-section-{{ sid }} .bks-acc__card:hover .bks-acc__media img {
    transform: scale(1.02);
  }
  #shopify-section-{{ sid }} .bks-acc__meta {
    padding-top: 16px;
  }
  #shopify-section-{{ sid }} .bks-acc__cat {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--bks-ash);
    margin: 0 0 4px;
  }
  #shopify-section-{{ sid }} .bks-acc__name {
    font-size: 15px;
    font-weight: 500;
    line-height: 1.3;
    margin: 0;
  }
  @media (prefers-reduced-motion: reduce) {
    #shopify-section-{{ sid }} .bks-acc * { transition: none !important; }
  }
</style>

<div class="bks-acc" data-bks-acc>
  <div class="bks-acc__inner">

    <header class="bks-acc__head">
      {%- if section.settings.kicker != blank -%}
        <p class="bks-acc__kicker">{{ section.settings.kicker | escape }}</p>
      {%- endif -%}
      <h2 class="bks-acc__title">{{ section.settings.title | default: 'Accessories' | escape }}</h2>
    </header>

    {%- comment -%} Raccolta categorie uniche dai blocchi {%- endcomment -%}
    {%- assign cats = '' -%}
    {%- for block in section.blocks -%}
      {%- assign c = block.settings.category | strip -%}
      {%- if c != blank -%}
        {%- assign probe = '|' | append: c | append: '|' -%}
        {%- assign haystack = '|' | append: cats | append: '|' -%}
        {%- unless haystack contains probe -%}
          {%- if cats == blank -%}
            {%- assign cats = c -%}
          {%- else -%}
            {%- assign cats = cats | append: '|' | append: c -%}
          {%- endif -%}
        {%- endunless -%}
      {%- endif -%}
    {%- endfor -%}
    {%- assign cat_list = cats | split: '|' -%}

    {%- if cat_list.size > 1 -%}
      <ul class="bks-acc__filters" role="group" aria-label="{{ 'Filter by category' }}">
        <li>
          <button type="button" class="bks-acc__filter" data-bks-filter="all" aria-pressed="true">
            {{ section.settings.all_label | default: 'All' | escape }}
          </button>
        </li>
        {%- for c in cat_list -%}
          <li>
            <button type="button" class="bks-acc__filter" data-bks-filter="{{ c | handleize }}" aria-pressed="false">
              {{ c | escape }}
            </button>
          </li>
        {%- endfor -%}
      </ul>
    {%- endif -%}

    <div class="bks-acc__grid">
      {%- for block in section.blocks -%}
        {%- assign cat = block.settings.category | strip -%}
        <a
          class="bks-acc__card"
          href="{{ block.settings.link | default: '#' }}"
          data-bks-cat="{{ cat | handleize }}"
          {{ block.shopify_attributes }}
        >
          <div class="bks-acc__media">
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 900 | image_tag:
                loading: 'lazy',
                widths: '450, 700, 900',
                alt: block.settings.name | escape
              }}
            {%- else -%}
              {{ 'product-1' | placeholder_svg_tag: 'bks-acc__placeholder' }}
            {%- endif -%}
          </div>
          <div class="bks-acc__meta">
            {%- if cat != blank -%}
              <p class="bks-acc__cat">{{ cat | escape }}</p>
            {%- endif -%}
            <p class="bks-acc__name">{{ block.settings.name | default: 'Untitled' | escape }}</p>
          </div>
        </a>
      {%- endfor -%}
    </div>

  </div>
</div>

<script>
  (function () {
    var root = document.querySelector('#shopify-section-{{ sid }} [data-bks-acc]');
    if (!root) return;
    var buttons = root.querySelectorAll('[data-bks-filter]');
    var cards = root.querySelectorAll('[data-bks-cat]');
    if (!buttons.length) return;

    buttons.forEach(function (btn) {
      btn.addEventListener('click', function () {
        var f = btn.getAttribute('data-bks-filter');
        buttons.forEach(function (b) {
          b.setAttribute('aria-pressed', b === btn ? 'true' : 'false');
        });
        cards.forEach(function (card) {
          var match = f === 'all' || card.getAttribute('data-bks-cat') === f;
          card.classList.toggle('is-hidden', !match);
        });
      });
    });
  })();
</script>

{% schema %}
{
  "name": "BKS Accessories Panel",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker",
      "default": "BKS Studio"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Titolo",
      "default": "Accessories"
    },
    {
      "type": "text",
      "id": "all_label",
      "label": "Etichetta filtro 'tutti'",
      "default": "All"
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Accessorio",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Immagine"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Nome",
          "default": "BKS Accessory"
        },
        {
          "type": "text",
          "id": "category",
          "label": "Categoria (per il filtro)",
          "info": "Es. Backpacks, Duffle Bags, Travel Gear. Stesse categorie = stesso filtro."
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "BKS Accessories Panel",
      "blocks": [
        { "type": "item", "settings": { "category": "Backpacks" } },
        { "type": "item", "settings": { "category": "Duffle Bags" } },
        { "type": "item", "settings": { "category": "Travel Gear" } }
      ]
    }
  ]
}
{% endschema %}
