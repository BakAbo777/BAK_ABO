{% doc %}
  @prompt
    An interactive vertical timeline that highlights as the user scrolls
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-timeline-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    padding: 60px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-timeline-container-{{ ai_gen_id }} {
    position: relative;
    max-width: 800px;
    margin: 0 auto;
  }

  .ai-timeline-line-{{ ai_gen_id }} {
    position: absolute;
    left: {{ block.settings.line_position }}px;
    top: 0;
    bottom: 0;
    width: {{ block.settings.line_thickness }}px;
    background-color: {{ block.settings.line_color }};
    transform: translateX(-50%);
  }

  .ai-timeline-progress-{{ ai_gen_id }} {
    position: absolute;
    left: 0;
    top: 0;
    width: 100%;
    height: 0;
    background-color: {{ block.settings.line_active_color }};
    transition: height 0.3s ease-out;
  }

  .ai-timeline-item-{{ ai_gen_id }} {
    position: relative;
    padding-left: calc({{ block.settings.line_position }}px + 40px);
    padding-bottom: 60px;
    opacity: 0.4;
    transition: opacity 0.5s ease;
  }

  .ai-timeline-item-{{ ai_gen_id }}.active {
    opacity: 1;
  }

  .ai-timeline-item-{{ ai_gen_id }}:last-child {
    padding-bottom: 0;
  }

  .ai-timeline-dot-{{ ai_gen_id }} {
    position: absolute;
    left: {{ block.settings.line_position }}px;
    top: 8px;
    width: {{ block.settings.dot_size }}px;
    height: {{ block.settings.dot_size }}px;
    background-color: {{ block.settings.dot_color }};
    border: {{ block.settings.dot_border_thickness }}px solid {{ block.settings.dot_border_color }};
    border-radius: 50%;
    transform: translate(-50%, 0) scale(0.8);
    transition: all 0.5s ease;
    z-index: 2;
  }

  .ai-timeline-item-{{ ai_gen_id }}.active .ai-timeline-dot-{{ ai_gen_id }} {
    background-color: {{ block.settings.dot_active_color }};
    border-color: {{ block.settings.dot_active_border_color }};
    transform: translate(-50%, 0) scale(1);
    box-shadow: 0 0 0 8px {{ block.settings.dot_active_color }}33;
  }

  .ai-timeline-content-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background_color }};
    padding: 24px;
    border-radius: {{ block.settings.card_border_radius }}px;
    border: {{ block.settings.card_border_thickness }}px solid {{ block.settings.card_border_color }};
    box-shadow: 0 2px 8px {{ block.settings.shadow_color }}1a;
    transition: all 0.5s ease;
  }

  .ai-timeline-item-{{ ai_gen_id }}.active .ai-timeline-content-{{ ai_gen_id }} {
    box-shadow: 0 4px 16px {{ block.settings.shadow_color }}33;
    border-color: {{ block.settings.card_active_border_color }};
  }

  .ai-timeline-date-{{ ai_gen_id }} {
    font-size: {{ block.settings.date_font_size }}px;
    color: {{ block.settings.date_color }};
    margin-bottom: 8px;
    font-weight: 600;
  }

  .ai-timeline-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_font_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 12px;
    font-weight: 700;
  }

  .ai-timeline-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_font_size }}px;
    color: {{ block.settings.description_color }};
    line-height: 1.6;
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-timeline-{{ ai_gen_id }} {
      padding: 40px 16px;
    }

    .ai-timeline-item-{{ ai_gen_id }} {
      padding-left: calc({{ block.settings.line_position | times: 0.6 }}px + 30px);
      padding-bottom: 40px;
    }

    .ai-timeline-line-{{ ai_gen_id }} {
      left: calc({{ block.settings.line_position }}px * 0.6);
    }

    .ai-timeline-dot-{{ ai_gen_id }} {
      left: calc({{ block.settings.line_position }}px * 0.6);
      width: calc({{ block.settings.dot_size }}px * 0.8);
      height: calc({{ block.settings.dot_size }}px * 0.8);
    }

    .ai-timeline-content-{{ ai_gen_id }} {
      padding: 20px;
    }

    .ai-timeline-title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.title_font_size }}px * 0.9);
    }

    .ai-timeline-description-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.description_font_size }}px * 0.95);
    }
  }
{% endstyle %}

<scroll-timeline-{{ ai_gen_id }}
  class="ai-timeline-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
