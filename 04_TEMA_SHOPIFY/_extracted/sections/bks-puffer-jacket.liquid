{% comment %}
  BakAbo / BKS Puffer Jacket — Product Description
  File: sections/bks-puffer-jacket.liquid
  v2 — layout desktop a due colonne, tabella unificata features+specs, migliore leggibilità
{% endcomment %}

<style>
  #shopify-section-{{ section.id }} .bks-pj {
    background: {{ section.settings.background_color }};
    color: {{ section.settings.text_color }};
    font-family: var(--font-body-family);
    padding: clamp(20px, 3vw, 36px) 0;
  }

  /* ── TAGLINE ── */
  #shopify-section-{{ section.id }} .bks-pj__tagline {
    font-size: clamp(16px, 1.8vw, 20px);
    font-style: italic;
    font-weight: 300;
    color: {{ section.settings.muted_color }};
    margin: 0 0 28px;
    padding-bottom: 20px;
    border-bottom: 1px solid {{ section.settings.border_color }};
    letter-spacing: 0.02em;
    line-height: 1.45;
  }

  /* ── SECTION LABEL ── */
  #shopify-section-{{ section.id }} .bks-pj__label {
    font-size: 9.5px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: {{ section.settings.accent_color }};
    font-weight: 600;
    margin: 0 0 14px;
    display: flex; align-items: center; gap: 10px;
  }
  #shopify-section-{{ section.id }} .bks-pj__label::before {
    content: ''; display: block;
    width: 18px; height: 1px; background: {{ section.settings.accent_color }};
  }

  /* ── DESKTOP TWO-COLUMN LAYOUT ── */
  @media screen and (min-width: 990px) {
    #shopify-section-{{ section.id }} .bks-pj__cols {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 32px;
      align-items: start;
    }
  }

  /* ── UNIFIED TABLE: features + specs ── */
  #shopify-section-{{ section.id }} .bks-pj__table {
    width: 100%;
    border-collapse: collapse;
    font-size: 13px;
    border: 1px solid {{ section.settings.border_color }};
    margin-bottom: 20px;
  }
  #shopify-section-{{ section.id }} .bks-pj__table thead tr {
    background: {{ section.settings.card_hover }};
    border-bottom: 2px solid {{ section.settings.border_color }};
  }
  #shopify-section-{{ section.id }} .bks-pj__table th {
    padding: 10px 14px;
    font-size: 9px; letter-spacing: 0.22em;
    text-transform: uppercase; color: {{ section.settings.muted_color }};
    font-weight: 600; text-align: left;
  }
  #shopify-section-{{ section.id }} .bks-pj__table td {
    padding: 11px 14px;
    border-bottom: 1px solid {{ section.settings.border_color }};
    vertical-align: top;
    line-height: 1.5;
  }
  #shopify-section-{{ section.id }} .bks-pj__table tr:last-child td { border-bottom: none; }
  /* Section divider row */
  #shopify-section-{{ section.id }} .bks-pj__table tr.bks-pj--divrow td {
    background: {{ section.settings.card_hover }};
    padding: 6px 14px;
    border-top: 2px solid {{ section.settings.border_color }};
    border-bottom: 2px solid {{ section.settings.border_color }};
  }
  #shopify-section-{{ section.id }} .bks-pj__table tr.bks-pj--divrow td span {
    font-size: 9px; letter-spacing: 0.26em;
    text-transform: uppercase; color: {{ section.settings.accent_color }};
    font-weight: 600; display: flex; align-items: center; gap: 8px;
  }
  #shopify-section-{{ section.id }} .bks-pj__table tr.bks-pj--divrow td span::before {
    content: ''; display: block; width: 14px; height: 1px; background: {{ section.settings.accent_color }};
  }

  /* Feature dot */
  #shopify-section-{{ section.id }} .bks-pj__table .bks-pj--feat-key {
    color: {{ section.settings.muted_color }};
    font-size: 11px; letter-spacing: 0.08em;
    text-transform: uppercase; font-weight: 500;
    white-space: nowrap; width: 38%;
  }
  #shopify-section-{{ section.id }} .bks-pj__table .bks-pj--feat-val {
    color: {{ section.settings.text_color }};
  }
  #shopify-section-{{ section.id }} .bks-pj__table .bks-pj--dot {
    display: inline-block; width: 7px; height: 7px;
    border-radius: 50%; background: {{ section.settings.accent_color }};
    margin-right: 8px; flex-shrink: 0; vertical-align: middle;
    margin-top: -1px;
  }

  /* ── CARE GRID ── */
  #shopify-section-{{ section.id }} .bks-pj__care {
    border: 1px solid {{ section.settings.border_color }};
    background: {{ section.settings.card_hover }};
    padding: 18px 18px 16px;
    margin-bottom: 20px;
  }
  #shopify-section-{{ section.id }} .bks-pj__care-grid {
    display: flex; gap: 6px; flex-wrap: wrap; margin-top: 12px;
  }
  #shopify-section-{{ section.id }} .bks-pj__care-item {
    display: flex; flex-direction: column;
    align-items: center; gap: 5px;
    min-width: 56px; text-align: center;
    flex: 1;
  }
  #shopify-section-{{ section.id }} .bks-pj__care-icon {
    font-size: 22px; line-height: 1;
    display: block; position: relative;
  }
  #shopify-section-{{ section.id }} .bks-pj__care-item.no .bks-pj__care-icon::after {
    content: ''; position: absolute;
    left: 0; right: 0; top: 50%;
    height: 2.5px; background: #c0392b;
    transform: translateY(-50%) rotate(-20deg); border-radius: 1px;
  }
  #shopify-section-{{ section.id }} .bks-pj__care-label {
    font-size: 9.5px; color: {{ section.settings.muted_color }};
    line-height: 1.3; letter-spacing: 0.01em;
  }

  /* ── WARRANTY ── */
  #shopify-section-{{ section.id }} .bks-pj__warranty {
    display: flex; align-items: flex-start; gap: 12px;
    font-size: 12.5px; color: {{ section.settings.muted_color }};
    padding: 13px 16px;
    border-left: 3px solid {{ section.settings.accent_color }};
    background: {{ section.settings.card_hover }};
    line-height: 1.5; margin: 0;
  }
  #shopify-section-{{ section.id }} .bks-pj__warranty strong {
    color: {{ section.settings.text_color }};
  }
  #shopify-section-{{ section.id }} .bks-pj__warranty-icon {
    font-size: 18px; flex-shrink: 0; margin-top: 1px;
  }
</style>

<div class="bks-pj">

  {%- if section.settings.tagline != blank -%}
    <p class="bks-pj__tagline">{{ section.settings.tagline }}</p>
  {%- endif -%}

  <div class="bks-pj__cols">

    {%- comment -%} COL LEFT — Tabella unificata Feature + Specs {%- endcomment -%}
    <div>
      <table class="bks-pj__table">
        <thead>
          <tr>
            <th colspan="2">Caratteristiche &amp; Specifiche</th>
          </tr>
        </thead>
        <tbody>
          {%- comment -%} FEATURES {%- endcomment -%}
          {%- if section.settings.feat_1_title != blank -%}
            <tr>
              <td class="bks-pj--feat-key">
                <span class="bks-pj--dot" aria-hidden="true"></span>{{ section.settings.feat_1_title }}
              </td>
              <td class="bks-pj--feat-val">{{ section.settings.feat_1_body }}</td>
            </tr>
          {%- endif -%}
          {%- if section.settings.feat_2_title != blank -%}
            <tr>
              <td class="bks-pj--feat-key"><span class="bks-pj--dot" aria-hidden="true"></span>{{ section.settings.feat_2_title }}</td>
              <td class="bks-pj--feat-val">{{ section.settings.feat_2_body }}</td>
            </tr>
          {%- endif -%}
          {%- if section.settings.feat_3_title != blank -%}
            <tr>
              <td class="bks-pj--feat-key"><span class="bks-pj--dot" aria-hidden="true"></span>{{ section.settings.feat_3_title }}</td>
              <td class="bks-pj--feat-val">{{ section.settings.feat_3_body }}</td>
            </tr>
          {%- endif -%}
          {%- if section.settings.feat_4_title != blank -%}
            <tr>
              <td class="bks-pj--feat-key"><span class="bks-pj--dot" aria-hidden="true"></span>{{ section.settings.feat_4_title }}</td>
              <td class="bks-pj--feat-val">{{ section.settings.feat_4_body }}</td>
            </tr>
          {%- endif -%}
          {%- if section.settings.feat_5_title != blank -%}
            <tr>
              <td class="bks-pj--feat-key"><span class="bks-pj--dot" aria-hidden="true"></span>{{ section.settings.feat_5_title }}</td>
              <td class="bks-pj--feat-val">{{ section.settings.feat_5_body }}</td>
            </tr>
          {%- endif -%}

          {%- comment -%} DIVIDER ROW {%- endcomment -%}
          <tr class="bks-pj--divrow">
            <td colspan="2"><span>Specifiche tecniche</span></td>
          </tr>

          {%- comment -%} SPECS {%- endcomment -%}
          <tr>
            <td class="bks-pj--feat-key">Materiale shell</td>
            <td class="bks-pj--feat-val">{{ section.settings.spec_shell | default: '100% Poliestere' }}</td>
          </tr>
          <tr>
            <td class="bks-pj--feat-key">Fodera</td>
            <td class="bks-pj--feat-val">{{ section.settings.spec_lining | default: 'Poliestere effetto cotone' }}</td>
          </tr>
          <tr>
            <td class="bks-pj--feat-key">Fit</td>
            <td class="bks-pj--feat-val">{{ section.settings.spec_fit | default: 'Regular fit' }}</td>
          </tr>
          <tr>
            <td class="bks-pj--feat-key">Collo</td>
            <td class="bks-pj--feat-val">{{ section.settings.spec_collar | default: 'Stand-up collar' }}</td>
          </tr>
          <tr>
            <td class="bks-pj--feat-key">Chiusura</td>
            <td class="bks-pj--feat-val">Zip con cursore in metallo</td>
          </tr>
          <tr>
            <td class="bks-pj--feat-key">Tasche</td>
            <td class="bks-pj--feat-val">2 tasche frontali con zip</td>
          </tr>
        </tbody>
      </table>
    </div>

    {%- comment -%} COL RIGHT — Cura del capo + Garanzia {%- endcomment -%}
    <div>
      <p class="bks-pj__label">Cura del capo</p>
      <div class="bks-pj__care">
        <div class="bks-pj__care-grid">
          <div class="bks-pj__care-item ok">
            <span class="bks-pj__care-icon">🫧</span>
            <span class="bks-pj__care-label">Lavatrice max 30°C</span>
          </div>
          <div class="bks-pj__care-item no">
            <span class="bks-pj__care-icon">🧺</span>
            <span class="bks-pj__care-label">No asciugatrice</span>
          </div>
          <div class="bks-pj__care-item no">
            <span class="bks-pj__care-icon">♨️</span>
            <span class="bks-pj__care-label">No stiratura</span>
          </div>
          <div class="bks-pj__care-item no">
            <span class="bks-pj__care-icon">🧴</span>
            <span class="bks-pj__care-label">No candeggio</span>
          </div>
          <div class="bks-pj__care-item no">
            <span class="bks-pj__care-icon">🧪</span>
            <span class="bks-pj__care-label">No lavaggio a secco</span>
          </div>
        </div>
      </div>

      <p class="bks-pj__label" style="margin-top:20px;">Garanzia</p>
      <p class="bks-pj__warranty">
        <span class="bks-pj__warranty-icon">🛡</span>
        <span>
          <strong>Garanzia legale 2 anni</strong><br>
          Valida nell'UE e Irlanda del Nord ai sensi della<br>
          Direttiva 1999/44/CE.
          {%- if section.settings.spec_warranty != blank -%}
            <br><span style="font-size:11.5px;">{{ section.settings.spec_warranty }}</span>
          {%- endif -%}
        </span>
      </p>
    </div>

  </div>
</div>

