{{ 'bks-future.css' | asset_url | stylesheet_tag }}

<style>
  /* ── BKS EDITORIAL MATRIX — Dark & Dynamic ─────────────── */
  #shopify-section-{{ section.id }} .bks-editorial-matrix {
    position: relative;
    background: #0A0A0A;
    color: #FAFAF7;
    overflow: hidden;
  }

  /* Background layers */
  #shopify-section-{{ section.id }} .bks-editorial-matrix::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.04) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(ellipse 80% 70% at 50% 50%, black 30%, transparent 75%);
    -webkit-mask-image: radial-gradient(ellipse 80% 70% at 50% 50%, black 30%, transparent 75%);
    pointer-events: none;
    z-index: 0;
    animation: gridDrift 20s ease-in-out infinite alternate;
  }

  #shopify-section-{{ section.id }} .bks-editorial-matrix::after {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle 600px at 20% 30%, rgba(200,183,156,0.08), transparent 60%),
      radial-gradient(circle 500px at 80% 70%, rgba(200,71,61,0.06), transparent 55%);
    pointer-events: none;
    z-index: 0;
    animation: blobDrift 15s ease-in-out infinite alternate;
  }

  #shopify-section-{{ section.id }} .bks-editorial-matrix__inner {
    position: relative;
    z-index: 1;
    width: min(1440px, calc(100% - 32px));
    margin: 0 auto;
    padding: clamp(56px,8vw,112px) 0;
  }

  /* Header */
  #shopify-section-{{ section.id }} .bks-section-head {
    display: grid;
    grid-template-columns: minmax(0,0.78fr) minmax(240px,0.42fr);
    gap: 24px;
    align-items: end;
    margin-bottom: 48px;
  }

  #shopify-section-{{ section.id }} .bks-kicker {
    font-family: var(--bks-font-mono,'DM Mono',monospace);
    font-size: 0.76rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--bks-dune, #C9B79C);
    margin-bottom: 10px;
    opacity: 0;
    animation: fadeInUp 0.8s ease 0.1s forwards;
  }

  #shopify-section-{{ section.id }} .bks-brand-context {
    display: inline-flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 10px;
    margin: 0 0 14px;
  }

  #shopify-section-{{ section.id }} .bks-brand-context__item {
    display: inline-flex;
    align-items: center;
    min-height: 34px;
    padding: 8px 12px;
    border: 1px solid rgba(250,250,247,0.28);
    border-radius: 999px;
    background: rgba(10,10,10,0.58);
    color: #FAFAF7;
    box-shadow: 0 12px 34px rgba(0,0,0,0.24);
    font-family: var(--bks-font-mono,'DM Mono',monospace);
    font-size: clamp(0.7rem,1vw,0.82rem);
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  #shopify-section-{{ section.id }} .bks-brand-context__container {
    border-color: rgba(201,183,156,0.72);
  }

  #shopify-section-{{ section.id }} .bks-brand-context__creator {
    gap: 8px;
    border-color: rgba(250,250,247,0.92);
    background: #FAFAF7;
    color: #0A0A0A;
  }

  #shopify-section-{{ section.id }} .bks-brand-context__creator img {
    display: block;
    width: auto;
    height: 18px;
    max-width: 76px;
    background: transparent;
  }

  #shopify-section-{{ section.id }} .bks-section-head h2 {
    margin: 0;
    font-family: var(--bks-font-display,'Bebas Neue',sans-serif);
    font-size: clamp(3.6rem,8.5vw,9rem);
    line-height: 0.86;
    text-transform: uppercase;
    color: #FAFAF7;
    opacity: 0;
    animation: fadeInUp 0.8s ease 0.2s forwards;
  }

  #shopify-section-{{ section.id }} .bks-section-head p {
    margin: 0;
    font-family: var(--bks-font-body,'DM Sans',sans-serif);
    color: rgba(250,250,247,0.72);
    font-size: 1rem;
    line-height: 1.6;
    opacity: 0;
    animation: fadeInUp 0.8s ease 0.3s forwards;
  }

  /* Grid — 4 col, 1px gap */
  #shopify-section-{{ section.id }} .bks-editorial-grid {
    display: grid;
    grid-template-columns: repeat(4,minmax(0,1fr));
    gap: 1px;
    background: rgba(250,250,247,0.08);
  }

  /* Card */
  #shopify-section-{{ section.id }} .bks-editorial-card {
    position: relative;
    min-height: 420px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 20px;
    color: #FAFAF7;
    background: #0A0A0A;
    text-decoration: none;
    overflow: hidden;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    cursor: pointer;
  }

  /* Accent color overlay */
  #shopify-section-{{ section.id }} .bks-editorial-card::before {
    content: "";
    position: absolute;
    inset: 0;
    background: var(--bks-accent, #EFEAE0);
    opacity: 0.14;
    transition: opacity 0.4s ease;
    pointer-events: none;
  }

  #shopify-section-{{ section.id }} .bks-editorial-card:hover {
    transform: translateY(-8px);
    background: #141414;
    box-shadow: 0 20px 60px rgba(0,0,0,0.5);
  }

  #shopify-section-{{ section.id }} .bks-editorial-card:hover::before {
    opacity: 0.28;
  }

  /* Card media */
  #shopify-section-{{ section.id }} .bks-editorial-card__media {
    position: relative;
    min-height: 240px;
    overflow: hidden;
    background: #1a1a1a;
    margin: -20px -20px 16px;
    border-radius: 0;
  }

  #shopify-section-{{ section.id }} .bks-editorial-card__media::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 60%, rgba(10,10,10,0.8) 100%);
    pointer-events: none;
  }

  #shopify-section-{{ section.id }} .bks-editorial-card__media img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    aspect-ratio: 3/4;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  #shopify-section-{{ section.id }} .bks-editorial-card:hover .bks-editorial-card__media img {
    transform: scale(1.08);
  }

  /* Card content */
  #shopify-section-{{ section.id }} .bks-editorial-card__content {
    position: relative;
    z-index: 1;
  }

  #shopify-section-{{ section.id }} .bks-editorial-card h3 {
    margin: 0 0 10px;
    font-family: var(--bks-font-display,'Bebas Neue',sans-serif);
    font-size: clamp(1.8rem,2.5vw,2.8rem);
    line-height: 1;
    text-transform: uppercase;
    color: #FAFAF7;
    transition: color 0.3s ease;
  }

  #shopify-section-{{ section.id }} .bks-editorial-card:hover h3 {
    color: var(--bks-accent, #C9B79C);
  }

  #shopify-section-{{ section.id }} .bks-editorial-card p {
    margin: 0;
    font-size: 0.85rem;
    line-height: 1.5;
    color: rgba(250,250,247,0.72);
  }

  #shopify-section-{{ section.id }} .bks-editorial-card__meta {
    position: relative;
    z-index: 1;
    font-family: var(--bks-font-mono,'DM Mono',monospace);
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(250,250,247,0.68);
    margin-top: 16px;
    padding-top: 12px;
    border-top: 1px solid rgba(250,250,247,0.15);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  #shopify-section-{{ section.id }} .bks-editorial-card__meta span {
    color: var(--bks-accent, #C9B79C);
    font-weight: 800;
  }

  /* Arrow indicator */
  #shopify-section-{{ section.id }} .bks-editorial-card__arrow {
    position: absolute;
    top: 20px;
    right: 20px;
    width: 32px;
    height: 32px;
    display: grid;
    place-items: center;
    background: rgba(250,250,247,0.1);
    border-radius: 50%;
    opacity: 0;
    transform: translate(-10px, 10px);
    transition: all 0.3s ease;
    z-index: 2;
  }

  #shopify-section-{{ section.id }} .bks-editorial-card__arrow::before {
    content: "→";
    color: #FAFAF7;
    font-size: 1rem;
  }

  #shopify-section-{{ section.id }} .bks-editorial-card:hover .bks-editorial-card__arrow {
    opacity: 1;
    transform: translate(0, 0);
  }

  /* Animations */
  @keyframes fadeInUp {
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes gridDrift {
    0% { opacity: 0.3; transform: translate(0, 0); }
    100% { opacity: 0.6; transform: translate(-10px, -10px); }
  }

  @keyframes blobDrift {
    0% { opacity: 0.7; transform: scale(1) translate(0, 0); }
    100% { opacity: 1; transform: scale(1.08) translate(-2%, 2%); }
  }

  /* Mobile — 2 col */
  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .bks-editorial-grid {
      grid-template-columns: repeat(2,minmax(0,1fr));
    }
    #shopify-section-{{ section.id }} .bks-section-head {
      grid-template-columns: 1fr;
    }
    #shopify-section-{{ section.id }} .bks-editorial-card {
      min-height: 320px;
    }
    #shopify-section-{{ section.id }} .bks-editorial-card__media {
      min-height: 180px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    * { animation: none !important; transition: none !important; }
  }


  /* BKS TM03 visual balance overrides: lighter imagery, calmer mobile type */
  #shopify-section-{{ section.id }} .bks-editorial-matrix {
    background: #171510;
  }
  #shopify-section-{{ section.id }} .bks-editorial-grid {
    background: rgba(250,250,247,0.14);
  }
  #shopify-section-{{ section.id }} .bks-editorial-card {
    background: #151f1b;
    padding: clamp(14px,2.4vw,20px);
  }
  #shopify-section-{{ section.id }} .bks-editorial-card::before {
    opacity: 0.07;
  }
  #shopify-section-{{ section.id }} .bks-editorial-card:hover::before {
    opacity: 0.16;
  }
  #shopify-section-{{ section.id }} .bks-editorial-card__media::after {
    background: linear-gradient(180deg, rgba(10,10,10,0.04) 0%, rgba(10,10,10,0.34) 100%);
  }
  #shopify-section-{{ section.id }} .bks-editorial-card__media img {
    filter: brightness(1.14) contrast(0.98) saturate(1.02);
    opacity: 0.98;
  }
  #shopify-section-{{ section.id }} .bks-editorial-card h3 {
    font-size: clamp(1.35rem,2.1vw,2.25rem);
    line-height: 0.98;
    letter-spacing: 0;
  }
  #shopify-section-{{ section.id }} .bks-editorial-card p {
    font-size: clamp(0.76rem,1vw,0.84rem);
    line-height: 1.45;
  }
  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .bks-editorial-matrix__inner {
      width: min(100% - 20px, 560px);
      padding: 40px 0;
    }
    #shopify-section-{{ section.id }} .bks-editorial-grid {
      grid-template-columns: 1fr;
      gap: 10px;
      background: transparent;
    }
    #shopify-section-{{ section.id }} .bks-editorial-card {
      min-height: auto;
      padding: 14px;
      background: #18231f;
    }
    #shopify-section-{{ section.id }} .bks-editorial-card__media {
      min-height: 188px;
      margin: -14px -14px 14px;
    }
    #shopify-section-{{ section.id }} .bks-editorial-card h3 {
      margin-bottom: 8px;
      font-size: clamp(1.24rem,7vw,1.55rem);
      line-height: 0.98;
    }
    #shopify-section-{{ section.id }} .bks-editorial-card p {
      font-size: 0.76rem;
      line-height: 1.42;
      display: -webkit-box;
      -webkit-line-clamp: 4;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    #shopify-section-{{ section.id }} .bks-editorial-card__meta {
      margin-top: 12px;
      padding-top: 10px;
      font-size: 0.56rem;
      letter-spacing: 0.08em;
    }
  }

</style>

{% liquid
  assign handles = section.settings.collection_handles | default: 'bks-folklore,bks-glyph,bks-marker,bks-riviera,bks-pulse,bks-token,bks-flag,bks-hours' | split: ','
%}

<section class="bks-editorial-matrix" id="bks-matrix-{{ section.id }}">
  <div class="bks-editorial-matrix__inner">
    <div class="bks-section-head">
      <div>
        <div class="bks-brand-context" aria-label="BakAbo container and BKS Studio creator">
          <span class="bks-brand-context__item bks-brand-context__container">BakAbo container</span>
          <span class="bks-brand-context__item bks-brand-context__creator">
            <img src="{{ 'bks-studio-logo.png' | asset_url }}" alt="" loading="lazy" width="223" height="67">
            Creator: BKS Studio
          </span>
        </div>
        <div class="bks-kicker">{{ section.settings.kicker }}</div>
        <h2>{{ section.settings.heading }}</h2>
      </div>
      <p>{{ section.settings.copy }}</p>
    </div>

    <div class="bks-editorial-grid">
      {% for raw_handle in handles %}
        {% liquid
          assign handle      = raw_handle | strip
          assign coll        = collections[handle]
          assign meta        = shop.metaobjects.bks_collection[handle]
          assign accent      = meta.color_hex.value | default: '#C9B79C'
          assign description = meta.tagline.value | default: meta.description.value | default: coll.description | strip_html
          assign image       = coll.featured_image
          if image == blank and coll.products.first
            assign image = coll.products.first.featured_image
          endif
        %}
        <a class="bks-editorial-card" href="{{ coll.url | default: '/collections' }}" style="--bks-accent: {{ accent }};">
          <div class="bks-editorial-card__arrow"></div>
          <div class="bks-editorial-card__media">
            {% if image != blank %}
              {{ image | image_url: width: 820 | image_tag: loading: 'lazy', widths: '320,540,720,820', alt: coll.title }}
            {% else %}
              <div style="width:100%;height:100%;min-height:240px;display:flex;align-items:center;justify-content:center;padding:24px;background:#141414">
                <span style="font-family:var(--bks-font-display,sans-serif);font-size:clamp(2rem,5vw,5rem);color:rgba(250,250,247,0.12);text-transform:uppercase;line-height:1">{{ handle }}</span>
              </div>
            {% endif %}
          </div>
          <div class="bks-editorial-card__content">
            <h3>{{ meta.name.value | default: coll.title | default: handle }}</h3>
            {% if description != blank %}<p>{{ description | truncate: 120 }}</p>{% endif %}
          </div>
          <div class="bks-editorial-card__meta">
            <span>{{ coll.products_count | default: 0 }} pieces</span>
            <span>Explore →</span>
          </div>
        </a>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "BKS editorial matrix",
  "settings": [
    { "type": "text",     "id": "kicker",             "label": "Kicker",              "default": "The eight editorial systems" },
    { "type": "text",     "id": "heading",             "label": "Heading",             "default": "Eight signals" },
    { "type": "textarea", "id": "copy",               "label": "Copy",                "default": "Folklore. Glyph. Marker. Riviera. Pulse. Token. Flag. Hours. Eight permanent collections, each a distinct visual language." },
    { "type": "text",     "id": "collection_handles",  "label": "Collection handles",  "default": "bks-folklore,bks-glyph,bks-marker,bks-riviera,bks-pulse,bks-token,bks-flag,bks-hours" }
  ],
  "presets": [{ "name": "BKS editorial matrix" }]
}
{% endschema %}
