{% comment %}
  BakAbo / BKS Care Guide — Universal
  File: sections/bks-care-guide.liquid
  Covers: Sneakers, Windbreaker, Swimwear, Hoodies, Bags, Hawaiian Shirts, Tees, Shorts
  Pattern: Dawn 15.4 — section-scoped CSS, modal + pulsante editabile
{% endcomment %}

<style>
  #shopify-section-{{ section.id }} .bks-cg__trigger {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-weight: 500;
    font-family: var(--font-body-family);
    background: {{ section.settings.btn_bg }};
    border: 1px solid {{ section.settings.btn_border_color }};
    color: {{ section.settings.btn_text_color }};
    padding: 10px 18px;
    cursor: pointer;
    transition: background 0.18s, color 0.18s, border-color 0.18s;
    touch-action: manipulation;
    -webkit-tap-highlight-color: transparent;
    min-height: 44px;
  }
  #shopify-section-{{ section.id }} .bks-cg__trigger:hover {
    background: {{ section.settings.accent_color }};
    color: #080808;
    border-color: {{ section.settings.accent_color }};
  }
  #shopify-section-{{ section.id }} .bks-cg__trigger svg {
    width: 13px; height: 13px;
    stroke: currentColor; fill: none;
    stroke-width: 1.7; stroke-linecap: round;
  }

  .bks-cg-modal {
    position: fixed;
    top: 0; right: 0; bottom: 0; left: 0;
    inset: 0;
    z-index: 10000;
    display: flex; align-items: center; justify-content: center;
    padding: 16px;
    background: rgba(8,8,8,0.72);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    opacity: 0; pointer-events: none;
    transition: opacity 0.22s ease;
  }
  .bks-cg-modal.is-open { opacity: 1; pointer-events: all; }

  .bks-cg-modal__box {
    background: {{ section.settings.background_color }};
    color: {{ section.settings.text_color }};
    width: 100%; max-width: 660px;
    max-height: 92vh; overflow-y: auto;
    padding: 36px 40px 32px;
    position: relative;
    transform: translateY(14px);
    transition: transform 0.22s ease;
    border-top: 2px solid {{ section.settings.accent_color }};
    font-family: var(--font-body-family);
  }
  .bks-cg-modal.is-open .bks-cg-modal__box { transform: translateY(0); }

  .bks-cg-modal__close {
    position: absolute; top: 16px; right: 18px;
    background: none; border: none;
    font-size: 20px; color: {{ section.settings.muted_color }};
    cursor: pointer; padding: 8px; line-height: 1;
    min-width: 44px; min-height: 44px;
    display: flex; align-items: center; justify-content: center;
    transition: color 0.15s;
  }
  .bks-cg-modal__close:hover { color: {{ section.settings.text_color }}; }

  .bks-cg__kicker {
    font-size: 10px; letter-spacing: 0.26em;
    text-transform: uppercase; color: {{ section.settings.accent_color }};
    margin: 0 0 6px;
    display: flex; align-items: center; gap: 10px;
  }
  .bks-cg__kicker::before {
    content: ''; display: block;
    width: 18px; height: 1px; background: {{ section.settings.accent_color }};
  }
  .bks-cg__title {
    font-size: clamp(17px, 2.2vw, 22px);
    font-weight: 600; letter-spacing: -0.02em;
    text-transform: uppercase; margin: 0 0 20px;
    color: {{ section.settings.text_color }};
    padding-bottom: 18px;
    border-bottom: 1px solid {{ section.settings.border_color }};
  }

  /* ── CARE ICONS GRID ── */
  .bks-cg__icons-label {
    font-size: 9.5px; letter-spacing: 0.26em;
    text-transform: uppercase; color: {{ section.settings.accent_color }};
    font-weight: 600; margin: 0 0 14px;
    display: flex; align-items: center; gap: 8px;
  }
  .bks-cg__icons-label::before {
    content: ''; display: block; width: 14px; height: 1px;
    background: {{ section.settings.accent_color }};
  }
  .bks-cg__icons {
    display: flex; gap: 8px; flex-wrap: wrap;
    margin-bottom: 24px;
    background: {{ section.settings.card_bg }};
    border: 1px solid {{ section.settings.border_color }};
    padding: 16px;
  }
  .bks-cg__icon-item {
    display: flex; flex-direction: column;
    align-items: center; gap: 6px;
    flex: 1; min-width: 52px; text-align: center;
  }
  .bks-cg__icon-wrap {
    font-size: 24px; line-height: 1;
    display: block; position: relative;
  }
  .bks-cg__icon-item.no .bks-cg__icon-wrap::after {
    content: '';
    position: absolute; left: -2px; right: -2px; top: 50%;
    height: 2.5px; background: #c0392b;
    transform: translateY(-50%) rotate(-20deg); border-radius: 1px;
  }
  .bks-cg__icon-label {
    font-size: 9.5px; color: {{ section.settings.muted_color }};
    line-height: 1.3;
  }

  /* ── CARE TABLE ── */
  .bks-cg__table {
    width: 100%; border-collapse: collapse;
    font-size: 13px;
    border: 1px solid {{ section.settings.border_color }};
    margin-bottom: 20px;
  }
  .bks-cg__table thead tr {
    background: {{ section.settings.card_bg }};
    border-bottom: 2px solid {{ section.settings.border_color }};
  }
  .bks-cg__table th {
    padding: 9px 14px; font-size: 9px;
    letter-spacing: 0.2em; text-transform: uppercase;
    color: {{ section.settings.muted_color }}; font-weight: 600; text-align: left;
  }
  .bks-cg__table td {
    padding: 10px 14px;
    border-bottom: 1px solid {{ section.settings.border_color }};
    vertical-align: top; line-height: 1.5;
  }
  .bks-cg__table tr:last-child td { border-bottom: none; }
  .bks-cg__table td:first-child {
    color: {{ section.settings.muted_color }};
    font-size: 11px; letter-spacing: 0.1em;
    text-transform: uppercase; font-weight: 500; width: 38%;
  }
  .bks-cg__table td:last-child { color: {{ section.settings.text_color }}; font-weight: 500; }

  /* ── MATERIAL TABLE ── */
  .bks-cg__divrow td {
    background: {{ section.settings.card_bg }};
    padding: 6px 14px;
    border-top: 2px solid {{ section.settings.border_color }};
    border-bottom: 2px solid {{ section.settings.border_color }};
  }
  .bks-cg__divrow td span {
    font-size: 9px; letter-spacing: 0.26em;
    text-transform: uppercase; color: {{ section.settings.accent_color }};
    font-weight: 600; display: flex; align-items: center; gap: 8px;
  }
  .bks-cg__divrow td span::before {
    content: ''; display: block; width: 12px; height: 1px;
    background: {{ section.settings.accent_color }};
  }

  /* ── TIP ── */
  .bks-cg__tip {
    font-size: 12.5px; color: {{ section.settings.muted_color }};
    padding: 12px 16px; line-height: 1.55;
    border-left: 3px solid {{ section.settings.accent_color }};
    background: {{ section.settings.card_bg }};
    margin-top: 16px;
  }
  .bks-cg__tip strong { color: {{ section.settings.text_color }}; }

  @media screen and (max-width: 600px) {
    .bks-cg-modal__box { padding: 22px 14px 18px; }
    .bks-cg__icons { gap: 6px; padding: 12px; }
  }
</style>

<button
  class="bks-cg__trigger bks-care__trigger"
  onclick="document.getElementById('BksCgModal-{{ section.id }}').classList.add('is-open');document.getElementById('BksCgModal-{{ section.id }}').focus();"
  aria-haspopup="dialog"
  aria-controls="BksCgModal-{{ section.id }}"
>
  <svg viewBox="0 0 16 16" aria-hidden="true">
    <path d="M8 1.5a6.5 6.5 0 100 13 6.5 6.5 0 000-13z"/>
    <line x1="8" y1="7" x2="8" y2="11"/>
    <line x1="8" y1="5" x2="8" y2="5"/>
  </svg>
  {{ section.settings.trigger_label | default: 'Cura e Manutenzione' }}
</button>

<div
  class="bks-cg-modal"
  id="BksCgModal-{{ section.id }}"
  role="dialog"
  aria-modal="true"
  tabindex="-1"
  onclick="if(event.target===this)this.classList.remove('is-open')"
>
  <div class="bks-cg-modal__box">
    <button class="bks-cg-modal__close" onclick="document.getElementById('BksCgModal-{{ section.id }}').classList.remove('is-open')" aria-label="Chiudi">&#215;</button>

    <p class="bks-cg__kicker">Bakabo Club · BKS</p>
    <h2 class="bks-cg__title">{{ section.settings.modal_title | default: 'Cura & Manutenzione' }}</h2>

    {%- comment -%} CARE ICONS {%- endcomment -%}
    <p class="bks-cg__icons-label">Istruzioni di lavaggio</p>
    <div class="bks-cg__icons">
      {%- if section.settings.care_wash_yes -%}
        <div class="bks-cg__icon-item ok">
          <span class="bks-cg__icon-wrap"><span style="display:inline-block;position:relative;">🫧</span></span>
          <span class="bks-cg__icon-label">Lavatrice {{ section.settings.care_wash_temp | default: '30°C' }}</span>
        </div>
      {%- else -%}
        <div class="bks-cg__icon-item no">
          <span class="bks-cg__icon-wrap"><span style="display:inline-block;position:relative;">🧺</span></span>
          <span class="bks-cg__icon-label">No lavatrice</span>
        </div>
        <div class="bks-cg__icon-item ok">
          <span class="bks-cg__icon-wrap"><span style="display:inline-block;position:relative;">🤲</span></span>
          <span class="bks-cg__icon-label">Lavaggio a mano</span>
        </div>
      {%- endif -%}
      {%- unless section.settings.care_tumble_dry -%}
        <div class="bks-cg__icon-item no">
          <span class="bks-cg__icon-wrap"><span style="display:inline-block;position:relative;">🧺</span></span>
          <span class="bks-cg__icon-label">No asciugatrice</span>
        </div>
      {%- endunless -%}
      {%- unless section.settings.care_iron -%}
        <div class="bks-cg__icon-item no">
          <span class="bks-cg__icon-wrap"><span style="display:inline-block;position:relative;">♨️</span></span>
          <span class="bks-cg__icon-label">No stiratura</span>
        </div>
      {%- else -%}
        <div class="bks-cg__icon-item ok">
          <span class="bks-cg__icon-wrap"><span style="display:inline-block;position:relative;">♨️</span></span>
          <span class="bks-cg__icon-label">Stiratura {{ section.settings.care_iron_temp | default: 'bassa temp.' }}</span>
        </div>
      {%- endunless -%}
      <div class="bks-cg__icon-item no">
        <span class="bks-cg__icon-wrap"><span style="display:inline-block;position:relative;">🧴</span></span>
        <span class="bks-cg__icon-label">No candeggio</span>
      </div>
      {%- unless section.settings.care_dryclean -%}
        <div class="bks-cg__icon-item no">
          <span class="bks-cg__icon-wrap"><span style="display:inline-block;position:relative;">🧪</span></span>
          <span class="bks-cg__icon-label">No lavaggio a secco</span>
        </div>
      {%- endunless -%}
    </div>

    {%- comment -%} MATERIALS + CARE TABLE {%- endcomment -%}
    <table class="bks-cg__table">
      <thead>
        <tr><th colspan="2">Materiali &amp; Composizione</th></tr>
      </thead>
      <tbody>
        {%- if section.settings.mat_outer != blank -%}
          <tr><td>Esterno</td><td>{{ section.settings.mat_outer }}</td></tr>
        {%- endif -%}
        {%- if section.settings.mat_lining != blank -%}
          <tr><td>Fodera</td><td>{{ section.settings.mat_lining }}</td></tr>
        {%- endif -%}
        {%- if section.settings.mat_sole != blank -%}
          <tr><td>Suola / Fondo</td><td>{{ section.settings.mat_sole }}</td></tr>
        {%- endif -%}
        {%- if section.settings.mat_other != blank -%}
          <tr><td>Altro</td><td>{{ section.settings.mat_other }}</td></tr>
        {%- endif -%}

        <tr class="bks-cg__divrow"><td colspan="2"><span>Manutenzione</span></td></tr>

        {%- if section.settings.care_storage != blank -%}
          <tr><td>Conservazione</td><td>{{ section.settings.care_storage }}</td></tr>
        {%- endif -%}
        {%- if section.settings.care_cleaning != blank -%}
          <tr><td>Pulizia</td><td>{{ section.settings.care_cleaning }}</td></tr>
        {%- endif -%}
        {%- if section.settings.care_drying != blank -%}
          <tr><td>Asciugatura</td><td>{{ section.settings.care_drying }}</td></tr>
        {%- endif -%}
        {%- if section.settings.care_note != blank -%}
          <tr><td>Nota</td><td>{{ section.settings.care_note }}</td></tr>
        {%- endif -%}

        <tr class="bks-cg__divrow"><td colspan="2"><span>Garanzia</span></td></tr>
        <tr>
          <td>Garanzia</td>
          <td>{{ section.settings.warranty | default: '2 anni — UE Direttiva 1999/44/CE' }}</td>
        </tr>
      </tbody>
    </table>

    {%- if section.settings.care_tip != blank -%}
      <p class="bks-cg__tip">
        <strong>Consiglio BKS:</strong> {{ section.settings.care_tip }}
      </p>
    {%- endif -%}
  </div>
</div>

<script>
document.addEventListener('keydown', function(e) {
  if (e.key === 'Escape') {
    var m = document.getElementById('BksCgModal-{{ section.id }}');
    if (m) m.classList.remove('is-open');
  }
});
</script>

{% schema %}
{
  "name": "BKS Care Guide",
  "tag": "div",
  "class": "bks-care-guide-section",
  "settings": [
    {
      "type": "header",
      "content": "Pulsante"
    },
    {
      "type": "text",
      "id": "trigger_label",
      "label": "Testo pulsante",
      "default": "Cura e Manutenzione"
    },
    {
      "type": "color",
      "id": "btn_bg",
      "label": "Sfondo pulsante",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "btn_text_color",
      "label": "Testo pulsante",
      "default": "#0a0a0a"
    },
    {
      "type": "color",
      "id": "btn_border_color",
      "label": "Bordo pulsante",
      "default": "#e0d9ce"
    },
    {
      "type": "header",
      "content": "Modal"
    },
    {
      "type": "text",
      "id": "modal_title",
      "label": "Titolo modal",
      "default": "Cura & Manutenzione"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Sfondo",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Testo principale",
      "default": "#0a0a0a"
    },
    {
      "type": "color",
      "id": "muted_color",
      "label": "Testo secondario",
      "default": "#666666"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Bordi",
      "default": "#e0d9ce"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accento oro",
      "default": "#c4964a"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Sfondo card",
      "default": "#f9f6f1"
    },
    {
      "type": "header",
      "content": "Istruzioni lavaggio"
    },
    {
      "type": "checkbox",
      "id": "care_wash_yes",
      "label": "Lavabile in lavatrice",
      "default": true
    },
    {
      "type": "text",
      "id": "care_wash_temp",
      "label": "Temperatura lavatrice",
      "default": "max 30°C"
    },
    {
      "type": "checkbox",
      "id": "care_tumble_dry",
      "label": "Asciugatrice consentita",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "care_iron",
      "label": "Stiratura consentita",
      "default": false
    },
    {
      "type": "text",
      "id": "care_iron_temp",
      "label": "Temperatura stiratura (se consentita)",
      "default": "bassa temperatura"
    },
    {
      "type": "checkbox",
      "id": "care_dryclean",
      "label": "Lavaggio a secco consentito",
      "default": false
    },
    {
      "type": "header",
      "content": "Materiali"
    },
    {
      "type": "text",
      "id": "mat_outer",
      "label": "Esterno / Shell"
    },
    {
      "type": "text",
      "id": "mat_lining",
      "label": "Fodera / Interno"
    },
    {
      "type": "text",
      "id": "mat_sole",
      "label": "Suola / Fondo (per scarpe)"
    },
    {
      "type": "text",
      "id": "mat_other",
      "label": "Altro materiale"
    },
    {
      "type": "header",
      "content": "Manutenzione"
    },
    {
      "type": "text",
      "id": "care_storage",
      "label": "Conservazione",
      "default": "Conservare in luogo fresco e asciutto, lontano dalla luce solare diretta."
    },
    {
      "type": "text",
      "id": "care_cleaning",
      "label": "Pulizia"
    },
    {
      "type": "text",
      "id": "care_drying",
      "label": "Asciugatura",
      "default": "Asciugatura all'aria aperta, lontano da fonti di calore dirette."
    },
    {
      "type": "text",
      "id": "care_note",
      "label": "Nota aggiuntiva"
    },
    {
      "type": "text",
      "id": "care_tip",
      "label": "Consiglio BKS"
    },
    {
      "type": "header",
      "content": "Garanzia"
    },
    {
      "type": "text",
      "id": "warranty",
      "label": "Garanzia",
      "default": "2 anni — UE Direttiva 1999/44/CE"
    }
  ],
  "presets": [
    {
      "name": "BKS Care Guide"
    }
  ]
}
{% endschema %}
