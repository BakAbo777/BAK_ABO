{% comment %}
  BakAbo / BKS Hero Video + Image
  File consigliato: sections/bks-hero-video-image.liquid
  Uso: aggiungi la sezione da Theme Editor oppure includila in un template JSON.
{% endcomment %}

<section
  id="BKS-Hero-{{ section.id }}"
  class="bks-hero bks-hero--{{ section.settings.mode }}{% if section.settings.full_height %} bks-hero--full{% endif %}"
  data-bks-hero
>
  <div class="bks-hero__bg" aria-hidden="true">
    {% if section.settings.hero_video != blank %}
      {{ section.settings.hero_video | video_tag:
        autoplay: true,
        loop: true,
        muted: true,
        controls: false,
        playsinline: true,
        class: 'bks-hero__video'
      }}
    {% elsif section.settings.hero_video_url != blank %}
      <video class="bks-hero__video" autoplay muted loop playsinline preload="metadata">
        <source src="{{ section.settings.hero_video_url }}" type="video/mp4">
      </video>
    {% endif %}

    {% if section.settings.hero_image != blank %}
      <picture class="bks-hero__picture">
        <source media="(max-width: 749px)" srcset="{{ section.settings.hero_image_mobile | image_url: width: 1200 }}">
        <img
          class="bks-hero__image"
          src="{{ section.settings.hero_image | image_url: width: 2400 }}"
          alt="{{ section.settings.image_alt | escape }}"
          width="2400"
          height="1400"
          loading="eager"
          fetchpriority="high"
        >
      </picture>
    {% endif %}

    <div class="bks-hero__veil"></div>
    <div class="bks-hero__grain"></div>
    <div class="bks-hero__spotlight"></div>
  </div>

  <div class="bks-hero__inner page-width">
    <div class="bks-hero__content">
      {% if section.settings.kicker != blank %}
        <p class="bks-hero__kicker">{{ section.settings.kicker }}</p>
      {% endif %}

      {% if section.settings.title != blank %}
        <h1 class="bks-hero__title">{{ section.settings.title }}</h1>
      {% endif %}

      {% if section.settings.text != blank %}
        <div class="bks-hero__text rte">{{ section.settings.text }}</div>
      {% endif %}

      <div class="bks-hero__actions">
        {% if section.settings.man_label != blank %}
          <a class="bks-hero__btn bks-hero__btn--man" href="{{ section.settings.man_link }}">
            <span>{{ section.settings.man_label }}</span>
          </a>
        {% endif %}

        {% if section.settings.woman_label != blank %}
          <a class="bks-hero__btn bks-hero__btn--woman" href="{{ section.settings.woman_link }}">
            <span>{{ section.settings.woman_label }}</span>
          </a>
        {% endif %}
      </div>
    </div>

    {% if section.settings.show_split_cards %}
      <div class="bks-hero__cards" aria-label="BKS collections">
        <a class="bks-hero__card bks-hero__card--man" href="{{ section.settings.man_link }}">
          <small>{{ section.settings.man_subtitle }}</small>
          <strong>{{ section.settings.man_card_title }}</strong>
        </a>
        <a class="bks-hero__card bks-hero__card--woman" href="{{ section.settings.woman_link }}">
          <small>{{ section.settings.woman_subtitle }}</small>
          <strong>{{ section.settings.woman_card_title }}</strong>
        </a>
      </div>
    {% endif %}
  </div>
</section>

<style>
  #BKS-Hero-{{ section.id }} {
    --bks-bg: {% if section.settings.mode == 'woman' %}#050505{% else %}#f7f4ef{% endif %};
    --bks-text: {% if section.settings.mode == 'woman' %}#ffffff{% else %}#080808{% endif %};
    --bks-muted: {% if section.settings.mode == 'woman' %}rgba(255,255,255,.68){% else %}rgba(0,0,0,.62){% endif %};
    --bks-line: {% if section.settings.mode == 'woman' %}rgba(255,255,255,.24){% else %}rgba(0,0,0,.20){% endif %};
    --bks-glow: {{ section.settings.glow_color }};
    position: relative;
    min-height: {{ section.settings.min_height }}vh;
    overflow: hidden;
    isolation: isolate;
    color: var(--bks-text);
    background: var(--bks-bg);
  }

  #BKS-Hero-{{ section.id }}.bks-hero--full { min-height: 100svh; }

  #BKS-Hero-{{ section.id }} .bks-hero__bg,
  #BKS-Hero-{{ section.id }} .bks-hero__picture,
  #BKS-Hero-{{ section.id }} .bks-hero__image,
  #BKS-Hero-{{ section.id }} .bks-hero__video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  #BKS-Hero-{{ section.id }} .bks-hero__image,
  #BKS-Hero-{{ section.id }} .bks-hero__video {
    object-fit: cover;
    transform: scale(1.04);
    filter: saturate({{ section.settings.saturation }}%) contrast({{ section.settings.contrast }}%);
  }

  #BKS-Hero-{{ section.id }} .bks-hero__veil {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at var(--mx, 50%) var(--my, 50%), rgba(255,255,255,.18), transparent 22rem),
      linear-gradient(90deg, rgba(0,0,0,.62), rgba(0,0,0,.22) 45%, rgba(0,0,0,.68));
    opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    z-index: 1;
  }

  #BKS-Hero-{{ section.id }}.bks-hero--man .bks-hero__veil {
    background:
      radial-gradient(circle at var(--mx, 50%) var(--my, 50%), rgba(255,255,255,.35), transparent 24rem),
      linear-gradient(90deg, rgba(255,255,255,.78), rgba(255,255,255,.22) 52%, rgba(0,0,0,.26));
  }

  #BKS-Hero-{{ section.id }} .bks-hero__grain {
    position: absolute;
    inset: -20%;
    z-index: 2;
    pointer-events: none;
    opacity: .14;
    background-image:
      linear-gradient(115deg, transparent 0 47%, rgba(255,255,255,.22) 48% 49%, transparent 50%),
      repeating-linear-gradient(90deg, rgba(255,255,255,.05) 0 1px, transparent 1px 7px);
    mix-blend-mode: overlay;
    animation: bksDrift 16s linear infinite;
  }

  #BKS-Hero-{{ section.id }} .bks-hero__spotlight {
    position: absolute;
    width: 34rem;
    height: 34rem;
    left: calc(var(--mx, 50%) - 17rem);
    top: calc(var(--my, 50%) - 17rem);
    z-index: 3;
    pointer-events: none;
    border-radius: 999px;
    background: radial-gradient(circle, color-mix(in srgb, var(--bks-glow), transparent 25%), transparent 64%);
    opacity: {{ section.settings.mouse_glow | divided_by: 100.0 }};
    filter: blur(28px);
    transform: translateZ(0);
  }

  #BKS-Hero-{{ section.id }} .bks-hero__inner {
    position: relative;
    z-index: 5;
    min-height: inherit;
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(280px, .95fr);
    gap: clamp(24px, 5vw, 72px);
    align-items: end;
    padding-top: clamp(92px, 10vw, 150px);
    padding-bottom: clamp(42px, 7vw, 96px);
  }

  #BKS-Hero-{{ section.id }} .bks-hero__content {
    max-width: 760px;
    transform: translate3d(calc(var(--px, 0) * -14px), calc(var(--py, 0) * -10px), 0);
    transition: transform .18s ease-out;
  }

  #BKS-Hero-{{ section.id }} .bks-hero__kicker {
    margin: 0 0 16px;
    letter-spacing: .28em;
    text-transform: uppercase;
    font-size: clamp(11px, 1vw, 13px);
    color: var(--bks-muted);
  }

  #BKS-Hero-{{ section.id }} .bks-hero__title {
    margin: 0;
    font-size: clamp(48px, 9vw, 132px);
    line-height: .86;
    letter-spacing: -.07em;
    font-weight: 500;
    text-transform: uppercase;
    text-wrap: balance;
  }

  #BKS-Hero-{{ section.id }} .bks-hero__text {
    margin-top: clamp(18px, 3vw, 30px);
    max-width: 560px;
    color: var(--bks-muted);
    font-size: clamp(14px, 1.2vw, 18px);
    line-height: 1.55;
  }

  #BKS-Hero-{{ section.id }} .bks-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: clamp(24px, 4vw, 42px);
  }

  #BKS-Hero-{{ section.id }} .bks-hero__btn {
    position: relative;
    display: inline-flex;
    min-width: 168px;
    min-height: 50px;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    border: 1px solid var(--bks-line);
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: .18em;
    font-size: 12px;
    color: var(--bks-text);
    backdrop-filter: blur(16px);
    background: rgba(255,255,255,.08);
    transition: transform .35s cubic-bezier(.2,.8,.2,1), border-color .35s ease, background .35s ease;
  }

  #BKS-Hero-{{ section.id }} .bks-hero__btn::before {
    content: '';
    position: absolute;
    inset: 0;
    transform: translateX(-105%) skewX(-18deg);
    background: linear-gradient(90deg, transparent, rgba(255,255,255,.45), transparent);
    transition: transform .7s cubic-bezier(.2,.8,.2,1);
  }

  #BKS-Hero-{{ section.id }} .bks-hero__btn:hover {
    transform: translateY(-3px);
    border-color: currentColor;
    background: rgba(255,255,255,.18);
  }

  #BKS-Hero-{{ section.id }} .bks-hero__btn:hover::before { transform: translateX(105%) skewX(-18deg); }
  #BKS-Hero-{{ section.id }} .bks-hero__btn span { position: relative; z-index: 1; }

  #BKS-Hero-{{ section.id }} .bks-hero__cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    align-self: end;
    transform: translate3d(calc(var(--px, 0) * 18px), calc(var(--py, 0) * 14px), 0);
    transition: transform .18s ease-out;
  }

  #BKS-Hero-{{ section.id }} .bks-hero__card {
    min-height: clamp(180px, 26vw, 330px);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    gap: 8px;
    padding: clamp(18px, 3vw, 32px);
    border: 1px solid var(--bks-line);
    text-decoration: none;
    overflow: hidden;
    position: relative;
    transition: transform .4s cubic-bezier(.2,.8,.2,1), filter .4s ease;
  }

  #BKS-Hero-{{ section.id }} .bks-hero__card--man {
    background: rgba(255,255,255,.86);
    color: #050505;
  }

  #BKS-Hero-{{ section.id }} .bks-hero__card--woman {
    background: rgba(0,0,0,.82);
    color: #fff;
  }

  #BKS-Hero-{{ section.id }} .bks-hero__card::after {
    content: '';
    position: absolute;
    inset: auto -20% -40% -20%;
    height: 70%;
    background: radial-gradient(circle, var(--bks-glow), transparent 60%);
    opacity: .28;
    transition: transform .45s ease, opacity .45s ease;
  }

  #BKS-Hero-{{ section.id }} .bks-hero__card:hover {
    transform: translateY(-6px) scale(1.015);
    filter: contrast(1.05);
  }

  #BKS-Hero-{{ section.id }} .bks-hero__card:hover::after {
    transform: translateY(-18%);
    opacity: .48;
  }

  #BKS-Hero-{{ section.id }} .bks-hero__card small,
  #BKS-Hero-{{ section.id }} .bks-hero__card strong {
    position: relative;
    z-index: 1;
  }

  #BKS-Hero-{{ section.id }} .bks-hero__card small {
    text-transform: uppercase;
    letter-spacing: .22em;
    font-size: 11px;
    opacity: .68;
  }

  #BKS-Hero-{{ section.id }} .bks-hero__card strong {
    font-size: clamp(28px, 4vw, 56px);
    line-height: .9;
    letter-spacing: -.055em;
    text-transform: uppercase;
    font-weight: 500;
  }

  @keyframes bksDrift {
    from { transform: translate3d(0,0,0) rotate(0deg); }
    to { transform: translate3d(5%,3%,0) rotate(1deg); }
  }

  @media screen and (max-width: 989px) {
    #BKS-Hero-{{ section.id }} .bks-hero__inner {
      grid-template-columns: 1fr;
      align-items: end;
    }
    #BKS-Hero-{{ section.id }} .bks-hero__cards { max-width: 720px; }
  }

  @media screen and (max-width: 749px) {
    #BKS-Hero-{{ section.id }} { min-height: {{ section.settings.mobile_min_height }}svh; }
    #BKS-Hero-{{ section.id }} .bks-hero__inner {
      padding-top: 92px;
      padding-bottom: 30px;
    }
    #BKS-Hero-{{ section.id }} .bks-hero__actions,
    #BKS-Hero-{{ section.id }} .bks-hero__cards { grid-template-columns: 1fr; }
    #BKS-Hero-{{ section.id }} .bks-hero__cards { display: {% if section.settings.show_cards_mobile %}grid{% else %}none{% endif %}; }
    #BKS-Hero-{{ section.id }} .bks-hero__btn { width: 100%; }
    #BKS-Hero-{{ section.id }} .bks-hero__card { min-height: 132px; }
  }

  @media (prefers-reduced-motion: reduce) {
    #BKS-Hero-{{ section.id }} *,
    #BKS-Hero-{{ section.id }} *::before,
    #BKS-Hero-{{ section.id }} *::after {
      animation: none !important;
      transition: none !important;
    }
  }
</style>

<script>
  (() => {
    const hero = document.querySelector('#BKS-Hero-{{ section.id }}[data-bks-hero]');
    if (!hero || window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    const update = (event) => {
      const rect = hero.getBoundingClientRect();
      const x = Math.max(0, Math.min(1, (event.clientX - rect.left) / rect.width));
      const y = Math.max(0, Math.min(1, (event.clientY - rect.top) / rect.height));
      hero.style.setProperty('--mx', `${x * 100}%`);
      hero.style.setProperty('--my', `${y * 100}%`);
      hero.style.setProperty('--px', (x - 0.5).toFixed(3));
      hero.style.setProperty('--py', (y - 0.5).toFixed(3));
    };

    hero.addEventListener('pointermove', update, { passive: true });
    hero.addEventListener('pointerleave', () => {
      hero.style.setProperty('--mx', '50%');
      hero.style.setProperty('--my', '50%');
      hero.style.setProperty('--px', '0');
      hero.style.setProperty('--py', '0');
    });
  })();
</script>

{% schema %}
{
  "name": "BKS Hero Video + Image",
  "tag": "section",
  "class": "section-bks-hero-video-image",
  "settings": [
    {
      "type": "select",
      "id": "mode",
      "label": "Contesto visivo",
      "default": "man",
      "options": [
        { "value": "man", "label": "Light code / bianco testo nero" },
        { "value": "woman", "label": "Dark code / nero testo bianco" }
      ]
    },
    { "type": "checkbox", "id": "full_height", "label": "Hero a schermo intero", "default": true },
    { "type": "range", "id": "min_height", "label": "Altezza desktop", "min": 60, "max": 100, "step": 5, "unit": "vh", "default": 90 },
    { "type": "range", "id": "mobile_min_height", "label": "Altezza mobile", "min": 70, "max": 100, "step": 5, "unit": "vh", "default": 90 },
    { "type": "video", "id": "hero_video", "label": "Video hero Shopify" },
    { "type": "url", "id": "hero_video_url", "label": "Video hero MP4 esterno / CDN" },
    { "type": "image_picker", "id": "hero_image", "label": "Immagine hero desktop / fallback" },
    { "type": "image_picker", "id": "hero_image_mobile", "label": "Immagine hero mobile" },
    { "type": "text", "id": "image_alt", "label": "Alt immagine SEO", "default": "BakAbo container with BKS Studio creator collection" },
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "BakAbo container / Creator: BKS Studio" },
    { "type": "text", "id": "title", "label": "Titolo", "default": "BKS Studio Catalog" },
    { "type": "richtext", "id": "text", "label": "Testo", "default": "<p>Wearable art, resort energy and geometric visual identity inside the BakAbo container.</p>" },
    { "type": "text", "id": "man_label", "label": "Bottone Light code", "default": "Explore Light Code" },
    { "type": "url", "id": "man_link", "label": "Link Light code" },
    { "type": "text", "id": "woman_label", "label": "Bottone Dark code", "default": "Explore Dark Code" },
    { "type": "url", "id": "woman_link", "label": "Link Dark code" },
    { "type": "checkbox", "id": "show_split_cards", "label": "Mostra card Light/Dark code", "default": true },
    { "type": "checkbox", "id": "show_cards_mobile", "label": "Mostra card anche su mobile", "default": true },
    { "type": "text", "id": "man_subtitle", "label": "Sottotitolo card Light code", "default": "White field" },
    { "type": "text", "id": "man_card_title", "label": "Titolo card Light code", "default": "Light Code" },
    { "type": "text", "id": "woman_subtitle", "label": "Sottotitolo card Dark code", "default": "Black field" },
    { "type": "text", "id": "woman_card_title", "label": "Titolo card Dark code", "default": "Dark Code" },
    { "type": "color", "id": "glow_color", "label": "Colore glow mouse", "default": "#b58cff" },
    { "type": "range", "id": "mouse_glow", "label": "Intensità glow mouse", "min": 0, "max": 100, "step": 5, "unit": "%", "default": 35 },
    { "type": "range", "id": "overlay_opacity", "label": "Overlay", "min": 0, "max": 100, "step": 5, "unit": "%", "default": 75 },
    { "type": "range", "id": "saturation", "label": "Saturazione media", "min": 70, "max": 140, "step": 5, "unit": "%", "default": 100 },
    { "type": "range", "id": "contrast", "label": "Contrasto media", "min": 80, "max": 140, "step": 5, "unit": "%", "default": 105 }
  ],
  "presets": [
    {
      "name": "BKS Hero Video + Image",
      "category": "BakAbo"
    }
  ]
}
{% endschema %}
