{% comment %}
  BKS Studio — Slogan Strip v2
  File: sections/bks-rich-text.liquid
  Modalità: static | ticker | fade
  Collection-aware via metafield custom.slogan
  Zero dipendenze esterne. CSS-only per ticker. JS vanilla inline per fade.
{% endcomment %}

{%- liquid
  assign sid = section.id
  assign mode = section.settings.mode | default: 'static'

  assign slogan_text = section.settings.slogan
  if section.settings.use_collection_metafield and collection != blank
    assign col_slogan = collection.metafields.custom.slogan.value | default: collection.metafields.custom.slogan
    if col_slogan != blank
      assign slogan_text = col_slogan
    endif
  endif

  assign slogan_text = slogan_text | default: 'AI-generated prints · Eight editorial collections · Made to order'

  assign t2 = section.settings.slogan_2 | default: ''
  assign t3 = section.settings.slogan_3 | default: ''
  assign t4 = section.settings.slogan_4 | default: ''
  assign t5 = section.settings.slogan_5 | default: ''
-%}

<style>
  /* ── WRAPPER ─────────────────────────────────────────────── */
  #shopify-section-{{ sid }} {
    position: relative;
    z-index: 1;
    margin-bottom: {{ section.settings.margin_bottom }}px;
    background: {{ section.settings.background_color }};
    border-top:    {% if section.settings.show_border %}1px solid {{ section.settings.border_color }}{% else %}none{% endif %};
    border-bottom: {% if section.settings.show_border %}1px solid {{ section.settings.border_color }}{% else %}none{% endif %};
    overflow: hidden;
  }

  /* ── BASE TEXT ───────────────────────────────────────────── */
  #shopify-section-{{ sid }} .bks-sl__text {
    font-family: var(--bks-font-body, sans-serif);
    font-size: clamp(11px, {{ section.settings.font_size_fluid }}vw, {{ section.settings.font_size_max }}px);
    font-weight: {{ section.settings.font_weight }};
    letter-spacing: {{ section.settings.letter_spacing }}em;
    line-height: 1;
    text-transform: {% if section.settings.uppercase %}uppercase{% else %}none{% endif %};
    font-style: {% if section.settings.italic %}italic{% else %}normal{% endif %};
    color: {{ section.settings.text_color }};
  }

  /* ── STATIC ──────────────────────────────────────────────── */
  #shopify-section-{{ sid }} .bks-sl--static {
    display: flex;
    align-items: center;
    justify-content: {{ section.settings.alignment }};
    padding: {{ section.settings.padding_v }}px {{ section.settings.padding_h }}px;
    min-height: {{ section.settings.min_height }}px;
  }
  #shopify-section-{{ sid }} .bks-sl--static .bks-sl__text {
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 100%;
  }

  /* ── TICKER ──────────────────────────────────────────────── */
  #shopify-section-{{ sid }} .bks-sl--ticker {
    display: flex;
    align-items: center;
    min-height: {{ section.settings.min_height }}px;
    padding: {{ section.settings.padding_v }}px 0;
  }
  #shopify-section-{{ sid }} .bks-sl__track {
    display: flex;
    white-space: nowrap;
    animation: bks-ticker-{{ sid }} {{ section.settings.ticker_speed }}s linear infinite;
    will-change: transform;
  }
  #shopify-section-{{ sid }} .bks-sl__track:hover {
    animation-play-state: {% if section.settings.ticker_pause_hover %}paused{% else %}running{% endif %};
  }
  #shopify-section-{{ sid }} .bks-sl__item {
    display: inline-flex;
    align-items: center;
    padding: 0 {{ section.settings.ticker_gap }}px;
  }
  #shopify-section-{{ sid }} .bks-sl__sep {
    display: inline-block;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: {{ section.settings.text_color }};
    opacity: 0.4;
    margin: 0 {{ section.settings.ticker_gap | divided_by: 2 }}px;
    vertical-align: middle;
    flex-shrink: 0;
  }
  @keyframes bks-ticker-{{ sid }} {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  /* ── FADE ────────────────────────────────────────────────── */
  #shopify-section-{{ sid }} .bks-sl--fade {
    display: flex;
    align-items: center;
    justify-content: {{ section.settings.alignment }};
    padding: {{ section.settings.padding_v }}px {{ section.settings.padding_h }}px;
    min-height: {{ section.settings.min_height }}px;
    position: relative;
  }
  #shopify-section-{{ sid }} .bks-sl__fade-wrap {
    position: relative;
    overflow: hidden;
  }
  #shopify-section-{{ sid }} .bks-sl__fade-item {
    display: block;
    position: absolute;
    top: 0; left: 0;
    opacity: 0;
    white-space: nowrap;
    transition: opacity 0.7s ease;
    pointer-events: none;
  }
  #shopify-section-{{ sid }} .bks-sl__fade-item.is-active {
    opacity: 1;
    position: relative;
    pointer-events: auto;
  }
  #shopify-section-{{ sid }} .bks-sl__fade-item.is-leaving {
    opacity: 0;
    position: absolute;
  }

  /* ── MOBILE ──────────────────────────────────────────────── */
  @media screen and (max-width: 749px) {
    #shopify-section-{{ sid }} .bks-sl__text {
      font-size: clamp(11px, {{ section.settings.font_size_fluid | times: 2.2 }}vw, {{ section.settings.font_size_max }}px);
    }
    #shopify-section-{{ sid }} .bks-sl--static,
    #shopify-section-{{ sid }} .bks-sl--fade {
      justify-content: center;
      padding: {{ section.settings.padding_v | times: 0.75 | round }}px 20px;
    }
  }
</style>

{%- if mode == 'ticker' -%}

  {%- comment %} Build items list for ticker — collect non-empty texts {%- endcomment -%}
  {%- assign ticker_items = slogan_text -%}
  {%- if t2 != blank -%}{%- assign ticker_items = ticker_items | append: '|||' | append: t2 -%}{%- endif -%}
  {%- if t3 != blank -%}{%- assign ticker_items = ticker_items | append: '|||' | append: t3 -%}{%- endif -%}
  {%- if t4 != blank -%}{%- assign ticker_items = ticker_items | append: '|||' | append: t4 -%}{%- endif -%}
  {%- if t5 != blank -%}{%- assign ticker_items = ticker_items | append: '|||' | append: t5 -%}{%- endif -%}
  {%- assign items_arr = ticker_items | split: '|||' -%}

  <div class="bks-sl--ticker">
    {{- '' -}}
    {%- comment %} Duplicate track for seamless loop {%- endcomment -%}
    <div class="bks-sl__track" aria-hidden="false">
      {%- for i in (1..2) -%}
        {%- for item in items_arr -%}
          <span class="bks-sl__item">
            <span class="bks-sl__text">{{ item }}</span>
          </span>
          <span class="bks-sl__sep" aria-hidden="true"></span>
        {%- endfor -%}
      {%- endfor -%}
    </div>
  </div>

{%- elsif mode == 'fade' -%}

  {%- assign fade_items = slogan_text -%}
  {%- if t2 != blank -%}{%- assign fade_items = fade_items | append: '|||' | append: t2 -%}{%- endif -%}
  {%- if t3 != blank -%}{%- assign fade_items = fade_items | append: '|||' | append: t3 -%}{%- endif -%}
  {%- if t4 != blank -%}{%- assign fade_items = fade_items | append: '|||' | append: t4 -%}{%- endif -%}
  {%- if t5 != blank -%}{%- assign fade_items = fade_items | append: '|||' | append: t5 -%}{%- endif -%}
  {%- assign fitems = fade_items | split: '|||' -%}

  <div class="bks-sl--fade">
    <div class="bks-sl__fade-wrap" id="bks-fade-{{ sid }}">
      {%- for fi in fitems -%}
        <span class="bks-sl__fade-item bks-sl__text{% if forloop.first %} is-active{% endif %}"
              data-index="{{ forloop.index0 }}">{{ fi }}</span>
      {%- endfor -%}
    </div>
  </div>

  <script>
  (function(){
    var wrap  = document.getElementById('bks-fade-{{ sid }}');
    if (!wrap) return;
    var items = wrap.querySelectorAll('.bks-sl__fade-item');
    if (items.length < 2) return;
    var cur   = 0;
    var delay = {{ section.settings.fade_interval | times: 1000 }};

    // Set wrap height to max item height to avoid layout shift
    var maxH = 0;
    items.forEach(function(el){
      el.style.position = 'relative';
      maxH = Math.max(maxH, el.offsetHeight);
    });
    items.forEach(function(el){ el.style.position = ''; });
    wrap.style.height = maxH + 'px';

    setInterval(function(){
      var next = (cur + 1) % items.length;
      items[cur].classList.remove('is-active');
      items[cur].classList.add('is-leaving');
      items[next].classList.add('is-active');
      var leaving = items[cur];
      setTimeout(function(){ leaving.classList.remove('is-leaving'); }, 750);
      cur = next;
    }, delay);
  })();
  </script>

{%- else -%}

  <div class="bks-sl--static">
    <p class="bks-sl__text">{{ slogan_text }}</p>
  </div>

{%- endif -%}

{% schema %}
{
  "name": "BKS Slogan",
  "tag": "section",
  "class": "section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [

    { "type": "header", "content": "Modalità" },
    {
      "type": "select",
      "id": "mode",
      "label": "Modalità visualizzazione",
      "options": [
        { "value": "static", "label": "Statico — testo fisso" },
        { "value": "ticker", "label": "Ticker — scorrimento continuo" },
        { "value": "fade",   "label": "Fade — alternanza con dissolvenza" }
      ],
      "default": "ticker",
      "info": "Ticker e Fade usano i testi 1-5. Statico usa solo il Testo 1."
    },

    { "type": "header", "content": "Testi" },
    {
      "type": "text",
      "id": "slogan",
      "label": "Testo 1 (principale / fallback)",
      "default": "AI-generated prints · Eight editorial collections · Made to order"
    },
    { "type": "text", "id": "slogan_2", "label": "Testo 2", "default": "BKS Studio · AI-Art Atelier · bakabo.club" },
    { "type": "text", "id": "slogan_3", "label": "Testo 3", "default": "Made to order · 30-Day Returns · 2-Year EU Warranty" },
    { "type": "text", "id": "slogan_4", "label": "Testo 4 (opzionale)" },
    { "type": "text", "id": "slogan_5", "label": "Testo 5 (opzionale)" },
    {
      "type": "checkbox",
      "id": "use_collection_metafield",
      "label": "Auto slogan from collection",
      "info": "On collection pages, replaces Text 1 with the collection metafield custom.slogan. Falls back to Text 1 if empty.",
      "default": true
    },

    { "type": "header", "content": "Ticker — opzioni" },
    {
      "type": "range",
      "id": "ticker_speed",
      "min": 10, "max": 80, "step": 5, "unit": "s",
      "label": "Velocità scorrimento",
      "default": 30,
      "info": "Valore più alto = più lento."
    },
    {
      "type": "range",
      "id": "ticker_gap",
      "min": 24, "max": 120, "step": 8, "unit": "px",
      "label": "Spazio tra elementi",
      "default": 56
    },
    {
      "type": "checkbox",
      "id": "ticker_pause_hover",
      "label": "Pausa al passaggio del mouse",
      "default": true
    },

    { "type": "header", "content": "Fade — opzioni" },
    {
      "type": "range",
      "id": "fade_interval",
      "min": 2, "max": 10, "step": 1, "unit": "s",
      "label": "Intervallo cambio testo",
      "default": 4
    },

    { "type": "header", "content": "Tipografia" },
    {
      "type": "select",
      "id": "font_weight",
      "label": "Peso",
      "options": [
        { "value": "300", "label": "Light"    },
        { "value": "400", "label": "Regular"  },
        { "value": "500", "label": "Medium"   },
        { "value": "600", "label": "Semibold" }
      ],
      "default": "400"
    },
    {
      "type": "select",
      "id": "letter_spacing",
      "label": "Spaziatura lettere",
      "options": [
        { "value": "0",    "label": "Nessuna"     },
        { "value": "0.1",  "label": "Stretta"     },
        { "value": "0.2",  "label": "Media"       },
        { "value": "0.35", "label": "Larga"       },
        { "value": "0.5",  "label": "Molto larga" }
      ],
      "default": "0.2"
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Allineamento (statico/fade)",
      "options": [
        { "value": "flex-start", "label": "Sinistra" },
        { "value": "center",     "label": "Centro"   },
        { "value": "flex-end",   "label": "Destra"   }
      ],
      "default": "center"
    },
    { "type": "range", "id": "font_size_fluid", "min": 1,  "max": 4,  "step": 0.5, "unit": "vw", "label": "Dimensione fluida",  "default": 1  },
    { "type": "range", "id": "font_size_max",   "min": 12, "max": 32, "step": 1,   "unit": "px", "label": "Dimensione massima", "default": 16 },
    { "type": "checkbox", "id": "uppercase", "label": "Maiuscolo", "default": true  },
    { "type": "checkbox", "id": "italic",    "label": "Corsivo",   "default": false },

    { "type": "header", "content": "Colori" },
    { "type": "color", "id": "background_color", "label": "Sfondo", "default": "#0A0A0A" },
    { "type": "color", "id": "text_color",       "label": "Testo",  "default": "#FAFAF7" },
    { "type": "color", "id": "border_color",     "label": "Bordi",  "default": "#1A1A1A" },
    { "type": "checkbox", "id": "show_border",   "label": "Mostra bordi top/bottom", "default": false },

    { "type": "header", "content": "Spaziatura" },
    { "type": "range", "id": "min_height",    "min": 32, "max": 120, "step": 4, "unit": "px", "label": "Altezza minima",      "default": 48 },
    { "type": "range", "id": "padding_v",     "min": 8,  "max": 48,  "step": 4, "unit": "px", "label": "Padding verticale",   "default": 16 },
    { "type": "range", "id": "padding_h",     "min": 0,  "max": 80,  "step": 8, "unit": "px", "label": "Padding orizzontale", "default": 40 },
    { "type": "range", "id": "margin_bottom", "min": 0,  "max": 80,  "step": 4, "unit": "px", "label": "Margine inferiore",   "default": 0  }
  ],

  "presets": [
    {
      "name": "BKS Slogan — Ticker",
      "settings": {
        "mode": "ticker",
        "slogan":   "AI-generated prints · Eight editorial collections · Made to order",
        "slogan_2": "BKS Studio · AI-Art Atelier · bakabo.club",
        "slogan_3": "Made to order · 30-Day Returns · 2-Year EU Warranty",
        "ticker_speed": 30,
        "ticker_gap": 56,
        "ticker_pause_hover": true,
        "uppercase": true,
        "letter_spacing": "0.2",
        "background_color": "#0A0A0A",
        "text_color": "#FAFAF7",
        "show_border": false,
        "min_height": 48
      }
    },
    {
      "name": "BKS Slogan — Fade",
      "settings": {
        "mode": "fade",
        "slogan":   "AI-generated prints · Eight editorial collections",
        "slogan_2": "Designed by algorithm. Curated by hand.",
        "slogan_3": "Made to order · 30-Day Returns",
        "fade_interval": 4,
        "uppercase": true,
        "alignment": "center",
        "background_color": "#EFEAE0",
        "text_color": "#0A0A0A",
        "show_border": true,
        "border_color": "#D0C8B8",
        "min_height": 52
      }
    },
    {
      "name": "BKS Slogan — Static",
      "settings": {
        "mode": "static",
        "slogan": "AI-generated prints · Eight editorial collections · Made to order",
        "use_collection_metafield": true,
        "uppercase": true,
        "alignment": "center",
        "background_color": "#ffffff",
        "text_color": "#0A0A0A",
        "show_border": true,
        "border_color": "#e8e8e8",
        "min_height": 52
      }
    }
  ]
}
{% endschema %}
