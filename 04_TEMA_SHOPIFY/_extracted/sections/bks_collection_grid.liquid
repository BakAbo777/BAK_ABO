{% comment %}
  BakAbo / BKS Collection Grid
  File: sections/bks-collection-grid.liquid
  Design: Editorial product grid — White & Dark versions
  Usabile come: collection template section O homepage featured collection
{% endcomment %}

{{ 'template-collection.css' | asset_url | stylesheet_tag }}
{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}

{%- unless section.settings.quick_add == 'none' -%}
  {{ 'quick-add.css' | asset_url | stylesheet_tag }}
{%- endunless -%}
{%- if section.settings.quick_add == 'standard' -%}
  <script src="{{ 'quick-add.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

<style>
  /* ================================
     TOKENS
  ================================ */
  #shopify-section-{{ section.id }} {
    --bks-bg:          {{ section.settings.background_color }};
    --bks-text:        {{ section.settings.text_color }};
    --bks-text-muted:  {{ section.settings.muted_color }};
    --bks-border:      {{ section.settings.border_color }};
    --bks-overlay:     {{ section.settings.overlay_color }};
    --bks-accent:      {{ section.settings.accent_color }};
    --bks-accent-text: {{ section.settings.accent_text_color }};
    --bks-cols:        {{ section.settings.columns_desktop }};
    --bks-gap:         {{ section.settings.grid_gap }}px;
    --bks-ratio:       {{ section.settings.image_ratio }};
  }

  /* ================================
     SECTION WRAPPER
  ================================ */
  #shopify-section-{{ section.id }} {
    position: relative;
    z-index: 1;
    background: var(--bks-bg);
    margin-bottom: {{ section.settings.margin_bottom }}px;
  }

  #shopify-section-{{ section.id }} .bks-grid-wrap {
    padding: {{ section.settings.padding_top }}px
             {{ section.settings.padding_h }}px
             {{ section.settings.padding_bottom }}px
             {{ section.settings.padding_h }}px;
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
  }

  /* ================================
     HEADER SEZIONE
  ================================ */
  #shopify-section-{{ section.id }} .bks-grid-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    padding-bottom: 24px;
    border-bottom: 1px solid var(--bks-border);
    margin-bottom: 32px;
    gap: 1rem;
  }

  #shopify-section-{{ section.id }} .bks-grid-header__left {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  #shopify-section-{{ section.id }} .bks-grid-header__eyebrow {
    font-size: 9px;
    font-weight: 600;
    letter-spacing: .32em;
    text-transform: uppercase;
    color: var(--bks-text-muted);
    display: flex;
    align-items: center;
    gap: .6rem;
  }
  #shopify-section-{{ section.id }} .bks-grid-header__eyebrow::before {
    content: '';
    width: 20px; height: 1px;
    background: currentColor;
    display: block;
  }

  #shopify-section-{{ section.id }} .bks-grid-header__title {
    font-size: clamp(22px, 2.8vw, 40px);
    font-weight: 800;
    letter-spacing: -.03em;
    line-height: 1;
    text-transform: uppercase;
    color: var(--bks-text);
    margin: 0;
  }

  #shopify-section-{{ section.id }} .bks-grid-header__count {
    font-size: 10px;
    letter-spacing: .2em;
    text-transform: uppercase;
    color: var(--bks-text-muted);
    align-self: flex-end;
    padding-bottom: 4px;
    white-space: nowrap;
  }

  #shopify-section-{{ section.id }} .bks-grid-header__cta {
    display: inline-flex;
    align-items: center;
    gap: .5rem;
    font-size: 9px;
    font-weight: 700;
    letter-spacing: .24em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--bks-bg);
    background: var(--bks-text);
    padding: 10px 20px;
    border: 1px solid var(--bks-text);
    transition: background .2s, color .2s;
    white-space: nowrap;
  }
  #shopify-section-{{ section.id }} .bks-grid-header__cta:hover {
    background: transparent;
    color: var(--bks-text);
  }
  #shopify-section-{{ section.id }} .bks-grid-header__cta svg {
    width: 11px; height: 11px;
    transition: transform .2s;
  }
  #shopify-section-{{ section.id }} .bks-grid-header__cta:hover svg {
    transform: translateX(3px);
  }

  /* ================================
     GRIGLIA PRODOTTI
  ================================ */
  #shopify-section-{{ section.id }} .bks-grid {
    display: grid;
    grid-template-columns: repeat(var(--bks-cols), 1fr);
    gap: var(--bks-gap);
    list-style: none;
    margin: 0; padding: 0;
  }

  /* Primo prodotto featured — occupa 2 colonne */
  {% if section.settings.featured_first %}
  #shopify-section-{{ section.id }} .bks-grid__item:first-child {
    grid-column: span 2;
  }
  #shopify-section-{{ section.id }} .bks-grid__item:first-child .bks-card__img-wrap {
    aspect-ratio: calc(var(--bks-ratio) * 2 + {{ section.settings.grid_gap }}px / 1px * 0.001);
  }
  {% endif %}

  /* ================================
     CARD
  ================================ */
  #shopify-section-{{ section.id }} .bks-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0;
    cursor: pointer;
    text-decoration: none;
    color: var(--bks-text);
  }

  /* Numero editoriale */
  #shopify-section-{{ section.id }} .bks-card__num {
    position: absolute;
    top: 12px;
    left: 14px;
    z-index: 3;
    font-size: 9px;
    font-weight: 600;
    letter-spacing: .2em;
    color: #ffffff;
    mix-blend-mode: difference;
    pointer-events: none;
    line-height: 1;
  }

  /* Badge NEW / SALE */
  #shopify-section-{{ section.id }} .bks-card__badge {
    position: absolute;
    top: 12px;
    right: 14px;
    z-index: 3;
    font-size: 8px;
    font-weight: 700;
    letter-spacing: .2em;
    text-transform: uppercase;
    padding: 4px 8px;
    line-height: 1;
    pointer-events: none;
  }
  #shopify-section-{{ section.id }} .bks-card__badge--new {
    background: var(--bks-text);
    color: var(--bks-bg);
  }
  #shopify-section-{{ section.id }} .bks-card__badge--sale {
    background: #c0392b;
    color: #fff;
  }

  /* Immagine */
  #shopify-section-{{ section.id }} .bks-card__img-wrap {
    position: relative;
    overflow: hidden;
    aspect-ratio: var(--bks-ratio);
    background: {{ section.settings.img_placeholder_color }};
  }

  #shopify-section-{{ section.id }} .bks-card__img {
    position: absolute;
    inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
    object-position: center top;
    transition: transform .5s cubic-bezier(.25,.46,.45,.94);
    display: block;
  }

  #shopify-section-{{ section.id }} .bks-card__img--secondary {
    opacity: 0;
    transition: opacity .4s ease, transform .5s cubic-bezier(.25,.46,.45,.94);
  }

  #shopify-section-{{ section.id }} .bks-card:hover .bks-card__img--primary {
    {% if section.settings.show_secondary_image %}
    opacity: 0;
    {% endif %}
    transform: scale(1.04);
  }
  #shopify-section-{{ section.id }} .bks-card:hover .bks-card__img--secondary {
    opacity: 1;
    transform: scale(1.04);
  }

  /* Overlay hover */
  #shopify-section-{{ section.id }} .bks-card__overlay {
    position: absolute;
    inset: 0;
    background: var(--bks-overlay);
    display: flex;
    align-items: flex-end;
    justify-content: center;
    padding-bottom: 20px;
    opacity: 0;
    transition: opacity .3s ease;
    z-index: 2;
  }
  #shopify-section-{{ section.id }} .bks-card:hover .bks-card__overlay {
    opacity: 1;
  }

  #shopify-section-{{ section.id }} .bks-card__overlay-btn {
    font-size: 9px;
    font-weight: 700;
    letter-spacing: .24em;
    text-transform: uppercase;
    color: #fff;
    background: transparent;
    border: 1px solid rgba(255,255,255,.7);
    padding: 10px 22px;
    display: inline-flex;
    align-items: center;
    gap: .5rem;
    text-decoration: none;
    transform: translateY(8px);
    transition: transform .3s ease, background .2s, border-color .2s;
  }
  #shopify-section-{{ section.id }} .bks-card:hover .bks-card__overlay-btn {
    transform: translateY(0);
  }
  #shopify-section-{{ section.id }} .bks-card__overlay-btn:hover {
    background: rgba(255,255,255,.15);
    border-color: #fff;
  }

  /* Info prodotto */
  #shopify-section-{{ section.id }} .bks-card__info {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: .5rem;
    padding: 12px 0 0;
    border-top: 1px solid var(--bks-border);
    margin-top: 0;
  }

  #shopify-section-{{ section.id }} .bks-card__name {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: .16em;
    text-transform: uppercase;
    color: var(--bks-text);
    line-height: 1.4;
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  #shopify-section-{{ section.id }} .bks-card__price {
    font-size: 11px;
    font-weight: 300;
    letter-spacing: .08em;
    color: var(--bks-text);
    white-space: nowrap;
    text-align: right;
  }

  #shopify-section-{{ section.id }} .bks-card__price s {
    color: var(--bks-text-muted);
    font-size: 10px;
    display: block;
  }

  #shopify-section-{{ section.id }} .bks-card__vendor {
    font-size: 9px;
    letter-spacing: .16em;
    text-transform: uppercase;
    color: var(--bks-text-muted);
    margin-top: 3px;
  }

  /* ================================
     SOLD OUT / UNAVAILABLE
  ================================ */
  #shopify-section-{{ section.id }} .bks-card--sold-out .bks-card__img {
    filter: grayscale(30%);
    opacity: .7;
  }
  #shopify-section-{{ section.id }} .bks-card--sold-out .bks-card__name {
    opacity: .5;
  }

  /* ================================
     EMPTY STATE
  ================================ */
  #shopify-section-{{ section.id }} .bks-grid-empty {
    padding: 80px 0;
    text-align: center;
    color: var(--bks-text-muted);
    font-size: 12px;
    letter-spacing: .2em;
    text-transform: uppercase;
    border-top: 1px solid var(--bks-border);
    border-bottom: 1px solid var(--bks-border);
  }

  /* ================================
     PAGINAZIONE
  ================================ */
  #shopify-section-{{ section.id }} .bks-pagination {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: .5rem;
    margin-top: 48px;
    padding-top: 24px;
    border-top: 1px solid var(--bks-border);
  }

  /* ================================
     TABLET 750–989px
  ================================ */
  @media screen and (min-width: 750px) and (max-width: 989px) {
    #shopify-section-{{ section.id }} {
      --bks-cols: {{ section.settings.columns_desktop | minus: 1 | at_least: 2 }};
    }
    {% if section.settings.featured_first %}
    #shopify-section-{{ section.id }} .bks-grid__item:first-child {
      grid-column: span 2;
    }
    {% endif %}
  }

  /* ================================
     MOBILE < 750px
  ================================ */
  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} {
      --bks-cols: {{ section.settings.columns_mobile }};
      --bks-gap: {{ section.settings.grid_gap | times: 0.6 | round }}px;
    }

    #shopify-section-{{ section.id }} .bks-grid-wrap {
      padding: {{ section.settings.padding_top | times: 0.65 | round }}px 16px
               {{ section.settings.padding_bottom | times: 0.65 | round }}px;
    }

    /* Reset featured su mobile */
    #shopify-section-{{ section.id }} .bks-grid__item:first-child {
      grid-column: span 1 !important;
    }
    #shopify-section-{{ section.id }} .bks-grid__item:first-child .bks-card__img-wrap {
      aspect-ratio: var(--bks-ratio) !important;
    }

    #shopify-section-{{ section.id }} .bks-grid-header {
      flex-wrap: wrap;
      gap: 12px;
      margin-bottom: 20px;
    }
    #shopify-section-{{ section.id }} .bks-grid-header__title {
      font-size: clamp(20px, 7vw, 32px);
    }
    #shopify-section-{{ section.id }} .bks-grid-header__cta {
      width: 100%;
      justify-content: center;
    }
    #shopify-section-{{ section.id }} .bks-card__num { display: none; }
    #shopify-section-{{ section.id }} .bks-card__overlay { display: none; }
    #shopify-section-{{ section.id }} .bks-card__name { font-size: 9px; }
    #shopify-section-{{ section.id }} .bks-card__price { font-size: 10px; }
    #shopify-section-{{ section.id }} .bks-card__info { padding-top: 8px; }
    #shopify-section-{{ section.id }} { margin-bottom: {{ section.settings.margin_bottom | times: 0.6 | round }}px; }
  }

  @media screen and (max-width: 390px) {
    #shopify-section-{{ section.id }} .bks-grid-wrap { padding-left: 12px; padding-right: 12px; }
  }
</style>

{%- liquid
  assign collection_source = section.settings.collection
  if collection_source == blank
    assign collection_source = collection
  endif

  assign cta_url = section.settings.cta_link
  if cta_url == blank and collection_source != blank
    assign cta_url = collection_source.url
  endif
-%}

<div class="bks-grid-wrap">

  {% comment %} ── HEADER ── {% endcomment %}
  {%- if section.settings.show_header -%}
  <div class="bks-grid-header">
    <div class="bks-grid-header__left">
      {%- if section.settings.eyebrow != blank -%}
        <span class="bks-grid-header__eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      {%- if section.settings.title != blank -%}
        <h2 class="bks-grid-header__title">{{ section.settings.title }}</h2>
      {%- endif -%}
    </div>

    <div style="display:flex;align-items:center;gap:1.5rem;flex-shrink:0;">
      {%- if collection_source != blank -%}
        <span class="bks-grid-header__count">
          {{ collection_source.products_count }}
          {%- if collection_source.products_count == 1 %} item{% else %} items{% endif %}
        </span>
      {%- endif -%}
      {%- if section.settings.cta_label != blank and cta_url != blank -%}
        <a href="{{ cta_url }}" class="bks-grid-header__cta">
          {{ section.settings.cta_label }}
          <svg viewBox="0 0 11 11" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M1 5.5h9M6 1l4 4.5L6 10" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      {%- endif -%}
    </div>
  </div>
  {%- endif -%}

  {% comment %} ── GRIGLIA ── {% endcomment %}
  {%- if collection_source != blank and collection_source.products_count > 0 -%}

    {%- paginate collection_source.products by section.settings.products_per_page -%}
    <ul class="bks-grid" id="bks-product-grid-{{ section.id }}">
      {%- for product in collection_source.products -%}

        {%- assign card_num = forloop.index -%}
        {%- assign num_display = forloop.index | prepend: '0' | slice: -2, 2 -%}

        <li class="bks-grid__item{% if product.available == false %} bks-card--sold-out{% endif %}">
          <a href="{{ product.url }}" class="bks-card" aria-label="{{ product.title | escape }}">

            {% comment %} Numero editoriale {% endcomment %}
            {%- if section.settings.show_numbers -%}
              <span class="bks-card__num" aria-hidden="true">{{ num_display }}</span>
            {%- endif -%}

            {% comment %} Badge {% endcomment %}
            {%- if product.available == false -%}
              <span class="bks-card__badge bks-card__badge--new">Sold Out</span>
            {%- elsif product.tags contains 'new' or forloop.index <= 2 and section.settings.show_new_badge -%}
              <span class="bks-card__badge bks-card__badge--new">New</span>
            {%- elsif product.compare_at_price > product.price -%}
              <span class="bks-card__badge bks-card__badge--sale">Sale</span>
            {%- endif -%}

            {% comment %} Immagine {% endcomment %}
            <div class="bks-card__img-wrap">
              {%- if product.featured_media -%}
                {{
                  product.featured_media
                  | image_url: width: 800
                  | image_tag:
                    class: 'bks-card__img bks-card__img--primary',
                    loading: 'lazy',
                    widths: '300,400,500,600,800',
                    sizes: '(max-width: 749px) 50vw, 25vw',
                    alt: product.title
                }}
                {%- if section.settings.show_secondary_image and product.media[1] != blank -%}
                  {{
                    product.media[1]
                    | image_url: width: 800
                    | image_tag:
                      class: 'bks-card__img bks-card__img--secondary',
                      loading: 'lazy',
                      widths: '300,400,500,600,800',
                      sizes: '(max-width: 749px) 50vw, 25vw',
                      alt: product.title
                  }}
                {%- endif -%}
              {%- else -%}
                <div style="width:100%;height:100%;background:{{ section.settings.img_placeholder_color }};display:flex;align-items:center;justify-content:center;">
                  {{ 'product-1' | placeholder_svg_tag }}
                </div>
              {%- endif -%}

              {% comment %} Overlay {% endcomment %}
              <div class="bks-card__overlay" aria-hidden="true">
                <span class="bks-card__overlay-btn">
                  View
                  <svg width="11" height="11" viewBox="0 0 11 11" fill="none">
                    <path d="M1 5.5h9M6 1l4 4.5L6 10" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </span>
              </div>
            </div>

            {% comment %} Info {% endcomment %}
            <div class="bks-card__info">
              <div>
                <p class="bks-card__name">{{ product.title }}</p>
                {%- if section.settings.show_vendor -%}
                  <p class="bks-card__vendor">{{ product.vendor }}</p>
                {%- endif -%}
              </div>
              <div class="bks-card__price">
                {%- if product.compare_at_price > product.price -%}
                  <s>{{ product.compare_at_price | money }}</s>
                {%- endif -%}
                {{ product.price | money }}
              </div>
            </div>

          </a>
        </li>

      {%- endfor -%}
    </ul>

    {%- if paginate.pages > 1 -%}
      <div class="bks-pagination">
        {% render 'pagination', paginate: paginate, anchor: '' %}
      </div>
    {%- endif -%}
    {%- endpaginate -%}

  {%- elsif collection_source != blank -%}
    <div class="bks-grid-empty">
      <p>{{ 'sections.collection_template.empty' | t }}</p>
    </div>
  {%- else -%}
    <div class="bks-grid-empty">
      <p>Seleziona una collezione nelle impostazioni della sezione.</p>
    </div>
  {%- endif -%}

</div>

{% schema %}
{
  "name": "BKS Collection Grid",
  "tag": "section",
  "class": "section",
  "settings": [

    { "type": "header", "content": "Collezione" },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collezione",
      "info": "Lascia vuoto se usato come template di collezione."
    },

    { "type": "header", "content": "Header sezione" },
    { "type": "checkbox", "id": "show_header",  "label": "Mostra header",    "default": true  },
    { "type": "text",     "id": "eyebrow",       "label": "Tag sopra titolo", "default": "Collection" },
    { "type": "text",     "id": "title",         "label": "Titolo",           "default": "All Products" },
    { "type": "text",     "id": "cta_label",     "label": "Testo CTA header", "default": "View All" },
    { "type": "url",      "id": "cta_link",      "label": "Link CTA (override)", "info": "Lascia vuoto per usare l'URL della collezione." },

    { "type": "header", "content": "Layout griglia" },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2, "max": 5, "step": 1,
      "label": "Colonne desktop",
      "default": 4
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Colonne mobile",
      "options": [
        { "value": "1", "label": "1 colonna"  },
        { "value": "2", "label": "2 colonne"  }
      ],
      "default": "2"
    },
    {
      "type": "range",
      "id": "grid_gap",
      "min": 8, "max": 48, "step": 4, "unit": "px",
      "label": "Spazio tra card",
      "default": 20
    },
    {
      "type": "range",
      "id": "products_per_page",
      "min": 4, "max": 48, "step": 4,
      "label": "Prodotti per pagina",
      "default": 12
    },
    {
      "type": "checkbox",
      "id": "featured_first",
      "label": "Primo prodotto in evidenza (2 colonne)",
      "default": true
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 960, "max": 1920, "step": 40, "unit": "px",
      "label": "Larghezza massima sezione",
      "default": 1400
    },

    { "type": "header", "content": "Immagini" },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Ratio immagine",
      "options": [
        { "value": "2/3",  "label": "2:3 Portrait (fashion)"  },
        { "value": "3/4",  "label": "3:4 Portrait"            },
        { "value": "1/1",  "label": "1:1 Quadrato"            },
        { "value": "4/3",  "label": "4:3 Landscape"           },
        { "value": "16/9", "label": "16:9 Wide"               }
      ],
      "default": "2/3"
    },
    { "type": "checkbox", "id": "show_secondary_image", "label": "Mostra immagine secondaria al hover", "default": true  },

    { "type": "header", "content": "Card dettagli" },
    { "type": "checkbox", "id": "show_numbers",   "label": "Numerazione editoriale",    "default": true  },
    { "type": "checkbox", "id": "show_new_badge", "label": "Badge NEW sui primi 2",     "default": true  },
    { "type": "checkbox", "id": "show_vendor",    "label": "Mostra brand/vendor",       "default": false },
    {
      "type": "select",
      "id": "quick_add",
      "label": "Quick add",
      "options": [
        { "value": "none",     "label": "Disabilitato" },
        { "value": "standard", "label": "Standard"     }
      ],
      "default": "none"
    },

    { "type": "header", "content": "Tema colori" },
    {
      "type": "select",
