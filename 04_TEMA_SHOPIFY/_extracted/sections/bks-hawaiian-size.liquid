{% comment %}
  BakAbo / BKS Hawaiian Shirt — Guida Taglie
  File: sections/bks-hawaiian-size-guide.liquid
  Pattern: Dawn 15.4 — section-scoped CSS, modal + pulsante editabile
{% endcomment %}

<style>
  /* ── TRIGGER ── */
  #shopify-section-{{ section.id }} .bks-hsg__trigger {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-weight: 500;
    font-family: var(--font-body-family);
    background: {{ section.settings.btn_bg }};
    border: 1px solid {{ section.settings.btn_border_color }};
    color: {{ section.settings.btn_text_color }};
    padding: 10px 18px;
    cursor: pointer;
    transition: background 0.18s, color 0.18s, border-color 0.18s;
  }
  #shopify-section-{{ section.id }} .bks-hsg__trigger:hover {
    background: {{ section.settings.accent_color }};
    color: #080808;
    border-color: {{ section.settings.accent_color }};
  }
  #shopify-section-{{ section.id }} .bks-hsg__trigger svg {
    width: 13px; height: 13px;
    stroke: currentColor; fill: none;
    stroke-width: 1.7; stroke-linecap: round;
  }

  /* ── MODAL OVERLAY ── */
  .bks-hsg-modal {
    position: fixed; inset: 0; z-index: 10000;
    display: flex; align-items: center; justify-content: center;
    padding: 16px;
    background: rgba(8,8,8,0.72);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    opacity: 0; pointer-events: none;
    transition: opacity 0.22s ease;
  }
  .bks-hsg-modal.is-open { opacity: 1; pointer-events: all; }

  .bks-hsg-modal__box {
    background: {{ section.settings.background_color }};
    color: {{ section.settings.text_color }};
    width: 100%; max-width: 780px;
    max-height: 92vh; overflow-y: auto;
    padding: 36px 40px 32px;
    position: relative;
    transform: translateY(14px);
    transition: transform 0.22s ease;
    border-top: 2px solid {{ section.settings.accent_color }};
    font-family: var(--font-body-family);
  }
  .bks-hsg-modal.is-open .bks-hsg-modal__box { transform: translateY(0); }

  .bks-hsg-modal__close {
    position: absolute; top: 16px; right: 18px;
    background: none; border: none;
    font-size: 20px; color: {{ section.settings.muted_color }};
    cursor: pointer; padding: 4px; line-height: 1;
    transition: color 0.15s;
  }
  .bks-hsg-modal__close:hover { color: {{ section.settings.text_color }}; }

  /* ── HEADER ── */
  .bks-hsg__head {
    display: flex; align-items: flex-start;
    justify-content: space-between; gap: 20px;
    margin-bottom: 24px;
    padding-bottom: 20px;
    border-bottom: 1px solid {{ section.settings.border_color }};
    flex-wrap: wrap;
  }
  .bks-hsg__kicker {
    font-size: 10px; letter-spacing: 0.26em;
    text-transform: uppercase; color: {{ section.settings.accent_color }};
    margin: 0 0 6px;
    display: flex; align-items: center; gap: 10px;
  }
  .bks-hsg__kicker::before {
    content: ''; display: block;
    width: 18px; height: 1px; background: {{ section.settings.accent_color }};
  }
  .bks-hsg__title {
    font-size: clamp(17px, 2.2vw, 22px);
    font-weight: 600; letter-spacing: -0.02em;
    text-transform: uppercase; margin: 0;
    color: {{ section.settings.text_color }};
  }

  /* ── UNIT TOGGLE ── */
  .bks-hsg__unit-toggle {
    display: inline-flex;
    border: 1px solid {{ section.settings.border_color }};
    overflow: hidden; align-self: flex-end; flex-shrink: 0;
  }
  .bks-hsg__unit-btn {
    background: none; border: none;
    padding: 7px 16px; font-size: 11px;
    letter-spacing: 0.12em; cursor: pointer;
    color: {{ section.settings.muted_color }};
    font-family: var(--font-body-family);
    transition: all 0.15s;
  }
  .bks-hsg__unit-btn.active {
    background: {{ section.settings.text_color }};
    color: {{ section.settings.background_color }};
  }

  /* ── FINDER ── */
  .bks-hsg__finder {
    background: {{ section.settings.card_bg }};
    border: 1px solid {{ section.settings.border_color }};
    padding: 20px 22px; margin-bottom: 22px;
  }
  .bks-hsg__finder-label {
    font-size: 10px; letter-spacing: 0.22em;
    text-transform: uppercase; color: {{ section.settings.accent_color }};
    margin: 0 0 14px; font-weight: 500;
    display: flex; align-items: center; gap: 8px;
  }
  .bks-hsg__finder-label::before {
    content: ''; display: block;
    width: 14px; height: 1px; background: {{ section.settings.accent_color }};
  }
  .bks-hsg__finder-inputs {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 12px; margin-bottom: 0;
  }
  .bks-hsg__field label {
    display: block; font-size: 10px;
    letter-spacing: 0.14em; text-transform: uppercase;
    color: {{ section.settings.muted_color }}; margin-bottom: 6px;
  }
  .bks-hsg__field input {
    width: 100%; border: 1px solid {{ section.settings.border_color }};
    padding: 9px 12px; font-size: 14px;
    font-family: var(--font-body-family);
    color: {{ section.settings.text_color }};
    background: {{ section.settings.background_color }};
    transition: border-color 0.15s;
    -moz-appearance: textfield;
  }
  .bks-hsg__field input::-webkit-inner-spin-button,
  .bks-hsg__field input::-webkit-outer-spin-button { -webkit-appearance: none; margin: 0; }
  .bks-hsg__field input:focus { outline: none; border-color: {{ section.settings.accent_color }}; }

  .bks-hsg__result {
    display: none; align-items: center; gap: 18px;
    padding-top: 16px; margin-top: 16px;
    border-top: 1px solid {{ section.settings.border_color }};
  }
  .bks-hsg__result.visible { display: flex; }
  .bks-hsg__res-size {
    font-size: 40px; font-weight: 700;
    color: {{ section.settings.text_color }}; min-width: 64px; line-height: 1;
  }
  .bks-hsg__res-badge {
    display: inline-block; font-size: 9px; letter-spacing: 0.18em;
    text-transform: uppercase;
    background: {{ section.settings.accent_color }};
    color: #080808; padding: 3px 10px;
    margin-bottom: 5px; font-weight: 600;
  }
  .bks-hsg__res-info { font-size: 12.5px; color: {{ section.settings.muted_color }}; line-height: 1.5; }

  /* ── MAIN TABLE ── */
  .bks-hsg__table-wrap {
    border: 1px solid {{ section.settings.border_color }};
    overflow: hidden; margin-bottom: 20px;
    overflow-x: auto;
  }
  .bks-hsg__table {
    width: 100%; border-collapse: collapse;
    font-size: 12.5px; min-width: 600px;
  }
  .bks-hsg__table thead tr {
    background: {{ section.settings.card_bg }};
  }
  .bks-hsg__table thead tr:first-child {
    border-bottom: 1px solid {{ section.settings.border_color }};
  }
  .bks-hsg__table th {
    padding: 9px 12px;
    font-size: 9px; letter-spacing: 0.2em;
    text-transform: uppercase; color: {{ section.settings.muted_color }};
    font-weight: 500; text-align: center; white-space: nowrap;
    border-bottom: 1px solid {{ section.settings.border_color }};
  }
  .bks-hsg__table th:first-child { text-align: left; }

  /* Group header row */
  .bks-hsg__table tr.bks-hsg--group th {
    background: {{ section.settings.card_bg }};
    color: {{ section.settings.accent_color }};
    font-size: 9px; letter-spacing: 0.26em;
    padding: 7px 12px;
    border-top: 2px solid {{ section.settings.border_color }};
    border-bottom: 1px solid {{ section.settings.border_color }};
  }
  .bks-hsg__table tr.bks-hsg--group th:first-child {
    display: flex; align-items: center; gap: 8px;
  }
  .bks-hsg__table tr.bks-hsg--group th:first-child::before {
    content: ''; display: block; width: 12px; height: 1px;
    background: {{ section.settings.accent_color }};
  }

  .bks-hsg__table td {
    padding: 10px 12px;
    border-bottom: 1px solid {{ section.settings.border_color }};
    color: {{ section.settings.muted_color }};
    text-align: center; white-space: nowrap;
  }
  .bks-hsg__table td:first-child {
    text-align: left;
    color: {{ section.settings.muted_color }};
    font-size: 11px; letter-spacing: 0.08em;
    text-transform: uppercase; font-weight: 500;
  }
  .bks-hsg__table tr:last-child td { border-bottom: none; }

  /* Highlighted column */
  .bks-hsg__table td.bks-hsg--hl,
  .bks-hsg__table th.bks-hsg--hl {
    background: {{ section.settings.highlight_bg }};
    color: {{ section.settings.accent_color }};
    font-weight: 600;
  }
  .bks-hsg__table th.bks-hsg--hl {
    color: {{ section.settings.accent_color }};
  }

  /* ── HOW TO MEASURE ── */
  .bks-hsg__how {
    background: {{ section.settings.card_bg }};
    border: 1px solid {{ section.settings.border_color }};
    padding: 18px 20px; margin-bottom: 16px;
  }
  .bks-hsg__how-label {
    font-size: 10px; letter-spacing: 0.22em;
    text-transform: uppercase; color: {{ section.settings.accent_color }};
    margin: 0 0 12px; font-weight: 500;
    display: flex; align-items: center; gap: 8px;
  }
  .bks-hsg__how-label::before {
    content: ''; display: block; width: 14px; height: 1px;
    background: {{ section.settings.accent_color }};
  }
  .bks-hsg__how-grid {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 10px;
  }
  .bks-hsg__how-item {
    display: flex; gap: 10px; align-items: flex-start;
  }
  .bks-hsg__how-dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: {{ section.settings.accent_color }};
    flex-shrink: 0; margin-top: 5px;
  }
  .bks-hsg__how-text strong {
    display: block; font-size: 11px; letter-spacing: 0.08em;
    text-transform: uppercase; color: {{ section.settings.text_color }};
    margin-bottom: 2px; font-weight: 600;
  }
  .bks-hsg__how-text span {
    font-size: 12px; color: {{ section.settings.muted_color }}; line-height: 1.4;
  }

  /* ── TIP ── */
  .bks-hsg__tip {
    font-size: 12.5px; color: {{ section.settings.muted_color }};
    padding: 12px 16px; line-height: 1.55;
    border-left: 3px solid {{ section.settings.accent_color }};
    background: {{ section.settings.card_bg }};
  }
  .bks-hsg__tip strong { color: {{ section.settings.text_color }}; }

  @media screen and (max-width: 600px) {
    .bks-hsg-modal__box { padding: 24px 16px 20px; }
    .bks-hsg__finder-inputs { grid-template-columns: 1fr; }
    .bks-hsg__how-grid { grid-template-columns: 1fr; }
  }
</style>

{%- comment -%} PULSANTE TRIGGER {%- endcomment -%}
<button
  class="bks-hsg__trigger"
  onclick="document.getElementById('BksHsgModal-{{ section.id }}').classList.add('is-open');document.getElementById('BksHsgModal-{{ section.id }}').focus();"
  aria-haspopup="dialog"
  aria-controls="BksHsgModal-{{ section.id }}"
>
  <svg viewBox="0 0 16 16" aria-hidden="true">
    <line x1="1" y1="4" x2="15" y2="4"/>
    <line x1="1" y1="8" x2="11" y2="8"/>
    <line x1="1" y1="12" x2="15" y2="12"/>
  </svg>
  {{ section.settings.trigger_label | default: 'Guida alle taglie' }}
</button>

{%- comment -%} MODAL {%- endcomment -%}
<div
  class="bks-hsg-modal"
  id="BksHsgModal-{{ section.id }}"
  role="dialog"
  aria-modal="true"
  aria-label="Guida alle taglie BKS Hawaiian Shirt"
  tabindex="-1"
  onclick="if(event.target===this)this.classList.remove('is-open')"
>
  <div class="bks-hsg-modal__box">
    <button
      class="bks-hsg-modal__close"
      onclick="document.getElementById('BksHsgModal-{{ section.id }}').classList.remove('is-open')"
      aria-label="Chiudi"
    >&#215;</button>

    <div class="bks-hsg__head">
      <div>
        <p class="bks-hsg__kicker">Bakabo Club · BKS</p>
        <h2 class="bks-hsg__title">{{ section.settings.modal_title | default: 'Guida alle Taglie — Hawaiian Shirt' }}</h2>
      </div>
      <div class="bks-hsg__unit-toggle" role="group" aria-label="Unità di misura">
        <button class="bks-hsg__unit-btn active" onclick="bksHsgUnit('cm','{{ section.id }}',this)" aria-pressed="true">cm</button>
        <button class="bks-hsg__unit-btn" onclick="bksHsgUnit('in','{{ section.id }}',this)" aria-pressed="false">in</button>
      </div>
    </div>

    {%- comment -%} FINDER {%- endcomment -%}
    <div class="bks-hsg__finder">
      <p class="bks-hsg__finder-label">Trova la tua taglia</p>
      <div class="bks-hsg__finder-inputs">
        <div class="bks-hsg__field">
          <label for="bksHsgLen-{{ section.id }}">Lunghezza corporea</label>
          <input type="number" id="bksHsgLen-{{ section.id }}" placeholder="es. 74" oninput="bksHsgFind('{{ section.id }}')" min="50" max="120">
        </div>
        <div class="bks-hsg__field">
          <label for="bksHsgWid-{{ section.id }}">Larghezza (mezzobusto)</label>
          <input type="number" id="bksHsgWid-{{ section.id }}" placeholder="es. 57" oninput="bksHsgFind('{{ section.id }}')" min="40" max="120">
        </div>
      </div>
      <div class="bks-hsg__result" id="bksHsgRes-{{ section.id }}" role="status" aria-live="polite">
        <div class="bks-hsg__res-size" id="bksHsgResS-{{ section.id }}">M</div>
        <div>
          <span class="bks-hsg__res-badge">Taglia consigliata</span>
          <div class="bks-hsg__res-info" id="bksHsgResI-{{ section.id }}"></div>
        </div>
      </div>
    </div>

    {%- comment -%} TABELLA MISURE {%- endcomment -%}
    <div class="bks-hsg__table-wrap">
      <table class="bks-hsg__table" id="bksHsgTab-{{ section.id }}">
        <thead>
          <tr>
            <th>Misura</th>
            <th id="bksHsgTh-{{ section.id }}-S">S</th>
            <th id="bksHsgTh-{{ section.id }}-M">M</th>
            <th id="bksHsgTh-{{ section.id }}-L">L</th>
            <th id="bksHsgTh-{{ section.id }}-XL">XL</th>
            <th id="bksHsgTh-{{ section.id }}-2XL">2XL</th>
            <th id="bksHsgTh-{{ section.id }}-3XL">3XL</th>
            <th id="bksHsgTh-{{ section.id }}-4XL">4XL</th>
            <th id="bksHsgTh-{{ section.id }}-5XL">5XL</th>
          </tr>
        </thead>
        <tbody id="bksHsgBody-{{ section.id }}"></tbody>
      </table>
    </div>

    {%- comment -%} COME MISURARSI {%- endcomment -%}
    <div class="bks-hsg__how">
      <p class="bks-hsg__how-label">Come misurarsi</p>
      <div class="bks-hsg__how-grid">
        <div class="bks-hsg__how-item">
          <span class="bks-hsg__how-dot"></span>
          <div class="bks-hsg__how-text">
            <strong>Lunghezza</strong>
            <span>Dal punto più alto della spalla all'orlo inferiore, tenendosi dritti.</span>
          </div>
        </div>
        <div class="bks-hsg__how-item">
          <span class="bks-hsg__how-dot"></span>
          <div class="bks-hsg__how-text">
            <strong>Larghezza</strong>
            <span>Da ascella ad ascella sul davanti, a giacca stesa piana.</span>
          </div>
        </div>
        <div class="bks-hsg__how-item">
          <span class="bks-hsg__how-dot"></span>
          <div class="bks-hsg__how-text">
            <strong>Lunghezza tasca</strong>
            <span>Dal bordo superiore al bordo inferiore della tasca frontale.</span>
          </div>
        </div>
        <div class="bks-hsg__how-item">
          <span class="bks-hsg__how-dot"></span>
          <div class="bks-hsg__how-text">
            <strong>Larghezza tasca</strong>
            <span>Da un lato all'altro della tasca, misurata orizzontalmente.</span>
          </div>
        </div>
      </div>
    </div>

    <p class="bks-hsg__tip">
      <strong>Fit BKS Hawaiian:</strong> Taglio relaxed, spalle leggermente dropped.
      Per un look oversize scegli una taglia in più, per un fit più aderente vai sulla taglia inferiore.
    </p>
  </div>
</div>

<script>
(function(){
  var SID = '{{ section.id }}';
  var unit = {};
  unit[SID] = 'cm';

  /* Dati capo (misure del capo, non del corpo) */
  var DATA = [
    {s:'S',   len:72.00, wid:52.00, pl:14.48, pw:12.45},
    {s:'M',   len:74.50, wid:57.00, pl:14.99, pw:12.95},
    {s:'L',   len:77.00, wid:62.00, pl:15.49, pw:13.46},
    {s:'XL',  len:79.50, wid:67.00, pl:16.00, pw:14.00},
    {s:'2XL', len:82.00, wid:72.00, pl:16.51, pw:14.48},
    {s:'3XL', len:84.50, wid:77.00, pl:17.02, pw:14.99},
    {s:'4XL', len:87.00, wid:82.00, pl:17.27, pw:15.49},
    {s:'5XL', len:89.50, wid:87.00, pl:17.27, pw:15.49}
  ];

  var ROWS = [
    {key:'len', label:'Lunghezza'},
    {key:'wid', label:'Larghezza'},
    {key:'pl',  label:'Lunghezza tasca'},
    {key:'pw',  label:'Larghezza tasca'}
  ];

  function toIn(v) { return Math.round(v / 2.54 * 100) / 100; }
  function disp(v, sid) { return unit[sid] === 'cm' ? v.toFixed(2) : toIn(v).toFixed(2); }
  function fromInp(v, sid) { return unit[sid] === 'cm' ? parseFloat(v) : parseFloat(v) * 2.54; }
  function u(sid) { return unit[sid]; }

  function render(sid) {
    var body = document.getElementById('bksHsgBody-' + sid);
    if (!body) return;
    body.innerHTML = ROWS.map(function(row) {
      return '<tr>'
        + '<td>' + row.label + ' (' + u(sid) + ')</td>'
        + DATA.map(function(d) {
            return '<td id="bksHsgCell-' + sid + '-' + row.key + '-' + d.s + '">'
              + disp(d[row.key], sid)
              + '</td>';
          }).join('')
        + '</tr>';
    }).join('');
  }

  function clearHighlight(sid) {
    DATA.forEach(function(d) {
      var th = document.getElementById('bksHsgTh-' + sid + '-' + d.s);
      if (th) th.classList.remove('bks-hsg--hl');
      ROWS.forEach(function(row) {
        var cell = document.getElementById('bksHsgCell-' + sid + '-' + row.key + '-' + d.s);
        if (cell) cell.classList.remove('bks-hsg--hl');
      });
    });
  }

  function highlightSize(sid, size) {
    var th = document.getElementById('bksHsgTh-' + sid + '-' + size);
    if (th) th.classList.add('bks-hsg--hl');
    ROWS.forEach(function(row) {
      var cell = document.getElementById('bksHsgCell-' + sid + '-' + row.key + '-' + size);
      if (cell) cell.classList.add('bks-hsg--hl');
    });
  }

  window.bksHsgUnit = function(u, sid, btn) {
    unit[sid] = u;
    btn.parentNode.querySelectorAll('.bks-hsg__unit-btn').forEach(function(b) {
      b.classList.remove('active'); b.setAttribute('aria-pressed', 'false');
    });
    btn.classList.add('active'); btn.setAttribute('aria-pressed', 'true');
    var lenEl = document.getElementById('bksHsgLen-' + sid);
    var widEl = document.getElementById('bksHsgWid-' + sid);
    if (lenEl) lenEl.placeholder = u === 'cm' ? 'es. 74' : 'es. 29';
    if (widEl) widEl.placeholder = u === 'cm' ? 'es. 57' : 'es. 22';
    render(sid);
    bksHsgFind(sid);
  };

  window.bksHsgFind = function(sid) {
    var lenEl = document.getElementById('bksHsgLen-' + sid);
    var widEl = document.getElementById('bksHsgWid-' + sid);
    var res   = document.getElementById('bksHsgRes-' + sid);
    clearHighlight(sid);

    var lenV = lenEl && lenEl.value ? fromInp(lenEl.value, sid) : null;
    var widV = widEl && widEl.value ? fromInp(widEl.value, sid) : null;

    if (!lenV && !widV) { if (res) res.classList.remove('visible'); return; }

    var best = null, bs = Infinity;
    DATA.forEach(function(d) {
      var sc = 0, cnt = 0;
      if (lenV) { sc += Math.abs(lenV - d.len); cnt++; }
      if (widV) { sc += Math.abs(widV - d.wid); cnt++; }
      if (cnt > 0 && sc / cnt < bs) { bs = sc / cnt; best = d; }
    });

    if (best) {
      document.getElementById('bksHsgResS-' + sid).textContent = best.s;
      document.getElementById('bksHsgResI-' + sid).innerHTML =
        'Lunghezza ' + disp(best.len, sid) + ' ' + u(sid)
        + ' · Larghezza ' + disp(best.wid, sid) + ' ' + u(sid);
      if (res) res.classList.add('visible');
      highlightSize(sid, best.s);
    }
  };

  /* Init */
  function init() { render(SID); }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }

  /* Keyboard close */
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') {
      var m = document.getElementById('BksHsgModal-' + SID);
      if (m) m.classList.remove('is-open');
    }
  });
})();
</script>

{% schema %}
{
  "name": "BKS Hawaiian Size Guide",
  "tag": "div",
  "class": "bks-hawaiian-size-guide",
  "settings": [
    {
      "type": "header",
      "content": "Pulsante"
    },
    {
      "type": "text",
      "id": "trigger_label",
      "label": "Testo del pulsante",
      "default": "Guida alle taglie"
    },
    {
      "type": "color",
      "id": "btn_bg",
      "label": "Sfondo pulsante",
      "default": "#ffffff"
    },
    {
      "type": "color",
