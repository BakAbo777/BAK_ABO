<div class="{% if section.settings.include_margins %}page-width{% endif %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
  {%- for block in section.blocks -%}
    {%- if block.type contains 'judge-me-reviews' -%}
      <section class="bakabo-product-reviews bakabo-product-reviews--app" aria-labelledby="bakabo-app-reviews-{{ block.id }}" {{ block.shopify_attributes }}>
        <div class="bakabo-product-reviews__header">
          <div>
            <p class="bakabo-product-reviews__kicker">BakAbo trust / app reviews</p>
            <h2 id="bakabo-app-reviews-{{ block.id }}" class="bakabo-product-reviews__title">Reviews in the BakAbo container</h2>
          </div>
          <div class="bakabo-review-context__meta" aria-hidden="true">
            <span>BKS Studio creator</span>
            <span>Policy accessible</span>
          </div>
        </div>
        {% render block %}
        <p class="bakabo-product-reviews__policy">
          Reviews, shipping, returns and support are connected:
          <a href="/policies/refund-policy">returns</a>,
          <a href="/policies/shipping-policy">shipping</a>,
          <a href="/policies/contact-information">support</a>.
        </p>
      </section>
    {%- else -%}
      {% render block %}
    {%- endif -%}
  {%- endfor -%}
</div>

{% schema %}
{
  "name": "t:sections.apps.name",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "checkbox",
      "id": "include_margins",
      "default": true,
      "label": "t:sections.apps.settings.include_margins.label"
    }
  ],
  "blocks": [
    {
      "type": "@app"
    }
  ],
  "presets": [
    {
      "name": "t:sections.apps.presets.name"
    }
  ]
}
{% endschema %}
