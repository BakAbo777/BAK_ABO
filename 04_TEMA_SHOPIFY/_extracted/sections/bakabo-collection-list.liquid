{% comment %}
  BakAbo / BKS Collection List — Puffer Jacket
  File: sections/bakabo-collection-list.liquid
  Pattern: Dawn 15.4 — sezione-scoped CSS via #shopify-section-{{ section.id }}
  Drop-in sostituto di collection-list.liquid con estetica BKS completa
{% endcomment %}

<style>
  #shopify-section-{{ section.id }} .bks-cl2 {
    position: relative;
    overflow: hidden;
    background: {{ section.settings.background }};
    color: {{ section.settings.text_color }};
  }

  /* Checker background opzionale — coerente con altri BKS sections */
  #shopify-section-{{ section.id }} .bks-cl2__checker {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    opacity: {{ section.settings.checker_opacity | divided_by: 100.0 }};
    background-image:
      linear-gradient(45deg, {{ section.settings.border_color }} 25%, transparent 25%),
      linear-gradient(-45deg, {{ section.settings.border_color }} 25%, transparent 25%),
      linear-gradient(45deg, transparent 75%, {{ section.settings.border_color }} 75%),
      linear-gradient(-45deg, transparent 75%, {{ section.settings.border_color }} 75%);
    background-size: {{ section.settings.checker_size }}px {{ section.settings.checker_size }}px;
    background-position: 0 0,
      0 {{ section.settings.checker_size | divided_by: 2 }}px,
      {{ section.settings.checker_size | divided_by: 2 }}px {{ section.settings.checker_size | divided_by: -2 }}px,
      {{ section.settings.checker_size | divided_by: -2 }}px 0;
  }

  #shopify-section-{{ section.id }} .bks-cl2 > * {
    position: relative;
    z-index: 1;
  }

  /* ── WRAP ── */
  #shopify-section-{{ section.id }} .bks-cl2__wrap {
    max-width: 1600px;
    margin: 0 auto;
    padding: 0 clamp(16px, 3vw, 48px);
  }

  /* ── HEADER ── */
  #shopify-section-{{ section.id }} .bks-cl2__head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    padding: clamp(36px, 4vw, 60px) 0 clamp(28px, 3vw, 44px);
    border-bottom: 1px solid {{ section.settings.border_color }};
    gap: 20px;
    flex-wrap: wrap;
  }

  #shopify-section-{{ section.id }} .bks-cl2__kicker {
    font-size: 10px;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: {{ section.settings.accent_color }};
    margin: 0 0 10px;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  #shopify-section-{{ section.id }} .bks-cl2__kicker::before {
    content: '';
    display: block;
    width: 22px;
    height: 1px;
    background: {{ section.settings.accent_color }};
  }

  #shopify-section-{{ section.id }} .bks-cl2__title {
    font-size: clamp(30px, 4.5vw, 68px);
    font-weight: 500;
    letter-spacing: -0.06em;
    line-height: 0.88;
    text-transform: uppercase;
    margin: 0;
    color: {{ section.settings.text_color }};
  }

  #shopify-section-{{ section.id }} .bks-cl2__count {
    font-size: 10px;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: {{ section.settings.muted_color }};
    padding: 8px 16px;
    border: 1px solid {{ section.settings.border_color }};
    white-space: nowrap;
    align-self: flex-end;
  }

  #shopify-section-{{ section.id }} .bks-cl2__view-all-link {
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    text-decoration: none;
    color: {{ section.settings.text_color }};
    padding: 10px 20px;
    border: 1px solid {{ section.settings.border_color }};
    transition: background 0.2s, color 0.2s;
    white-space: nowrap;
    align-self: flex-end;
  }
  #shopify-section-{{ section.id }} .bks-cl2__view-all-link:hover {
    background: {{ section.settings.text_color }};
    color: {{ section.settings.background }};
  }

  /* ── GRID ── */
  #shopify-section-{{ section.id }} .bks-cl2__grid {
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns_desktop }}, 1fr);
    gap: 1px;
    background: {{ section.settings.border_color }};
    border-bottom: 1px solid {{ section.settings.border_color }};
  }

  /* Featured first item spans 2 rows when 3+ cols */
  {%- if section.settings.columns_desktop >= 3 and section.settings.feature_first -%}
  #shopify-section-{{ section.id }} .bks-cl2__item:first-child {
    grid-row: span 2;
  }
  {%- endif -%}

  /* ── CARD ── */
  #shopify-section-{{ section.id }} .bks-cl2__item {
    background: {{ section.settings.background }};
    text-decoration: none;
    color: {{ section.settings.text_color }};
    display: flex;
    flex-direction: column;
    position: relative;
    overflow: hidden;
    transition: background 0.22s ease;
  }
  #shopify-section-{{ section.id }} .bks-cl2__item:hover {
    background: {{ section.settings.card_bg_hover }};
  }

  /* Gold accent top line on hover */
  #shopify-section-{{ section.id }} .bks-cl2__item::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: {{ section.settings.accent_color }};
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.3s ease;
    z-index: 3;
  }
  #shopify-section-{{ section.id }} .bks-cl2__item:hover::before {
    transform: scaleX(1);
  }

  #shopify-section-{{ section.id }} .bks-cl2__media {
    aspect-ratio: {{ section.settings.card_ratio }};
    overflow: hidden;
    position: relative;
    background: {{ section.settings.border_color }};
  }

  #shopify-section-{{ section.id }} .bks-cl2__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    transition: transform 0.6s ease;
  }
  #shopify-section-{{ section.id }} .bks-cl2__item:hover .bks-cl2__img {
    transform: scale(1.06);
  }

  #shopify-section-{{ section.id }} .bks-cl2__veil {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 40%, rgba(0,0,0,0.5) 100%);
    opacity: 0;
    transition: opacity 0.3s;
  }
  #shopify-section-{{ section.id }} .bks-cl2__item:hover .bks-cl2__veil {
    opacity: 1;
  }

  #shopify-section-{{ section.id }} .bks-cl2__num {
    position: absolute;
    top: 12px; left: 14px;
    font-size: 10px;
    letter-spacing: 0.18em;
    color: rgba(255,255,255,0.75);
    font-weight: 600;
    z-index: 2;
  }

  #shopify-section-{{ section.id }} .bks-cl2__hover-cta {
    position: absolute;
    bottom: 18px;
    left: 50%;
    transform: translateX(-50%);
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #fff;
    padding: 9px 20px;
    border: 1px solid rgba(255,255,255,0.5);
    background: rgba(0,0,0,0.24);
    opacity: 0;
    transition: opacity 0.3s;
    z-index: 3;
    white-space: nowrap;
  }
  #shopify-section-{{ section.id }} .bks-cl2__item:hover .bks-cl2__hover-cta {
    opacity: 1;
  }

  /* Card info bar */
  #shopify-section-{{ section.id }} .bks-cl2__info {
    padding: clamp(14px, 2vw, 22px) clamp(14px, 2vw, 22px) clamp(18px, 2.5vw, 28px);
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 10px;
    border-top: 1px solid {{ section.settings.border_color }};
  }

  #shopify-section-{{ section.id }} .bks-cl2__name {
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin: 0 0 4px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    color: {{ section.settings.text_color }};
  }

  #shopify-section-{{ section.id }} .bks-cl2__sub {
    font-size: 11px;
    color: {{ section.settings.muted_color }};
    letter-spacing: 0.06em;
  }

  #shopify-section-{{ section.id }} .bks-cl2__arrow {
    font-size: 16px;
    color: {{ section.settings.muted_color }};
    flex-shrink: 0;
    margin-top: 2px;
    transition: transform 0.2s, color 0.2s;
  }
  #shopify-section-{{ section.id }} .bks-cl2__item:hover .bks-cl2__arrow {
    transform: translateX(4px);
    color: {{ section.settings.accent_color }};
  }

  /* ── VIEW ALL BOTTOM ── */
  #shopify-section-{{ section.id }} .bks-cl2__bottom {
    display: flex;
    justify-content: center;
    padding: clamp(28px, 4vw, 48px) clamp(16px, 3vw, 48px);
  }

  #shopify-section-{{ section.id }} .bks-cl2__btn-all {
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    text-decoration: none;
    color: {{ section.settings.background }};
    background: {{ section.settings.text_color }};
    padding: 13px 36px;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    transition: background 0.2s, color 0.2s;
  }
  #shopify-section-{{ section.id }} .bks-cl2__btn-all:hover {
    background: {{ section.settings.accent_color }};
    color: {{ section.settings.background }};
  }

  /* ── MOBILE SLIDER ── */
  #shopify-section-{{ section.id }} .bks-cl2__slider-btns {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    padding: 20px clamp(16px, 3vw, 48px);
    border-top: 1px solid {{ section.settings.border_color }};
  }

  #shopify-section-{{ section.id }} .bks-cl2__slider-btn {
    width: 40px; height: 40px;
    border: 1px solid {{ section.settings.border_color }};
    background: transparent;
    color: {{ section.settings.text_color }};
    font-size: 16px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: border-color 0.2s, background 0.2s;
  }
  #shopify-section-{{ section.id }} .bks-cl2__slider-btn:hover {
    border-color: {{ section.settings.accent_color }};
    color: {{ section.settings.accent_color }};
  }

  #shopify-section-{{ section.id }} .bks-cl2__slider-count {
    font-size: 11px;
    letter-spacing: 0.12em;
    color: {{ section.settings.muted_color }};
    min-width: 44px;
    text-align: center;
  }

  /* ── RESPONSIVE ── */
  @media screen and (max-width: 989px) {
    #shopify-section-{{ section.id }} .bks-cl2__grid {
      grid-template-columns: repeat(2, 1fr);
    }
    {%- if section.settings.feature_first -%}
    #shopify-section-{{ section.id }} .bks-cl2__item:first-child {
      grid-row: span 1;
      grid-column: span 2;
    }
    {%- endif -%}
  }

  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .bks-cl2__grid {
      grid-template-columns: repeat({{ section.settings.columns_mobile }}, 1fr);
    }
    {%- if section.settings.feature_first -%}
    #shopify-section-{{ section.id }} .bks-cl2__item:first-child {
      grid-row: span 1;
      grid-column: span 1;
    }
    {%- endif -%}
  }
</style>

{%- liquid
  assign columns_mobile_int = section.settings.columns_mobile | plus: 0
  assign show_mobile_slider = false
  if section.settings.swipe_on_mobile and section.blocks.size > columns_mobile_int
    assign show_mobile_slider = true
  endif
-%}

<div class="bks-cl2">
  <div class="bks-cl2__checker" aria-hidden="true"></div>

  <div class="bks-cl2__wrap">

    {%- unless section.settings.title == blank -%}
      <div class="bks-cl2__head">
        <div>
          <p class="bks-cl2__kicker">{{ section.settings.kicker | default: 'Bakabo Club · BKS' }}</p>
          <h2
            id="SectionHeading-{{ section.id }}"
            class="bks-cl2__title"
          >{{ section.settings.title }}</h2>
        </div>
        <div style="display:flex;align-items:flex-end;gap:12px;flex-wrap:wrap;">
          {%- if section.settings.show_collection_count -%}
            <span class="bks-cl2__count">{{ section.blocks.size }} {{ section.blocks.size | pluralize: 'Collezione', 'Collezioni' }}</span>
          {%- endif -%}
          {%- if section.settings.show_view_all and show_mobile_slider -%}
            <a
              href="{{ routes.collections_url }}"
              class="bks-cl2__view-all-link large-up-hide"
              id="ViewAll-{{ section.id }}"
              aria-labelledby="ViewAll-{{ section.id }} SectionHeading-{{ section.id }}"
            >{{ 'sections.collection_list.view_all' | t }} →</a>
          {%- endif -%}
          {%- if section.settings.show_view_all and section.blocks.size < collections.size -%}
            <a
              href="{{ routes.collections_url }}"
              class="bks-cl2__view-all-link small-hide"
              aria-label="{{ 'sections.collection_list.view_all' | t }}"
            >{{ 'sections.collection_list.view_all' | t }} →</a>
          {%- endif -%}
        </div>
      </div>
    {%- endunless -%}

  </div>

  <slider-component class="{% if show_mobile_slider %}slider-mobile-gutter{% endif %}">
    <ul
      class="bks-cl2__grid{% if show_mobile_slider %} slider slider--tablet grid--peek{% endif %}"
      id="Slider-{{ section.id }}"
      role="list"
    >
      {%- for block in section.blocks -%}
        {%- assign col = block.settings.collection -%}
        <li
          id="Slide-{{ section.id }}-{{ forloop.index }}"
          class="{% if show_mobile_slider %}slider__slide{% endif %}"
          {{ block.shopify_attributes }}
        >
          <a
            href="{{ col.url | default: routes.collections_url }}"
            class="bks-cl2__item"
            aria-label="{{ col.title | default: section.settings.title | escape }}"
          >
            <div class="bks-cl2__media">
              {%- if col.featured_image -%}
                {{
                  col.featured_image
                  | image_url: width: 900
                  | image_tag:
                    class: 'bks-cl2__img',
                    loading: 'lazy',
                    widths: '400, 600, 900',
                    sizes: '(min-width: 990px) 33vw, (min-width: 750px) 50vw, 100vw',
                    alt: col.title
                }}
              {%- else -%}
                {%- assign placeholder_image_index = forloop.index0 | modulo: 4 | plus: 1 -%}
                {{
                  'collection-apparel-' | append: placeholder_image_index
                  | placeholder_svg_tag: 'bks-cl2__img placeholder'
                }}
              {%- endif -%}
              <div class="bks-cl2__veil"></div>
              <span class="bks-cl2__num">0{{ forloop.index }}</span>
              <span class="bks-cl2__hover-cta">Esplora →</span>
            </div>

            <div class="bks-cl2__info">
              <div>
                <p class="bks-cl2__name">{{ col.title | default: 'Collezione' }}</p>
                {%- if col.products_count and section.settings.show_product_count -%}
                  <p class="bks-cl2__sub">{{ col.products_count }} prodotti</p>
                {%- endif -%}
              </div>
              <span class="bks-cl2__arrow">→</span>
            </div>
          </a>
        </li>
      {%- endfor -%}
    </ul>

    {%- if show_mobile_slider -%}
      <div class="bks-cl2__wrap">
        <div class="bks-cl2__slider-btns">
          <button
            type="button"
            class="bks-cl2__slider-btn slider-button slider-button--prev"
            name="previous"
            aria-label="{{ 'general.slider.previous_slide' | t }}"
          >
            <span class="svg-wrapper">{{- 'icon-caret.svg' | inline_asset_content -}}</span>
          </button>
          <span class="bks-cl2__slider-count caption">
            <span class="slider-counter--current">1</span>
            <span aria-hidden="true"> / </span>
            <span class="visually-hidden">{{ 'general.slider.of' | t }}</span>
            <span class="slider-counter--total">{{ section.blocks.size }}</span>
          </span>
          <button
            type="button"
            class="bks-cl2__slider-btn slider-button slider-button--next"
            name="next"
            aria-label="{{ 'general.slider.next_slide' | t }}"
          >
            <span class="svg-wrapper">{{- 'icon-caret.svg' | inline_asset_content -}}</span>
          </button>
        </div>
      </div>
    {%- endif -%}
  </slider-component>

  {%- if section.settings.show_view_all and section.blocks.size < collections.size -%}
    <div class="bks-cl2__wrap">
      <div class="bks-cl2__bottom{% if show_mobile_slider %} small-hide medium-hide{% endif %}">
        <a
          href="{{ routes.collections_url }}"
          class="bks-cl2__btn-all"
          id="ViewAllButton-{{ section.id }}"
          aria-labelledby="ViewAllButton-{{ section.id }} SectionHeading-{{ section.id }}"
        >
          {{ 'sections.collection_list.view_all' | t }} →
        </a>
      </div>
    </div>
  {%- endif -%}

</div>

{% schema %}
{
  "name": "BKS Collection List",
  "tag": "section",
  "class": "section section-collection-list",
  "max_blocks": 15,
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Testo"
    },
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker sopra il titolo",
      "default": "Bakabo Club · BKS"
    },
    {
      "type": "inline_richtext",
      "id": "title",
      "default": "Le Nostre Collezioni",
      "label": "Titolo sezione"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "card_ratio",
      "label": "Proporzione immagini",
      "options": [
        { "value": "1 / 1",   "label": "Quadrato (1:1)" },
        { "value": "3 / 4",   "label": "Verticale (3:4)" },
        { "value": "4 / 5",   "label": "Ritratto (4:5)" },
        { "value": "16 / 9",  "label": "Paesaggio (16:9)" }
      ],
      "default": "3 / 4"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 3,
      "label": "Colonne desktop"
    },
    {
      "type": "checkbox",
      "id": "feature_first",
      "label": "Prima card in evidenza (doppia altezza)",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_product_count",
      "label": "Mostra numero prodotti",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_collection_count",
      "label": "Mostra badge numero collezioni",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "default": true,
      "label": "Mostra \"Vedi tutto\""
    },
    {
      "type": "header",
      "content": "Mobile"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "options": [
        { "value": "1", "label": "1 colonna" },
        { "value": "2", "label": "2 colonne" }
      ],
      "default": "1",
      "label": "Colonne mobile"
    },
    {
      "type": "checkbox",
      "id": "swipe_on_mobile",
      "default": true,
      "label": "Slider swipe su mobile"
    },
    {
      "type": "header",
      "content": "Colori"
    },
    {
      "type": "color",
      "id": "background",
      "label": "Sfondo",
      "default": "#080808"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Testo",
      "default": "#f2ede6"
    },
    {
      "type": "color",
      "id": "muted_color",
      "label": "Testo secondario",
      "default": "#888888"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Bordi / separatori",
      "default": "#1e1e1e"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accento (oro BKS)",
      "default": "#c4964a"
    },
    {
      "type": "color",
      "id": "card_bg_hover",
      "label": "Sfondo card hover",
      "default": "#0e0e0e"
    },
    {
      "type": "header",
      "content": "Sfondo checker (opzionale)"
    },
    {
      "type": "range",
      "id": "checker_opacity",
      "min": 0,
      "max": 15,
      "step": 1,
      "default": 0,
      "label": "Opacità checker (0 = disattivo)"
    },
    {
      "type": "range",
      "id": "checker_size",
      "min": 8,
      "max": 40,
      "step": 2,
      "default": 16,
      "label": "Dimensione checker (px)"
    }
  ],
  "blocks": [
    {
      "type": "featured_collection",
      "name": "t:sections.collection-list.blocks.featured_collection.name",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "t:sections.collection-list.blocks.featured_collection.settings.collection.label"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "BKS Collection List",
      "blocks": [
        { "type": "featured_collection" },
        { "type": "featured_collection" },
        { "type": "featured_collection" }
      ]
    }
  ]
}
{% endschema %}
