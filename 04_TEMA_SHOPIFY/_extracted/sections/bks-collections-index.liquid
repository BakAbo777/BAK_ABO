{% comment %}
  BKS COLLECTIONS INDEX — BKS_Tm01
  Indice tipografico delle 8 collezioni permanenti BKS.
  Filosofia BAK/ABO: il cliente naviga per mondo visivo, non per categoria
  prodotto. Tipografia protagonista, righe numerate, hover invertito.
  Design tokens: bakabo-design-system §2-7.
{% endcomment %}

<section class="bks-cindex bks-cindex--{{ section.settings.scheme }}" aria-label="BKS Collections">
  <div class="bks-cindex__inner">
    {%- if section.settings.heading != blank -%}
      <header class="bks-cindex__head">
        <h2 class="bks-cindex__heading">{{ section.settings.heading | escape }}</h2>
        {%- if section.settings.subheading != blank -%}
          <p class="bks-cindex__sub">{{ section.settings.subheading | escape }}</p>
        {%- endif -%}
      </header>
    {%- endif -%}

    <ol class="bks-cindex__list">
      {%- for block in section.blocks -%}
        {%- liquid
          assign c = collections[block.settings.collection_handle]
          assign target = block.settings.link
          if target == blank and c != blank
            assign target = c.url
          endif
        -%}
        <li class="bks-cindex__row" {{ block.shopify_attributes }}>
          <a class="bks-cindex__link" href="{{ target | default: '#' }}">
            <span class="bks-cindex__num">{{ forloop.index | prepend: '0' | slice: -2, 2 }}</span>
            <span class="bks-cindex__name">
              {{- block.settings.name | escape -}}
              <sup class="bks-cindex__tm">&trade;</sup>
            </span>
            <span class="bks-cindex__tagline">{{ block.settings.tagline | escape }}</span>
            <span class="bks-cindex__arrow" aria-hidden="true">&rarr;</span>
          </a>
        </li>
      {%- endfor -%}
    </ol>
  </div>
</section>

{% style %}
  .bks-cindex {
    --bks-onyx: #0a0a0a;
    --bks-salt: #fafaf7;
    --bks-bone: #efeae0;
    --bks-graphite: #3d3d3d;
    --bks-ash: #9a9a9a;
    background: var(--bks-salt);
    color: var(--bks-onyx);
    padding: 64px 24px;
  }
  .bks-cindex--dark {
    background: var(--bks-onyx);
    color: var(--bks-salt);
  }
  .bks-cindex__inner {
    max-width: 1440px;
    margin: 0 auto;
  }
  .bks-cindex__head { margin-bottom: 48px; }
  .bks-cindex__heading {
    margin: 0;
    font-size: clamp(26px, 3vw, 44px);
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.1;
    text-transform: uppercase;
  }
  .bks-cindex__sub {
    margin: 12px 0 0;
    max-width: 52ch;
    font-size: 15px;
    line-height: 1.5;
    color: var(--bks-graphite);
  }
  .bks-cindex--dark .bks-cindex__sub { color: var(--bks-bone); }
  .bks-cindex__list {
    list-style: none;
    margin: 0;
    padding: 0;
    border-top: 1px solid currentColor;
  }
  .bks-cindex__row { border-bottom: 1px solid currentColor; }
  .bks-cindex__link {
    display: grid;
    grid-template-columns: auto 1fr auto;
    grid-template-areas:
      "num name arrow"
      "num tagline arrow";
    align-items: baseline;
    column-gap: 24px;
    padding: 24px 8px;
    text-decoration: none;
    color: inherit;
    transition: background-color 200ms ease-out, color 200ms ease-out;
  }
  .bks-cindex__num {
    grid-area: num;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.06em;
    align-self: start;
    padding-top: 6px;
    color: var(--bks-ash);
  }
  .bks-cindex__name {
    grid-area: name;
    font-size: clamp(26px, 4.5vw, 56px);
    font-weight: 600;
    letter-spacing: -0.03em;
    line-height: 1.1;
    text-transform: uppercase;
  }
  .bks-cindex__tm {
    font-size: 0.3em;
    font-weight: 500;
    vertical-align: super;
  }
  .bks-cindex__tagline {
    grid-area: tagline;
    margin-top: 4px;
    font-size: 13px;
    letter-spacing: 0.01em;
    color: var(--bks-graphite);
  }
  .bks-cindex--dark .bks-cindex__tagline { color: var(--bks-bone); }
  .bks-cindex__arrow {
    grid-area: arrow;
    align-self: center;
    font-size: 20px;
    opacity: 0;
    transform: translateX(-8px);
    transition: opacity 200ms ease-out, transform 200ms ease-out;
  }
  .bks-cindex__link:hover {
    background: var(--bks-onyx);
    color: var(--bks-salt);
  }
  .bks-cindex__link:hover .bks-cindex__tagline,
  .bks-cindex__link:hover .bks-cindex__num { color: var(--bks-bone); }
  .bks-cindex--dark .bks-cindex__link:hover {
    background: var(--bks-salt);
    color: var(--bks-onyx);
  }
  .bks-cindex--dark .bks-cindex__link:hover .bks-cindex__tagline,
  .bks-cindex--dark .bks-cindex__link:hover .bks-cindex__num { color: var(--bks-graphite); }
  .bks-cindex__link:hover .bks-cindex__arrow {
    opacity: 1;
    transform: translateX(0);
  }
  .bks-cindex__link:focus-visible {
    outline: 1px solid currentColor;
    outline-offset: 4px;
  }
  @media (prefers-reduced-motion: reduce) {
    .bks-cindex__link,
    .bks-cindex__arrow { transition: none; }
  }
  @media screen and (min-width: 768px) {
    .bks-cindex { padding: 96px 80px; }
    .bks-cindex__link {
      grid-template-areas: "num name tagline arrow";
      grid-template-columns: 48px 1fr minmax(200px, 28ch) 32px;
      align-items: center;
    }
    .bks-cindex__tagline { margin-top: 0; text-align: right; }
    .bks-cindex__num { align-self: center; padding-top: 0; }
  }
{% endstyle %}

{% schema %}
{
  "name": "BKS Collections Index",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Collections"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Eight permanent visual worlds. Every piece printed on demand."
    },
    {
      "type": "select",
      "id": "scheme",
      "label": "Scheme",
      "options": [
        { "value": "light", "label": "Salt (light)" },
        { "value": "dark", "label": "Onyx (dark)" }
      ],
      "default": "light"
    }
  ],
  "blocks": [
    {
      "type": "collection_row",
      "name": "Collection",
      "settings": [
        {
          "type": "text",
          "id": "name",
          "label": "Name",
          "default": "BKS Hours"
        },
        {
          "type": "text",
          "id": "tagline",
          "label": "Tagline",
          "default": "Time as Graphic Language"
        },
        {
          "type": "text",
          "id": "collection_handle",
          "label": "Collection handle",
          "info": "e.g. bks-hours — used to resolve the link automatically."
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link override"
        }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "BKS Collections Index",
      "blocks": [
        { "type": "collection_row", "settings": { "name": "BKS Hours", "tagline": "Time as Graphic Language", "collection_handle": "bks-hours" } },
        { "type": "collection_row", "settings": { "name": "BKS Folklore", "tagline": "Contemporary Cultural Fragments", "collection_handle": "bks-folklore" } },
        { "type": "collection_row", "settings": { "name": "BKS Glyph", "tagline": "Symbols and Signs", "collection_handle": "bks-glyph" } },
        { "type": "collection_row", "settings": { "name": "BKS Marker", "tagline": "Urban Gestures", "collection_handle": "bks-marker" } },
        { "type": "collection_row", "settings": { "name": "BKS Riviera", "tagline": "Mediterranean Geometry", "collection_handle": "bks-riviera" } },
        { "type": "collection_row", "settings": { "name": "BKS Pulse", "tagline": "Digital Motion", "collection_handle": "bks-pulse" } },
        { "type": "collection_row", "settings": { "name": "BKS Token", "tagline": "Encoded Identity", "collection_handle": "bks-token" } },
        { "type": "collection_row", "settings": { "name": "BKS Flag", "tagline": "Global Signals", "collection_handle": "bks-flag" } }
      ]
    }
  ]
}
{% endschema %}
