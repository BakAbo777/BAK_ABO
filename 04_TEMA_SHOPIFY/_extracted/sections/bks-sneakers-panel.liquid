{% comment %}
  BakAbo / BKS Sneakers Panel
  File: sections/bks-sneakers-panel.liquid
  6 sneaker lines displayed in editorial campaign style
  Each card: hero campaign image + headline + tagline + features
  Pattern: inherits from bks-accessories-panel.liquid DNA
  Mobile-first | Dawn 15.4
{% endcomment %}

<style>
  #shopify-section-{{ section.id }} .bks-snk {
    background: {{ section.settings.background }};
    color: {{ section.settings.text_color }};
    overflow: hidden;
    position: relative;
  }

  /* ── NOISE OVERLAY ── */
  #shopify-section-{{ section.id }} .bks-snk::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
    opacity: 0.04;
    pointer-events: none;
    z-index: 0;
  }

  #shopify-section-{{ section.id }} .bks-snk > * {
    position: relative;
    z-index: 1;
  }

  /* ── HEADER ── */
  #shopify-section-{{ section.id }} .bks-snk__head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    padding: clamp(36px, 4vw, 64px) clamp(20px, 4vw, 52px) clamp(24px, 3vw, 40px);
    border-bottom: 1px solid {{ section.settings.border_color }};
    gap: 20px;
    flex-wrap: wrap;
    max-width: 1600px;
    margin: 0 auto;
  }

  #shopify-section-{{ section.id }} .bks-snk__kicker {
    font-size: 10px;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: {{ section.settings.accent_color }};
    margin: 0 0 12px;
    display: flex;
    align-items: center;
    gap: 12px;
  }
  #shopify-section-{{ section.id }} .bks-snk__kicker::before {
    content: '';
    display: block;
    width: 24px;
    height: 1px;
    background: {{ section.settings.accent_color }};
  }

  #shopify-section-{{ section.id }} .bks-snk__title {
    font-size: clamp(36px, 5.5vw, 80px);
    font-weight: 700;
    letter-spacing: -0.05em;
    line-height: 0.86;
    text-transform: uppercase;
    margin: 0;
    color: {{ section.settings.text_color }};
  }
  #shopify-section-{{ section.id }} .bks-snk__title em {
    font-style: normal;
    color: {{ section.settings.accent_color }};
  }

  #shopify-section-{{ section.id }} .bks-snk__desc {
    font-size: 13px;
    color: {{ section.settings.muted_color }};
    margin: 16px 0 0;
    max-width: 400px;
    line-height: 1.65;
    letter-spacing: 0.01em;
  }

  #shopify-section-{{ section.id }} .bks-snk__meta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 8px;
    flex-shrink: 0;
  }
  #shopify-section-{{ section.id }} .bks-snk__badge {
    font-size: 9px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    padding: 6px 14px;
    border: 1px solid {{ section.settings.border_color }};
    color: {{ section.settings.muted_color }};
    white-space: nowrap;
  }
  #shopify-section-{{ section.id }} .bks-snk__count {
    font-size: 42px;
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 1;
    color: {{ section.settings.border_color }};
    user-select: none;
  }

  /* ── GRID ── */
  #shopify-section-{{ section.id }} .bks-snk__grid {
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns_desktop }}, 1fr);
    gap: 1px;
    background: {{ section.settings.border_color }};
    border: 1px solid {{ section.settings.border_color }};
    border-top: none;
  }

  /* ── CARD ── */
  #shopify-section-{{ section.id }} .bks-snk__card {
    background: {{ section.settings.card_bg }};
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: {{ section.settings.text_color }};
    position: relative;
    overflow: hidden;
    cursor: pointer;
    transition: background 0.3s ease;
  }
  #shopify-section-{{ section.id }} .bks-snk__card:hover {
    background: {{ section.settings.card_bg_hover }};
  }

  /* Campaign image area */
  #shopify-section-{{ section.id }} .bks-snk__img-wrap {
    position: relative;
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    flex-shrink: 0;
  }
  #shopify-section-{{ section.id }} .bks-snk__img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s cubic-bezier(.22,1,.36,1);
  }
  #shopify-section-{{ section.id }} .bks-snk__card:hover .bks-snk__img-wrap img {
    transform: scale(1.04);
  }

  /* Numero linea sul'immagine */
  #shopify-section-{{ section.id }} .bks-snk__linenum {
    position: absolute;
    top: 12px;
    left: 14px;
    font-size: 9px;
    letter-spacing: 0.22em;
    color: rgba(255,255,255,0.55);
    font-weight: 500;
    z-index: 2;
    font-family: var(--font-body-family);
  }

  /* Tag "NEW" o "DROP" */
  #shopify-section-{{ section.id }} .bks-snk__tag {
    position: absolute;
    top: 12px;
    right: 14px;
    font-size: 8px;
    letter-spacing: 0.22em;
    font-weight: 700;
    text-transform: uppercase;
    padding: 4px 8px;
    background: {{ section.settings.accent_color }};
    color: #080808;
    z-index: 2;
  }

  /* ── COPY BLOCK ── */
  #shopify-section-{{ section.id }} .bks-snk__copy {
    padding: clamp(16px, 1.8vw, 24px) clamp(14px, 1.6vw, 22px);
    border-top: 1px solid {{ section.settings.border_color }};
    display: flex;
    flex-direction: column;
    flex: 1;
    gap: 8px;
  }

  #shopify-section-{{ section.id }} .bks-snk__line-label {
    font-size: 9px;
    letter-spacing: 0.26em;
    text-transform: uppercase;
    color: {{ section.settings.accent_color }};
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  #shopify-section-{{ section.id }} .bks-snk__line-label::before {
    content: '';
    display: block;
    width: 14px;
    height: 1px;
    background: {{ section.settings.accent_color }};
    flex-shrink: 0;
  }

  #shopify-section-{{ section.id }} .bks-snk__name {
    font-size: clamp(14px, 1.6vw, 18px);
    font-weight: 700;
    letter-spacing: -0.01em;
    text-transform: uppercase;
    line-height: 1.1;
    margin: 0;
    color: {{ section.settings.text_color }};
  }

  #shopify-section-{{ section.id }} .bks-snk__tagline {
    font-size: 11.5px;
    color: {{ section.settings.muted_color }};
    line-height: 1.5;
    letter-spacing: 0.01em;
    flex: 1;
  }

  /* Features — 4 icon row matching campaign images */
  #shopify-section-{{ section.id }} .bks-snk__features {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: {{ section.settings.border_color }};
    border-top: 1px solid {{ section.settings.border_color }};
    margin-top: 4px;
  }
  #shopify-section-{{ section.id }} .bks-snk__feat {
    background: {{ section.settings.card_bg }};
    padding: 10px 6px;
    text-align: center;
    transition: background 0.18s;
  }
  #shopify-section-{{ section.id }} .bks-snk__card:hover .bks-snk__feat {
    background: {{ section.settings.card_bg_hover }};
  }
  #shopify-section-{{ section.id }} .bks-snk__feat-icon {
    font-size: 14px;
    line-height: 1;
    display: block;
    margin-bottom: 4px;
  }
  #shopify-section-{{ section.id }} .bks-snk__feat-text {
    font-size: 8px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: {{ section.settings.muted_color }};
    line-height: 1.3;
    display: block;
  }

  /* ── CTA ARROW ── */
  #shopify-section-{{ section.id }} .bks-snk__arrow {
    position: absolute;
    bottom: 14px;
    right: 16px;
    font-size: 16px;
    color: {{ section.settings.muted_color }};
    transition: color 0.18s, transform 0.18s;
    pointer-events: none;
  }
  #shopify-section-{{ section.id }} .bks-snk__card:hover .bks-snk__arrow {
    color: {{ section.settings.accent_color }};
    transform: translate(3px, -3px);
  }

  /* ── FOOTER ── */
  #shopify-section-{{ section.id }} .bks-snk__footer {
    padding: clamp(20px, 2.5vw, 32px) clamp(20px, 4vw, 52px);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
    max-width: 1600px;
    margin: 0 auto;
    border-top: 1px solid {{ section.settings.border_color }};
  }

  #shopify-section-{{ section.id }} .bks-snk__footer-text {
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: {{ section.settings.muted_color }};
  }

  #shopify-section-{{ section.id }} .bks-snk__footer-cta {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    text-decoration: none;
    color: {{ section.settings.text_color }};
    padding: 12px 26px;
    border: 1px solid {{ section.settings.border_color }};
    transition: background 0.22s, color 0.22s, border-color 0.22s;
  }
  #shopify-section-{{ section.id }} .bks-snk__footer-cta:hover {
    background: {{ section.settings.accent_color }};
    color: #080808;
    border-color: {{ section.settings.accent_color }};
  }
  #shopify-section-{{ section.id }} .bks-snk__footer-cta::after {
    content: '→';
    font-size: 14px;
  }

  /* ── RESPONSIVE ── */
  @media screen and (max-width: 989px) {
    #shopify-section-{{ section.id }} .bks-snk__grid {
      grid-template-columns: repeat({{ section.settings.columns_tablet }}, 1fr);
    }
  }
  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .bks-snk__grid {
      grid-template-columns: repeat({{ section.settings.columns_mobile }}, 1fr);
    }
    #shopify-section-{{ section.id }} .bks-snk__head {
      padding: 28px 16px 20px;
      flex-direction: column;
      align-items: flex-start;
    }
    #shopify-section-{{ section.id }} .bks-snk__title {
      font-size: clamp(32px, 11vw, 56px);
    }
    #shopify-section-{{ section.id }} .bks-snk__meta { display: none; }
    #shopify-section-{{ section.id }} .bks-snk__name { font-size: 13px; }
    #shopify-section-{{ section.id }} .bks-snk__tagline { display: none; }
    #shopify-section-{{ section.id }} .bks-snk__copy { padding: 12px 10px; gap: 5px; }
    #shopify-section-{{ section.id }} .bks-snk__feat-text { display: none; }
    #shopify-section-{{ section.id }} .bks-snk__feat { padding: 8px 4px; }
    #shopify-section-{{ section.id }} .bks-snk__footer { padding: 20px 16px; }
  }
</style>

<section class="bks-snk">

  {%- comment -%} HEADER {%- endcomment -%}
  <header class="bks-snk__head">
    <div>
      {%- if section.settings.kicker != blank -%}
        <p class="bks-snk__kicker">{{ section.settings.kicker | escape }}</p>
      {%- endif -%}
      {%- if section.settings.title != blank -%}
        <h2 class="bks-snk__title">{{ section.settings.title }}</h2>
      {%- endif -%}
      {%- if section.settings.description != blank -%}
        <p class="bks-snk__desc">{{ section.settings.description | escape }}</p>
      {%- endif -%}
    </div>
    <div class="bks-snk__meta">
      {%- if section.settings.badge != blank -%}
        <span class="bks-snk__badge">{{ section.settings.badge | escape }}</span>
      {%- endif -%}
      <span class="bks-snk__count" aria-hidden="true">
        {{ section.blocks | where: 'type', 'sneaker' | size | prepend: '0' | slice: -2, 2 }}
      </span>
    </div>
  </header>

  {%- comment -%} CARDS GRID {%- endcomment -%}
  <div class="bks-snk__grid">
    {%- for block in section.blocks -%}
      {%- if block.type == 'sneaker' -%}
        {%- assign card_link = block.settings.link | default: '/collections/all' -%}
        <a class="bks-snk__card" href="{{ card_link }}" {{ block.shopify_attributes }}>

          {%- comment -%} Campaign image {%- endcomment -%}
          <div class="bks-snk__img-wrap">
            <span class="bks-snk__linenum">{{ forloop.index | prepend: '0' | slice: -2, 2 }}</span>
            {%- if block.settings.tag != blank -%}
              <span class="bks-snk__tag">{{ block.settings.tag | escape }}</span>
            {%- endif -%}
            {%- if block.settings.campaign_image != blank -%}
              <img
                src="{{ block.settings.campaign_image | image_url: width: 600 }}"
                alt="{{ block.settings.name | default: 'BKS Sneakers' | escape }}"
                width="600"
                height="600"
                loading="lazy"
              >
            {%- else -%}
              <div style="width:100%;height:100%;background:{{ section.settings.card_bg | default: '#0a0a0a' }};display:flex;align-items:center;justify-content:center;min-height:200px;">
                <span style="font-family:var(--bks-font-display,'Bebas Neue',sans-serif);font-size:clamp(1.2rem,3vw,2.8rem);color:rgba(250,250,247,0.12);text-transform:uppercase;letter-spacing:0.04em;text-align:center;padding:16px">{{ block.settings.name | default: 'BKS' }}</span>
              </div>
            {%- endif -%}
          </div>

          {%- comment -%} Copy block {%- endcomment -%}
          <div class="bks-snk__copy">
            {%- if block.settings.line_label != blank -%}
              <span class="bks-snk__line-label">{{ block.settings.line_label | escape }}</span>
            {%- endif -%}
            {%- if block.settings.name != blank -%}
              <h3 class="bks-snk__name">{{ block.settings.name | escape }}</h3>
            {%- endif -%}
            {%- if block.settings.tagline != blank -%}
              <p class="bks-snk__tagline">{{ block.settings.tagline | escape }}</p>
            {%- endif -%}
          </div>

          {%- comment -%} Features row (matches campaign image icons) {%- endcomment -%}
          <div class="bks-snk__features">
            {%- if block.settings.feat1_label != blank -%}
              <div class="bks-snk__feat">
                <span class="bks-snk__feat-icon" aria-hidden="true">{{ block.settings.feat1_icon | default: '◈' }}</span>
                <span class="bks-snk__feat-text">{{ block.settings.feat1_label | escape }}</span>
              </div>
            {%- endif -%}
            {%- if block.settings.feat2_label != blank -%}
              <div class="bks-snk__feat">
                <span class="bks-snk__feat-icon" aria-hidden="true">{{ block.settings.feat2_icon | default: '◇' }}</span>
                <span class="bks-snk__feat-text">{{ block.settings.feat2_label | escape }}</span>
              </div>
            {%- endif -%}
            {%- if block.settings.feat3_label != blank -%}
              <div class="bks-snk__feat">
                <span class="bks-snk__feat-icon" aria-hidden="true">{{ block.settings.feat3_icon | default: '◎' }}</span>
                <span class="bks-snk__feat-text">{{ block.settings.feat3_label | escape }}</span>
              </div>
            {%- endif -%}
            {%- if block.settings.feat4_label != blank -%}
              <div class="bks-snk__feat">
                <span class="bks-snk__feat-icon" aria-hidden="true">{{ block.settings.feat4_icon | default: '◉' }}</span>
                <span class="bks-snk__feat-text">{{ block.settings.feat4_label | escape }}</span>
              </div>
            {%- endif -%}
          </div>

          <span class="bks-snk__arrow" aria-hidden="true">↗</span>
        </a>
      {%- endif -%}
    {%- endfor -%}
  </div>

  {%- comment -%} FOOTER CTA {%- endcomment -%}
  {%- if section.settings.show_footer -%}
    <div class="bks-snk__footer">
      <span class="bks-snk__footer-text">
        {%- if section.settings.footer_label != blank -%}
          {{ section.settings.footer_label | escape }}
        {%- else -%}
          BKS Sneakers — {{ section.blocks | where: 'type', 'sneaker' | size }} Collections
        {%- endif -%}
      </span>
      {%- if section.settings.footer_cta != blank -%}
        <a href="{{ section.settings.footer_cta_link | default: '/collections/all' }}" class="bks-snk__footer-cta">
          {{ section.settings.footer_cta | escape }}
        </a>
      {%- endif -%}
    </div>
  {%- endif -%}

</section>

{% schema %}
{
  "name": "BKS Sneakers Panel",
  "tag": "section",
  "class": "section-bks-sneakers-panel",
  "settings": [
    {
      "type": "header",
      "content": "Intestazione"
    },
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker (sopra titolo)",
      "default": "BAK|ABO · CONTEMPORARY STREETWEAR"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Titolo sezione",
      "default": "BKS <em>SNEAKERS</em>"
    },
    {
      "type": "text",
      "id": "description",
      "label": "Descrizione",
      "default": "Six limited-edition lines. Each pair a wearable artwork. EU 36–47."
    },
    {
      "type": "text",
      "id": "badge",
      "label": "Badge header",
      "default": "DROPS · SS25"
    },
    {
      "type": "header",
      "content": "Footer"
    },
    {
