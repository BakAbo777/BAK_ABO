        },
        {
          "type": "text",
          "id": "feat2_label",
          "label": "Label feature 2",
          "default": "Premium"
        },
        {
          "type": "header",
          "content": "Feature 3"
        },
        {
          "type": "text",
          "id": "feat3_icon",
