{{ 'bks-future.css' | asset_url | stylesheet_tag }}

{% liquid
  # Ottieni gli handle dalle impostazioni
  assign handles_string = section.settings.collection_handles | default: 'bks-folklore,bks-glyph,bks-marker,bks-riviera,bks-pulse,bks-token,bks-flag,bks-hours'
  assign collection_handles = handles_string | split: ','
  assign collection_count = collection_handles | size
%}

<style>
  /* ── BKS IMPACT HOME — Advanced Interactions ───────────── */

  #shopify-section-{{ section.id }} .bks-impact {
    position: relative;
    min-height: calc(100svh - var(--header-height, 72px));
    overflow: hidden;
    background: #0A0A0A;
    color: #FAFAF7;
    cursor: crosshair;
  }

  /* Canvas per particelle matematiche */
  #shopify-section-{{ section.id }} .bks-math-canvas {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    opacity: 0.4;
  }

  /* SVG Container per linee elastiche */
  #shopify-section-{{ section.id }} .bks-elastic-lines {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 5;
    overflow: visible;
  }

  #shopify-section-{{ section.id }} .bks-impact__inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(0,1fr) minmax(280px,0.86fr);
    gap: clamp(28px,5vw,80px);
    align-items: center;
    width: min(1560px, calc(100% - 32px));
    min-height: inherit;
    margin: 0 auto;
    padding: clamp(52px,8vw,132px) 0 clamp(36px,5vw,72px);
  }

  /* ── CONTENT COLUMN ── */
  #shopify-section-{{ section.id }} .bks-impact__content {
    color: #FAFAF7;
    pointer-events: none;
  }

  #shopify-section-{{ section.id }} .bks-brand-context {
    display: inline-flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 10px;
    margin: 0 0 18px;
    pointer-events: auto;
  }

  #shopify-section-{{ section.id }} .bks-brand-context__item {
    display: inline-flex;
    align-items: center;
    min-height: 34px;
    padding: 8px 12px;
    border: 1px solid rgba(250,250,247,0.28);
    border-radius: 999px;
    background: rgba(10,10,10,0.48);
    color: #FAFAF7;
    box-shadow: 0 12px 34px rgba(0,0,0,0.24);
    font-family: var(--bks-font-mono,'DM Mono',monospace);
    font-size: clamp(0.7rem,1vw,0.82rem);
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  #shopify-section-{{ section.id }} .bks-brand-context__container {
    border-color: rgba(201,183,156,0.72);
  }

  #shopify-section-{{ section.id }} .bks-brand-context__creator {
    gap: 8px;
    border-color: rgba(250,250,247,0.92);
    background: #FAFAF7;
    color: #0A0A0A;
  }

  #shopify-section-{{ section.id }} .bks-brand-context__creator img {
    display: block;
    width: auto;
    height: 18px;
    max-width: 76px;
    background: transparent;
  }

  #shopify-section-{{ section.id }} .bks-impact__eyebrow {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-bottom: 18px;
    font-family: var(--bks-font-mono,'DM Mono',monospace);
    font-size: 0.76rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--bks-dune, #C9B79C);
    opacity: 0;
    animation: fadeInUp 0.8s ease 0.1s forwards;
  }

  #shopify-section-{{ section.id }} .bks-impact__title {
    margin: 0;
    font-family: var(--bks-font-display,'Bebas Neue',sans-serif);
    font-size: clamp(4rem,10vw,12rem);
    line-height: 0.82;
    letter-spacing: 0.01em;
    text-transform: uppercase;
    color: #FAFAF7;
    max-width: 10ch;
    opacity: 0;
    animation: fadeInUp 0.8s ease 0.2s forwards;
  }

  #shopify-section-{{ section.id }} .bks-impact__copy {
    max-width: 56ch;
    margin: 24px 0 0;
    font-family: var(--bks-font-body,'DM Sans',sans-serif);
    font-size: clamp(1rem,1.3vw,1.2rem);
    line-height: 1.65;
    color: rgba(250,250,247,0.72);
    opacity: 0;
    animation: fadeInUp 0.8s ease 0.3s forwards;
  }

  #shopify-section-{{ section.id }} .bks-impact__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 32px;
    opacity: 0;
    animation: fadeInUp 0.8s ease 0.4s forwards;
    pointer-events: auto;
  }

  #shopify-section-{{ section.id }} .bks-button {
    position: relative;
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    padding: 0 24px;
    background: #FAFAF7;
    color: #0A0A0A;
    border: 1px solid #FAFAF7;
    text-decoration: none;
    font-family: var(--bks-font-mono,'DM Mono',monospace);
    font-size: 0.74rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    border-radius: 0;
    overflow: hidden;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    pointer-events: auto;
  }

  #shopify-section-{{ section.id }} .bks-button--ghost {
    background: transparent;
    color: #FAFAF7;
    border-color: rgba(250,250,247,0.3);
  }

  #shopify-section-{{ section.id }} .bks-button:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(250,250,247,0.15);
  }

  /* ── ORBIT SYSTEM ── */
  #shopify-section-{{ section.id }} .bks-orbit {
    position: relative;
    display: grid;
    min-height: min(72svh,720px);
    isolation: isolate;
    pointer-events: auto;
  }

  /* Core centrale interattivo */
  #shopify-section-{{ section.id }} .bks-orbit__core {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    z-index: 10;
    width: clamp(100px,14vw,180px);
    aspect-ratio: 1;
    border-radius: 50%;
    display: grid;
    place-items: center;
    background: radial-gradient(circle at 30% 30%, #FAFAF7, #D4D4D4);
    color: #0A0A0A;
    font-family: var(--bks-font-display,'Bebas Neue',sans-serif);
    font-size: clamp(2.4rem,5vw,4rem);
    line-height: 1;
    letter-spacing: 0.02em;
    box-shadow: 
      0 0 0 4px rgba(250,250,247,0.1),
      0 0 60px rgba(250,250,247,0.2),
      inset 0 0 40px rgba(0,0,0,0.1);
    cursor: pointer;
    transition: all 0.3s ease;
    pointer-events: auto;
  }

  #shopify-section-{{ section.id }} .bks-orbit__core:hover {
    transform: translate(-50%, -50%) scale(1.05);
    box-shadow: 
      0 0 0 6px rgba(250,250,247,0.15),
      0 0 80px rgba(250,250,247,0.3),
      inset 0 0 40px rgba(0,0,0,0.1);
  }

  #shopify-section-{{ section.id }} .bks-orbit__core:active {
    transform: translate(-50%, -50%) scale(0.98);
  }

  /* Anelli orbitali */
  #shopify-section-{{ section.id }} .bks-orbit__ring {
    position: absolute;
    left: 50%;
    top: 50%;
    border: 1px solid rgba(250,250,247,0.08);
    border-radius: 50%;
    pointer-events: none;
    transform: translate(-50%, -50%);
  }

  #shopify-section-{{ section.id }} .bks-orbit__ring--1 { width: 40%; height: 40%; animation: orbitSpin 60s linear infinite; }
  #shopify-section-{{ section.id }} .bks-orbit__ring--2 { width: 65%; height: 65%; animation: orbitSpinReverse 80s linear infinite; border-color: rgba(200,71,61,0.12); }
  #shopify-section-{{ section.id }} .bks-orbit__ring--3 { width: 90%; height: 90%; animation: orbitSpin 100s linear infinite; border-color: rgba(200,183,156,0.08); }

  /* Card collezioni */
  #shopify-section-{{ section.id }} .bks-collection-card {
    position: absolute;
    width: clamp(120px,16vw,200px);
    aspect-ratio: 1;
    display: grid;
    place-items: center;
    cursor: grab;
    pointer-events: auto;
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1), filter 0.3s ease;
    user-select: none;
    z-index: 20;
  }

  #shopify-section-{{ section.id }} .bks-collection-card:active {
    cursor: grabbing;
  }

  #shopify-section-{{ section.id }} .bks-collection-card__inner {
    width: 100%;
    height: 100%;
    position: relative;
    overflow: visible;
    border-radius: 50%;
    background: rgba(250,250,247,0.05);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(250,250,247,0.1);
    box-shadow: 
      0 8px 32px rgba(0,0,0,0.3),
      inset 0 0 0 1px rgba(250,250,247,0.05);
    transition: all 0.3s ease;
  }

  #shopify-section-{{ section.id }} .bks-collection-card img {
    width: 80%;
    height: 80%;
    object-fit: contain;
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    filter: drop-shadow(0 8px 16px rgba(0,0,0,0.4));
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  #shopify-section-{{ section.id }} .bks-collection-card__label {
    position: absolute;
    bottom: -20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 4px 12px;
    background: rgba(10,10,10,0.9);
    color: #FAFAF7;
    font-family: var(--bks-font-mono,'DM Mono',monospace);
    font-size: 0.64rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    border-radius: 4px;
    white-space: nowrap;
    pointer-events: none;
  }

  /* Stati interattivi */
  #shopify-section-{{ section.id }} .bks-collection-card:hover {
    transform: scale(1.1);
    z-index: 30;
  }

  #shopify-section-{{ section.id }} .bks-collection-card:hover .bks-collection-card__inner {
    background: rgba(250,250,247,0.1);
    border-color: rgba(250,250,247,0.3);
    box-shadow: 
      0 12px 48px rgba(0,0,0,0.4),
      0 0 0 2px rgba(250,250,247,0.1),
      inset 0 0 20px rgba(250,250,247,0.05);
  }

  #shopify-section-{{ section.id }} .bks-collection-card:hover img {
    transform: translate(-50%, -50%) scale(1.15);
  }

  #shopify-section-{{ section.id }} .bks-collection-card.connected {
    z-index: 25;
  }

  #shopify-section-{{ section.id }} .bks-collection-card.connected .bks-collection-card__inner {
    background: rgba(200,183,156,0.15);
    border-color: rgba(200,183,156,0.4);
    box-shadow: 
      0 0 0 3px rgba(200,183,156,0.2),
      0 12px 48px rgba(0,0,0,0.4);
  }

  /* Linea elastica SVG */
  #shopify-section-{{ section.id }} .elastic-path {
    fill: none;
    stroke: url(#gradientLine);
    stroke-width: 2;
    stroke-linecap: round;
    opacity: 0;
    transition: opacity 0.3s ease;
    filter: drop-shadow(0 0 4px rgba(200,183,156,0.5));
  }

  #shopify-section-{{ section.id }} .elastic-path.active {
    opacity: 0.8;
  }

  /* Tooltip matematico */
  #shopify-section-{{ section.id }} .math-tooltip {
    position: absolute;
    padding: 8px 16px;
    background: rgba(10,10,10,0.95);
    border: 1px solid rgba(200,183,156,0.3);
    color: #C9B79C;
    font-family: var(--bks-font-mono,'DM Mono',monospace);
    font-size: 0.7rem;
    border-radius: 4px;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.3s ease;
    z-index: 100;
    white-space: nowrap;
    box-shadow: 0 8px 32px rgba(0,0,0,0.4);
  }

  #shopify-section-{{ section.id }} .math-tooltip.visible {
    opacity: 1;
  }

  /* Stats */
  #shopify-section-{{ section.id }} .bks-impact__stats {
    display: grid;
    grid-template-columns: repeat(3,minmax(0,1fr));
    gap: 1px;
    max-width: 520px;
    margin-top: 46px;
    background: rgba(250,250,247,0.15);
    opacity: 0;
    animation: fadeInUp 0.8s ease 0.5s forwards;
    pointer-events: auto;
  }

  #shopify-section-{{ section.id }} .bks-impact__stat {
    padding: 14px 16px;
    background: rgba(10,10,10,0.85);
    transition: all 0.3s ease;
    cursor: pointer;
  }

  #shopify-section-{{ section.id }} .bks-impact__stat:hover {
    background: rgba(200,183,156,0.1);
  }

  #shopify-section-{{ section.id }} .bks-impact__stat strong {
    display: block;
    font-family: var(--bks-font-display,'Bebas Neue',sans-serif);
    font-size: clamp(2.2rem,4.5vw,4.5rem);
    line-height: 0.85;
    color: #FAFAF7;
  }

  #shopify-section-{{ section.id }} .bks-impact__stat span {
    display: block;
    margin-top: 8px;
    font-family: var(--bks-font-mono,'DM Mono',monospace);
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(250,250,247,0.55);
  }

  /* Animazioni */
  @keyframes fadeInUp {
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes orbitSpin {
    from { transform: translate(-50%, -50%) rotate(0deg); }
    to { transform: translate(-50%, -50%) rotate(360deg); }
  }

  @keyframes orbitSpinReverse {
    from { transform: translate(-50%, -50%) rotate(360deg); }
    to { transform: translate(-50%, -50%) rotate(0deg); }
  }

  @keyframes pulse {
    0%, 100% { transform: scale(1); opacity: 0.6; }
    50% { transform: scale(1.3); opacity: 1; }
  }

  /* Responsive */
  @media screen and (max-width: 989px) {
    #shopify-section-{{ section.id }} .bks-impact__inner {
      grid-template-columns: 1fr;
      padding: clamp(40px,8vw,80px) 0 clamp(24px,5vw,48px);
    }

    #shopify-section-{{ section.id }} .bks-orbit {
      min-height: 600px;
      margin-top: 40px;
    }

    #shopify-section-{{ section.id }} .bks-collection-card {
      width: clamp(100px,22vw,160px);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    * { animation: none !important; transition: none !important; }
  }
</style>

<section class="bks-impact" id="bks-impact-{{ section.id }}">
  <!-- Canvas per effetti matematici -->
  <canvas class="bks-math-canvas" id="mathCanvas"></canvas>

  <!-- SVG per linee elastiche -->
  <svg class="bks-elastic-lines" id="elasticSvg">
    <defs>
      <linearGradient id="gradientLine" x1="0%" y1="0%" x2="100%" y2="0%">
        <stop offset="0%" style="stop-color:#C9B79C;stop-opacity:1" />
        <stop offset="50%" style="stop-color:#FAFAF7;stop-opacity:1" />
        <stop offset="100%" style="stop-color:#C9B79C;stop-opacity:1" />
      </linearGradient>
    </defs>
  </svg>

  <!-- Tooltip -->
  <div class="math-tooltip" id="mathTooltip"></div>

  <div class="bks-impact__inner">
    <div class="bks-impact__content">
      <div class="bks-brand-context" aria-label="BakAbo container and BKS Studio creator">
        <span class="bks-brand-context__item bks-brand-context__container">BakAbo container</span>
        <span class="bks-brand-context__item bks-brand-context__creator">
          <img src="{{ 'bks-studio-logo.png' | asset_url }}" alt="" loading="eager" width="223" height="67">
          Creator: BKS Studio
        </span>
      </div>

      <div class="bks-impact__eyebrow">
        <span>{{ section.settings.kicker }}</span>
        <span>{{ section.settings.drop_label }}</span>
      </div>
      <h1 class="bks-impact__title">{{ section.settings.heading }}</h1>
      <p class="bks-impact__copy">{{ section.settings.copy }}</p>
      <div class="bks-impact__actions">
        <a class="bks-button" href="{{ section.settings.primary_link }}">{{ section.settings.primary_label }}</a>
        <a class="bks-button bks-button--ghost" href="{{ section.settings.secondary_link }}">{{ section.settings.secondary_label }}</a>
      </div>
      <div class="bks-impact__stats">
        <div class="bks-impact__stat"><strong>{{ collection_count }}</strong><span>Collections</span></div>
        <div class="bks-impact__stat"><strong>189</strong><span>Pieces</span></div>
        <div class="bks-impact__stat"><strong>AOP</strong><span>On Demand</span></div>
      </div>
    </div>

    <div class="bks-orbit" id="orbitContainer">
      <!-- Anelli orbitali -->
      <div class="bks-orbit__ring bks-orbit__ring--1"></div>
      <div class="bks-orbit__ring bks-orbit__ring--2"></div>
      <div class="bks-orbit__ring bks-orbit__ring--3"></div>

      <!-- Core centrale -->
      <div class="bks-orbit__core" id="orbitCore">BKS</div>

      <!-- Cards generate dagli handle specifici -->
      {% for handle in collection_handles %}
        {% assign collection = collections[handle] %}
        {% if collection %}
          {% assign angle = forloop.index0 | times: 45 %}
          <div class="bks-collection-card" 
               data-index="{{ forloop.index0 }}"
               data-angle="{{ angle }}"
               data-handle="{{ collection.handle }}"
               id="card-{{ forloop.index0 }}">
            <div class="bks-collection-card__inner">
              {% if collection.image %}
                <img src="{{ collection.image | img_url: '400x400' }}" 
                     alt="{{ collection.title }}"
                     loading="lazy">
              {% else %}
                <div style="width:100%;height:100%;display:grid;place-items:center;color:rgba(250,250,247,0.5);font-size:0.7rem;text-align:center;padding:20px;">
                  {{ collection.title }}
                </div>
              {% endif %}
              <span class="bks-collection-card__label">{{ collection.title }}</span>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

<script>
(function() {
  'use strict';

  const container = document.getElementById('orbitContainer');
  const core = document.getElementById('orbitCore');
  const svg = document.getElementById('elasticSvg');
  const tooltip = document.getElementById('mathTooltip');
  const cards = document.querySelectorAll('.bks-collection-card');
  const canvas = document.getElementById('mathCanvas');
  const ctx = canvas.getContext('2d');

  // Stato
  let connections = new Map();
  let isDragging = false;
  let draggedCard = null;
  let mousePos = { x: 0, y: 0 };
  let corePos = { x: 0, y: 0 };

  // Parametri funzione di Weierstrass per elasticità
  const weierstrassParams = {
    a: 0.5,  // fattore di attenuazione
    b: 3,    // fattore di frequenza
    n: 50    // numero di termini
  };

  // Inizializzazione posizioni
  function initPositions() {
    const rect = container.getBoundingClientRect();
    const coreRect = core.getBoundingClientRect();
    
    corePos = {
      x: coreRect.left + coreRect.width / 2 - rect.left,
      y: coreRect.top + coreRect.height / 2 - rect.top
    };

    const centerX = rect.width / 2;
    const centerY = rect.height / 2;
    const radius = Math.min(rect.width, rect.height) * 0.35;

    cards.forEach((card, index) => {
      const angle = (index * (360 / cards.length) - 90) * (Math.PI / 180);
      const x = Math.cos(angle) * radius + centerX;
      const y = Math.sin(angle) * radius + centerY;
      
      card.style.left = `${x}px`;
      card.style.top = `${y}px`;
      card.style.transform = 'translate(-50%, -50%)';
      
      // Salva posizione originale
      card.dataset.ox = x;
      card.dataset.oy = y;
    });

    resizeCanvas();
  }

  // Funzione di Weierstrass per curva frattale
  function weierstrassFunction(x, a = 0.5, b = 3, n = 50) {
    let sum = 0;
    for (let i = 0; i < n; i++) {
      sum += Math.pow(a, i) * Math.cos(Math.pow(b, i) * Math.PI * x);
    }
    return sum;
  }

  // Calcola punto sulla curva di Weierstrass
  function getWeierstrassPoint(t, startX, startY, endX, endY, amplitude = 30) {
    const x = startX + (endX - startX) * t;
    const y = startY + (endY - startY) * t;
    const deviation = weierstrassFunction(t * 2, weierstrassParams.a, weierstrassParams.b) * amplitude;
    const perpX = -(endY - startY) / Math.sqrt(Math.pow(endX - startX, 2) + Math.pow(endY - startY, 2));
    const perpY = (endX - startX) / Math.sqrt(Math.pow(endX - startX, 2) + Math.pow(endY - startY, 2));
    
    return {
      x: x + perpX * deviation,
      y: y + perpY * deviation
    };
  }

  // Crea/aggiorna linea elastica
  function updateElasticLine(cardIndex, targetX, targetY) {
    const card = document.getElementById(`card-${cardIndex}`);
    if (!card) return;

    const rect = container.getBoundingClientRect();
    const cardRect = card.getBoundingClientRect();
    
    const startX = cardRect.left + cardRect.width / 2 - rect.left;
    const startY = cardRect.top + cardRect.height / 2 - rect.top;
    const endX = targetX || corePos.x;
    const endY = targetY || corePos.y;

    // Crea path SVG
    let path = document.getElementById(`path-${cardIndex}`);
    if (!path) {
      path = document.createElementNS('http://www.w3.org/2000/svg', 'path');
      path.id = `path-${cardIndex}`;
      path.classList.add('elastic-path');
      svg.appendChild(path);
    }

    // Genera punti della curva di Weierstrass
    const points = [];
    const steps = 100;
    for (let i = 0; i <= steps; i++) {
      const t = i / steps;
      const point = getWeierstrassPoint(t, startX, startY, endX, endY, 40);
      points.push(`${point.x},${point.y}`);
    }

    const d = `M ${points.join(' L ')}`;
    path.setAttribute('d', d);
    path.classList.add('active');
  }

  // Rimuovi linea
  function removeElasticLine(cardIndex) {
    const path = document.getElementById(`path-${cardIndex}`);
    if (path) {
      path.classList.remove('active');
      setTimeout(() => path.remove(), 300);
    }
    const card = document.getElementById(`card-${cardIndex}`);
    if (card) card.classList.remove('connected');
  }

  // Animazione elastica al rilascio
  function animateElasticReturn(cardIndex) {
    const card = document.getElementById(`card-${cardIndex}`);
    if (!card) return;

    const ox = parseFloat(card.dataset.ox);
    const oy = parseFloat(card.dataset.oy);
    let startTime = null;
    const duration = 800;

    function animate(timestamp) {
      if (!startTime) startTime = timestamp;
      const progress = (timestamp - startTime) / duration;
      
      // Easing con funzione gaussiana modificata
      const eased = 1 - Math.exp(-5 * progress);
      
      const currentX = ox + (parseFloat(card.dataset.dx || ox) - ox) * (1 - eased);
      const currentY = oy + (parseFloat(card.dataset.dy || oy) - oy) * (1 - eased);
      
      card.style.left = `${currentX}px`;
      card.style.top = `${currentY}px`;
      
      // Aggiorna linea durante l'animazione
      if (connections.has(cardIndex)) {
        updateElasticLine(cardIndex, corePos.x, corePos.y);
      }

      if (progress < 1) {
        requestAnimationFrame(animate);
      } else {
        card.style.left = `${ox}px`;
        card.style.top = `${oy}px`;
        card.style.transform = 'translate(-50%, -50%)';
        delete card.dataset.dx;
        delete card.dataset.dy;
      }
    }

    requestAnimationFrame(animate);
  }

  // Event Listeners
  cards.forEach((card, index) => {
    // Click per connettere
    card.addEventListener('click', (e) => {
      e.stopPropagation();
      
      if (connections.has(index)) {
        // Disconnetti
        connections.delete(index);
        removeElasticLine(index);
        showTooltip('Connessione rimossa', e.clientX, e.clientY);
      } else {
        // Connetti
        connections.set(index, true);
        card.classList.add('connected');
        updateElasticLine(index, corePos.x, corePos.y);
        showTooltip('Weierstrass: f(x)=Σ aⁿcos(bⁿπx)', e.clientX, e.clientY);
      }
    });

    // Drag
    card.addEventListener('mousedown', (e) => {
      isDragging = true;
      draggedCard = card;
      card.style.cursor = 'grabbing';
      
      const rect = container.getBoundingClientRect();
      card.dataset.ox = parseFloat(card.dataset.ox) || card.offsetLeft;
      card.dataset.oy = parseFloat(card.dataset.oy) || card.offsetTop;
      
      e.preventDefault();
    });

    // Hover
    card.addEventListener('mouseenter', () => {
      if (!connections.has(index)) {
        card.style.transform = 'translate(-50%, -50%) scale(1.15)';
      }
    });

    card.addEventListener('mouseleave', () => {
      if (!isDragging || draggedCard !== card) {
        card.style.transform = 'translate(-50%, -50%)';
      }
    });
  });

  // Mouse move globale
  document.addEventListener('mousemove', (e) => {
    const rect = container.getBoundingClientRect();
    mousePos.x = e.clientX - rect.left;
    mousePos.y = e.clientY - rect.top;

    if (isDragging && draggedCard) {
      const x = Math.max(0, Math.min(rect.width, mousePos.x));
      const y = Math.max(0, Math.min(rect.height, mousePos.y));
      
      draggedCard.style.left = `${x}px`;
      draggedCard.style.top = `${y}px`;
      draggedCard.style.transform = 'translate(-50%, -50%) scale(1.1)';
      draggedCard.dataset.dx = x;
      draggedCard.dataset.dy = y;

      // Aggiorna linea se connessa
      const index = parseInt(draggedCard.dataset.index);
      if (connections.has(index)) {
        updateElasticLine(index, corePos.x, corePos.y);
      }
    }
  });

  // Mouse up
  document.addEventListener('mouseup', () => {
    if (isDragging && draggedCard) {
      const index = parseInt(draggedCard.dataset.index);
      draggedCard.style.cursor = 'grab';
      
      // Se connesso, animazione elastica di ritorno
      if (connections.has(index)) {
        animateElasticReturn(index);
      } else {
        // Ritorno morbido alla posizione originale
        const ox = parseFloat(draggedCard.dataset.ox);
        const oy = parseFloat(draggedCard.dataset.oy);
        draggedCard.style.transition = 'all 0.5s cubic-bezier(0.16, 1, 0.3, 1)';
        draggedCard.style.left = `${ox}px`;
        draggedCard.style.top = `${oy}px`;
        setTimeout(() => {
          draggedCard.style.transition = '';
        }, 500);
      }
      
      isDragging = false;
      draggedCard = null;
    }
  });

  // Core click
  core.addEventListener('click', () => {
    if (connections.size > 0) {
      connections.forEach((_, index) => {
        removeElasticLine(index);
      });
      connections.clear();
      showTooltip('Tutte le connessioni rimosse', corePos.x, corePos.y);
    } else {
      cards.forEach((_, index) => {
        connections.set(index, true);
        document.getElementById(`card-${index}`).classList.add('connected');
        updateElasticLine(index, corePos.x, corePos.y);
      });
      showTooltip('Funzione Zeta di Riemann: connessioni critiche', corePos.x, corePos.y);
    }
  });

  // Tooltip
  function showTooltip(text, x, y) {
    tooltip.textContent = text;
    tooltip.classList.add('visible');
    tooltip.style.left = `${x + 15}px`;
    tooltip.style.top = `${y}px`;
    
    setTimeout(() => {
      tooltip.classList.remove('visible');
    }, 2000);
  }

  // Canvas animazione particelle
  function resizeCanvas() {
    const rect = container.getBoundingClientRect();
    canvas.width = rect.width;
    canvas.height = rect.height;
  }

  function animateCanvas() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    
    const time = Date.now() / 1000;
    ctx.fillStyle = 'rgba(201, 183, 156, 0.3)';
    
    for (let i = 0; i < 50; i++) {
      const angle = (i / 50) * Math.PI * 2 + time * 0.2;
      const radius = 100 + Math.sin(time + i) * 20;
      const x = corePos.x + Math.cos(angle) * radius;
      const y = corePos.y + Math.sin(angle) * radius;
      
      ctx.beginPath();
      ctx.arc(x, y, 2, 0, Math.PI * 2);
      ctx.fill();
    }

    requestAnimationFrame(animateCanvas);
  }

  // Init
  window.addEventListener('load', () => {
    initPositions();
    animateCanvas();
  });

  window.addEventListener('resize', () => {
    initPositions();
  });

  // Click fuori per chiudere
  document.addEventListener('click', (e) => {
    if (!container.contains(e.target) && e.target !== core) {
      connections.forEach((_, index) => {
        removeElasticLine(index);
      });
      connections.clear();
    }
  });
})();
</script>

