{% comment %}
  BakAbo / BKS Universal Size Guide
  File: sections/bks-universal-size-guide.liquid
  Covers: Apparel (S→5XL), Sneakers (EU/US/UK/CM), Swimwear, Bags (One Size)
  Pattern: Dawn 15.4 — section-scoped CSS, modal + finder, mobile-first
{% endcomment %}

<style>
  #shopify-section-{{ section.id }} .bks-usg__trigger {
    display: inline-flex; align-items: center; gap: 9px;
    font-size: 11px; letter-spacing: 0.18em;
    text-transform: uppercase; font-weight: 500;
    font-family: var(--font-body-family);
    background: {{ section.settings.btn_bg }};
    border: 1px solid {{ section.settings.btn_border_color }};
    color: {{ section.settings.btn_text_color }};
    padding: 10px 18px; cursor: pointer;
    transition: background 0.18s, color 0.18s, border-color 0.18s;
    touch-action: manipulation; min-height: 44px;
  }
  #shopify-section-{{ section.id }} .bks-usg__trigger:hover {
    background: {{ section.settings.accent_color }};
    color: #080808;
    border-color: {{ section.settings.accent_color }};
  }
  #shopify-section-{{ section.id }} .bks-usg__trigger svg {
    width: 13px; height: 13px;
    stroke: currentColor; fill: none; stroke-width: 1.7; stroke-linecap: round;
  }

  .bks-usg-modal {
    position: fixed;
    top: 0; right: 0; bottom: 0; left: 0;
    inset: 0;
    z-index: 10000;
    display: flex; align-items: center; justify-content: center;
    padding: 16px;
    background: rgba(8,8,8,0.72);
    backdrop-filter: blur(6px); -webkit-backdrop-filter: blur(6px);
    opacity: 0; pointer-events: none;
    transition: opacity 0.22s ease;
  }
  .bks-usg-modal.is-open { opacity: 1; pointer-events: all; }
  .bks-usg-modal__box {
    background: {{ section.settings.background_color }};
    color: {{ section.settings.text_color }};
    width: 100%; max-width: 720px; max-height: 92vh;
    overflow-y: auto; padding: 36px 40px 32px;
    position: relative; transform: translateY(14px);
    transition: transform 0.22s ease;
    border-top: 2px solid {{ section.settings.accent_color }};
    font-family: var(--font-body-family);
  }
  .bks-usg-modal.is-open .bks-usg-modal__box { transform: translateY(0); }
  .bks-usg-modal__close {
    position: absolute; top: 16px; right: 18px;
    background: none; border: none; font-size: 20px;
    color: {{ section.settings.muted_color }}; cursor: pointer;
    min-width: 44px; min-height: 44px;
    display: flex; align-items: center; justify-content: center;
    transition: color 0.15s;
  }
  .bks-usg-modal__close:hover { color: {{ section.settings.text_color }}; }

  .bks-usg__head {
    display: flex; align-items: flex-start;
    justify-content: space-between; gap: 20px; flex-wrap: wrap;
    margin-bottom: 22px; padding-bottom: 18px;
    border-bottom: 1px solid {{ section.settings.border_color }};
  }
  .bks-usg__kicker {
    font-size: 10px; letter-spacing: 0.26em; text-transform: uppercase;
    color: {{ section.settings.accent_color }}; margin: 0 0 6px;
    display: flex; align-items: center; gap: 10px;
  }
  .bks-usg__kicker::before { content: ''; display: block; width: 18px; height: 1px; background: {{ section.settings.accent_color }}; }
  .bks-usg__title {
    font-size: clamp(16px, 2.2vw, 21px); font-weight: 600;
    letter-spacing: -0.02em; text-transform: uppercase; margin: 0;
    color: {{ section.settings.text_color }};
  }
  .bks-usg__unit-toggle {
    display: inline-flex; border: 1px solid {{ section.settings.border_color }};
    overflow: hidden; align-self: flex-end; flex-shrink: 0;
  }
  .bks-usg__unit-btn {
    background: none; border: none; padding: 7px 14px;
    font-size: 11px; letter-spacing: 0.12em; cursor: pointer;
    color: {{ section.settings.muted_color }}; font-family: var(--font-body-family);
    transition: all 0.15s;
  }
  .bks-usg__unit-btn.active { background: {{ section.settings.text_color }}; color: {{ section.settings.background_color }}; }

  /* ── TAB SWITCHER for product type ── */
  .bks-usg__tabs {
    display: flex; gap: 0;
    border: 1px solid {{ section.settings.border_color }};
    margin-bottom: 20px; overflow-x: auto;
    scrollbar-width: none;
  }
  .bks-usg__tabs::-webkit-scrollbar { display: none; }
  .bks-usg__tab {
    flex: 1; min-width: max-content;
    padding: 9px 16px; background: none; border: none;
    font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase;
    color: {{ section.settings.muted_color }}; cursor: pointer;
    font-family: var(--font-body-family);
    border-right: 1px solid {{ section.settings.border_color }};
    transition: background 0.15s, color 0.15s;
    min-height: 44px;
  }
  .bks-usg__tab:last-child { border-right: none; }
  .bks-usg__tab.active {
    background: {{ section.settings.accent_color }}; color: #080808; font-weight: 600;
  }
  .bks-usg__panel { display: none; }
  .bks-usg__panel.active { display: block; }

  /* ── FINDER ── */
  .bks-usg__finder {
    background: {{ section.settings.card_bg }};
    border: 1px solid {{ section.settings.border_color }};
    padding: 18px 20px; margin-bottom: 20px;
  }
  .bks-usg__finder-label {
    font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase;
    color: {{ section.settings.accent_color }}; margin: 0 0 12px; font-weight: 500;
    display: flex; align-items: center; gap: 8px;
  }
  .bks-usg__finder-label::before { content: ''; display: block; width: 14px; height: 1px; background: {{ section.settings.accent_color }}; }
  .bks-usg__finder-inputs { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
  .bks-usg__field label {
    display: block; font-size: 10px; letter-spacing: 0.12em;
    text-transform: uppercase; color: {{ section.settings.muted_color }}; margin-bottom: 5px;
  }
  .bks-usg__field input {
    width: 100%; border: 1px solid {{ section.settings.border_color }};
    padding: 9px 12px; font-size: 14px;
    font-family: var(--font-body-family); color: {{ section.settings.text_color }};
    background: {{ section.settings.background_color }};
    transition: border-color 0.15s; -moz-appearance: textfield;
  }
  .bks-usg__field input::-webkit-inner-spin-button,
  .bks-usg__field input::-webkit-outer-spin-button { -webkit-appearance: none; }
  .bks-usg__field input:focus { outline: none; border-color: {{ section.settings.accent_color }}; }

  .bks-usg__result {
    display: none; align-items: center; gap: 18px;
    padding-top: 14px; margin-top: 14px;
    border-top: 1px solid {{ section.settings.border_color }};
  }
  .bks-usg__result.visible { display: flex; }
  .bks-usg__res-size { font-size: 38px; font-weight: 700; color: {{ section.settings.text_color }}; min-width: 60px; line-height: 1; }
  .bks-usg__res-badge {
    display: inline-block; font-size: 9px; letter-spacing: 0.18em;
    text-transform: uppercase; background: {{ section.settings.accent_color }};
    color: #080808; padding: 3px 10px; margin-bottom: 5px; font-weight: 600;
  }
  .bks-usg__res-info { font-size: 12.5px; color: {{ section.settings.muted_color }}; line-height: 1.5; }

  /* ── TABLES ── */
  .bks-usg__table-wrap { border: 1px solid {{ section.settings.border_color }}; overflow-x: auto; margin-bottom: 16px; }
  .bks-usg__table { width: 100%; border-collapse: collapse; font-size: 12.5px; min-width: 480px; }
  .bks-usg__table thead tr { background: {{ section.settings.card_bg }}; border-bottom: 1px solid {{ section.settings.border_color }}; }
  .bks-usg__table th {
    padding: 9px 12px; font-size: 9px; letter-spacing: 0.2em;
    text-transform: uppercase; color: {{ section.settings.muted_color }};
    font-weight: 500; text-align: left; white-space: nowrap;
  }
  .bks-usg__table th:not(:first-child) { text-align: center; }
  .bks-usg__table td { padding: 10px 12px; border-bottom: 1px solid {{ section.settings.border_color }}; color: {{ section.settings.muted_color }}; text-align: center; white-space: nowrap; }
  .bks-usg__table td:first-child { text-align: left; font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; font-weight: 500; }
  .bks-usg__table tr:last-child td { border-bottom: none; }
  .bks-usg__table td strong { font-size: 15px; font-weight: 700; color: {{ section.settings.text_color }}; display: block; }
  .bks-usg__table td small { font-size: 9.5px; color: {{ section.settings.muted_color }}; }
  .bks-usg__table .hl { background: {{ section.settings.highlight_bg }}; }
  .bks-usg__table .hl strong { color: {{ section.settings.accent_color }}; }

  .bks-usg__tip {
    font-size: 12.5px; color: {{ section.settings.muted_color }};
    padding: 12px 16px; line-height: 1.55;
    border-left: 3px solid {{ section.settings.accent_color }};
    background: {{ section.settings.card_bg }};
  }
  .bks-usg__tip strong { color: {{ section.settings.text_color }}; }

  @media screen and (max-width: 600px) {
    .bks-usg-modal__box { padding: 22px 14px 18px; }
    .bks-usg__finder-inputs { grid-template-columns: 1fr; }
    .bks-usg__head { gap: 10px; }
  }
</style>

<button
  class="bks-usg__trigger"
  onclick="document.getElementById('BksUsgModal-{{ section.id }}').classList.add('is-open');document.getElementById('BksUsgModal-{{ section.id }}').focus();"
  aria-haspopup="dialog"
>
  <svg viewBox="0 0 16 16" aria-hidden="true">
    <line x1="1" y1="4" x2="15" y2="4"/>
    <line x1="1" y1="8" x2="11" y2="8"/>
    <line x1="1" y1="12" x2="15" y2="12"/>
  </svg>
  {{ section.settings.trigger_label | default: 'Guida alle taglie' }}
</button>

<div
  class="bks-usg-modal"
  id="BksUsgModal-{{ section.id }}"
  role="dialog" aria-modal="true" tabindex="-1"
  onclick="if(event.target===this)this.classList.remove('is-open')"
>
  <div class="bks-usg-modal__box">
    <button class="bks-usg-modal__close" onclick="document.getElementById('BksUsgModal-{{ section.id }}').classList.remove('is-open')" aria-label="Chiudi">&#215;</button>

    <div class="bks-usg__head">
      <div>
        <p class="bks-usg__kicker">Bakabo Club · BKS</p>
        <h2 class="bks-usg__title">{{ section.settings.modal_title | default: 'Guida alle Taglie' }}</h2>
      </div>
      {%- if section.settings.product_type != 'bags' -%}
      <div class="bks-usg__unit-toggle" role="group" aria-label="Unità">
        <button class="bks-usg__unit-btn active" onclick="bksUsgUnit('cm','{{ section.id }}',this)">cm</button>
        <button class="bks-usg__unit-btn" onclick="bksUsgUnit('in','{{ section.id }}',this)">in</button>
      </div>
      {%- endif -%}
    </div>

    {%- comment -%} APPAREL TAB {%- endcomment -%}
    {%- if section.settings.product_type == 'apparel' or section.settings.product_type == 'swimwear' -%}

    <div class="bks-usg__finder">
      <p class="bks-usg__finder-label">Trova la tua taglia</p>
      <div class="bks-usg__finder-inputs">
        <div class="bks-usg__field">
          <label for="bksUsgCh-{{ section.id }}">Petto / Busto</label>
          <input type="number" id="bksUsgCh-{{ section.id }}" placeholder="es. 96" oninput="bksUsgFind('{{ section.id }}','apparel')">
        </div>
        <div class="bks-usg__field">
          <label for="bksUsgWa-{{ section.id }}">Vita</label>
          <input type="number" id="bksUsgWa-{{ section.id }}" placeholder="es. 82" oninput="bksUsgFind('{{ section.id }}','apparel')">
        </div>
      </div>
      <div class="bks-usg__result" id="bksUsgRes-{{ section.id }}">
        <div class="bks-usg__res-size" id="bksUsgResS-{{ section.id }}">M</div>
        <div>
          <span class="bks-usg__res-badge">Taglia consigliata</span>
          <div class="bks-usg__res-info" id="bksUsgResI-{{ section.id }}"></div>
        </div>
      </div>
    </div>

    <div class="bks-usg__table-wrap">
      <table class="bks-usg__table" id="bksUsgTabApp-{{ section.id }}">
        <thead><tr>
          <th>Misura</th>
          <th>XS</th><th>S</th><th>M</th><th>L</th><th>XL</th><th>2XL</th><th>3XL</th>
        </tr></thead>
        <tbody id="bksUsgBodyApp-{{ section.id }}"></tbody>
      </table>
    </div>
    <p class="bks-usg__tip"><strong>Fit BKS:</strong> {{ section.settings.fit_tip | default: 'Taglio regular. Per un look più ampio scegli una taglia in più.' }}</p>

    {%- elsif section.settings.product_type == 'sneakers' -%}

    <div class="bks-usg__finder">
      <p class="bks-usg__finder-label">Trova la tua taglia</p>
      <div class="bks-usg__finder-inputs">
        <div class="bks-usg__field">
          <label for="bksUsgFoot-{{ section.id }}">Lunghezza piede (cm)</label>
          <input type="number" id="bksUsgFoot-{{ section.id }}" placeholder="es. 26.5" step="0.5" oninput="bksUsgFind('{{ section.id }}','sneakers')">
        </div>
        <div class="bks-usg__field">
          <label>Risultato</label>
          <div class="bks-usg__result visible" id="bksUsgRes-{{ section.id }}" style="padding:0;margin:0;border:none;">
            <div class="bks-usg__res-size" id="bksUsgResS-{{ section.id }}" style="font-size:28px;">—</div>
            <div class="bks-usg__res-info" id="bksUsgResI-{{ section.id }}"></div>
          </div>
        </div>
      </div>
    </div>

    <div class="bks-usg__table-wrap">
      <table class="bks-usg__table" id="bksUsgTabSnk-{{ section.id }}">
        <thead><tr>
          <th>EU</th><th>US M</th><th>US W</th><th>UK</th><th>CM</th>
        </tr></thead>
        <tbody id="bksUsgBodySnk-{{ section.id }}"></tbody>
      </table>
    </div>
    <p class="bks-usg__tip"><strong>Fit:</strong> {{ section.settings.fit_tip | default: 'Le sneakers BKS seguono la taglia standard EU. In caso di dubbio tra due misure, scegli la più grande.' }}</p>

    {%- elsif section.settings.product_type == 'bags' -%}

    <div class="bks-usg__table-wrap">
      <table class="bks-usg__table">
        <thead><tr><th>Dimensione</th><th>Misura</th></tr></thead>
        <tbody>
          {%- if section.settings.bag_length != blank -%}<tr><td>Lunghezza</td><td>{{ section.settings.bag_length }}</td></tr>{%- endif -%}
          {%- if section.settings.bag_height != blank -%}<tr><td>Altezza</td><td>{{ section.settings.bag_height }}</td></tr>{%- endif -%}
          {%- if section.settings.bag_depth != blank -%}<tr><td>Profondità</td><td>{{ section.settings.bag_depth }}</td></tr>{%- endif -%}
          {%- if section.settings.bag_strap != blank -%}<tr><td>Tracolla / Manico</td><td>{{ section.settings.bag_strap }}</td></tr>{%- endif -%}
          {%- if section.settings.bag_weight != blank -%}<tr><td>Peso</td><td>{{ section.settings.bag_weight }}</td></tr>{%- endif -%}
          {%- if section.settings.bag_capacity != blank -%}<tr><td>Capacità</td><td>{{ section.settings.bag_capacity }}</td></tr>{%- endif -%}
        </tbody>
      </table>
    </div>
    <p class="bks-usg__tip"><strong>Note:</strong> {{ section.settings.fit_tip | default: 'Le misure si riferiscono al prodotto finito. Piccole variazioni (+/- 1cm) sono nella norma per articoli artigianali.' }}</p>

    {%- endif -%}
  </div>
</div>

<script>
(function(){
  var SID = '{{ section.id }}';
  var unit = {}; unit[SID] = 'cm';
  var ptype = '{{ section.settings.product_type }}';

  function toIn(v){ return Math.round(v/2.54*10)/10; }
  function d(v,sid){ return unit[sid]==='cm'?v:toIn(v); }
  function fi(v,sid){ return unit[sid]==='cm'?parseFloat(v):parseFloat(v)*2.54; }

  var APPAREL = [
    {s:'XS', eu:'44', chest:[82,87], waist:[68,73]},
    {s:'S',  eu:'46', chest:[88,93], waist:[74,79]},
    {s:'M',  eu:'48', chest:[94,99], waist:[80,85]},
    {s:'L',  eu:'50', chest:[100,105], waist:[86,91]},
    {s:'XL', eu:'52', chest:[106,111], waist:[92,97]},
    {s:'2XL',eu:'54', chest:[112,118], waist:[98,104]},
    {s:'3XL',eu:'56', chest:[118,124], waist:[104,110]}
  ];

  var SNEAKERS = [
    {eu:'36',usm:'4',usw:'5.5',uk:'3.5',cm:22.5},
    {eu:'37',usm:'4.5',usw:'6',uk:'4',cm:23.0},
    {eu:'38',usm:'5',usw:'6.5',uk:'4.5',cm:23.5},
    {eu:'39',usm:'6',usw:'7.5',uk:'5.5',cm:24.5},
    {eu:'40',usm:'7',usw:'8.5',uk:'6.5',cm:25.5},
    {eu:'41',usm:'7.5',usw:'9',uk:'7',cm:26.0},
    {eu:'42',usm:'8.5',usw:'10',uk:'8',cm:26.5},
    {eu:'43',usm:'9',usw:'10.5',uk:'8.5',cm:27.5},
    {eu:'44',usm:'10',usw:'11.5',uk:'9.5',cm:28.0},
    {eu:'45',usm:'11',usw:'12.5',uk:'10.5',cm:29.0},
    {eu:'46',usm:'12',usw:'13.5',uk:'11.5',cm:30.0},
    {eu:'47',usm:'12.5',usw:'14',uk:'12',cm:30.5}
  ];

  function renderApparel(sid){
    var b = document.getElementById('bksUsgBodyApp-'+sid);
    if(!b)return;
    var rows = ['Petto / Busto','Vita'];
    var keys = ['chest','waist'];
    b.innerHTML = keys.map(function(k,i){
      return '<tr><td>'+rows[i]+' ('+unit[sid]+')</td>'+
        APPAREL.map(function(r){
          return '<td id="bksUsgA-'+sid+'-'+k+'-'+r.s+'">'+d(r[k][0],sid)+'–'+d(r[k][1],sid)+'</td>';
        }).join('')+'</tr>';
    }).join('');
  }

  function renderSneakers(sid){
    var b = document.getElementById('bksUsgBodySnk-'+sid);
    if(!b)return;
    b.innerHTML = SNEAKERS.map(function(r){
      return '<tr id="bksUsgSnk-'+sid+'-'+r.eu+'">'
        +'<td><strong>'+r.eu+'</strong></td>'
        +'<td>'+r.usm+'</td><td>'+r.usw+'</td><td>'+r.uk+'</td><td>'+r.cm+' cm</td>'
        +'</tr>';
    }).join('');
  }

  window.bksUsgUnit = function(u,sid,btn){
    unit[sid]=u;
    btn.parentNode.querySelectorAll('.bks-usg__unit-btn').forEach(function(b){b.classList.remove('active');});
    btn.classList.add('active');
    var chEl=document.getElementById('bksUsgCh-'+sid);
    var waEl=document.getElementById('bksUsgWa-'+sid);
    if(chEl)chEl.placeholder=u==='cm'?'es. 96':'es. 38';
    if(waEl)waEl.placeholder=u==='cm'?'es. 82':'es. 32';
    if(ptype==='apparel'||ptype==='swimwear')renderApparel(sid);
    bksUsgFind(sid,ptype);
  };

  window.bksUsgFind = function(sid,type){
    var res = document.getElementById('bksUsgRes-'+sid);
    if(type==='apparel'||type==='swimwear'){
      var cv=document.getElementById('bksUsgCh-'+sid);
      var wv=document.getElementById('bksUsgWa-'+sid);
      // clear
      APPAREL.forEach(function(r){
        ['chest','waist'].forEach(function(k){
          var c=document.getElementById('bksUsgA-'+sid+'-'+k+'-'+r.s);
          if(c)c.classList.remove('hl');
        });
      });
      if(!cv||(!cv.value&&!wv.value)){if(res)res.classList.remove('visible');return;}
      var chest=cv.value?fi(cv.value,sid):null;
      var waist=wv.value?fi(wv.value,sid):null;
      var best=null,bs=Infinity;
      APPAREL.forEach(function(r){
        var sc=0,cnt=0;
        if(chest){sc+=Math.abs(chest-(r.chest[0]+r.chest[1])/2);cnt++;}
        if(waist){sc+=Math.abs(waist-(r.waist[0]+r.waist[1])/2);cnt++;}
        if(cnt>0&&sc/cnt<bs){bs=sc/cnt;best=r;}
      });
      if(best){
        document.getElementById('bksUsgResS-'+sid).textContent=best.s;
        document.getElementById('bksUsgResI-'+sid).innerHTML='EU '+best.eu+
          '<br>Petto '+d(best.chest[0],sid)+'–'+d(best.chest[1],sid)+' '+unit[sid];
        if(res)res.classList.add('visible');
        ['chest','waist'].forEach(function(k){
          var c=document.getElementById('bksUsgA-'+sid+'-'+k+'-'+best.s);
          if(c)c.classList.add('hl');
        });
      }
    }
    else if(type==='sneakers'){
      var fEl=document.getElementById('bksUsgFoot-'+sid);
      if(!fEl||!fEl.value)return;
      var footCm=parseFloat(fEl.value);
      SNEAKERS.forEach(function(r){
        var row=document.getElementById('bksUsgSnk-'+sid+'-'+r.eu);
        if(row)row.classList.remove('hl');
      });
      var best=null,bs=Infinity;
      SNEAKERS.forEach(function(r){
        var diff=Math.abs(footCm-r.cm);
        if(diff<bs){bs=diff;best=r;}
      });
      if(best){
        document.getElementById('bksUsgResS-'+sid).textContent='EU '+best.eu;
        document.getElementById('bksUsgResI-'+sid).textContent='US '+best.usm+' · UK '+best.uk+' · '+best.cm+' cm';
        var row=document.getElementById('bksUsgSnk-'+sid+'-'+best.eu);
        if(row)row.classList.add('hl');
      }
    }
  };

  function init(){
    if(ptype==='apparel'||ptype==='swimwear') renderApparel(SID);
    else if(ptype==='sneakers') renderSneakers(SID);
  }
  if(document.readyState==='loading'){document.addEventListener('DOMContentLoaded',init);}else{init();}
  document.addEventListener('keydown',function(e){
    if(e.key==='Escape'){var m=document.getElementById('BksUsgModal-'+SID);if(m)m.classList.remove('is-open');}
  });
})();
</script>

{% schema %}
{
