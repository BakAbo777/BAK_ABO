  "member_tryon_system": {
    "purpose": "Allow members to try on garments currently in cart using a phone photo, with optional uploaded or preset set backgrounds.",
    "public_entry": "sections/bks-members-entry.liquid",
    "account_dashboard": "sections/bks-member-dashboard.liquid",
    "assets": [
      "assets/bks-tryon.css",
      "assets/bks-tryon.js"
    ],
    "template": "templates/customers/account.json",
    "default_endpoint": "/apps/bks-tryon",
    "extension_hook": "#bks-tryon-app-extension-root[data-bks-extension-hook='member-tryon']",
    "browser_flow": [
      "Fetch /cart.js",
      "Select cart garment",
      "Capture/upload image/* with capture=user",
      "Optionally choose a preset set background or upload a custom background image",
      "Require consent",
      "Post FormData to endpoint or dispatch bks:tryon:submit custom event"
    ],
    "required_backend": [
      "Shopify App Proxy or same-origin endpoint",
      "Image processing / virtual try-on AI",
      "Optional background compositing or scene replacement logic",
      "Privacy retention/deletion policy",
      "Return JSON with image_url or preview_url"
    ],
    "event_contract": {
      "event": "bks:tryon:submit",
      "cancelable": true,
      "detail": [
        "root",
        "endpoint",
        "cart",
        "item",
        "imageFile",
        "background",
        "customerId",
        "customerEmail"
      ]
    },
    "local_ai_targets": {
      "brand_root": "I:\\BAK ABO\\members_tryon",
      "database_root": "I:\\BKS database\\members_tryon",
      "generated_previews": "I:\\BKS database\\members_tryon\\previews",
      "logs": "I:\\BKS database\\members_tryon\\logs"
    },
    "background_options": {
      "theme_settings": [
        "tryon_bg_preset_1",
        "tryon_bg_preset_2",
        "tryon_bg_preset_3",
        "tryon_bg_preset_4"
      ],
      "accepted_upload": "image/*",
      "payload_fields": [
        "background_mode",
        "background_photo",
        "background_preset_id",
        "background_preset_label",
        "background_preset_image"
      ]
    },
    "mobile_ux_system": {
      "purpose": "Touch-first guided Try-On experience inside BKS Members.",
      "steps": [
        "1 garment from cart",
        "2 phone photo",
        "3 set background",
        "4 review and generate preview"
      ],
      "key_ui_files": [
        "sections/bks-member-dashboard.liquid",
        "assets/bks-tryon.css",
        "assets/bks-tryon.js"
      ],
      "mobile_behaviour": [
        "single active step on screens <= 900px",
        "sticky progress bar",
        "sticky final action area",
        "large touch targets",
        "review summary before submitting",
        "loading spinner while endpoint processes"
      ],
      "desktop_behaviour": [
        "all panels visible with sticky progress tracker",
        "same state and endpoint payload"
      ]
    }
  }
