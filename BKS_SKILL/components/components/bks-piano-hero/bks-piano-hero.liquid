{%- comment -%}
  BKS Studio — Piano Hero Section
  File: sections/bks-piano-hero.liquid
  Version: 1.0 — Giugno 2026
  Dipendenze: assets/bks-piano-hero.css · assets/bks-piano-hero.js
  Note: richiede file audio per ogni collezione in assets/
        (BKS-Concept-Ambient-001.mp3 … 008.mp3)
        o URL esterni configurabili dallo schema.
{%- endcomment -%}

<div
  id="shopify-section-{{ section.id }}"
  class="bks-piano-hero"
  data-section-id="{{ section.id }}"
  style="height:{{ section.settings.height }}px"
>
  <canvas id="bks-piano-canvas" aria-label="BKS Studio — Esplora le 8 collezioni sul pianoforte"></canvas>

  {%- comment -%} Collection reveal overlay {%- endcomment -%}
  <div id="bks-coll-screen" aria-live="polite" aria-atomic="true">

    <div id="bks-model-panel">
      <div id="bks-model-bg"></div>
      <div id="bks-mannequin" aria-hidden="true">
        <div id="bks-mq-head">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
            <circle cx="12" cy="12" r="10" stroke="rgba(255,255,255,0.28)" stroke-width="1.2"/>
            <circle cx="12" cy="10" r="4" stroke="rgba(255,255,255,0.2)" stroke-width="1"/>
          </svg>
        </div>
        <div id="bks-mq-body"><div id="bks-mq-body-fill"></div></div>
        <div id="bks-mq-legs">
          <div class="bks-mq-leg"><div class="bks-mq-leg-fill" id="bks-leg-l"></div></div>
          <div class="bks-mq-leg"><div class="bks-mq-leg-fill" id="bks-leg-r"></div></div>
        </div>
      </div>
      <div id="bks-arm-info">
        <div id="bks-arm-season">Stagione</div>
        <div id="bks-arm-desc"></div>
      </div>
    </div>

    <div id="bks-coll-info">
      <div id="bks-coll-divider" aria-hidden="true"></div>
      <div class="bks-coll-eyebrow">BKS Studio · Collezione</div>
      <h2 id="bks-coll-name">Hours</h2>
      <div id="bks-coll-note">Do · 261 Hz</div>
      <p id="bks-coll-quote"></p>
      <div id="bks-coll-pills"></div>
      <a id="bks-coll-cta" href="#" class="bks-cta-link">
        Esplora la collezione
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M2 8h12M9 3l5 5-5 5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </div>

  {%- comment -%} Audio elements — one per collection {%- endcomment -%}
  {%- for block in section.blocks -%}
    {%- if block.type == 'collection' -%}
      <audio
        id="bks-audio-{{ forloop.index0 }}"
        preload="none"
        loop
        aria-hidden="true"
      >
        {%- if block.settings.audio_url != blank -%}
          <source src="{{ block.settings.audio_url }}" type="audio/mpeg">
        {%- elsif block.settings.audio_file != blank -%}
          <source src="{{ block.settings.audio_file | asset_url }}" type="audio/mpeg">
        {%- endif -%}
      </audio>
    {%- endif -%}
  {%- endfor -%}

  {%- comment -%} Music indicator {%- endcomment -%}
  <div id="bks-music-ind" aria-hidden="true">
    <span></span><span></span><span></span><span></span>
  </div>

  {%- comment -%} Back button {%- endcomment -%}
  <button
    id="bks-back-btn"
    type="button"
    aria-label="Torna al pianoforte"
    onclick="BKSPiano.closeCollection()"
  >
    ↑ Torna al piano
  </button>

  {%- comment -%} Hint {%- endcomment -%}
  <div id="bks-hint" aria-hidden="true">
    {{ section.settings.hint_text | escape }}
  </div>

  {%- comment -%} Volume control {%- endcomment -%}
  {%- if section.settings.show_volume -%}
  <div id="bks-vol-wrap">
    <label for="bks-vol-sl" class="bks-vol-label">volume</label>
    <input
      type="range" min="0" max="100" value="70" step="1"
      id="bks-vol-sl"
      oninput="BKSPiano.setVolume(this.value/100)"
      aria-label="Volume audio collezione"
    >
  </div>
  {%- endif -%}
</div>

{%- comment -%} Collection data — passed to JS as JSON {%- endcomment -%}
<script id="bks-piano-data" type="application/json">
{
  "collections": [
    {%- for block in section.blocks -%}
    {%- if block.type == 'collection' -%}
    {
      "name": {{ block.settings.name | json }},
      "note": {{ block.settings.note | json }},
      "freq": {{ block.settings.freq }},
      "white": {{ block.settings.white_key }},
      "color": {{ block.settings.color | json }},
      "url": {{ block.settings.collection_url | json }},
      "quote": {{ block.settings.quote | json }},
      "products": {{ block.settings.products | json }},
      "arm_season": {{ block.settings.arm_season | json }},
      "arm_desc": {{ block.settings.arm_desc | json }},
      "gradient": {{ block.settings.bg_gradient | json }},
      "audio_index": {{ forloop.index0 }},
      "pattern": {{ block.settings.pattern | json }},
      "bpm": {{ block.settings.bpm }},
      "decay": {{ block.settings.decay }}
    }{% unless forloop.last %},{% endunless %}
    {%- endif -%}
    {%- endfor -%}
  ],
  "fallboard_label": {{ section.settings.fallboard_label | json }},
  "use_webaudio_fallback": {{ section.settings.use_webaudio_fallback | json }}
}
</script>

{{ 'bks-piano-hero.css' | asset_url | stylesheet_tag }}
{{ 'bks-piano-hero.js' | asset_url | script_tag }}

{% schema %}
