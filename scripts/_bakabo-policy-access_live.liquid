<style>
  .bakabo-policy-access {
    background: #FAFAF7;
    color: #0A0A0A;
    border-top: 1px solid rgba(10,10,10,0.12);
    border-bottom: 1px solid rgba(10,10,10,0.12);
  }

  .bakabo-policy-access__inner {
    width: min(1440px, calc(100% - 32px));
    margin: 0 auto;
    padding: clamp(20px,3vw,34px) 0;
    display: grid;
    grid-template-columns: minmax(0,0.55fr) minmax(260px,0.45fr);
    gap: clamp(18px,3vw,38px);
    align-items: center;
  }

  .bakabo-policy-access__kicker {
    margin: 0 0 6px;
    font-family: var(--bks-font-mono,'DM Mono',monospace);
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #5F5A52;
  }

  .bakabo-policy-access__copy {
    margin: 0;
    color: #242424;
    font-size: 0.94rem;
    line-height: 1.55;
  }

  .bakabo-policy-access__links {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 8px;
  }

  .bakabo-policy-access__links a {
    display: inline-flex;
    align-items: center;
    min-height: 36px;
    padding: 8px 12px;
    border: 1px solid rgba(10,10,10,0.22);
    color: #0A0A0A;
    background: #FFFFFF;
    text-decoration: none;
    font-family: var(--bks-font-mono,'DM Mono',monospace);
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .bakabo-policy-access__links a:hover,
  .bakabo-policy-access__links a:focus-visible {
    color: #FAFAF7;
    background: #0A0A0A;
    opacity: 1;
  }

  @media screen and (max-width: 749px) {
    .bakabo-policy-access__inner {
      grid-template-columns: 1fr;
    }

    .bakabo-policy-access__links {
      justify-content: flex-start;
    }
  }
</style>

<section class="bakabo-policy-access" aria-labelledby="bakabo-policy-access-title">
  <div class="bakabo-policy-access__inner">
    <div>
      <p class="bakabo-policy-access__kicker" id="bakabo-policy-access-title">BKS Policies &amp; Support</p>
      <p class="bakabo-policy-access__copy">
        Privacy, terms, shipping, returns and contact information are always accessible from any page.
      </p>
    </div>
    <nav class="bakabo-policy-access__links" aria-label="Site policies">
      {%- assign policy_count = 0 -%}
      {%- for policy in shop.policies -%}
        {%- if policy != blank -%}
          {%- assign policy_count = policy_count | plus: 1 -%}
          <a href="{{ policy.url }}">{{ policy.title | escape }}</a>
        {%- endif -%}
      {%- endfor -%}

      {%- if policy_count == 0 -%}
        <a href="/policies/privacy-policy">Privacy</a>
        <a href="/policies/terms-of-service">Terms</a>
        <a href="/policies/refund-policy">Returns</a>
        <a href="/policies/shipping-policy">Shipping</a>
        <a href="/policies/contact-information">Contact</a>
      {%- endif -%}
    </nav>
  </div>
</section>
